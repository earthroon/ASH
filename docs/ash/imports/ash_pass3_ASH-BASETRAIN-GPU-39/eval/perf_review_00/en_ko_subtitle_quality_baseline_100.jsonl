{"case_id": "PERF_ENKO_0001", "category": "short_dialogue", "source_text": "I don't know.", "reference_ko": "난 몰라.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0002", "category": "short_dialogue", "source_text": "Wait.", "reference_ko": "기다려.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0003", "category": "short_dialogue", "source_text": "Come here.", "reference_ko": "이리 와.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0004", "category": "short_dialogue", "source_text": "Stay with me.", "reference_ko": "내 옆에 있어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0005", "category": "short_dialogue", "source_text": "It's over.", "reference_ko": "끝났어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0006", "category": "short_dialogue", "source_text": "I'm fine.", "reference_ko": "난 괜찮아.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0007", "category": "short_dialogue", "source_text": "Look at me.", "reference_ko": "나 봐.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0008", "category": "short_dialogue", "source_text": "Don't move.", "reference_ko": "움직이지 마.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0009", "category": "short_dialogue", "source_text": "Tell me.", "reference_ko": "말해 봐.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0010", "category": "short_dialogue", "source_text": "Trust me.", "reference_ko": "날 믿어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0011", "category": "short_dialogue", "source_text": "We need to go.", "reference_ko": "우리 가야 해.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0012", "category": "short_dialogue", "source_text": "This is bad.", "reference_ko": "이거 큰일이야.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0013", "category": "interjection", "source_text": "Oh, no.", "reference_ko": "아, 안 돼.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0014", "category": "interjection", "source_text": "Wow.", "reference_ko": "와.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0015", "category": "interjection", "source_text": "Hey!", "reference_ko": "야!", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0016", "category": "interjection", "source_text": "Seriously?", "reference_ko": "진심이야?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0017", "category": "interjection", "source_text": "Come on.", "reference_ko": "제발 좀.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0018", "category": "interjection", "source_text": "No, no, no.", "reference_ko": "아니, 아니야.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0019", "category": "interjection", "source_text": "Uh... what?", "reference_ko": "어... 뭐라고?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0020", "category": "interjection", "source_text": "Damn it.", "reference_ko": "젠장.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "rough"}}
{"case_id": "PERF_ENKO_0021", "category": "negative_sentence", "source_text": "That's not true.", "reference_ko": "그건 사실이 아니야.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0022", "category": "negative_sentence", "source_text": "I can't do this.", "reference_ko": "난 이거 못 해.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0023", "category": "negative_sentence", "source_text": "Don't tell anyone.", "reference_ko": "아무한테도 말하지 마.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0024", "category": "negative_sentence", "source_text": "It doesn't matter.", "reference_ko": "상관없어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0025", "category": "negative_sentence", "source_text": "I never said that.", "reference_ko": "난 그런 말 한 적 없어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0026", "category": "negative_sentence", "source_text": "You're not alone.", "reference_ko": "넌 혼자가 아니야.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0027", "category": "negative_sentence", "source_text": "We shouldn't be here.", "reference_ko": "우린 여기 있으면 안 돼.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0028", "category": "negative_sentence", "source_text": "This isn't working.", "reference_ko": "이거 안 되고 있어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0029", "category": "proper_noun", "source_text": "NASA called.", "reference_ko": "NASA에서 연락했어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0030", "category": "proper_noun", "source_text": "OpenAI said no.", "reference_ko": "OpenAI가 안 된다고 했어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0031", "category": "proper_noun", "source_text": "Meet me at Seoul Station.", "reference_ko": "서울역에서 만나.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0032", "category": "proper_noun", "source_text": "Dr. Kim is waiting.", "reference_ko": "김 박사님이 기다리고 있어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "polite"}}
{"case_id": "PERF_ENKO_0033", "category": "proper_noun", "source_text": "The file is on GitHub.", "reference_ko": "파일은 GitHub에 있어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0034", "category": "proper_noun", "source_text": "Ask Mina first.", "reference_ko": "먼저 미나한테 물어봐.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0035", "category": "proper_noun", "source_text": "Tell Alex to hurry.", "reference_ko": "알렉스한테 서두르라고 해.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0036", "category": "proper_noun", "source_text": "Busan is too far.", "reference_ko": "부산은 너무 멀어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0037", "category": "number_date_time", "source_text": "Give me ten minutes.", "reference_ko": "10분만 줘.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0038", "category": "number_date_time", "source_text": "It's 3 a.m.", "reference_ko": "새벽 3시야.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0039", "category": "number_date_time", "source_text": "We have two days.", "reference_ko": "우리한텐 이틀이 있어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0040", "category": "number_date_time", "source_text": "Thirty percent is gone.", "reference_ko": "30%가 사라졌어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0041", "category": "number_date_time", "source_text": "Take the second exit.", "reference_ko": "두 번째 출구로 나가.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0042", "category": "number_date_time", "source_text": "I paid 50 dollars.", "reference_ko": "50달러 냈어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0043", "category": "number_date_time", "source_text": "The code is 2048.", "reference_ko": "코드는 2048이야.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0044", "category": "number_date_time", "source_text": "Wait until Friday.", "reference_ko": "금요일까지 기다려.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0045", "category": "rough_speech", "source_text": "Shut up.", "reference_ko": "닥쳐.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "rough"}}
{"case_id": "PERF_ENKO_0046", "category": "rough_speech", "source_text": "You idiot.", "reference_ko": "이 멍청아.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "rough"}}
{"case_id": "PERF_ENKO_0047", "category": "rough_speech", "source_text": "Get lost.", "reference_ko": "꺼져.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "rough"}}
{"case_id": "PERF_ENKO_0048", "category": "rough_speech", "source_text": "What the hell is this?", "reference_ko": "이게 대체 뭐야?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "rough"}}
{"case_id": "PERF_ENKO_0049", "category": "rough_speech", "source_text": "I'm sick of this.", "reference_ko": "나 이거 지긋지긋해.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "rough"}}
{"case_id": "PERF_ENKO_0050", "category": "rough_speech", "source_text": "Don't mess with me.", "reference_ko": "나 건드리지 마.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "rough"}}
{"case_id": "PERF_ENKO_0051", "category": "rough_speech", "source_text": "This is insane.", "reference_ko": "이건 미쳤어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "rough"}}
{"case_id": "PERF_ENKO_0052", "category": "rough_speech", "source_text": "Screw that.", "reference_ko": "그딴 건 됐어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "rough"}}
{"case_id": "PERF_ENKO_0053", "category": "honorific_candidate", "source_text": "Are you okay?", "reference_ko": "괜찮으세요?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "polite"}}
{"case_id": "PERF_ENKO_0054", "category": "honorific_candidate", "source_text": "Please wait here.", "reference_ko": "여기서 기다려 주세요.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "polite"}}
{"case_id": "PERF_ENKO_0055", "category": "honorific_candidate", "source_text": "I understand.", "reference_ko": "알겠습니다.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "polite"}}
{"case_id": "PERF_ENKO_0056", "category": "honorific_candidate", "source_text": "May I come in?", "reference_ko": "들어가도 될까요?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "polite"}}
{"case_id": "PERF_ENKO_0057", "category": "honorific_candidate", "source_text": "Thank you for your help.", "reference_ko": "도와주셔서 감사합니다.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "polite"}}
{"case_id": "PERF_ENKO_0058", "category": "honorific_candidate", "source_text": "Could you repeat that?", "reference_ko": "다시 말씀해 주시겠어요?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "polite"}}
{"case_id": "PERF_ENKO_0059", "category": "honorific_candidate", "source_text": "I'll call you later.", "reference_ko": "나중에 연락드리겠습니다.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "polite"}}
{"case_id": "PERF_ENKO_0060", "category": "honorific_candidate", "source_text": "Please be careful.", "reference_ko": "조심하세요.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "polite"}}
{"case_id": "PERF_ENKO_0061", "category": "casual_candidate", "source_text": "Are you okay?", "reference_ko": "괜찮아?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0062", "category": "casual_candidate", "source_text": "I'll call you later.", "reference_ko": "나중에 전화할게.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0063", "category": "casual_candidate", "source_text": "Stop joking.", "reference_ko": "장난 그만해.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0064", "category": "casual_candidate", "source_text": "You knew?", "reference_ko": "알고 있었어?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0065", "category": "casual_candidate", "source_text": "I'm hungry.", "reference_ko": "나 배고파.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0066", "category": "casual_candidate", "source_text": "Let's go home.", "reference_ko": "집에 가자.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0067", "category": "casual_candidate", "source_text": "Don't cry.", "reference_ko": "울지 마.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0068", "category": "casual_candidate", "source_text": "I missed you.", "reference_ko": "보고 싶었어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0069", "category": "context_dependent", "source_text": "Me too.", "reference_ko": "나도.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0070", "category": "context_dependent", "source_text": "Not again.", "reference_ko": "또야?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0071", "category": "context_dependent", "source_text": "That one.", "reference_ko": "저거.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0072", "category": "context_dependent", "source_text": "Do it now.", "reference_ko": "지금 해.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0073", "category": "context_dependent", "source_text": "Same as before.", "reference_ko": "전이랑 똑같아.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0074", "category": "context_dependent", "source_text": "You promised.", "reference_ko": "약속했잖아.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0075", "category": "context_dependent", "source_text": "After all this?", "reference_ko": "이렇게까지 했는데?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0076", "category": "context_dependent", "source_text": "Then what?", "reference_ko": "그럼 뭐?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0077", "category": "compression_needed", "source_text": "I was just trying to tell you that this might not be the best time.", "reference_ko": "지금은 말할 때가 아닌 것 같다고 하려던 거야.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0078", "category": "compression_needed", "source_text": "If we leave now, we might still make it before sunrise.", "reference_ko": "지금 떠나면 해 뜨기 전엔 도착할 수 있어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0079", "category": "compression_needed", "source_text": "You don't have to pretend everything is okay.", "reference_ko": "괜찮은 척 안 해도 돼.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0080", "category": "compression_needed", "source_text": "I thought you said we were done talking about this.", "reference_ko": "이 얘긴 끝났다고 했잖아.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0081", "category": "compression_needed", "source_text": "There's no way we can explain this to them tonight.", "reference_ko": "오늘 밤엔 이걸 설명 못 해.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0082", "category": "compression_needed", "source_text": "I need you to listen before you get angry.", "reference_ko": "화내기 전에 내 말부터 들어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0083", "category": "compression_needed", "source_text": "This is exactly why I didn't want to come back.", "reference_ko": "그래서 돌아오기 싫었던 거야.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0084", "category": "compression_needed", "source_text": "We only get one chance to make this right.", "reference_ko": "바로잡을 기회는 한 번뿐이야.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0085", "category": "linebreak_subtitle", "source_text": "Are you okay?<br>Say something.", "reference_ko": "괜찮아?\n뭐라도 말해.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0086", "category": "linebreak_subtitle", "source_text": "Wait here.<br>I'll be back.", "reference_ko": "여기서 기다려.\n금방 올게.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0087", "category": "linebreak_subtitle", "source_text": "Don't look down.<br>Just breathe.", "reference_ko": "아래 보지 마.\n그냥 숨 쉬어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0088", "category": "linebreak_subtitle", "source_text": "It's not your fault.<br>Do you hear me?", "reference_ko": "네 잘못 아니야.\n알겠어?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0089", "category": "linebreak_subtitle", "source_text": "Open the door.<br>Now.", "reference_ko": "문 열어.\n지금.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0090", "category": "linebreak_subtitle", "source_text": "I know.<br>I'm sorry.", "reference_ko": "알아.\n미안해.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0091", "category": "linebreak_subtitle", "source_text": "One more step.<br>That's all.", "reference_ko": "한 걸음만 더.\n그거면 돼.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0092", "category": "linebreak_subtitle", "source_text": "Stay quiet.<br>They're close.", "reference_ko": "조용히 해.\n가까이 있어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0093", "category": "idiom_or_slang", "source_text": "You're kidding me.", "reference_ko": "농담이지?", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0094", "category": "idiom_or_slang", "source_text": "That's a long story.", "reference_ko": "얘기가 좀 길어.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0095", "category": "idiom_or_slang", "source_text": "Don't push your luck.", "reference_ko": "운 좋다고 까불지 마.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "rough"}}
{"case_id": "PERF_ENKO_0096", "category": "idiom_or_slang", "source_text": "I'm all ears.", "reference_ko": "말해 봐.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
{"case_id": "PERF_ENKO_0097", "category": "idiom_or_slang", "source_text": "It's now or never.", "reference_ko": "지금 아니면 끝이야.", "context": {"previous_source": null, "next_source": null}, "constraints": {"subtitle_style": true, "prefer_short": true, "tone": "casual"}}
