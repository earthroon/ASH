+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct StaticSemanticPriorControlledConfig {
+    pub enabled: bool,
+    pub profile: StaticSemanticPriorProfile,
+    pub require_run01_pass: bool,
+    pub require_sampler04_strict_ready: bool,
+    pub require_minp_c2a_alignment_pass: bool,
+    pub qwave_weight: f32,
+    pub deltak_weight: f32,
+    pub cross_weight: f32,
+    pub bias_cap: f32,
+    pub domination_guard_enabled: bool,
+    pub domination_guard_strict: bool,
+    pub max_rank_flip_ratio: f32,
+    pub max_bias_to_margin_ratio: f32,
+}
+
+impl Default for StaticSemanticPriorControlledConfig {
+    fn default() -> Self {
+        Self {
+            enabled: false,
+            profile: StaticSemanticPriorProfile::StaticSafeV1,
+            require_run01_pass: true,
+            require_sampler04_strict_ready: true,
+            require_minp_c2a_alignment_pass: true,
+            qwave_weight: 0.05,
+            deltak_weight: 0.05,
+            cross_weight: 0.0,
+            bias_cap: 0.20,
+            domination_guard_enabled: true,
+            domination_guard_strict: false,
+            max_rank_flip_ratio: 0.25,
+            max_bias_to_margin_ratio: 0.5,
+        }
+    }
+}
+
+impl StaticSemanticPriorControlledConfig {
+    pub fn sanitized(mut self) -> Self {
+        if !self.qwave_weight.is_finite() { self.qwave_weight = 0.0; }
+        if !self.deltak_weight.is_finite() { self.deltak_weight = 0.0; }
+        if !self.cross_weight.is_finite() { self.cross_weight = 0.0; }
+        if !self.bias_cap.is_finite() || self.bias_cap < 0.0 { self.bias_cap = 0.0; }
+        self.bias_cap = self.bias_cap.min(0.20);
+        if !self.max_rank_flip_ratio.is_finite() || self.max_rank_flip_ratio < 0.0 { self.max_rank_flip_ratio = 0.25; }
+        if !self.max_bias_to_margin_ratio.is_finite() || self.max_bias_to_margin_ratio < 0.0 { self.max_bias_to_margin_ratio = 0.5; }
+        self
+    }
+
+    pub fn to_semantic_prior_config(&self) -> SemanticPriorConfig {
+        let cfg = self.clone().sanitized();
+        SemanticPriorConfig {
+            enabled: cfg.enabled,
+            qwave_weight: cfg.qwave_weight,
+            deltak_weight: cfg.deltak_weight,
+            cross_weight: cfg.cross_weight,
+            bias_cap: cfg.bias_cap,
+            apply_to_min_p: true,
+            apply_to_top_p: true,
+            apply_to_sampling_score: true,
+            require_sampler04_strict_ready: cfg.require_sampler04_strict_ready,
+        }
+    }
+}
