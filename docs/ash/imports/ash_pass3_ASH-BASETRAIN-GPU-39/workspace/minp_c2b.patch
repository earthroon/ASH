++pub fn compute_static_safe_v1_bias(cfg: &StaticSemanticPriorControlledConfig, qwave: f32, deltak: f32) -> f32 {
++    let cfg = cfg.clone().sanitized();
++    let q = if qwave.is_finite() { qwave.clamp(-1.0, 1.0) } else { 0.0 };
++    let k = if deltak.is_finite() { deltak.clamp(-1.0, 1.0) } else { 0.0 };
++    let raw = cfg.qwave_weight * q + cfg.deltak_weight * k + cfg.cross_weight * q * k;
++    if raw.is_finite() { raw.clamp(-cfg.bias_cap, cfg.bias_cap) } else { 0.0 }
++}
++
++pub fn apply_static_semantic_prior_controlled(
++    cfg: &StaticSemanticPriorControlledConfig,
++    scaled_logit: f32,
++    qwave: f32,
++    deltak: f32,
++    source_available: bool,
++    snapshot_present: bool,
++) -> StaticSemanticPriorApplyResult {
++    let cfg = cfg.clone().sanitized();
++    let (gate_status, gate_reason) = static_semantic_prior_gate_status_from_env(&cfg, source_available, snapshot_present);
++    if !matches!(gate_status, StaticSemanticPriorGateStatus::Pass) {
++        return StaticSemanticPriorApplyResult {
++            effective: false,
++            gate_status,
++            gate_reason,
++            semantic_bias: 0.0,
++            weighted_logit_before: scaled_logit,
++            weighted_logit_after: scaled_logit,
++            qwave_score: if qwave.is_finite() { qwave } else { 0.0 },
++            deltak_score: if deltak.is_finite() { deltak } else { 0.0 },
++        };
++    }
++    let bias = compute_static_safe_v1_bias(&cfg, qwave, deltak);
++    StaticSemanticPriorApplyResult {
++        effective: true,
++        gate_status,
++        gate_reason,
++        semantic_bias: bias,
++        weighted_logit_before: scaled_logit,
++        weighted_logit_after: scaled_logit + bias,
++        qwave_score: if qwave.is_finite() { qwave.clamp(-1.0, 1.0) } else { 0.0 },
++        deltak_score: if deltak.is_finite() { deltak.clamp(-1.0, 1.0) } else { 0.0 },
++    }
++}
