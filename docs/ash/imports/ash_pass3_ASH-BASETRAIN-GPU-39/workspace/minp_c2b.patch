++pub fn static_semantic_prior_gate_status_from_env(
++    cfg: &StaticSemanticPriorControlledConfig,
++    source_available: bool,
++    snapshot_present: bool,
++) -> (StaticSemanticPriorGateStatus, Option<String>) {
++    if !cfg.enabled {
++        return (StaticSemanticPriorGateStatus::Disabled, Some("SEMANTIC_PRIOR_CONTROLLED_DISABLED".to_string()));
++    }
++    if cfg.require_run01_pass {
++        let cargo = env::var("ASH_RUN01_CARGO_STATUS").unwrap_or_else(|_| "NOT_RUN".to_string());
++        let wgsl = env::var("ASH_RUN01_WGSL_STATUS").unwrap_or_else(|_| "NOT_RUN".to_string());
++        if cargo != "PASS" || wgsl != "PASS" {
++            return (StaticSemanticPriorGateStatus::BlockedRun01NotPass, Some("RUN01_CARGO_OR_WGSL_NOT_PASS".to_string()));
++        }
++    }
++    if cfg.require_sampler04_strict_ready {
++        let status = env::var("ASH_SAMPLER04_PROMOTION_STATUS").unwrap_or_else(|_| "NOT_RUN".to_string());
++        if status != "STRICT_CANDIDATE_READY" {
++            return (StaticSemanticPriorGateStatus::BlockedSampler04NotReady, Some("SAMPLER04_STRICT_NOT_READY".to_string()));
++        }
++    }
++    if cfg.require_minp_c2a_alignment_pass {
++        let status = env::var("ASH_MINP_C2A_ALIGNMENT_STATUS").unwrap_or_else(|_| "NOT_RUN".to_string());
++        if status != "PASS" {
++            return (StaticSemanticPriorGateStatus::BlockedMinpC2aAlignmentNotPass, Some("MINP_C2A_ALIGNMENT_NOT_PASS".to_string()));
++        }
++    }
++    if !snapshot_present {
++        return (StaticSemanticPriorGateStatus::BlockedSnapshotMissing, Some("SCORE_SNAPSHOT_MISSING".to_string()));
++    }
++    if !source_available {
++        return (StaticSemanticPriorGateStatus::BlockedSourceUnavailable, Some("NO_QWAVE_DELTAK_SOURCE".to_string()));
++    }
++    (StaticSemanticPriorGateStatus::Pass, None)
++}
