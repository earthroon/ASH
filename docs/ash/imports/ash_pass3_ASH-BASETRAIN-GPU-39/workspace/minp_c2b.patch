+        let cfg = StaticSemanticPriorControlledConfig { enabled: true, require_run01_pass: false, require_sampler04_strict_ready: false, require_minp_c2a_alignment_pass: false, ..Default::default() };
+        let out = apply_static_semantic_prior_controlled(&cfg, 10.0, 1.0, 1.0, false, false);
