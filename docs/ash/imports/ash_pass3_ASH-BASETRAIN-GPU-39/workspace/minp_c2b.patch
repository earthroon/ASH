+pub fn static_semantic_prior_controlled_config_from_env() -> StaticSemanticPriorControlledConfig {
+    let mode = env::var("ASH_SEMANTIC_PRIOR").unwrap_or_else(|_| "off".to_string());
+    let enabled = matches!(mode.as_str(), "controlled" | "on") && env_bool("ASH_SEMANTIC_PRIOR_CONTROLLED_ENABLE", false);
+    StaticSemanticPriorControlledConfig {
+        enabled,
+        qwave_weight: env_f32("ASH_SEMANTIC_PRIOR_QWAVE_WEIGHT", 0.05),
+        deltak_weight: env_f32("ASH_SEMANTIC_PRIOR_DELTAK_WEIGHT", 0.05),
+        cross_weight: env_f32("ASH_SEMANTIC_PRIOR_CROSS_WEIGHT", 0.0),
+        bias_cap: env_f32("ASH_SEMANTIC_PRIOR_BIAS_CAP", 0.20),
+        domination_guard_enabled: env_bool("ASH_SEMANTIC_PRIOR_DOMINATION_GUARD", true),
+        domination_guard_strict: env_bool("ASH_SEMANTIC_PRIOR_DOMINATION_GUARD_STRICT", false),
+        ..Default::default()
+    }.sanitized()
+}
