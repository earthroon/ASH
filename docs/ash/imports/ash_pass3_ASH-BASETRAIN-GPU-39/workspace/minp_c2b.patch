+fn env_bool(name: &str, default: bool) -> bool {
+    match env::var(name).ok().as_deref() {
+        Some("1") | Some("true") | Some("TRUE") | Some("on") | Some("ON") | Some("yes") | Some("YES") => true,
+        Some("0") | Some("false") | Some("FALSE") | Some("off") | Some("OFF") | Some("no") | Some("NO") => false,
+        _ => default,
+    }
+}
+
+fn env_f32(name: &str, default: f32) -> f32 {
+    env::var(name).ok().and_then(|v| v.parse::<f32>().ok()).filter(|v| v.is_finite()).unwrap_or(default)
+}
