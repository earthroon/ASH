+#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
+pub enum StaticSemanticPriorGateStatus {
+    Pass,
+    BlockedRun01NotPass,
+    BlockedSampler04NotReady,
+    BlockedMinpC2aAlignmentNotPass,
+    BlockedSnapshotMissing,
+    BlockedSourceUnavailable,
+    BlockedDominationGuard,
+    Disabled,
+}
+
+impl StaticSemanticPriorGateStatus {
+    pub fn as_str(&self) -> &'static str {
+        match self {
+            Self::Pass => "PASS",
+            Self::BlockedRun01NotPass => "RUN01_NOT_PASS",
+            Self::BlockedSampler04NotReady => "SAMPLER04_STRICT_NOT_READY",
+            Self::BlockedMinpC2aAlignmentNotPass => "MINP_C2A_ALIGNMENT_NOT_PASS",
+            Self::BlockedSnapshotMissing => "SCORE_SNAPSHOT_MISSING",
+            Self::BlockedSourceUnavailable => "NO_QWAVE_DELTAK_SOURCE",
+            Self::BlockedDominationGuard => "SEMANTIC_PRIOR_DOMINATION_GUARD",
+            Self::Disabled => "DISABLED",
+        }
+    }
+}
