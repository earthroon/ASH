++#[derive(Debug, Clone, Serialize, Deserialize)]
++pub struct CpuOracleSampleResult {
++    pub selected_id: u32,
++    pub selected_logit: f32,
++    pub selected_logprob: f32,
++    pub active_count_before_min_p: usize,
++    pub active_count_after_min_p: usize,
++    pub active_count_after_top_p: usize,
++    pub min_p_threshold: Option<f32>,
++    pub sampler_applied: bool,
++    pub apply_mode: SamplingApplyMode,
++    pub active_softmax_renormalized: bool,
++    pub candidate_empty_recovered: bool,
++    pub recovery_mode: Option<String>,
++}
++
++#[derive(Debug, Clone)]
++struct Candidate {
++    id: u32,
++    logit: f32,
++    scaled: f32,
++    prob: f32,
++}
++
++pub fn sampler_requested(config: &GenerationSamplingConfig) -> bool {
++    config.temperature > 0.0 || config.top_k > 0 || config.top_p < 1.0 || config.min_p > 0.0
++}
++
++pub fn sample_with_cpu_oracle(
++    logits: &[f32],
++    config: &GenerationSamplingConfig,
++    ctx: &CpuOracleContext,
++) -> CpuOracleSampleResult {
++    if logits.is_empty() {
++        return CpuOracleSampleResult {
++            selected_id: ctx.eos_token_id.unwrap_or(0),
++            selected_logit: f32::NEG_INFINITY,
++            selected_logprob: f32::NEG_INFINITY,
++            active_count_before_min_p: 0,
++            active_count_after_min_p: 0,
++            active_count_after_top_p: 0,
++            min_p_threshold: None,
++            sampler_applied: false,
++            apply_mode: SamplingApplyMode::GreedyFallbackDisabled,
++            active_softmax_renormalized: false,
++            candidate_empty_recovered: true,
++            recovery_mode: Some("empty_logits".to_string()),
++        };
++    }
++
++    let requested = sampler_requested(config);
++    if !requested {
++        return greedy_result(logits, ctx, SamplingApplyMode::Greedy);
++    }
++
++    let temp = if config.temperature.is_finite() && config.temperature > 0.0 {
++        config.temperature
++    } else {
++        1.0
++    };
++
++    let banned = |id: u32| -> bool { ctx.banned_token_ids.binary_search(&id).is_ok() || ctx.banned_token_ids.contains(&id) };
++    let eos_blocked = |id: u32| -> bool {
++        ctx.eos_token_id == Some(id) && ctx.min_new_tokens > 0 && ctx.step < ctx.min_new_tokens
++    };
++
++    let mut candidates = logits
++        .iter()
++        .copied()
++        .enumerate()
++        .filter_map(|(idx, logit)| {
++            let id = idx as u32;
++            if !logit.is_finite() || banned(id) || eos_blocked(id) {
++                return None;
++            }
++            Some(Candidate {
++                id,
++                logit,
++                scaled: logit / temp,
++                prob: 0.0,
++            })
++        })
++        .collect::<Vec<_>>();
++
++    if candidates.is_empty() {
++        return recover_valid_top1(logits, ctx, "no_candidate_after_ban_eos_guard");
++    }
++
++    candidates.sort_by(|a, b| b.scaled.total_cmp(&a.scaled));
++    if config.top_k > 0 {
++        let k = (config.top_k as usize).min(candidates.len()).max(1);
++        candidates.truncate(k);
++    }
++
++    let active_count_before_min_p = candidates.len();
++    let mut min_p_threshold = None;
++    if config.min_p.is_finite() && config.min_p > 0.0 {
++        let min_p = config.min_p.clamp(0.0, 0.95);
++        if let Some(max_scaled) = candidates.iter().map(|c| c.scaled).max_by(|a, b| a.total_cmp(b)) {
++            let threshold = max_scaled + min_p.ln();
++            min_p_threshold = Some(threshold);
++            candidates.retain(|c| c.scaled >= threshold);
++        }
++    }
++
++    if candidates.is_empty() {
++        return recover_valid_top1(logits, ctx, "no_candidate_after_min_p");
++    }
++    let active_count_after_min_p = candidates.len();
++
++    renormalize_active_set(&mut candidates);
++
++    candidates.sort_by(|a, b| b.prob.total_cmp(&a.prob));
++    let mut top_p_cut = candidates.len();
++    if config.top_p.is_finite() && config.top_p > 0.0 && config.top_p < 1.0 {
++        let mut acc = 0.0f32;
++        top_p_cut = 0;
++        for cand in &candidates {
++            acc += cand.prob;
++            top_p_cut += 1;
++            if acc >= config.top_p {
++                break;
++            }
++        }
++        top_p_cut = top_p_cut.max(1).min(candidates.len());
++        candidates.truncate(top_p_cut);
++        renormalize_active_set(&mut candidates);
++    }
++
++    if candidates.is_empty() {
++        return recover_valid_top1(logits, ctx, "no_candidate_after_top_p");
++    }
++
++    let r = deterministic_unit(ctx.seed, ctx.step, config.min_p, config.top_p, config.top_k, config.temperature);
++    let mut acc = 0.0f32;
++    let mut selected = candidates.last().cloned().unwrap();
++    for cand in &candidates {
++        acc += cand.prob;
++        if r <= acc {
++            selected = cand.clone();
++            break;
++        }
++    }
++
++    CpuOracleSampleResult {
++        selected_id: selected.id,
++        selected_logit: selected.logit,
++        selected_logprob: selected.prob.max(1e-20).ln(),
++        active_count_before_min_p,
++        active_count_after_min_p,
++        active_count_after_top_p: candidates.len(),
++        min_p_threshold,
++        sampler_applied: true,
++        apply_mode: SamplingApplyMode::CpuOracleSampler,
++        active_softmax_renormalized: true,
++        candidate_empty_recovered: false,
++        recovery_mode: None,
++    }
++}
++
++fn renormalize_active_set(candidates: &mut [Candidate]) {
++    if candidates.is_empty() {
++        return;
++    }
++    let max_scaled = candidates
++        .iter()
++        .map(|c| c.scaled)
++        .max_by(|a, b| a.total_cmp(b))
++        .unwrap_or(0.0);
++    let mut sum = 0.0f32;
++    for cand in candidates.iter_mut() {
++        cand.prob = (cand.scaled - max_scaled).exp();
++        sum += cand.prob;
++    }
++    if sum.is_finite() && sum > 0.0 {
++        for cand in candidates.iter_mut() {
++            cand.prob /= sum;
++        }
++    } else {
++        let uniform = 1.0 / candidates.len() as f32;
++        for cand in candidates.iter_mut() {
++            cand.prob = uniform;
++        }
++    }
++}
++
++fn greedy_result(logits: &[f32], ctx: &CpuOracleContext, mode: SamplingApplyMode) -> CpuOracleSampleResult {
++    let mut best_id = ctx.eos_token_id.unwrap_or(0);
++    let mut best_logit = f32::NEG_INFINITY;
++    for (idx, &logit) in logits.iter().enumerate() {
++        if !logit.is_finite() {
++            continue;
++        }
++        let id = idx as u32;
++        if ctx.banned_token_ids.contains(&id) || ctx.pad_token_id == Some(id) {
++            continue;
++        }
++        if logit > best_logit {
++            best_id = id;
++            best_logit = logit;
++        }
++    }
++    CpuOracleSampleResult {
++        selected_id: best_id,
++        selected_logit: best_logit,
++        selected_logprob: f32::NEG_INFINITY,
++        active_count_before_min_p: 1,
++        active_count_after_min_p: 1,
++        active_count_after_top_p: 1,
++        min_p_threshold: None,
++        sampler_applied: false,
++        apply_mode: mode,
++        active_softmax_renormalized: false,
++        candidate_empty_recovered: false,
++        recovery_mode: None,
++    }
++}
++
++fn recover_valid_top1(logits: &[f32], ctx: &CpuOracleContext, reason: &str) -> CpuOracleSampleResult {
++    let mut result = greedy_result(logits, ctx, SamplingApplyMode::GreedyFallbackDisabled);
++    result.candidate_empty_recovered = true;
++    result.recovery_mode = Some(reason.to_string());
++    result.sampler_applied = true;
++    result.apply_mode = SamplingApplyMode::CpuOracleSampler;
++    result
++}
++
++fn deterministic_unit(seed: u64, step: usize, min_p: f32, top_p: f32, top_k: u32, temperature: f32) -> f32 {
++    let mut x = seed
++        ^ ((step as u64).wrapping_mul(0x9E37_79B9_7F4A_7C15))
++        ^ ((top_k as u64) << 32)
++        ^ ((min_p.to_bits() as u64) << 1)
++        ^ ((top_p.to_bits() as u64) << 7)
++        ^ ((temperature.to_bits() as u64) << 13);
++    x ^= x >> 30;
++    x = x.wrapping_mul(0xBF58_476D_1CE4_E5B9);
++    x ^= x >> 27;
++    x = x.wrapping_mul(0x94D0_49BB_1331_11EB);
++    x ^= x >> 31;
++    let mantissa = (x >> 40) as u32;
++    (mantissa as f32) / ((1u32 << 24) as f32)
++}
