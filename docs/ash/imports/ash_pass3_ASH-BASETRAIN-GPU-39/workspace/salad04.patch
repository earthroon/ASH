++pub fn classify_korean_morph_piece(piece: Option<&str>) -> KoreanMorphClass {
++    let Some(piece) = piece else { return KoreanMorphClass::Unknown; };
++    let normalized = normalize_piece(piece);
++    if normalized.is_empty() {
++        return KoreanMorphClass::Whitespace;
++    }
++    if normalized.contains('�') || normalized.contains("<0x") || normalized.contains("0x") || normalized.starts_with("<U+") {
++        return KoreanMorphClass::BytePiece;
++    }
++    if normalized.chars().count() == 1 && normalized.chars().all(is_hangul_jamo) {
++        return KoreanMorphClass::HangulJamo;
++    }
++    if josa_like(&normalized) {
++        return KoreanMorphClass::JosaLike;
++    }
++    if eomi_like(&normalized) && normalized.chars().any(is_hangul_syllable) {
++        return KoreanMorphClass::EomiLike;
++    }
++    if normalized.chars().all(is_hangul_syllable) {
++        return KoreanMorphClass::HangulSyllable;
++    }
++    if normalized.chars().all(|c| c.is_whitespace()) {
++        return KoreanMorphClass::Whitespace;
++    }
++    if normalized.chars().all(is_common_punctuation) {
++        return KoreanMorphClass::Punctuation;
++    }
++    if normalized.chars().all(is_symbol) {
++        return KoreanMorphClass::Symbol;
++    }
++    if normalized.chars().any(is_hangul_syllable) || normalized.chars().any(is_hangul_jamo) {
++        KoreanMorphClass::Mixed
++    } else {
++        KoreanMorphClass::Unknown
++    }
++}
