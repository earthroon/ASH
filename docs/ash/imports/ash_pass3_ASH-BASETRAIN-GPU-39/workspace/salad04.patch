+pub fn append_salad04_receipt_from_sampler03(source: &SamplerParityReceipt) {
+    let mode = Salad04Mode::from_env();
+    if !mode.enabled() {
+        return;
+    }
+    let entropy_receipt = receipt_from_sampler03(Decode03AMode::Receipt, source);
+    let pci_receipt = receipt_from_decode03a(Decode03BMode::Receipt, &entropy_receipt, None, 0);
+    let shadow_receipt = receipt_from_decode03b(Decode03CMode::Receipt, &pci_receipt, Some(&entropy_receipt));
+    let dynamic_mode = DynamicSamplerMode::from_env();
+    let mut decode03d_receipt = receipt_from_decode03c(dynamic_mode, &shadow_receipt);
+    decode03d_receipt.selected_id_after_apply = Some(source.cpu.selected_id);
+    let salad02_receipt = receipt_from_decode03d(&decode03d_receipt);
+    let receipt = receipt_from_salad02(mode, &salad02_receipt);
+    let path = receipt_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(line) = serde_json::to_string(&receipt) {
+        use std::io::Write;
+        if let Ok(mut file) = fs::OpenOptions::new().create(true).append(true).open(path) {
+            let _ = writeln!(file, "{}", line);
+        }
+    }
+}
+
+fn read_receipts(path: PathBuf) -> Vec<Salad04StepReceipt> {
+    let Ok(content) = fs::read_to_string(path) else { return Vec::new(); };
+    content
+        .lines()
+        .filter_map(|line| serde_json::from_str::<Salad04StepReceipt>(line).ok())
+        .collect()
+}
+
+pub fn summary_from_receipts(receipts: &[Salad04StepReceipt]) -> Salad04Summary {
+    let mut risk_counts = Salad04RiskCounts::default();
+    let mut loop_kinds = Salad04LoopKindCounts::default();
+    let mut overlay = Salad04OverlayCounts::default();
+    let mut safety = Salad04SafetyCounts::default();
+
+    for receipt in receipts {
+        if receipt.behavior_change || receipt.detection.behavior_change { safety.behavior_change_count += 1; }
+        if !receipt.guard_overlay_only || !receipt.detection.guard_overlay_only { safety.guard_execution_count += 1; }
+        if !(0.0..=1.0).contains(&receipt.detection.morph_score) { safety.score_out_of_range_count += 1; }
+        match receipt.detection.morph_risk_stable.as_str() {
+            "Critical" => risk_counts.critical += 1,
+            "High" => risk_counts.high += 1,
+            "Medium" => risk_counts.medium += 1,
+            _ => risk_counts.low += 1,
+        }
+        match receipt.detection.dominant_loop_kind {
+            KoreanMorphLoopKind::JosaRepeat => loop_kinds.josa_repeat_count += 1,
+            KoreanMorphLoopKind::JosaChain => loop_kinds.josa_chain_count += 1,
+            KoreanMorphLoopKind::EomiRepeat => loop_kinds.eomi_repeat_count += 1,
+            KoreanMorphLoopKind::EomiPunctuationLoop => loop_kinds.eomi_punctuation_loop_count += 1,
+            KoreanMorphLoopKind::JamoLeak => loop_kinds.jamo_leak_count += 1,
+            KoreanMorphLoopKind::ByteJamoMixedLeak => loop_kinds.byte_jamo_mixed_leak_count += 1,
+            KoreanMorphLoopKind::SyllableFragmentLoop => loop_kinds.syllable_fragment_loop_count += 1,
+            KoreanMorphLoopKind::EojeolBoundaryCollapse => loop_kinds.eojeol_boundary_collapse_count += 1,
+            KoreanMorphLoopKind::PunctuationGlueLoop => loop_kinds.punctuation_glue_loop_count += 1,
+            KoreanMorphLoopKind::MixedMorphLoop => loop_kinds.mixed_morph_loop_count += 1,
+            KoreanMorphLoopKind::None => {}
+        }
+        let rec = &receipt.detection.overlay_recommendation;
+        if rec.raise_salad02_risk_candidate { overlay.raise_salad02_risk_candidate_count += 1; }
+        if rec.rollback_candidate_boost { overlay.rollback_candidate_boost_count += 1; }
+        if rec.safe_stop_candidate_boost { overlay.safe_stop_candidate_boost_count += 1; }
+        if rec.suggested_guard_strength.as_deref() == Some("Panic") { overlay.panic_guard_hint_count += 1; }
+        if rec.no_repeat_ngram_hint.is_some() { overlay.no_repeat_ngram_hint_count += 1; }
+    }
+
+    let steps_observed = receipts.len();
+    let contract_fail = safety.behavior_change_count > 0
+        || safety.guard_execution_count > 0
+        || safety.rollback_execution_count > 0
+        || safety.stop_execution_count > 0
+        || safety.score_out_of_range_count > 0;
+    Salad04Summary {
+        patch_id: SALAD04_PATCH_ID.to_string(),
+        input_patch: SALAD04_INPUT_PATCH_ID.to_string(),
+        status: if contract_fail { "FAIL_STATIC_CONTRACT" } else if steps_observed > 0 { "PASS_WITH_WARNINGS" } else { "STATIC_BAKE_DEFINED_NOT_RUN" }.to_string(),
+        mode: Salad04Mode::from_env().as_str().to_string(),
+        behavior_change: false,
+        guard_overlay_only: true,
+        steps_observed,
+        risk_counts,
+        loop_kinds,
+        overlay,
+        safety,
+        ready_for_eval00_decode_regression: !contract_fail,
+        ready_for_decode03e_guard_overlay_apply: false,
+        reason: if contract_fail {
+            "SALAD-04 contract violation detected; morph guard must remain overlay-only".to_string()
+        } else if steps_observed == 0 {
+            "Korean morph loop guard schema baked; run SALAD-02 fixtures before overlay promotion".to_string()
+        } else {
+            "korean morph loop guard sealed as risk overlay; no direct behavior change".to_string()
+        },
+    }
+}
+
+pub fn write_salad04_summary_from_receipt_file() {
+    let summary = summary_from_receipts(&read_receipts(receipt_path()));
+    let path = summary_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(json) = serde_json::to_string_pretty(&summary) {
+        let _ = fs::write(path, format!("{}\n", json));
+    }
+}
