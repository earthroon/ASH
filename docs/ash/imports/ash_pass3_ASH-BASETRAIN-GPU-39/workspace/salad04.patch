+pub fn input_from_salad02(receipt: &Salad02StepReceipt, mode: Salad04Mode) -> Salad04Input {
+    let current = observation_from_salad02(receipt);
+    let recent = observe_window(current.clone());
+    Salad04Input {
+        mode,
+        current,
+        recent,
+        salad02_score: Some(receipt.detection.score),
+        salad02_risk_stable: Some(receipt.detection.risk_stable.as_str().to_string()),
+        pci_raw: receipt.input.current.pci_raw,
+        pci_bucket: receipt.input.current.pci_bucket.clone(),
+        entropy_spike: receipt.input.entropy_spike,
+        fallback_risk: receipt.input.fallback_risk,
+        numeric_risk: receipt.input.numeric_risk,
+        global_finite_fallback_seen: receipt.input.global_finite_fallback_seen,
+        decode03d_guard_strength: receipt.input.current.guard_strength.clone(),
+        stop01_executed: false,
+    }
+}
+
+pub fn receipt_from_salad02(mode: Salad04Mode, receipt: &Salad02StepReceipt) -> Salad04StepReceipt {
+    let input = input_from_salad02(receipt, mode);
+    let detection = detect_korean_morph_loop(&input);
+    let selected_id = input.current.token_id;
+    let selected_piece_preview = input.current.piece_preview.clone();
+    Salad04StepReceipt {
+        patch_id: SALAD04_PATCH_ID.to_string(),
+        input_patch: SALAD04_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: run_id_from_env(),
+        prompt_hash: receipt.prompt_hash.clone(),
+        seed: receipt.seed,
+        step: receipt.step,
+        backend: receipt.backend.clone(),
+        sampler_ssot: SALAD04_SSOT.to_string(),
+        mode,
+        behavior_change: false,
+        guard_overlay_only: true,
+        salad02_status_seen: Some("DERIVED_IN_MEMORY_FROM_SALAD02_RECEIPT".to_string()),
+        decode03d_status_seen: receipt.decode03d_status_seen.clone(),
+        stop02_status_seen: env::var("ASH_STOP02_STATUS_SEEN").ok(),
+        input,
+        detection,
+        selected_id,
+        selected_piece_preview,
+    }
+}
