+fn normalize_piece(piece: &str) -> String {
+    piece.trim().trim_start_matches('▁').trim().to_string()
+}
+
+fn is_hangul_syllable(c: char) -> bool {
+    ('가'..='힣').contains(&c)
+}
+
+fn is_hangul_jamo(c: char) -> bool {
+    ('ㄱ'..='ㅎ').contains(&c) || ('ㅏ'..='ㅣ').contains(&c) || ('ᄀ'..='ᇿ').contains(&c)
+}
+
+fn is_common_punctuation(c: char) -> bool {
+    matches!(c, '.' | ',' | '?' | '!' | ';' | ':' | '…' | '·' | '“' | '”' | '‘' | '’' | '(' | ')' | '[' | ']' | '。' | '、')
+}
+
+fn is_symbol(c: char) -> bool {
+    c.is_ascii_punctuation() || matches!(c, '~' | '`' | '@' | '#' | '$' | '%' | '^' | '&' | '*' | '_' | '+' | '=' | '|' | '\\' | '/' | '<' | '>' | '★' | '☆' | '※' | '■' | '□')
+}
+
+fn josa_like(piece: &str) -> bool {
+    matches!(piece,
+        "은" | "는" | "이" | "가" | "을" | "를" | "의" | "에" | "에서" | "에게" | "께" |
+        "으로" | "로" | "와" | "과" | "랑" | "도" | "만" | "부터" | "까지" | "보다" |
+        "처럼" | "마다" | "조차" | "마저")
+}
+
+fn eomi_like(piece: &str) -> bool {
+    let endings = [
+        "다", "요", "죠", "네", "며", "고", "서", "면", "지만", "는데", "니까", "습니다", "합니다", "했다", "된다", "있다", "없다", "것이다", "겁니다", "습니다.", "합니다.",
+    ];
+    endings.iter().any(|ending| piece == *ending || piece.ends_with(ending))
+}
+
+pub fn classify_korean_morph_piece(piece: Option<&str>) -> KoreanMorphClass {
+    let Some(piece) = piece else { return KoreanMorphClass::Unknown; };
+    let normalized = normalize_piece(piece);
+    if normalized.is_empty() {
+        return KoreanMorphClass::Whitespace;
+    }
+    if normalized.contains('�') || normalized.contains("<0x") || normalized.contains("0x") || normalized.starts_with("<U+") {
+        return KoreanMorphClass::BytePiece;
+    }
+    if normalized.chars().count() == 1 && normalized.chars().all(is_hangul_jamo) {
+        return KoreanMorphClass::HangulJamo;
+    }
+    if josa_like(&normalized) {
+        return KoreanMorphClass::JosaLike;
+    }
+    if eomi_like(&normalized) && normalized.chars().any(is_hangul_syllable) {
+        return KoreanMorphClass::EomiLike;
+    }
+    if normalized.chars().all(is_hangul_syllable) {
+        return KoreanMorphClass::HangulSyllable;
+    }
+    if normalized.chars().all(|c| c.is_whitespace()) {
+        return KoreanMorphClass::Whitespace;
+    }
+    if normalized.chars().all(is_common_punctuation) {
+        return KoreanMorphClass::Punctuation;
+    }
+    if normalized.chars().all(is_symbol) {
+        return KoreanMorphClass::Symbol;
+    }
+    if normalized.chars().any(is_hangul_syllable) || normalized.chars().any(is_hangul_jamo) {
+        KoreanMorphClass::Mixed
+    } else {
+        KoreanMorphClass::Unknown
+    }
+}
+
+fn tail_slice<T>(items: &[T], len: usize) -> &[T] {
+    if items.len() <= len { items } else { &items[items.len() - len..] }
+}
+
+fn ngram_repeat_count<T: Eq + Hash + Clone>(items: &[T], n: usize) -> usize {
+    if items.len() < n * 2 || n == 0 { return 0; }
+    let mut counts: HashMap<Vec<T>, usize> = HashMap::new();
+    for window in items.windows(n) {
+        *counts.entry(window.to_vec()).or_insert(0) += 1;
+    }
+    counts.values().map(|count| count.saturating_sub(1)).sum()
+}
+
+fn distinct_ratio<T: Eq + Hash + Clone>(items: &[T]) -> Option<f32> {
+    if items.is_empty() { return None; }
+    let mut set = HashSet::new();
+    for item in items {
+        set.insert(item.clone());
+    }
+    Some(set.len() as f32 / items.len() as f32)
+}
+
+fn class_streak(recent: &[Salad04MorphObservation], class: KoreanMorphClass) -> usize {
+    let mut count = 0;
+    for item in recent.iter().rev() {
+        if item.morph_class == class { count += 1; } else { break; }
+    }
+    count
+}
+
+fn same_piece_streak_for_class(recent: &[Salad04MorphObservation], class: KoreanMorphClass) -> usize {
+    let Some(last) = recent.last() else { return 0; };
+    if last.morph_class != class { return 0; }
+    let last_piece = last.piece_preview.as_deref().unwrap_or("");
+    let mut count = 0;
+    for item in recent.iter().rev() {
+        if item.morph_class == class && item.piece_preview.as_deref().unwrap_or("") == last_piece {
+            count += 1;
+        } else {
+            break;
+        }
+    }
+    count
+}
+
+fn punctuation_after_eomi(recent: &[Salad04MorphObservation]) -> usize {
+    recent.windows(2).filter(|pair| {
+        pair[0].morph_class == KoreanMorphClass::EomiLike
+            && pair[1].morph_class == KoreanMorphClass::Punctuation
+    }).count()
+}
+
+fn boundary_collapse_count(recent: &[Salad04MorphObservation]) -> usize {
+    recent.windows(2).filter(|pair| {
+        matches!(pair[0].morph_class, KoreanMorphClass::JosaLike | KoreanMorphClass::EomiLike)
+            && matches!(pair[1].morph_class, KoreanMorphClass::JosaLike | KoreanMorphClass::EomiLike)
+    }).count()
+}
