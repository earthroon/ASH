++pub fn compute_salad04_overlay(
++    input: &Salad04Input,
++    detection: &Salad04Detection,
++) -> Salad04OverlayRecommendation {
++    let mut overlay_reasons = Vec::new();
++    let high_or_critical = matches!(detection.morph_risk_stable.as_str(), "High" | "Critical");
++    let critical = detection.morph_risk_stable == "Critical";
++    let mut suggested_min_p_floor = None;
++    let mut suggested_top_p_ceiling = None;
++    let mut suggested_guard_strength = None;
++    let mut no_repeat_ngram_hint = None;
++
++    if high_or_critical {
++        overlay_reasons.push("morph_risk_high_or_critical".to_string());
++        suggested_guard_strength = Some("Panic".to_string());
++        no_repeat_ngram_hint = Some(3);
++    }
++    if critical {
++        overlay_reasons.push("morph_risk_critical".to_string());
++        suggested_min_p_floor = Some(0.12);
++        suggested_top_p_ceiling = Some(0.82);
++    }
++    if matches!(detection.dominant_loop_kind, KoreanMorphLoopKind::JamoLeak | KoreanMorphLoopKind::ByteJamoMixedLeak) {
++        overlay_reasons.push("jamo_or_byte_leak".to_string());
++        suggested_guard_strength = Some("Panic".to_string());
++        suggested_min_p_floor = Some(suggested_min_p_floor.unwrap_or(0.14).max(0.14));
++    }
++    if input.fallback_risk {
++        overlay_reasons.push("fallback_risk_amplifier".to_string());
++    }
++
++    Salad04OverlayRecommendation {
++        raise_salad02_risk_candidate: high_or_critical,
++        rollback_candidate_boost: high_or_critical,
++        safe_stop_candidate_boost: critical || input.numeric_risk || input.global_finite_fallback_seen,
++        suggested_min_p_floor,
++        suggested_top_p_ceiling,
++        suggested_guard_strength,
++        no_repeat_ngram_hint,
++        overlay_reasons,
++    }
++}
