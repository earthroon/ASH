++pub fn compute_salad04_score(
++    input: &Salad04Input,
++    metrics: &Salad04WindowMetrics,
++) -> Salad04RiskComponents {
++    let josa_loop_score = clamp01(
++        metrics.same_josa_streak.saturating_sub(1) as f32 / 4.0
++            + metrics.josa_chain_len.saturating_sub(1) as f32 / 5.0
++            + metrics.josa_count_short as f32 / 8.0,
++    );
++    let eomi_loop_score = clamp01(
++        metrics.same_eomi_streak.saturating_sub(1) as f32 / 4.0
++            + metrics.eomi_chain_len.saturating_sub(1) as f32 / 5.0
++            + metrics.punctuation_glue_count as f32 / 4.0,
++    );
++    let jamo_leak_score = clamp01(metrics.jamo_count_short as f32 / 3.0 + metrics.jamo_count_mid as f32 / 8.0);
++    let byte_jamo_score = clamp01(metrics.byte_jamo_mixed_count as f32 / 3.0);
++    let syllable_fragment_score = clamp01(metrics.syllable_fragment_repeat_count as f32 / 4.0 + metrics.morph_trigram_repeat_count as f32 / 5.0);
++    let eojeol_boundary_score = clamp01(metrics.eojeol_boundary_collapse_count as f32 / 4.0);
++    let punctuation_glue_score = clamp01(metrics.punctuation_glue_count as f32 / 4.0);
++    let pci_amplifier = pci_amplifier(input.pci_bucket.as_deref(), input.pci_raw);
++    let entropy_amplifier = clamp01(input.current.h_final_norm.unwrap_or(0.0) + if input.entropy_spike { 0.25 } else { 0.0 });
++    let raw_score = clamp01(
++        0.22 * josa_loop_score
++            + 0.22 * eomi_loop_score
++            + 0.18 * jamo_leak_score
++            + 0.10 * byte_jamo_score
++            + 0.10 * syllable_fragment_score
++            + 0.08 * eojeol_boundary_score
++            + 0.06 * punctuation_glue_score
++            + 0.02 * pci_amplifier
++            + 0.02 * entropy_amplifier,
++    );
++    let mut capped_score = raw_score;
++    if metrics.same_josa_streak >= 4 { capped_score = capped_score.max(0.55); }
++    if metrics.same_eomi_streak >= 4 { capped_score = capped_score.max(0.55); }
++    if metrics.jamo_count_short >= 3 { capped_score = capped_score.max(0.70); }
++    if metrics.byte_jamo_mixed_count >= 2 { capped_score = capped_score.max(0.80); }
++    if metrics.morph_trigram_repeat_count >= 2 && matches!(input.pci_bucket.as_deref(), Some("Unstable") | Some("Collapsing")) {
++        capped_score = capped_score.max(0.75);
++    }
++    if input.numeric_risk { capped_score = capped_score.max(0.85); }
++    if input.global_finite_fallback_seen { capped_score = capped_score.max(0.85); }
++    if matches!(input.pci_bucket.as_deref(), Some("Stable") | Some("Confident"))
++        && metrics.morph_trigram_repeat_count == 0
++        && metrics.jamo_count_short == 0
++        && metrics.byte_jamo_mixed_count == 0
++    {
++        capped_score = capped_score.min(0.35);
++    }
++    Salad04RiskComponents {
++        josa_loop_score,
++        eomi_loop_score,
++        jamo_leak_score,
++        byte_jamo_score,
++        syllable_fragment_score,
++        eojeol_boundary_score,
++        punctuation_glue_score,
++        pci_amplifier,
++        entropy_amplifier,
++        raw_score,
++        capped_score: clamp01(capped_score),
++    }
++}
