+pub fn detect_korean_loop_kind(
+    current: &Salad04MorphObservation,
+    recent: &[Salad04MorphObservation],
+) -> KoreanMorphLoopKind {
+    let short = tail_slice(recent, env_usize("ASH_SALAD04_WINDOW_SHORT", 8));
+    let same_josa = same_piece_streak_for_class(short, KoreanMorphClass::JosaLike);
+    let same_eomi = same_piece_streak_for_class(short, KoreanMorphClass::EomiLike);
+    let josa_chain = class_streak(short, KoreanMorphClass::JosaLike);
+    let eomi_chain = class_streak(short, KoreanMorphClass::EomiLike);
+    let jamo_count = short.iter().filter(|t| t.morph_class == KoreanMorphClass::HangulJamo).count();
+    let byte_count = short.iter().filter(|t| t.morph_class == KoreanMorphClass::BytePiece).count();
+    let punctuation_glue = punctuation_after_eomi(short);
+    let morph_classes: Vec<KoreanMorphClass> = short.iter().map(|t| t.morph_class).collect();
+    let trigram_repeat = ngram_repeat_count(&morph_classes, 3);
+    if byte_count > 0 && jamo_count > 0 {
+        KoreanMorphLoopKind::ByteJamoMixedLeak
+    } else if jamo_count >= 2 || current.morph_class == KoreanMorphClass::HangulJamo {
+        KoreanMorphLoopKind::JamoLeak
+    } else if same_josa >= 2 {
+        KoreanMorphLoopKind::JosaRepeat
+    } else if josa_chain >= 3 {
+        KoreanMorphLoopKind::JosaChain
+    } else if same_eomi >= 2 {
+        KoreanMorphLoopKind::EomiRepeat
+    } else if eomi_chain >= 2 && punctuation_glue > 0 {
+        KoreanMorphLoopKind::EomiPunctuationLoop
+    } else if boundary_collapse_count(short) >= 2 {
+        KoreanMorphLoopKind::EojeolBoundaryCollapse
+    } else if trigram_repeat >= 2 {
+        KoreanMorphLoopKind::SyllableFragmentLoop
+    } else if current.morph_class == KoreanMorphClass::Punctuation && class_streak(short, KoreanMorphClass::Punctuation) >= 3 {
+        KoreanMorphLoopKind::PunctuationGlueLoop
+    } else if current.morph_class == KoreanMorphClass::Mixed {
+        KoreanMorphLoopKind::MixedMorphLoop
+    } else {
+        KoreanMorphLoopKind::None
+    }
+}
+
+pub fn compute_salad04_window_metrics(recent: &[Salad04MorphObservation]) -> Salad04WindowMetrics {
+    let short_len = env_usize("ASH_SALAD04_WINDOW_SHORT", 8);
+    let mid_len = env_usize("ASH_SALAD04_WINDOW_MID", 32);
+    let long_len = env_usize("ASH_SALAD04_WINDOW_LONG", 96);
+    let short = tail_slice(recent, short_len);
+    let mid = tail_slice(recent, mid_len);
+    let long = tail_slice(recent, long_len);
+    let long_classes: Vec<KoreanMorphClass> = long.iter().map(|t| t.morph_class).collect();
+    let mid_classes: Vec<KoreanMorphClass> = mid.iter().map(|t| t.morph_class).collect();
+    let mid_pieces: Vec<String> = mid.iter().map(|t| t.piece_preview.clone().unwrap_or_default()).collect();
+    let byte_count = short.iter().filter(|t| t.morph_class == KoreanMorphClass::BytePiece).count();
+    let jamo_count_short = short.iter().filter(|t| t.morph_class == KoreanMorphClass::HangulJamo).count();
+    Salad04WindowMetrics {
+        window_size_short: short_len,
+        window_size_mid: mid_len,
+        window_size_long: long_len,
+        josa_count_short: short.iter().filter(|t| t.morph_class == KoreanMorphClass::JosaLike).count(),
+        josa_count_mid: mid.iter().filter(|t| t.morph_class == KoreanMorphClass::JosaLike).count(),
+        josa_chain_len: class_streak(short, KoreanMorphClass::JosaLike),
+        same_josa_streak: same_piece_streak_for_class(short, KoreanMorphClass::JosaLike),
+        eomi_count_short: short.iter().filter(|t| t.morph_class == KoreanMorphClass::EomiLike).count(),
+        eomi_count_mid: mid.iter().filter(|t| t.morph_class == KoreanMorphClass::EomiLike).count(),
+        eomi_chain_len: class_streak(short, KoreanMorphClass::EomiLike),
+        same_eomi_streak: same_piece_streak_for_class(short, KoreanMorphClass::EomiLike),
+        jamo_count_short,
+        jamo_count_mid: mid.iter().filter(|t| t.morph_class == KoreanMorphClass::HangulJamo).count(),
+        byte_jamo_mixed_count: if byte_count > 0 && jamo_count_short > 0 { byte_count + jamo_count_short } else { 0 },
+        punctuation_glue_count: punctuation_after_eomi(short),
+        syllable_fragment_repeat_count: ngram_repeat_count(&mid_pieces, 3),
+        eojeol_boundary_collapse_count: boundary_collapse_count(mid),
+        morph_distinct_ratio: distinct_ratio(&long_classes),
+        morph_bigram_repeat_count: ngram_repeat_count(&mid_classes, 2),
+        morph_trigram_repeat_count: ngram_repeat_count(&mid_classes, 3),
+    }
+}
+
+fn pci_amplifier(bucket: Option<&str>, pci_raw: Option<f32>) -> f32 {
+    let bucket_score = match bucket.unwrap_or("") {
+        "Collapsing" => 1.0,
+        "Unstable" => 0.75,
+        "Uncertain" => 0.45,
+        "Stable" => 0.15,
+        "Confident" => 0.0,
+        _ => 0.35,
+    };
+    bucket_score.max(pci_raw.map(|v| 1.0 - v).unwrap_or(0.0)).clamp(0.0, 1.0)
+}
+
+fn risk_from_score(score: f32) -> &'static str {
+    let score = clamp01(score);
+    if score >= 0.80 { "Critical" }
+    else if score >= 0.55 { "High" }
+    else if score >= 0.30 { "Medium" }
+    else { "Low" }
+}
+
+pub fn compute_salad04_score(
+    input: &Salad04Input,
+    metrics: &Salad04WindowMetrics,
+) -> Salad04RiskComponents {
+    let josa_loop_score = clamp01(
+        metrics.same_josa_streak.saturating_sub(1) as f32 / 4.0
+            + metrics.josa_chain_len.saturating_sub(1) as f32 / 5.0
+            + metrics.josa_count_short as f32 / 8.0,
+    );
+    let eomi_loop_score = clamp01(
+        metrics.same_eomi_streak.saturating_sub(1) as f32 / 4.0
+            + metrics.eomi_chain_len.saturating_sub(1) as f32 / 5.0
+            + metrics.punctuation_glue_count as f32 / 4.0,
+    );
+    let jamo_leak_score = clamp01(metrics.jamo_count_short as f32 / 3.0 + metrics.jamo_count_mid as f32 / 8.0);
+    let byte_jamo_score = clamp01(metrics.byte_jamo_mixed_count as f32 / 3.0);
+    let syllable_fragment_score = clamp01(metrics.syllable_fragment_repeat_count as f32 / 4.0 + metrics.morph_trigram_repeat_count as f32 / 5.0);
+    let eojeol_boundary_score = clamp01(metrics.eojeol_boundary_collapse_count as f32 / 4.0);
+    let punctuation_glue_score = clamp01(metrics.punctuation_glue_count as f32 / 4.0);
+    let pci_amplifier = pci_amplifier(input.pci_bucket.as_deref(), input.pci_raw);
+    let entropy_amplifier = clamp01(input.current.h_final_norm.unwrap_or(0.0) + if input.entropy_spike { 0.25 } else { 0.0 });
+    let raw_score = clamp01(
+        0.22 * josa_loop_score
+            + 0.22 * eomi_loop_score
+            + 0.18 * jamo_leak_score
+            + 0.10 * byte_jamo_score
+            + 0.10 * syllable_fragment_score
+            + 0.08 * eojeol_boundary_score
+            + 0.06 * punctuation_glue_score
+            + 0.02 * pci_amplifier
+            + 0.02 * entropy_amplifier,
+    );
+    let mut capped_score = raw_score;
+    if metrics.same_josa_streak >= 4 { capped_score = capped_score.max(0.55); }
+    if metrics.same_eomi_streak >= 4 { capped_score = capped_score.max(0.55); }
+    if metrics.jamo_count_short >= 3 { capped_score = capped_score.max(0.70); }
+    if metrics.byte_jamo_mixed_count >= 2 { capped_score = capped_score.max(0.80); }
+    if metrics.morph_trigram_repeat_count >= 2 && matches!(input.pci_bucket.as_deref(), Some("Unstable") | Some("Collapsing")) {
+        capped_score = capped_score.max(0.75);
+    }
+    if input.numeric_risk { capped_score = capped_score.max(0.85); }
+    if input.global_finite_fallback_seen { capped_score = capped_score.max(0.85); }
+    if matches!(input.pci_bucket.as_deref(), Some("Stable") | Some("Confident"))
+        && metrics.morph_trigram_repeat_count == 0
+        && metrics.jamo_count_short == 0
+        && metrics.byte_jamo_mixed_count == 0
+    {
+        capped_score = capped_score.min(0.35);
+    }
+    Salad04RiskComponents {
+        josa_loop_score,
+        eomi_loop_score,
+        jamo_leak_score,
+        byte_jamo_score,
+        syllable_fragment_score,
+        eojeol_boundary_score,
+        punctuation_glue_score,
+        pci_amplifier,
+        entropy_amplifier,
+        raw_score,
+        capped_score: clamp01(capped_score),
+    }
+}
+
+pub fn compute_salad04_overlay(
+    input: &Salad04Input,
+    detection: &Salad04Detection,
+) -> Salad04OverlayRecommendation {
+    let mut overlay_reasons = Vec::new();
+    let high_or_critical = matches!(detection.morph_risk_stable.as_str(), "High" | "Critical");
+    let critical = detection.morph_risk_stable == "Critical";
+    let mut suggested_min_p_floor = None;
+    let mut suggested_top_p_ceiling = None;
+    let mut suggested_guard_strength = None;
+    let mut no_repeat_ngram_hint = None;
+
+    if high_or_critical {
+        overlay_reasons.push("morph_risk_high_or_critical".to_string());
+        suggested_guard_strength = Some("Panic".to_string());
+        no_repeat_ngram_hint = Some(3);
+    }
+    if critical {
+        overlay_reasons.push("morph_risk_critical".to_string());
+        suggested_min_p_floor = Some(0.12);
+        suggested_top_p_ceiling = Some(0.82);
+    }
+    if matches!(detection.dominant_loop_kind, KoreanMorphLoopKind::JamoLeak | KoreanMorphLoopKind::ByteJamoMixedLeak) {
+        overlay_reasons.push("jamo_or_byte_leak".to_string());
+        suggested_guard_strength = Some("Panic".to_string());
+        suggested_min_p_floor = Some(suggested_min_p_floor.unwrap_or(0.14).max(0.14));
+    }
+    if input.fallback_risk {
+        overlay_reasons.push("fallback_risk_amplifier".to_string());
+    }
+
+    Salad04OverlayRecommendation {
+        raise_salad02_risk_candidate: high_or_critical,
+        rollback_candidate_boost: high_or_critical,
+        safe_stop_candidate_boost: critical || input.numeric_risk || input.global_finite_fallback_seen,
+        suggested_min_p_floor,
+        suggested_top_p_ceiling,
+        suggested_guard_strength,
+        no_repeat_ngram_hint,
+        overlay_reasons,
+    }
+}
+
+fn morph_reasons(metrics: &Salad04WindowMetrics, input: &Salad04Input, kind: KoreanMorphLoopKind) -> Vec<String> {
+    let mut reasons = Vec::new();
+    if metrics.same_josa_streak >= 2 { reasons.push(format!("same_josa_streak_{}", metrics.same_josa_streak)); }
+    if metrics.same_eomi_streak >= 2 { reasons.push(format!("same_eomi_streak_{}", metrics.same_eomi_streak)); }
+    if metrics.jamo_count_short > 0 { reasons.push(format!("jamo_count_short_{}", metrics.jamo_count_short)); }
+    if metrics.byte_jamo_mixed_count > 0 { reasons.push(format!("byte_jamo_mixed_count_{}", metrics.byte_jamo_mixed_count)); }
+    if metrics.morph_trigram_repeat_count > 0 { reasons.push(format!("morph_trigram_repeat_count_{}", metrics.morph_trigram_repeat_count)); }
+    if input.entropy_spike { reasons.push("entropy_spike_amplifier".to_string()); }
+    if input.fallback_risk { reasons.push("fallback_risk".to_string()); }
+    if input.numeric_risk { reasons.push("numeric_risk".to_string()); }
+    if kind != KoreanMorphLoopKind::None { reasons.push(format!("dominant_loop_{:?}", kind)); }
+    reasons
+}
+
+pub fn detect_korean_morph_loop(input: &Salad04Input) -> Salad04Detection {
+    let metrics = compute_salad04_window_metrics(&input.recent);
+    let components = compute_salad04_score(input, &metrics);
+    let morph_risk_raw = risk_from_score(components.capped_score).to_string();
+    let morph_risk_stable = morph_risk_raw.clone();
+    let dominant_loop_kind = detect_korean_loop_kind(&input.current, &input.recent);
+    let mut preliminary = Salad04Detection {
+        behavior_change: false,
+        guard_overlay_only: true,
+        morph_score: components.capped_score,
+        morph_risk_raw,
+        morph_risk_stable,
+        dominant_loop_kind,
+        window_metrics: metrics,
+        components,
+        overlay_recommendation: Salad04OverlayRecommendation {
+            raise_salad02_risk_candidate: false,
+            rollback_candidate_boost: false,
+            safe_stop_candidate_boost: false,
+            suggested_min_p_floor: None,
+            suggested_top_p_ceiling: None,
+            suggested_guard_strength: None,
+            no_repeat_ngram_hint: None,
+            overlay_reasons: Vec::new(),
+        },
+        morph_reasons: Vec::new(),
+    };
+    preliminary.morph_reasons = morph_reasons(&preliminary.window_metrics, input, preliminary.dominant_loop_kind);
+    preliminary.overlay_recommendation = compute_salad04_overlay(input, &preliminary);
+    preliminary
+}
+
+static SALAD04_WINDOW: OnceLock<Mutex<VecDeque<Salad04MorphObservation>>> = OnceLock::new();
+
+fn window_store() -> &'static Mutex<VecDeque<Salad04MorphObservation>> {
+    SALAD04_WINDOW.get_or_init(|| Mutex::new(VecDeque::new()))
+}
+
+fn observe_window(current: Salad04MorphObservation) -> Vec<Salad04MorphObservation> {
+    let mut guard = window_store().lock().unwrap_or_else(|poisoned| poisoned.into_inner());
+    guard.push_back(current);
+    let max_len = env_usize("ASH_SALAD04_WINDOW_STORE", env_usize("ASH_SALAD04_WINDOW_LONG", 96).max(96));
+    while guard.len() > max_len {
+        guard.pop_front();
+    }
+    guard.iter().cloned().collect()
+}
