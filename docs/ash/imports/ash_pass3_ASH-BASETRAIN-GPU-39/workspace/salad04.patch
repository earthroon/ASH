++pub fn detect_korean_loop_kind(
++    current: &Salad04MorphObservation,
++    recent: &[Salad04MorphObservation],
++) -> KoreanMorphLoopKind {
++    let short = tail_slice(recent, env_usize("ASH_SALAD04_WINDOW_SHORT", 8));
++    let same_josa = same_piece_streak_for_class(short, KoreanMorphClass::JosaLike);
++    let same_eomi = same_piece_streak_for_class(short, KoreanMorphClass::EomiLike);
++    let josa_chain = class_streak(short, KoreanMorphClass::JosaLike);
++    let eomi_chain = class_streak(short, KoreanMorphClass::EomiLike);
++    let jamo_count = short.iter().filter(|t| t.morph_class == KoreanMorphClass::HangulJamo).count();
++    let byte_count = short.iter().filter(|t| t.morph_class == KoreanMorphClass::BytePiece).count();
++    let punctuation_glue = punctuation_after_eomi(short);
++    let morph_classes: Vec<KoreanMorphClass> = short.iter().map(|t| t.morph_class).collect();
++    let trigram_repeat = ngram_repeat_count(&morph_classes, 3);
++    if byte_count > 0 && jamo_count > 0 {
++        KoreanMorphLoopKind::ByteJamoMixedLeak
++    } else if jamo_count >= 2 || current.morph_class == KoreanMorphClass::HangulJamo {
++        KoreanMorphLoopKind::JamoLeak
++    } else if same_josa >= 2 {
++        KoreanMorphLoopKind::JosaRepeat
++    } else if josa_chain >= 3 {
++        KoreanMorphLoopKind::JosaChain
++    } else if same_eomi >= 2 {
++        KoreanMorphLoopKind::EomiRepeat
++    } else if eomi_chain >= 2 && punctuation_glue > 0 {
++        KoreanMorphLoopKind::EomiPunctuationLoop
++    } else if boundary_collapse_count(short) >= 2 {
++        KoreanMorphLoopKind::EojeolBoundaryCollapse
++    } else if trigram_repeat >= 2 {
++        KoreanMorphLoopKind::SyllableFragmentLoop
++    } else if current.morph_class == KoreanMorphClass::Punctuation && class_streak(short, KoreanMorphClass::Punctuation) >= 3 {
++        KoreanMorphLoopKind::PunctuationGlueLoop
++    } else if current.morph_class == KoreanMorphClass::Mixed {
++        KoreanMorphLoopKind::MixedMorphLoop
++    } else {
++        KoreanMorphLoopKind::None
++    }
++}
