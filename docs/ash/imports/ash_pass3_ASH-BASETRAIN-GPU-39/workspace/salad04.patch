++fn risk_from_score(score: f32) -> &'static str {
++    let score = clamp01(score);
++    if score >= 0.80 { "Critical" }
++    else if score >= 0.55 { "High" }
++    else if score >= 0.30 { "Medium" }
++    else { "Low" }
++}
