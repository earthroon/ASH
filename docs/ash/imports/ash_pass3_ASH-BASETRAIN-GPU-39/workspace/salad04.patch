+fn observation_from_salad02(receipt: &Salad02StepReceipt) -> Salad04MorphObservation {
+    let piece = receipt.selected_piece_preview.clone();
+    let morph_class = classify_korean_morph_piece(piece.as_deref());
+    let salad02_token_class = Some(format!("{:?}", receipt.input.current.token_class));
+    let mut observation = Salad04MorphObservation {
+        token_id: receipt.selected_id,
+        piece_preview: piece,
+        morph_class,
+        morph_loop_kind: KoreanMorphLoopKind::None,
+        salad02_token_class,
+        selected_rank: receipt.input.current.selected_rank,
+        selected_logprob: receipt.input.current.selected_logprob,
+        pci_raw: receipt.input.current.pci_raw,
+        pci_bucket: receipt.input.current.pci_bucket.clone(),
+        h_final_norm: receipt.input.current.h_final_norm,
+    };
+    observation.morph_loop_kind = detect_korean_loop_kind(&observation, std::slice::from_ref(&observation));
+    observation
+}
