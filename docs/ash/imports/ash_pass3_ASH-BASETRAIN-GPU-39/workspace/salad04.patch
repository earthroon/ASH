++fn pci_amplifier(bucket: Option<&str>, pci_raw: Option<f32>) -> f32 {
++    let bucket_score = match bucket.unwrap_or("") {
++        "Collapsing" => 1.0,
++        "Unstable" => 0.75,
++        "Uncertain" => 0.45,
++        "Stable" => 0.15,
++        "Confident" => 0.0,
++        _ => 0.35,
++    };
++    bucket_score.max(pci_raw.map(|v| 1.0 - v).unwrap_or(0.0)).clamp(0.0, 1.0)
++}
