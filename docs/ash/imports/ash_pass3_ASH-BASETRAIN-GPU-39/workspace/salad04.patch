++pub fn compute_salad04_window_metrics(recent: &[Salad04MorphObservation]) -> Salad04WindowMetrics {
++    let short_len = env_usize("ASH_SALAD04_WINDOW_SHORT", 8);
++    let mid_len = env_usize("ASH_SALAD04_WINDOW_MID", 32);
++    let long_len = env_usize("ASH_SALAD04_WINDOW_LONG", 96);
++    let short = tail_slice(recent, short_len);
++    let mid = tail_slice(recent, mid_len);
++    let long = tail_slice(recent, long_len);
++    let long_classes: Vec<KoreanMorphClass> = long.iter().map(|t| t.morph_class).collect();
++    let mid_classes: Vec<KoreanMorphClass> = mid.iter().map(|t| t.morph_class).collect();
++    let mid_pieces: Vec<String> = mid.iter().map(|t| t.piece_preview.clone().unwrap_or_default()).collect();
++    let byte_count = short.iter().filter(|t| t.morph_class == KoreanMorphClass::BytePiece).count();
++    let jamo_count_short = short.iter().filter(|t| t.morph_class == KoreanMorphClass::HangulJamo).count();
++    Salad04WindowMetrics {
++        window_size_short: short_len,
++        window_size_mid: mid_len,
++        window_size_long: long_len,
++        josa_count_short: short.iter().filter(|t| t.morph_class == KoreanMorphClass::JosaLike).count(),
++        josa_count_mid: mid.iter().filter(|t| t.morph_class == KoreanMorphClass::JosaLike).count(),
++        josa_chain_len: class_streak(short, KoreanMorphClass::JosaLike),
++        same_josa_streak: same_piece_streak_for_class(short, KoreanMorphClass::JosaLike),
++        eomi_count_short: short.iter().filter(|t| t.morph_class == KoreanMorphClass::EomiLike).count(),
++        eomi_count_mid: mid.iter().filter(|t| t.morph_class == KoreanMorphClass::EomiLike).count(),
++        eomi_chain_len: class_streak(short, KoreanMorphClass::EomiLike),
++        same_eomi_streak: same_piece_streak_for_class(short, KoreanMorphClass::EomiLike),
++        jamo_count_short,
++        jamo_count_mid: mid.iter().filter(|t| t.morph_class == KoreanMorphClass::HangulJamo).count(),
++        byte_jamo_mixed_count: if byte_count > 0 && jamo_count_short > 0 { byte_count + jamo_count_short } else { 0 },
++        punctuation_glue_count: punctuation_after_eomi(short),
++        syllable_fragment_repeat_count: ngram_repeat_count(&mid_pieces, 3),
++        eojeol_boundary_collapse_count: boundary_collapse_count(mid),
++        morph_distinct_ratio: distinct_ratio(&long_classes),
++        morph_bigram_repeat_count: ngram_repeat_count(&mid_classes, 2),
++        morph_trigram_repeat_count: ngram_repeat_count(&mid_classes, 3),
++    }
++}
