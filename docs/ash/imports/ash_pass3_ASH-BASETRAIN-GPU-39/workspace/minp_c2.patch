+use serde::{Deserialize, Serialize};
+
+#[derive(Debug, Clone, Copy, Serialize, Deserialize)]
+pub struct ScoreRange {
+    pub min: f32,
+    pub max: f32,
+}
+
+impl ScoreRange {
+    pub const UNIT_NEG_POS: Self = Self { min: -1.0, max: 1.0 };
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct SemanticPriorProviderConfig {
+    pub enabled: bool,
+    pub qwave_enabled: bool,
+    pub deltak_enabled: bool,
+    pub normalize: bool,
+    pub clamp_min: f32,
+    pub clamp_max: f32,
+    pub require_vocab_match: bool,
+}
+
+impl Default for SemanticPriorProviderConfig {
+    fn default() -> Self {
+        Self {
+            enabled: false,
+            qwave_enabled: true,
+            deltak_enabled: true,
+            normalize: true,
+            clamp_min: -1.0,
+            clamp_max: 1.0,
+            require_vocab_match: true,
+        }
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct SemanticPriorScoreSummary {
+    pub qwave_min: f32,
+    pub qwave_max: f32,
+    pub qwave_mean: f32,
+    pub deltak_min: f32,
+    pub deltak_max: f32,
+    pub deltak_mean: f32,
+    pub zero_count_qwave: usize,
+    pub zero_count_deltak: usize,
+    pub control_token_count: usize,
+    pub byte_token_count: usize,
+    pub mojibake_suspect_count: usize,
+    pub nan_count: usize,
+    pub inf_count: usize,
+}
+
+impl Default for SemanticPriorScoreSummary {
+    fn default() -> Self {
+        Self {
+            qwave_min: 0.0,
+            qwave_max: 0.0,
+            qwave_mean: 0.0,
+            deltak_min: 0.0,
+            deltak_max: 0.0,
+            deltak_mean: 0.0,
+            zero_count_qwave: 0,
+            zero_count_deltak: 0,
+            control_token_count: 0,
+            byte_token_count: 0,
+            mojibake_suspect_count: 0,
+            nan_count: 0,
+            inf_count: 0,
+        }
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct SemanticPriorScoreSnapshot {
+    pub vocab_size: usize,
+    pub vocab_hash: String,
+    pub tokenizer_hash: Option<String>,
+    pub qwave_scores: Vec<f32>,
+    pub deltak_scores: Vec<f32>,
+    pub qwave_available: bool,
+    pub deltak_available: bool,
+    pub qwave_source_id: String,
+    pub deltak_source_id: String,
+    pub qwave_range: ScoreRange,
+    pub deltak_range: ScoreRange,
+    pub normalized_range: ScoreRange,
+    pub score_basis: String,
+    pub dynamic_context_scoring: bool,
+    pub created_by_patch: String,
+    pub summary: SemanticPriorScoreSummary,
+}
+
+impl SemanticPriorScoreSnapshot {
+    pub fn empty(vocab_size: usize, vocab_hash: impl Into<String>) -> Self {
+        Self {
+            vocab_size,
+            vocab_hash: vocab_hash.into(),
+            tokenizer_hash: None,
+            qwave_scores: vec![0.0; vocab_size],
+            deltak_scores: vec![0.0; vocab_size],
+            qwave_available: false,
+            deltak_available: false,
+            qwave_source_id: "unavailable_zero_buffer".to_string(),
+            deltak_source_id: "unavailable_zero_buffer".to_string(),
+            qwave_range: ScoreRange::UNIT_NEG_POS,
+            deltak_range: ScoreRange::UNIT_NEG_POS,
+            normalized_range: ScoreRange::UNIT_NEG_POS,
+            score_basis: "zero_source_fallback".to_string(),
+            dynamic_context_scoring: false,
+            created_by_patch: "16AI-QW-38G-R6A-MINP-C2".to_string(),
+            summary: SemanticPriorScoreSummary::default(),
+        }
+    }
+
+    pub fn validate_alignment(&self, vocab_size: usize) -> Result<(), String> {
+        if self.vocab_size != vocab_size {
+            return Err(format!("semantic score vocab_size mismatch: snapshot={} expected={}", self.vocab_size, vocab_size));
+        }
+        if self.qwave_scores.len() != vocab_size {
+            return Err(format!("qwave_scores length mismatch: {} != {}", self.qwave_scores.len(), vocab_size));
+        }
+        if self.deltak_scores.len() != vocab_size {
+            return Err(format!("deltak_scores length mismatch: {} != {}", self.deltak_scores.len(), vocab_size));
+        }
+        Ok(())
+    }
+}
+
+pub fn build_semantic_prior_score_snapshot(
+    vocab: &[(u32, String)],
+    config: &SemanticPriorProviderConfig,
+) -> SemanticPriorScoreSnapshot {
+    let vocab_size = vocab.iter().map(|(id, _)| *id as usize).max().map(|v| v + 1).unwrap_or(0);
+    let vocab_hash = stable_vocab_hash(vocab);
+    if !config.enabled {
+        let mut snap = SemanticPriorScoreSnapshot::empty(vocab_size, vocab_hash);
+        snap.qwave_source_id = "provider_disabled_zero_buffer".to_string();
+        snap.deltak_source_id = "provider_disabled_zero_buffer".to_string();
+        return snap;
+    }
+
+    let mut qwave_scores = vec![0.0f32; vocab_size];
+    let mut deltak_scores = vec![0.0f32; vocab_size];
+    let mut control_count = 0usize;
+    let mut byte_count = 0usize;
+    let mut mojibake_count = 0usize;
+    let mut nan_count = 0usize;
+    let mut inf_count = 0usize;
+
+    for (token_id, piece) in vocab {
+        let idx = *token_id as usize;
+        if idx >= vocab_size { continue; }
+        let features = classify_piece(piece);
+        if features.control { control_count += 1; }
+        if features.byte_token { byte_count += 1; }
+        if features.mojibake_suspect { mojibake_count += 1; }
+
+        let mut q = if config.qwave_enabled { qwave_static_score(piece, &features) } else { 0.0 };
+        let mut k = if config.deltak_enabled { deltak_static_score(piece, &features) } else { 0.0 };
+        q = sanitize_score(q, config, &mut nan_count, &mut inf_count);
+        k = sanitize_score(k, config, &mut nan_count, &mut inf_count);
+        qwave_scores[idx] = q;
+        deltak_scores[idx] = k;
+    }
+
+    let summary = summarize_scores(&qwave_scores, &deltak_scores, control_count, byte_count, mojibake_count, nan_count, inf_count);
+    SemanticPriorScoreSnapshot {
+        vocab_size,
+        vocab_hash,
+        tokenizer_hash: None,
+        qwave_scores,
+        deltak_scores,
+        qwave_available: config.qwave_enabled,
+        deltak_available: config.deltak_enabled,
+        qwave_source_id: "qwave_token_static_prior_v1".to_string(),
+        deltak_source_id: "deltak_token_static_prior_v1".to_string(),
+        qwave_range: ScoreRange::UNIT_NEG_POS,
+        deltak_range: ScoreRange::UNIT_NEG_POS,
+        normalized_range: ScoreRange::UNIT_NEG_POS,
+        score_basis: "token_static_prior_v1".to_string(),
+        dynamic_context_scoring: false,
+        created_by_patch: "16AI-QW-38G-R6A-MINP-C2".to_string(),
+        summary,
+    }
+}
+
+#[derive(Debug, Clone, Copy, Default)]
+pub struct PieceFeatures {
+    pub control: bool,
+    pub byte_token: bool,
+    pub mojibake_suspect: bool,
+    pub unknown: bool,
+    pub has_hangul: bool,
+    pub has_ascii_alpha: bool,
+    pub has_digit: bool,
+    pub sentencepiece_boundary: bool,
+    pub whitespace_only: bool,
+    pub punctuation_heavy: bool,
+}
+
+pub fn classify_piece(piece: &str) -> PieceFeatures {
+    let control = matches!(piece, "<pad>" | "<bos>" | "<eos>" | "<unk>")
+        || (piece.starts_with("<glossary:") && piece.ends_with('>'));
+    let byte_token = (piece.starts_with("<byte:") && piece.ends_with('>'))
+        || (piece.starts_with("<0x") && piece.ends_with('>'));
+    let mojibake_suspect = piece.contains('�')
+        || piece.contains("?댁")
+        || piece.contains('媛')
+        || piece.contains('怨')
+        || piece.contains('Ã')
+        || piece.contains('ì')
+        || piece.contains('ê');
+    let unknown = piece == "<unk>";
+    let has_hangul = piece.chars().any(|ch| ('가'..='힣').contains(&ch) || ('ㄱ'..='ㅎ').contains(&ch) || ('ㅏ'..='ㅣ').contains(&ch));
+    let has_ascii_alpha = piece.chars().any(|ch| ch.is_ascii_alphabetic());
+    let has_digit = piece.chars().any(|ch| ch.is_ascii_digit());
+    let sentencepiece_boundary = piece.starts_with('▁');
+    let stripped = piece.trim_matches('▁');
+    let whitespace_only = stripped.trim().is_empty();
+    let punct_count = stripped.chars().filter(|ch| ch.is_ascii_punctuation() || matches!(ch, '…' | '·' | '—' | '–' | '。' | '、' | '！' | '？')).count();
+    let char_count = stripped.chars().count().max(1);
+    let punctuation_heavy = punct_count >= 3 || (punct_count * 2 >= char_count && char_count > 1);
+    PieceFeatures { control, byte_token, mojibake_suspect, unknown, has_hangul, has_ascii_alpha, has_digit, sentencepiece_boundary, whitespace_only, punctuation_heavy }
+}
+
+pub fn qwave_static_score(piece: &str, f: &PieceFeatures) -> f32 {
+    if f.control { return -1.0; }
+    if f.mojibake_suspect { return -0.8; }
+    if f.byte_token { return -0.4; }
+    if f.unknown { return -0.6; }
+    if f.whitespace_only { return -0.2; }
+    let mut score = 0.0f32;
+    if f.has_hangul { score += 0.4; }
+    if f.sentencepiece_boundary && f.has_hangul { score += 0.1; }
+    if looks_like_korean_particle_or_ending(piece) { score += 0.2; }
+    if f.has_ascii_alpha { score += 0.05; }
+    if f.punctuation_heavy { score -= 0.25; }
+    score.clamp(-1.0, 1.0)
+}
+
+pub fn deltak_static_score(piece: &str, f: &PieceFeatures) -> f32 {
+    if f.control { return -1.0; }
+    if f.mojibake_suspect { return -0.8; }
+    if f.byte_token { return -0.5; }
+    if f.unknown { return -0.6; }
+    if f.whitespace_only { return -0.2; }
+    let mut score = 0.0f32;
+    let stripped = piece.trim_matches('▁');
+    let len = stripped.chars().count();
+    if f.has_hangul || f.has_ascii_alpha { score += 0.3; }
+    if (1..=8).contains(&len) { score += 0.1; }
+    if f.has_digit { score += 0.05; }
+    if f.punctuation_heavy { score -= 0.25; }
+    score.clamp(-1.0, 1.0)
+}
+
+fn looks_like_korean_particle_or_ending(piece: &str) -> bool {
+    let p = piece.trim_start_matches('▁');
+    matches!(p, "은" | "는" | "이" | "가" | "을" | "를" | "에" | "에서" | "으로" | "로" | "와" | "과" | "도" | "만" | "까지" | "부터" | "요" | "다" | "니다" | "습니다" | "한다" | "했다" | "하며" | "하고" | "지만" | "면서")
+        || p.ends_with("다")
+        || p.ends_with("요")
+        || p.ends_with("니다")
+        || p.ends_with("고")
+        || p.ends_with("며")
+}
+
+fn sanitize_score(value: f32, config: &SemanticPriorProviderConfig, nan_count: &mut usize, inf_count: &mut usize) -> f32 {
+    if value.is_nan() {
+        *nan_count += 1;
+        return 0.0;
+    }
+    if !value.is_finite() {
+        *inf_count += 1;
+        return 0.0;
+    }
+    if config.normalize {
+        value.clamp(config.clamp_min.max(-1.0), config.clamp_max.min(1.0))
+    } else {
+        value
+    }
+}
+
+fn summarize_scores(
+    qwave: &[f32],
+    deltak: &[f32],
+    control_count: usize,
+    byte_count: usize,
+    mojibake_count: usize,
+    nan_count: usize,
+    inf_count: usize,
+) -> SemanticPriorScoreSummary {
+    fn stats(values: &[f32]) -> (f32, f32, f32, usize) {
+        if values.is_empty() { return (0.0, 0.0, 0.0, 0); }
+        let min = values.iter().copied().fold(f32::INFINITY, f32::min);
+        let max = values.iter().copied().fold(f32::NEG_INFINITY, f32::max);
+        let mean = values.iter().sum::<f32>() / values.len() as f32;
+        let zeros = values.iter().filter(|v| **v == 0.0).count();
+        (min, max, mean, zeros)
+    }
+    let (qmin, qmax, qmean, qzeros) = stats(qwave);
+    let (kmin, kmax, kmean, kzeros) = stats(deltak);
+    SemanticPriorScoreSummary {
+        qwave_min: qmin,
+        qwave_max: qmax,
+        qwave_mean: qmean,
+        deltak_min: kmin,
+        deltak_max: kmax,
+        deltak_mean: kmean,
+        zero_count_qwave: qzeros,
+        zero_count_deltak: kzeros,
+        control_token_count: control_count,
+        byte_token_count: byte_count,
+        mojibake_suspect_count: mojibake_count,
+        nan_count,
+        inf_count,
+    }
+}
+
+pub fn stable_vocab_hash(vocab: &[(u32, String)]) -> String {
+    let mut hash: u64 = 0xcbf29ce484222325;
+    let mut sorted = vocab.to_vec();
+    sorted.sort_by_key(|(id, _)| *id);
+    for (id, piece) in sorted {
+        for b in id.to_le_bytes() { hash = (hash ^ b as u64).wrapping_mul(0x100000001b3); }
+        for b in piece.as_bytes() { hash = (hash ^ *b as u64).wrapping_mul(0x100000001b3); }
+        hash = (hash ^ 0xff).wrapping_mul(0x100000001b3);
+    }
+    format!("fnv1a64:{hash:016x}")
+}
