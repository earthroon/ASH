++            (0, "<pad>".to_string()),
++            (1, "▁이어가고".to_string()),
++            (2, "<eos>".to_string()),
++            (3, "<byte:EC>".to_string()),
++            (4, "?댁뼱媛怨?".to_string()),
++        ];
++        let cfg = SemanticPriorProviderConfig { enabled: true, ..Default::default() };
++        let snap = build_semantic_prior_score_snapshot(&vocab, &cfg);
++        assert_eq!(snap.qwave_scores.len(), 5);
