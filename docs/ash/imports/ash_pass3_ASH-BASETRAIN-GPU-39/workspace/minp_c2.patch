++        assert!(snap.qwave_scores[0] <= -0.8);
++        assert!(snap.qwave_scores[1] >= 0.0);
++        assert!(snap.deltak_scores[3] < 0.0);
++        assert!(snap.summary.mojibake_suspect_count >= 1);
++    }
++}
