++pub fn qwave_static_score(piece: &str, f: &PieceFeatures) -> f32 {
++    if f.control { return -1.0; }
++    if f.mojibake_suspect { return -0.8; }
++    if f.byte_token { return -0.4; }
++    if f.unknown { return -0.6; }
++    if f.whitespace_only { return -0.2; }
++    let mut score = 0.0f32;
++    if f.has_hangul { score += 0.4; }
++    if f.sentencepiece_boundary && f.has_hangul { score += 0.1; }
++    if looks_like_korean_particle_or_ending(piece) { score += 0.2; }
++    if f.has_ascii_alpha { score += 0.05; }
++    if f.punctuation_heavy { score -= 0.25; }
++    score.clamp(-1.0, 1.0)
++}
++
++pub fn deltak_static_score(piece: &str, f: &PieceFeatures) -> f32 {
++    if f.control { return -1.0; }
++    if f.mojibake_suspect { return -0.8; }
++    if f.byte_token { return -0.5; }
++    if f.unknown { return -0.6; }
++    if f.whitespace_only { return -0.2; }
++    let mut score = 0.0f32;
++    let stripped = piece.trim_matches('▁');
++    let len = stripped.chars().count();
++    if f.has_hangul || f.has_ascii_alpha { score += 0.3; }
++    if (1..=8).contains(&len) { score += 0.1; }
++    if f.has_digit { score += 0.05; }
++    if f.punctuation_heavy { score -= 0.25; }
++    score.clamp(-1.0, 1.0)
++}
++
++fn looks_like_korean_particle_or_ending(piece: &str) -> bool {
++    let p = piece.trim_start_matches('▁');
++    matches!(p, "은" | "는" | "이" | "가" | "을" | "를" | "에" | "에서" | "으로" | "로" | "와" | "과" | "도" | "만" | "까지" | "부터" | "요" | "다" | "니다" | "습니다" | "한다" | "했다" | "하며" | "하고" | "지만" | "면서")
++        || p.ends_with("다")
++        || p.ends_with("요")
++        || p.ends_with("니다")
++        || p.ends_with("고")
++        || p.ends_with("며")
++}
++
++fn sanitize_score(value: f32, config: &SemanticPriorProviderConfig, nan_count: &mut usize, inf_count: &mut usize) -> f32 {
++    if value.is_nan() {
++        *nan_count += 1;
++        return 0.0;
++    }
++    if !value.is_finite() {
++        *inf_count += 1;
++        return 0.0;
++    }
++    if config.normalize {
++        value.clamp(config.clamp_min.max(-1.0), config.clamp_max.min(1.0))
++    } else {
++        value
++    }
++}
++
++fn summarize_scores(
++    qwave: &[f32],
++    deltak: &[f32],
++    control_count: usize,
++    byte_count: usize,
++    mojibake_count: usize,
++    nan_count: usize,
++    inf_count: usize,
++) -> SemanticPriorScoreSummary {
++    fn stats(values: &[f32]) -> (f32, f32, f32, usize) {
++        if values.is_empty() { return (0.0, 0.0, 0.0, 0); }
++        let min = values.iter().copied().fold(f32::INFINITY, f32::min);
++        let max = values.iter().copied().fold(f32::NEG_INFINITY, f32::max);
++        let mean = values.iter().sum::<f32>() / values.len() as f32;
++        let zeros = values.iter().filter(|v| **v == 0.0).count();
++        (min, max, mean, zeros)
++    }
++    let (qmin, qmax, qmean, qzeros) = stats(qwave);
++    let (kmin, kmax, kmean, kzeros) = stats(deltak);
++    SemanticPriorScoreSummary {
++        qwave_min: qmin,
++        qwave_max: qmax,
++        qwave_mean: qmean,
++        deltak_min: kmin,
++        deltak_max: kmax,
++        deltak_mean: kmean,
++        zero_count_qwave: qzeros,
++        zero_count_deltak: kzeros,
++        control_token_count: control_count,
++        byte_token_count: byte_count,
++        mojibake_suspect_count: mojibake_count,
++        nan_count,
++        inf_count,
++    }
++}
++
++pub fn stable_vocab_hash(vocab: &[(u32, String)]) -> String {
++    let mut hash: u64 = 0xcbf29ce484222325;
++    let mut sorted = vocab.to_vec();
++    sorted.sort_by_key(|(id, _)| *id);
++    for (id, piece) in sorted {
++        for b in id.to_le_bytes() { hash = (hash ^ b as u64).wrapping_mul(0x100000001b3); }
++        for b in piece.as_bytes() { hash = (hash ^ *b as u64).wrapping_mul(0x100000001b3); }
++        hash = (hash ^ 0xff).wrapping_mul(0x100000001b3);
++    }
++    format!("fnv1a64:{hash:016x}")
++}
++
