++pub fn classify_piece(piece: &str) -> PieceFeatures {
++    let control = matches!(piece, "<pad>" | "<bos>" | "<eos>" | "<unk>")
++        || (piece.starts_with("<glossary:") && piece.ends_with('>'));
++    let byte_token = (piece.starts_with("<byte:") && piece.ends_with('>'))
++        || (piece.starts_with("<0x") && piece.ends_with('>'));
++    let mojibake_suspect = piece.contains('�')
++        || piece.contains("?댁")
++        || piece.contains('媛')
++        || piece.contains('怨')
++        || piece.contains('Ã')
++        || piece.contains('ì')
++        || piece.contains('ê');
++    let unknown = piece == "<unk>";
++    let has_hangul = piece.chars().any(|ch| ('가'..='힣').contains(&ch) || ('ㄱ'..='ㅎ').contains(&ch) || ('ㅏ'..='ㅣ').contains(&ch));
++    let has_ascii_alpha = piece.chars().any(|ch| ch.is_ascii_alphabetic());
++    let has_digit = piece.chars().any(|ch| ch.is_ascii_digit());
++    let sentencepiece_boundary = piece.starts_with('▁');
++    let stripped = piece.trim_matches('▁');
++    let whitespace_only = stripped.trim().is_empty();
++    let punct_count = stripped.chars().filter(|ch| ch.is_ascii_punctuation() || matches!(ch, '…' | '·' | '—' | '–' | '。' | '、' | '！' | '？')).count();
++    let char_count = stripped.chars().count().max(1);
++    let punctuation_heavy = punct_count >= 3 || (punct_count * 2 >= char_count && char_count > 1);
++    PieceFeatures { control, byte_token, mojibake_suspect, unknown, has_hangul, has_ascii_alpha, has_digit, sentencepiece_boundary, whitespace_only, punctuation_heavy }
++}
