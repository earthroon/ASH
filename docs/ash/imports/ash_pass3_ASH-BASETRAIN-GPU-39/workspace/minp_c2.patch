+use serde::{Deserialize, Serialize};
+
+use crate::semantic_prior_scores::{
+    SemanticPriorProviderConfig,
+    build_semantic_prior_score_snapshot,
+};
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct MinpC2FixtureReceipt {
+    pub fixture: String,
+    pub status: String,
+    pub vocab_size: usize,
+    pub qwave_len: usize,
+    pub deltak_len: usize,
+    pub qwave_available: bool,
+    pub deltak_available: bool,
+    pub control_token_negative: bool,
+    pub korean_token_non_negative: bool,
+    pub byte_token_negative: bool,
+    pub mojibake_token_negative: bool,
+    pub nan_count: usize,
+    pub inf_count: usize,
+}
+
+pub fn run_minp_c2_score_provider_smoke() -> Vec<MinpC2FixtureReceipt> {
+    let vocab = vec![
+        (0, "<pad>".to_string()),
+        (1, "▁이어가고".to_string()),
+        (2, "<eos>".to_string()),
+        (3, "<byte:EC>".to_string()),
+        (4, "?댁뼱媛怨?".to_string()),
+    ];
+    let cfg = SemanticPriorProviderConfig { enabled: true, ..Default::default() };
+    let snap = build_semantic_prior_score_snapshot(&vocab, &cfg);
+    vec![MinpC2FixtureReceipt {
+        fixture: "token_static_prior_v1".to_string(),
+        status: if snap.qwave_scores.len() == snap.vocab_size
+            && snap.deltak_scores.len() == snap.vocab_size
+            && snap.qwave_scores[0] <= -0.8
+            && snap.qwave_scores[1] >= 0.0
+            && snap.deltak_scores[3] < 0.0
+            && snap.qwave_scores[4] < 0.0
+        { "PASS".to_string() } else { "FAIL".to_string() },
+        vocab_size: snap.vocab_size,
+        qwave_len: snap.qwave_scores.len(),
+        deltak_len: snap.deltak_scores.len(),
+        qwave_available: snap.qwave_available,
+        deltak_available: snap.deltak_available,
+        control_token_negative: snap.qwave_scores[0] <= -0.8 && snap.deltak_scores[0] <= -0.8,
+        korean_token_non_negative: snap.qwave_scores[1] >= 0.0 && snap.deltak_scores[1] >= 0.0,
+        byte_token_negative: snap.qwave_scores[3] < 0.0 && snap.deltak_scores[3] < 0.0,
+        mojibake_token_negative: snap.qwave_scores[4] < 0.0 && snap.deltak_scores[4] < 0.0,
+        nan_count: snap.summary.nan_count,
+        inf_count: snap.summary.inf_count,
+    }]
+}
