+fn eos_policy_from_env(default: Stop02EosPolicy) -> Stop02EosPolicy {
+    match env::var("ASH_STOP02_EOS_POLICY").unwrap_or_default().trim().to_ascii_lowercase().as_str() {
+        "none" => Stop02EosPolicy::None,
+        "virtual" | "append_virtual_eos" => Stop02EosPolicy::AppendVirtualEos,
+        "ledger" | "append_ledger_eos" => Stop02EosPolicy::AppendLedgerEos,
+        "surface" | "surface_only" => Stop02EosPolicy::SurfaceOnly,
+        _ => default,
+    }
+}
