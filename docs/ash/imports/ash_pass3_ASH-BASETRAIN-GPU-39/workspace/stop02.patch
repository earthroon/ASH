++        if receipt.finalization.visible_range.visible_end_step > receipt.finalization.visible_range.raw_end_step { safety.visible_range_invalid_count += 1; }
++
++        match receipt.policy.tail_policy {
++            Stop02TailPolicy::PreserveAll => tail_policy.preserve_all_count += 1,
++            Stop02TailPolicy::MarkRiskTail => tail_policy.mark_risk_tail_count += 1,
++            Stop02TailPolicy::HideRiskTailSurfaceOnly => tail_policy.hide_risk_tail_surface_only_count += 1,
