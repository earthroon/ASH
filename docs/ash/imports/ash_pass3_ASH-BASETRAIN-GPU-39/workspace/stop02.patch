+fn tail_policy_from_env(default: Stop02TailPolicy) -> Stop02TailPolicy {
+    match env::var("ASH_STOP02_TAIL_POLICY").unwrap_or_default().trim().to_ascii_lowercase().as_str() {
+        "preserve" | "preserve_all" => Stop02TailPolicy::PreserveAll,
+        "hide" | "hide_risk_tail" | "hide_risk_tail_surface_only" => Stop02TailPolicy::HideRiskTailSurfaceOnly,
+        "truncate" | "truncate_ledger_tail" => Stop02TailPolicy::TruncateLedgerTail,
+        "mark" | "mark_risk_tail" => Stop02TailPolicy::MarkRiskTail,
+        _ => default,
+    }
+}
