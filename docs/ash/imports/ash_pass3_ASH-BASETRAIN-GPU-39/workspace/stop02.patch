+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+pub enum Stop02Mode {
+    Off,
+    SurfaceOnly,
+    ControlledFinalize,
+    StrictControlledFinalize,
+}
+
+impl Stop02Mode {
+    pub fn from_env() -> Self {
+        let value = env::var("ASH_STOP02_MODE")
+            .or_else(|_| env::var("ASH_STOP02_FINALIZATION"))
+            .unwrap_or_else(|_| "surface_only".to_string())
+            .trim()
+            .to_ascii_lowercase();
+        match value.as_str() {
+            "off" | "false" | "0" | "disabled" => Self::Off,
+            "controlled" | "controlled_finalize" | "finalize" | "true" | "1" => Self::ControlledFinalize,
+            "strict" | "strict_controlled" | "strict_controlled_finalize" => Self::StrictControlledFinalize,
+            _ => Self::SurfaceOnly,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::SurfaceOnly => "SurfaceOnly",
+            Self::ControlledFinalize => "ControlledFinalize",
+            Self::StrictControlledFinalize => "StrictControlledFinalize",
+        }
+    }
+
+    pub fn requested(self) -> bool {
+        !matches!(self, Self::Off)
+    }
+}
