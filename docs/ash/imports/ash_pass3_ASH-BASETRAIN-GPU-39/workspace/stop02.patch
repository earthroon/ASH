+<template>
+  <section
+    v-if="visible"
+    class="stop-surface"
+    :class="`stop-surface--${normalizedSeverity}`"
+    role="status"
+    aria-live="polite"
+  >
+    <header class="stop-surface__header">
+      <strong>{{ title }}</strong>
+      <span class="stop-surface__kind">{{ surfaceKind }}</span>
+    </header>
+    <p class="stop-surface__message">{{ primaryMessage }}</p>
+    <div v-if="retryAvailable || continueFromSafePointAvailable" class="stop-surface__actions" aria-label="safe stop actions">
+      <button v-if="retryAvailable" type="button" @click="$emit('retry')">다시 생성</button>
+      <button v-if="continueFromSafePointAvailable" type="button" @click="$emit('continue-from-safe-point', safePointStep)">
+        안전 지점부터 이어쓰기
+      </button>
+    </div>
+  </section>
+</template>
+
+<script setup lang="ts">
+import { computed } from 'vue';
+
+const props = defineProps<{
+  visible?: boolean;
+  surfaceKind?: string;
+  messageCodes?: string[];
+  displaySeverity?: 'info' | 'warning' | 'critical' | string;
+  retryAvailable?: boolean;
+  continueFromSafePointAvailable?: boolean;
+  safePointStep?: number | null;
+}>();
+
+defineEmits<{
+  retry: [];
+  'continue-from-safe-point': [step?: number | null];
+}>();
+
+const normalizedSeverity = computed(() => {
+  const value = props.displaySeverity || 'info';
+  return ['info', 'warning', 'critical'].includes(value) ? value : 'info';
+});
+
+const title = computed(() => {
+  switch (props.surfaceKind) {
+    case 'NumericSafetyStopped':
+    case 'GlobalFallbackStopped':
+      return '안전 중단';
+    case 'SaladRiskStopped':
+    case 'RollbackFailedStopped':
+    case 'ResampleFailedStopped':
+      return '불안정 신호 감지';
+    default:
+      return '생성 중단';
+  }
+});
+
+const primaryMessage = computed(() => {
+  const codes = new Set(props.messageCodes || []);
+  if (codes.has('SafeStopNumericRisk')) return '수치적으로 불안정한 상태가 감지되어 생성을 멈췄습니다.';
+  if (codes.has('SafeStopGlobalFallback')) return '안전하지 않은 fallback 경로가 감지되어 생성을 멈췄습니다.';
+  if (codes.has('SafeStopResampleFailed')) return '복구 샘플링 후에도 출력 안정성이 충분하지 않아 생성을 멈췄습니다.';
+  if (codes.has('SafeStopRollbackUnavailable')) return '복구 가능한 내부 체크포인트가 없어 추가 생성을 중단했습니다.';
+  if (codes.has('SafeStopRiskTailMarked')) return '마지막 일부 토큰에서 불안정 신호가 감지되어 안전 중단 상태로 표시했습니다.';
+  return '응답이 불안정해질 수 있어 안전한 지점에서 생성을 멈췄습니다.';
+});
+</script>
