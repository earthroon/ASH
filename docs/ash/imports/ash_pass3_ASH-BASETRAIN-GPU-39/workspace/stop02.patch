++fn display_severity(kind: Stop02SurfaceKind) -> &'static str {
++    match kind {
++        Stop02SurfaceKind::NumericSafetyStopped | Stop02SurfaceKind::GlobalFallbackStopped => "critical",
++        Stop02SurfaceKind::SaladRiskStopped | Stop02SurfaceKind::RollbackFailedStopped | Stop02SurfaceKind::ResampleFailedStopped => "warning",
++        Stop02SurfaceKind::SafeStopped | Stop02SurfaceKind::PartialOutput => "info",
++        Stop02SurfaceKind::None => "info",
++    }
