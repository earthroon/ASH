+pub fn surface_kind_from_stop_reason(reason: Option<&str>) -> Stop02SurfaceKind {
+    match reason.unwrap_or("") {
+        "SaladHighPersistent" | "SaladCritical" | "SAFE_STOP_SALAD_HIGH_PERSISTENT" | "SAFE_STOP_SALAD_CRITICAL" => Stop02SurfaceKind::SaladRiskStopped,
+        "PostResampleCritical" | "PostResampleHighUnimproved" | "ResampleFailed" |
+        "SAFE_STOP_POST_RESAMPLE_CRITICAL" | "SAFE_STOP_POST_RESAMPLE_HIGH_UNIMPROVED" | "SAFE_STOP_RESAMPLE_FAILED" => Stop02SurfaceKind::ResampleFailedStopped,
+        "RollbackDenied" | "RollbackWindowLimitReached" | "SAFE_STOP_ROLLBACK_DENIED" | "SAFE_STOP_ROLLBACK_WINDOW_LIMIT_REACHED" => Stop02SurfaceKind::RollbackFailedStopped,
+        "NumericRisk" | "EmptyActiveSet" | "SAFE_STOP_NUMERIC_RISK" | "SAFE_STOP_EMPTY_ACTIVE_SET" => Stop02SurfaceKind::NumericSafetyStopped,
+        "GlobalFiniteFallback" | "SAFE_STOP_GLOBAL_FINITE_FALLBACK" => Stop02SurfaceKind::GlobalFallbackStopped,
+        "RuntimeStopRequested" | "StrictSafetyStop" | "SAFE_STOP_RUNTIME_STOP_REQUESTED" | "SAFE_STOP_STRICT_SAFETY_STOP" => Stop02SurfaceKind::SafeStopped,
+        _ => Stop02SurfaceKind::None,
+    }
+}
+
+fn display_severity(kind: Stop02SurfaceKind) -> &'static str {
+    match kind {
+        Stop02SurfaceKind::NumericSafetyStopped | Stop02SurfaceKind::GlobalFallbackStopped => "critical",
+        Stop02SurfaceKind::SaladRiskStopped | Stop02SurfaceKind::RollbackFailedStopped | Stop02SurfaceKind::ResampleFailedStopped => "warning",
+        Stop02SurfaceKind::SafeStopped | Stop02SurfaceKind::PartialOutput => "info",
+        Stop02SurfaceKind::None => "info",
+    }
+}
+
+fn message_codes_for(kind: Stop02SurfaceKind, input: &Stop02Input, tail_policy: Stop02TailPolicy) -> Vec<Stop02MessageCode> {
+    let mut codes = Vec::new();
+    if !matches!(kind, Stop02SurfaceKind::None) {
+        codes.push(Stop02MessageCode::SafeStopGeneratedPartial);
+    }
+    match kind {
+        Stop02SurfaceKind::SaladRiskStopped => codes.push(Stop02MessageCode::SafeStopRiskTailMarked),
+        Stop02SurfaceKind::ResampleFailedStopped => codes.push(Stop02MessageCode::SafeStopResampleFailed),
+        Stop02SurfaceKind::RollbackFailedStopped => codes.push(Stop02MessageCode::SafeStopRollbackUnavailable),
+        Stop02SurfaceKind::NumericSafetyStopped => codes.push(Stop02MessageCode::SafeStopNumericRisk),
+        Stop02SurfaceKind::GlobalFallbackStopped => codes.push(Stop02MessageCode::SafeStopGlobalFallback),
+        _ => {}
+    }
+    if matches!(tail_policy, Stop02TailPolicy::MarkRiskTail | Stop02TailPolicy::HideRiskTailSurfaceOnly)
+        && !codes.contains(&Stop02MessageCode::SafeStopRiskTailMarked)
+    {
+        codes.push(Stop02MessageCode::SafeStopRiskTailMarked);
+    }
+    if input.user_visible_surface_enabled {
+        codes.push(Stop02MessageCode::SafeStopCanRetry);
+        if input.risk_tail_start_step.is_some() {
+            codes.push(Stop02MessageCode::SafeStopCanContinueFromSafePoint);
+        }
+    }
+    if codes.is_empty() {
+        codes.push(Stop02MessageCode::None);
+    }
+    codes
+}
+
+pub fn decide_stop02_policy(input: &Stop02Input) -> Stop02FinalizationPolicy {
+    let surface_kind = if input.stop01_executed && input.generation_loop_stop_requested {
+        surface_kind_from_stop_reason(input.stop01_reason.as_deref())
+    } else {
+        Stop02SurfaceKind::None
+    };
+    let mut eos_policy = if matches!(surface_kind, Stop02SurfaceKind::None) {
+        Stop02EosPolicy::None
+    } else {
+        Stop02EosPolicy::SurfaceOnly
+    };
+    eos_policy = eos_policy_from_env(eos_policy);
+
+    let mut tail_policy = if matches!(surface_kind, Stop02SurfaceKind::None) {
+        Stop02TailPolicy::PreserveAll
+    } else {
+        Stop02TailPolicy::MarkRiskTail
+    };
+    if matches!(surface_kind, Stop02SurfaceKind::NumericSafetyStopped | Stop02SurfaceKind::GlobalFallbackStopped)
+        && input.risk_tail_start_step.is_some()
+    {
+        tail_policy = Stop02TailPolicy::HideRiskTailSurfaceOnly;
+    }
+    tail_policy = tail_policy_from_env(tail_policy);
+
+    let mut policy_reasons = Vec::new();
+    if input.stop01_executed { policy_reasons.push("stop01_executed".to_string()); }
+    if input.generation_loop_stop_requested { policy_reasons.push("generation_loop_stop_requested".to_string()); }
+    if matches!(eos_policy, Stop02EosPolicy::AppendLedgerEos) {
+        policy_reasons.push("append_ledger_eos_requested_but_forbidden".to_string());
+        if matches!(input.mode, Stop02Mode::StrictControlledFinalize) {
+            // Keep the forbidden value visible for strict failure accounting.
+        } else {
+            eos_policy = Stop02EosPolicy::SurfaceOnly;
+        }
+    }
+    if matches!(tail_policy, Stop02TailPolicy::TruncateLedgerTail) {
+        policy_reasons.push("truncate_ledger_tail_requested_but_forbidden".to_string());
+        if matches!(input.mode, Stop02Mode::StrictControlledFinalize) {
+            // Keep the forbidden value visible for strict failure accounting.
+        } else {
+            tail_policy = Stop02TailPolicy::MarkRiskTail;
+        }
+    }
+
+    let message_codes = message_codes_for(surface_kind, input, tail_policy);
+    Stop02FinalizationPolicy {
+        eos_policy,
+        tail_policy,
+        surface_kind,
+        ledger_mutation_allowed: false,
+        visible_output_mutation_allowed: input.user_visible_surface_enabled && !matches!(surface_kind, Stop02SurfaceKind::None),
+        allow_retry: !matches!(surface_kind, Stop02SurfaceKind::None),
+        allow_continue_from_safe_point: input.risk_tail_start_step.is_some() && !matches!(surface_kind, Stop02SurfaceKind::None),
+        require_user_acknowledgement: matches!(surface_kind, Stop02SurfaceKind::NumericSafetyStopped | Stop02SurfaceKind::GlobalFallbackStopped),
+        message_codes,
+        policy_reasons,
+    }
+}
+
+pub fn finalize_stop02_surface(input: &Stop02Input, policy: &Stop02FinalizationPolicy) -> Stop02FinalizationReceipt {
+    let raw_start = 0;
+    let raw_end = input.raw_output_token_count;
+    let mut warnings = Vec::new();
+
+    let mut hidden_start = None;
+    let mut hidden_end = None;
+    let mut risk_marked = false;
+    let mut risk_hidden = false;
+    let mut visible_end = raw_end;
+
+    match policy.tail_policy {
+        Stop02TailPolicy::PreserveAll => {}
+        Stop02TailPolicy::MarkRiskTail => {
+            if input.risk_tail_start_step.is_some() {
+                risk_marked = true;
+            } else {
+                warnings.push("risk_tail_range_missing_mark_downgraded_to_preserve".to_string());
+            }
+        }
+        Stop02TailPolicy::HideRiskTailSurfaceOnly => {
+            if let (Some(start), Some(end)) = (input.risk_tail_start_step, input.risk_tail_end_step) {
+                hidden_start = Some(start.min(raw_end));
+                hidden_end = Some(end.min(raw_end));
+                visible_end = start.min(raw_end);
+                risk_marked = true;
+                risk_hidden = true;
+            } else {
+                warnings.push("risk_tail_range_missing_hide_downgraded_to_mark".to_string());
+                risk_marked = input.risk_tail_start_step.is_some();
+            }
+        }
+        Stop02TailPolicy::TruncateLedgerTail => {
+            warnings.push("truncate_ledger_tail_forbidden_ledger_preserved".to_string());
+            risk_marked = input.risk_tail_start_step.is_some();
+        }
+    }
+
+    let eos_appended_to_ledger = false;
+    let mut virtual_eos_added = matches!(policy.eos_policy, Stop02EosPolicy::AppendVirtualEos);
+    if matches!(policy.eos_policy, Stop02EosPolicy::AppendLedgerEos) {
+        warnings.push("append_ledger_eos_forbidden_ledger_preserved".to_string());
+        virtual_eos_added = !matches!(input.mode, Stop02Mode::StrictControlledFinalize);
+    }
+    if matches!(policy.eos_policy, Stop02EosPolicy::SurfaceOnly | Stop02EosPolicy::None) {
+        virtual_eos_added = false;
+    }
+
+    let visible_tail_hash = Some(format!("sha256:stop02-visible-tail-{}-{}-{:?}", visible_end, risk_marked, policy.surface_kind));
+    let range_valid = visible_end <= raw_end && hidden_start.zip(hidden_end).map(|(s, e)| s <= e && e <= raw_end).unwrap_or(true);
+    if !range_valid {
+        warnings.push("visible_range_invalid".to_string());
+    }
+
+    let surface = Stop02SurfaceReceipt {
+        surface_kind: policy.surface_kind,
+        message_codes: policy.message_codes.clone(),
+        user_visible: input.user_visible_surface_enabled && !matches!(policy.surface_kind, Stop02SurfaceKind::None),
+        copy_safe: !matches!(policy.surface_kind, Stop02SurfaceKind::NumericSafetyStopped | Stop02SurfaceKind::GlobalFallbackStopped),
+        retry_available: policy.allow_retry,
+        continue_from_safe_point_available: policy.allow_continue_from_safe_point,
+        safe_point_step: input.risk_tail_start_step,
+        display_severity: display_severity(policy.surface_kind).to_string(),
+        surface_reasons: policy.policy_reasons.clone(),
+    };
+
+    let finalized = !matches!(policy.surface_kind, Stop02SurfaceKind::None);
+    Stop02FinalizationReceipt {
+        finalized,
+        ledger_mutated: false,
+        visible_output_mutated: finalized && policy.visible_output_mutation_allowed,
+        eos_appended_to_ledger,
+        virtual_eos_added,
+        output_tail_preserved: !matches!(policy.tail_policy, Stop02TailPolicy::HideRiskTailSurfaceOnly),
+        output_tail_marked: risk_marked,
+        output_tail_hidden_surface_only: risk_hidden,
+        output_tail_truncated_from_ledger: false,
+        visible_range: Stop02VisibleRange {
+            raw_start_step: raw_start,
+            raw_end_step: raw_end,
+            visible_start_step: raw_start,
+            visible_end_step: visible_end,
+            hidden_tail_start_step: hidden_start,
+            hidden_tail_end_step: hidden_end,
+            risk_tail_marked: risk_marked,
+            risk_tail_hidden: risk_hidden,
+            raw_tail_hash: input.raw_output_tail_hash.clone(),
+            visible_tail_hash,
+        },
+        surface,
+        finalization_reasons: vec!["surface_finalized".to_string(), "ledger_preserved".to_string(), "user_visible_stop_surface_created".to_string()],
+        finalization_warnings: warnings,
+    }
+}
+
+pub fn input_from_stop01(mode: Stop02Mode, stop01: &Stop01StepReceipt) -> Stop02Input {
+    let raw_count = env::var("ASH_STOP02_RAW_OUTPUT_TOKEN_COUNT")
+        .ok()
+        .and_then(|v| v.parse::<usize>().ok())
+        .unwrap_or_else(|| stop01.execution.stop_step.unwrap_or(stop01.step).max(stop01.step));
+    let risk_start = env::var("ASH_STOP02_RISK_TAIL_START_STEP")
+        .ok()
+        .and_then(|v| v.parse::<usize>().ok())
+        .or_else(|| raw_count.checked_sub(4));
+    let risk_end = env::var("ASH_STOP02_RISK_TAIL_END_STEP")
+        .ok()
+        .and_then(|v| v.parse::<usize>().ok())
+        .or(Some(raw_count));
+    Stop02Input {
+        mode,
+        run_id: env_string("ASH_STOP02_RUN_ID", "stop02_sampler03_bridge"),
+        prompt_hash: stop01.prompt_hash.clone(),
+        seed: stop01.seed,
+        step: stop01.step,
+        backend: stop01.backend.clone(),
+        stop01_executed: stop01.execution.executed,
+        stop01_reason: Some(format!("{:?}", stop01.execution.stop_reason)),
+        generation_loop_stop_requested: stop01.execution.generation_loop_stop_requested,
+        salad03b_post_risk: stop01.input.salad03b_post_risk.clone(),
+        salad03b_risk_improved: stop01.input.salad03b_risk_improved,
+        salad03b_risk_worsened: stop01.input.salad03b_risk_worsened,
+        salad03b_resample_success: stop01.input.salad03b_resample_success,
+        salad03b_safe_stop_recommended: stop01.input.salad03b_safe_stop_recommended,
+        salad02_score: stop01.input.salad02_score,
+        salad02_risk_stable: stop01.input.salad02_risk_stable.clone(),
+        raw_output_token_count: raw_count,
+        raw_output_tail_hash: stop01.post_fingerprint.as_ref().and_then(|f| f.tail_token_hash.clone()).or(Some(format!("sha256:stop02-raw-tail-{}", stop01.step))),
+        risk_tail_start_step: risk_start,
+        risk_tail_end_step: risk_end,
+        eos_token_id: env::var("ASH_STOP02_EOS_TOKEN_ID").ok().and_then(|v| v.parse::<u32>().ok()),
+        eos_allowed: env_bool("ASH_STOP02_EOS_ALLOWED", true),
+        user_visible_surface_enabled: env_bool("ASH_STOP02_USER_VISIBLE_SURFACE", true),
+    }
+}
+
+pub fn receipt_from_stop01(mode: Stop02Mode, stop01: &Stop01StepReceipt) -> Stop02StepReceipt {
+    let input = input_from_stop01(mode, stop01);
+    let policy = decide_stop02_policy(&input);
+    let finalization = finalize_stop02_surface(&input, &policy);
+    let ledger_behavior_change = finalization.ledger_mutated || finalization.eos_appended_to_ledger || finalization.output_tail_truncated_from_ledger;
+    let surface_behavior_change = finalization.visible_output_mutated || finalization.output_tail_marked || finalization.output_tail_hidden_surface_only || finalization.virtual_eos_added;
+    Stop02StepReceipt {
+        patch_id: STOP02_PATCH_ID.to_string(),
+        input_patch: STOP02_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: input.run_id.clone(),
+        prompt_hash: input.prompt_hash.clone(),
+        seed: input.seed,
+        step: input.step,
+        backend: input.backend.clone(),
+        sampler_ssot: STOP02_SSOT.to_string(),
+        mode,
+        behavior_change: ledger_behavior_change || surface_behavior_change,
+        ledger_behavior_change,
+        surface_behavior_change,
+        surface_only: true,
+        stop01_status_seen: Some("DERIVED_IN_MEMORY_FROM_STOP01_RECEIPT".to_string()),
+        salad03b_status_seen: stop01.salad03b_status_seen.clone(),
+        salad02_status_seen: stop01.salad02_status_seen.clone(),
+        input,
+        policy,
+        finalization,
+        selected_id_current: stop01.selected_id_current,
+        selected_piece_current: stop01.selected_piece_current.clone(),
+    }
+}
+
+pub fn append_stop02_receipt_from_sampler03(source: &SamplerParityReceipt) {
+    let mode = Stop02Mode::from_env();
+    if !mode.requested() {
+        return;
+    }
+    let entropy_receipt = receipt_from_sampler03(Decode03AMode::Receipt, source);
+    let pci_receipt = receipt_from_decode03a(Decode03BMode::Receipt, &entropy_receipt, None, 0);
+    let shadow_receipt = receipt_from_decode03b(Decode03CMode::Receipt, &pci_receipt, Some(&entropy_receipt));
+    let dynamic_mode = DynamicSamplerMode::from_env();
+    let mut decode03d_receipt = receipt_from_decode03c(dynamic_mode, &shadow_receipt);
+    decode03d_receipt.selected_id_after_apply = Some(source.cpu.selected_id);
+    let salad02_receipt = salad02_receipt_from_decode03d(&decode03d_receipt);
+    let salad03_mode = Salad03Mode::from_env();
+    let salad03_receipt = receipt_from_salad02(salad03_mode, &salad02_receipt);
+    let kv00 = kv00_receipt_from_salad03(KvRollback00Mode::ForkedReplayProbe, &salad03_receipt);
+    let kv01 = kv01_receipt_from_kvrollback00(KvRollback01Mode::ForkedReplayProbe, &kv00);
+    let salad03b_mode = Salad03BMode::from_env();
+    let salad03b = salad03b_receipt_from_salad03_and_kv01(salad03b_mode, &salad03_receipt, &kv01);
+    let stop01_mode = Stop01Mode::from_env();
+    let stop01 = receipt_from_salad03b(stop01_mode, &salad03b);
+    let receipt = receipt_from_stop01(mode, &stop01);
+    let path = receipt_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(line) = serde_json::to_string(&receipt) {
+        use std::io::Write;
+        if let Ok(mut file) = fs::OpenOptions::new().create(true).append(true).open(path) {
+            let _ = writeln!(file, "{}", line);
+        }
+    }
+}
+
+fn read_receipts(path: PathBuf) -> Vec<Stop02StepReceipt> {
+    let data = match fs::read_to_string(path) {
+        Ok(data) => data,
+        Err(_) => return Vec::new(),
+    };
+    data.lines().filter_map(|line| serde_json::from_str::<Stop02StepReceipt>(line).ok()).collect()
+}
+
+pub fn summary_from_receipts(receipts: &[Stop02StepReceipt]) -> Stop02Summary {
+    let mut finalization = Stop02FinalizationStats::default();
+    let mut tail_policy = Stop02TailPolicyStats::default();
+    let mut surface_kind = Stop02SurfaceKindStats::default();
+    let mut user_surface = Stop02UserSurfaceStats::default();
+    let mut safety = Stop02SafetyStats::default();
+
+    for receipt in receipts {
+        if receipt.finalization.finalized { finalization.finalized_count += 1; }
+        if receipt.surface_behavior_change { finalization.surface_behavior_change_count += 1; }
+        if receipt.ledger_behavior_change { finalization.ledger_behavior_change_count += 1; }
+        if receipt.finalization.ledger_mutated { finalization.ledger_mutated_count += 1; safety.ledger_mutation_count += 1; }
+        if receipt.finalization.virtual_eos_added { finalization.virtual_eos_added_count += 1; }
+        if receipt.finalization.eos_appended_to_ledger { finalization.ledger_eos_appended_count += 1; safety.eos_ledger_append_count += 1; }
+        if receipt.finalization.output_tail_truncated_from_ledger { safety.silent_truncate_count += 1; }
+        if receipt.input.stop01_reason.as_deref().unwrap_or("None") == "None" && receipt.finalization.finalized { safety.missing_stop_reason_count += 1; }
+        if receipt.finalization.visible_range.visible_end_step > receipt.finalization.visible_range.raw_end_step { safety.visible_range_invalid_count += 1; }
+
+        match receipt.policy.tail_policy {
+            Stop02TailPolicy::PreserveAll => tail_policy.preserve_all_count += 1,
+            Stop02TailPolicy::MarkRiskTail => tail_policy.mark_risk_tail_count += 1,
+            Stop02TailPolicy::HideRiskTailSurfaceOnly => tail_policy.hide_risk_tail_surface_only_count += 1,
+            Stop02TailPolicy::TruncateLedgerTail => tail_policy.truncate_ledger_tail_count += 1,
+        }
+        match receipt.policy.surface_kind {
+            Stop02SurfaceKind::SafeStopped => surface_kind.safe_stopped_count += 1,
+            Stop02SurfaceKind::PartialOutput => surface_kind.partial_output_count += 1,
+            Stop02SurfaceKind::SaladRiskStopped => surface_kind.salad_risk_stopped_count += 1,
+            Stop02SurfaceKind::ResampleFailedStopped => surface_kind.resample_failed_stopped_count += 1,
+            Stop02SurfaceKind::RollbackFailedStopped => surface_kind.rollback_failed_stopped_count += 1,
+            Stop02SurfaceKind::NumericSafetyStopped => surface_kind.numeric_safety_stopped_count += 1,
+            Stop02SurfaceKind::GlobalFallbackStopped => surface_kind.global_fallback_stopped_count += 1,
+            Stop02SurfaceKind::None => {}
+        }
+        if receipt.finalization.surface.user_visible { user_surface.user_visible_count += 1; }
+        if receipt.finalization.surface.retry_available { user_surface.retry_available_count += 1; }
+        if receipt.finalization.surface.continue_from_safe_point_available { user_surface.continue_from_safe_point_count += 1; }
+        if receipt.policy.require_user_acknowledgement { user_surface.require_user_acknowledgement_count += 1; }
+    }
+
+    let steps_observed = receipts.len();
+    let contract_fail = safety.ledger_mutation_count > 0
+        || safety.eos_ledger_append_count > 0
+        || safety.silent_truncate_count > 0
+        || safety.missing_stop_reason_count > 0
+        || safety.visible_range_invalid_count > 0;
+    Stop02Summary {
+        patch_id: STOP02_PATCH_ID.to_string(),
+        input_patch: STOP02_INPUT_PATCH_ID.to_string(),
+        status: if contract_fail { "FAIL_STATIC_CONTRACT" } else if steps_observed > 0 { "PASS_WITH_WARNINGS" } else { "STATIC_BAKE_DEFINED_NOT_RUN" }.to_string(),
+        mode: Stop02Mode::from_env().as_str().to_string(),
+        surface_only: true,
+        default_enable: true,
+        requires_stop01: env_bool("ASH_STOP02_REQUIRE_STOP01", true),
+        stop01_status_seen: if steps_observed > 0 { Some("DERIVED_IN_MEMORY_FROM_STOP01_RECEIPT".to_string()) } else { None },
+        steps_observed,
+        finalization,
+        tail_policy,
+        surface_kind,
+        user_surface,
+        safety,
+        ready_for_stop03_ledger_eos_commit: false,
+        ready_for_salad04_korean_morph_loop_guard: !contract_fail,
+        reason: if contract_fail {
+            "STOP-02 contract violation detected; ledger mutation/truncate/EOS commit remains forbidden".to_string()
+        } else if steps_observed == 0 {
+            "surface finalization schema baked; run STOP-01 receipt fixtures before UI enable".to_string()
+        } else {
+            "surface finalization sealed; ledger mutation remains forbidden".to_string()
+        },
+    }
+}
+
+pub fn write_stop02_summary_from_receipt_file() {
+    let summary = summary_from_receipts(&read_receipts(receipt_path()));
+    let path = summary_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(json) = serde_json::to_string_pretty(&summary) {
+        let _ = fs::write(path, format!("{}\n", json));
+    }
+}
