+pub fn append_eval03_receipt_from_sampler03(receipt: &SamplerParityReceipt) {
+    let mode = Eval03Mode::from_env();
+    if !mode.enabled() { return; }
+    let _ = write_eval03_manifests();
+    let candidates = load_decode03f_candidates(&candidates_path().to_string_lossy()).unwrap_or_else(|_| vec![synthetic_candidate()]);
+    if matches!(mode, Eval03Mode::ManifestOnly) {
+        let _ = write_eval03_summary_from_receipt_file();
+        return;
+    }
+    if let Some(candidate) = candidates.first() {
+        let profile = materialize_candidate_profile(candidate);
+        let run = build_synthetic_candidate_run(receipt, &profile);
+        append_jsonl(runs_path(), &run);
+        if let Some(metrics) = &run.backend_metrics {
+            let diff = Eval03CandidateBackendDiff {
+                candidate_id: run.candidate_id.clone(),
+                candidate_profile_id: run.candidate_profile_id.clone(),
+                prompt_id: run.prompt_id.clone(),
+                seed: run.seed,
+                canonical_backend: metrics.canonical_backend.clone(),
+                candidate_backend: metrics.candidate_backend.clone(),
+                selected_match_rate_delta_vs_parent: None,
+                top5_overlap_delta_vs_parent: None,
+                active_set_delta_fail_delta_vs_parent: metrics.active_set_delta_fail_count as i64,
+                fallback_divergence_delta_vs_parent: metrics.fallback_divergence_count as i64,
+                stop_divergence_delta_vs_parent: metrics.stop_decision_divergence_count as i64,
+                parity_regressed: !metrics.semantic_parity_pass || metrics.fallback_divergence_count > 0,
+                diff_reasons: if metrics.semantic_parity_pass { vec!["semantic_parity_pass".to_string()] } else { vec!["semantic_parity_fail".to_string()] },
+            };
+            append_jsonl(backend_diffs_path(), &diff);
+        }
+    }
+    let _ = write_eval03_summary_from_receipt_file();
+}
