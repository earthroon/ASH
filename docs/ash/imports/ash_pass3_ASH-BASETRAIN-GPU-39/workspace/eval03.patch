+pub fn build_synthetic_candidate_run(receipt: &SamplerParityReceipt, profile: &Eval03CandidateProfile) -> Eval03CandidateRunReceipt {
+    let suite_kind = env::var("ASH_EVAL03_SUITE_KIND").unwrap_or_else(|_| "short_regression".to_string());
+    let backend = env::var("ASH_EVAL03_BACKEND").unwrap_or_else(|_| "sampler03_projection".to_string());
+    let seed = env_u64("ASH_EVAL03_SEED", 0);
+    let salad02 = env_f32("ASH_EVAL03_SALAD02_SCORE");
+    let salad04 = env_f32("ASH_EVAL03_SALAD04_SCORE");
+    let selected_match = env_f32("ASH_EVAL03_SELECTED_MATCH_RATE").unwrap_or(1.0);
+    let top5_overlap = env_f32("ASH_EVAL03_TOP5_OVERLAP_MEAN").unwrap_or(5.0);
+    let drift = env_f32("ASH_EVAL03_DRIFT_SCORE").unwrap_or(0.20);
+    let normal_stop = env_bool("ASH_EVAL03_NORMAL_PROMPT_STOP", false);
+    let active_empty = env_usize("ASH_EVAL03_ACTIVE_SET_EMPTY_COUNT", 0);
+    let global_fallback = env_usize("ASH_EVAL03_GLOBAL_FALLBACK_COUNT", 0);
+    let output_token_count = env_usize("ASH_EVAL03_OUTPUT_TOKEN_COUNT", receipt.step.saturating_add(1).max(1));
+    let prompt_id = env::var("ASH_EVAL03_PROMPT_ID").unwrap_or_else(|_| format!("candidate_sampler03_step_{}", receipt.step));
+    let short_metrics = Some(Eval03ShortMetrics {
+        salad02_score_max: salad02,
+        salad04_score_max: salad04,
+        salad02_high_count: risk_count(salad02, 0.55),
+        salad02_critical_count: risk_count(salad02, 0.80),
+        salad04_high_count: risk_count(salad04, 0.55),
+        salad04_critical_count: risk_count(salad04, 0.80),
+        byte_piece_count: env_usize("ASH_EVAL03_BYTE_PIECE_COUNT", 0),
+        jamo_leak_count: env_usize("ASH_EVAL03_JAMO_LEAK_COUNT", 0),
+        normal_prompt_stop: normal_stop,
+        output_too_short: output_token_count < 8,
+        repeat_3gram_rate: env_f32("ASH_EVAL03_REPEAT_3GRAM_RATE"),
+        distinct_2_ratio: env_f32("ASH_EVAL03_DISTINCT_2_RATIO"),
+    });
+    let backend_metrics = Some(Eval03BackendParityMetrics {
+        canonical_backend: "cpu_oracle".to_string(),
+        candidate_backend: backend.clone(),
+        selected_match_rate: Some(selected_match),
+        top5_overlap_mean: Some(top5_overlap),
+        threshold_kind_mismatch_count: env_usize("ASH_EVAL03_THRESHOLD_KIND_MISMATCH_COUNT", 0),
+        active_set_delta_fail_count: env_usize("ASH_EVAL03_ACTIVE_SET_DELTA_FAIL_COUNT", 0),
+        entropy_delta_fail_count: env_usize("ASH_EVAL03_ENTROPY_DELTA_FAIL_COUNT", 0),
+        pci_delta_fail_count: env_usize("ASH_EVAL03_PCI_DELTA_FAIL_COUNT", 0),
+        fallback_divergence_count: env_usize("ASH_EVAL03_FALLBACK_DIVERGENCE_COUNT", 0),
+        stop_decision_divergence_count: env_usize("ASH_EVAL03_STOP_DIVERGENCE_COUNT", 0),
+        semantic_parity_pass: env_bool("ASH_EVAL03_SEMANTIC_PARITY_PASS", selected_match >= 0.80 && top5_overlap >= 3.0),
+        strict_parity_pass: env_bool("ASH_EVAL03_STRICT_PARITY_PASS", selected_match >= 0.95),
+    });
+    let long_metrics = Some(Eval03LongHorizonMetrics {
+        drift_score: Some(drift),
+        drift_risk: Some(risk_label(drift)),
+        pci_decay_rate: env_f32("ASH_EVAL03_PCI_DECAY_RATE"),
+        entropy_growth_rate: env_f32("ASH_EVAL03_ENTROPY_GROWTH_RATE"),
+        salad02_growth_rate: env_f32("ASH_EVAL03_SALAD02_GROWTH_RATE"),
+        salad04_growth_rate: env_f32("ASH_EVAL03_SALAD04_GROWTH_RATE"),
+        morph_loop_growth_rate: env_f32("ASH_EVAL03_MORPH_LOOP_GROWTH_RATE"),
+        guard_panic_growth_rate: env_f32("ASH_EVAL03_GUARD_PANIC_GROWTH_RATE"),
+        stop_pressure_growth_rate: env_f32("ASH_EVAL03_STOP_PRESSURE_GROWTH_RATE"),
+        fallback_pressure_growth_rate: env_f32("ASH_EVAL03_FALLBACK_PRESSURE_GROWTH_RATE"),
+        global_finite_fallback_count: global_fallback,
+        active_set_empty_count: active_empty,
+        tokens_per_second_mean: env_f32("ASH_EVAL03_TOKENS_PER_SECOND"),
+    });
+    let run_id = env::var("ASH_EVAL03_RUN_ID").unwrap_or_else(|_| "eval03_candidate_sampler03_replay".to_string());
+    let output_sig = format!("{}:{}:{}:{}:{}", run_id, profile.candidate_profile_id, prompt_id, backend, output_token_count);
+    let mut run = Eval03CandidateRunReceipt {
+        patch_id: EVAL03_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id,
+        candidate_id: profile.source_candidate_id.clone(),
+        candidate_profile_id: profile.candidate_profile_id.clone(),
+        profile_hash: profile.profile_hash.clone(),
+        prompt_hash: hash_string(&prompt_id),
+        prompt_id,
+        suite_kind,
+        backend,
+        seed,
+        max_new_tokens: env_usize("ASH_EVAL03_MAX_NEW_TOKENS", 96),
+        output_hash: hash_string(&output_sig),
+        visible_output_hash: None,
+        finish_reason: env::var("ASH_EVAL03_FINISH_REASON").unwrap_or_else(|_| "length".to_string()),
+        output_token_count,
+        short_metrics,
+        backend_metrics,
+        long_metrics,
+        judgement: Eval03RunJudgement { status: "PENDING".to_string(), fail_reasons: Vec::new(), warn_reasons: Vec::new(), candidate_improved_over_parent: None, candidate_regressed_vs_parent: None },
+    };
+    run.judgement = judge_eval03_run(&run);
+    run
+}
