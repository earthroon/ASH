+pub fn load_decode03f_candidates(path: &str) -> Result<Vec<Decode03FCalibrationCandidate>, String> {
+    let content = fs::read_to_string(path).map_err(|e| format!("read candidates: {}", e))?;
+    let mut out = Vec::new();
+    for (idx, line) in content.lines().enumerate() {
+        let trimmed = line.trim();
+        if trimmed.is_empty() { continue; }
+        let value: Decode03FCalibrationCandidate = serde_json::from_str(trimmed)
+            .map_err(|e| format!("parse candidate line {}: {}", idx + 1, e))?;
+        out.push(value);
+    }
+    Ok(out)
+}
