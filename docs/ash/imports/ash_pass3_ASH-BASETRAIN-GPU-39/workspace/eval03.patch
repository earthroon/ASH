+pub fn materialize_candidate_profile(candidate: &Decode03FCalibrationCandidate) -> Eval03CandidateProfile {
+    let candidate_profile_id = format!("C03F_{}", candidate.candidate_id.to_ascii_lowercase().replace("decode03f_", "").replace('-', "_").replace(' ', "_"));
+    let profile_sig = format!("{}:{}:{}", candidate.candidate_id, candidate.baseline_profile, candidate.source_run_id);
+    Eval03CandidateProfile {
+        candidate_profile_id,
+        source_candidate_id: candidate.candidate_id.clone(),
+        baseline_profile: candidate.baseline_profile.clone(),
+        parent_guard_profile: candidate.candidate_profile.clone(),
+        candidate_only: true,
+        runtime_apply: false,
+        proposed_params: candidate.proposed_params.clone(),
+        decode03e_controlled_apply: true,
+        salad04_overlay_enabled: true,
+        profile_hash: hash_string(&profile_sig),
+    }
+}
