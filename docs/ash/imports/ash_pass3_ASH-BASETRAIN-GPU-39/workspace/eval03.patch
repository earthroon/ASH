+fn risk_label(score: f32) -> String {
+    let s = score.clamp(0.0, 1.0);
+    if s >= 0.80 { "Critical" } else if s >= 0.55 { "High" } else if s >= 0.30 { "Medium" } else { "Low" }.to_string()
