+pub fn judge_eval03_run(run: &Eval03CandidateRunReceipt) -> Eval03RunJudgement {
+    let mut fail = Vec::new();
+    let mut warn = Vec::new();
+    if let Some(short) = &run.short_metrics {
+        if short.salad02_critical_count > 0 { fail.push("salad02_critical".to_string()); }
+        if short.salad04_critical_count > 0 { fail.push("salad04_critical".to_string()); }
+        if short.byte_piece_count >= 3 { fail.push("byte_piece_threshold_exceeded".to_string()); }
+        if short.jamo_leak_count >= 5 { fail.push("jamo_leak_threshold_exceeded".to_string()); }
+        if short.normal_prompt_stop { warn.push("normal_prompt_stop_seen".to_string()); }
+        if short.output_too_short { fail.push("output_too_short".to_string()); }
+        if short.salad02_high_count > 0 || short.salad04_high_count > 0 { warn.push("high_salad_or_morph_risk_seen".to_string()); }
+    }
+    if let Some(backend) = &run.backend_metrics {
+        if backend.threshold_kind_mismatch_count > 0 { fail.push("threshold_kind_mismatch".to_string()); }
+        if backend.fallback_divergence_count > 0 { fail.push("fallback_divergence".to_string()); }
+        if !backend.semantic_parity_pass { fail.push("backend_semantic_parity_fail".to_string()); }
+        if !backend.strict_parity_pass { warn.push("backend_strict_parity_warn".to_string()); }
+        if backend.active_set_delta_fail_count > 0 { fail.push("active_set_delta_fail".to_string()); }
+        if backend.stop_decision_divergence_count > 0 { warn.push("stop_decision_divergence".to_string()); }
+    }
+    if let Some(long) = &run.long_metrics {
+        if long.global_finite_fallback_count > 0 { fail.push("global_finite_fallback".to_string()); }
+        if long.active_set_empty_count > 0 { fail.push("active_set_empty".to_string()); }
+        if matches!(long.drift_risk.as_deref(), Some("High" | "Critical")) { warn.push("long_horizon_drift_warn".to_string()); }
+        if long.stop_pressure_growth_rate.unwrap_or(0.0) > 0.05 { warn.push("stop_pressure_growth_warn".to_string()); }
+        if long.tokens_per_second_mean.unwrap_or(9999.0) < 1.0 { warn.push("speed_regression_warn".to_string()); }
+    }
+    if run.finish_reason == "NOT_COMPARABLE" {
+        return Eval03RunJudgement { status: "NOT_COMPARABLE".to_string(), fail_reasons: fail, warn_reasons: warn, candidate_improved_over_parent: None, candidate_regressed_vs_parent: None };
+    }
+    let status = if !fail.is_empty() { "FAIL" } else if !warn.is_empty() { "PASS_WITH_WARNINGS" } else { "PASS" };
+    let candidate_regressed = !fail.is_empty();
+    Eval03RunJudgement {
+        status: status.to_string(),
+        fail_reasons: fail,
+        warn_reasons: warn,
+        candidate_improved_over_parent: Some(!candidate_regressed),
+        candidate_regressed_vs_parent: Some(candidate_regressed),
+    }
+}
