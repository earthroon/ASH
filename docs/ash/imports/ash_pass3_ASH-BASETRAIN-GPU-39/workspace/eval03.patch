+pub fn summarize_eval03_runs(runs: &[Eval03CandidateRunReceipt], candidates_seen: usize) -> Eval03Summary {
+    let mut overall = Eval03OverallStats::default();
+    let mut by_raw: BTreeMap<String, Vec<&Eval03CandidateRunReceipt>> = BTreeMap::new();
+    for run in runs {
+        match run.judgement.status.as_str() {
+            "PASS" => overall.pass_count += 1,
+            "PASS_WITH_WARNINGS" => overall.warn_count += 1,
+            "FAIL" => overall.fail_count += 1,
+            "NOT_COMPARABLE" => overall.not_comparable_count += 1,
+            _ => {}
+        }
+        by_raw.entry(run.candidate_id.clone()).or_default().push(run);
+    }
+    let mut by_candidate = BTreeMap::new();
+    for (candidate_id, list) in by_raw.iter() {
+        let run_count = list.len();
+        let pass_count = list.iter().filter(|r| r.judgement.status == "PASS").count();
+        let warn_count = list.iter().filter(|r| r.judgement.status == "PASS_WITH_WARNINGS").count();
+        let fail_count = list.iter().filter(|r| r.judgement.status == "FAIL").count();
+        let not_comparable_count = list.iter().filter(|r| r.judgement.status == "NOT_COMPARABLE").count();
+        let backend_parity_regression = list.iter().any(|r| r.backend_metrics.as_ref().map(|m| !m.semantic_parity_pass || m.fallback_divergence_count > 0 || m.threshold_kind_mismatch_count > 0).unwrap_or(false));
+        let over_stop_regression = list.iter().any(|r| r.short_metrics.as_ref().map(|m| m.normal_prompt_stop).unwrap_or(false));
+        let speed_regression_warn = list.iter().any(|r| r.long_metrics.as_ref().and_then(|m| m.tokens_per_second_mean).map(|t| t < 1.0).unwrap_or(false));
+        let critical = list.iter().any(|r| {
+            r.short_metrics.as_ref().map(|m| m.salad02_critical_count > 0 || m.salad04_critical_count > 0).unwrap_or(false)
+                || r.long_metrics.as_ref().map(|m| m.global_finite_fallback_count > 0 || m.active_set_empty_count > 0).unwrap_or(false)
+        });
+        let short_regression_pass = !critical && list.iter().all(|r| r.short_metrics.is_some());
+        let backend_parity_pass = !backend_parity_regression;
+        let long_horizon_pass = list.iter().all(|r| r.long_metrics.as_ref().map(|m| !matches!(m.drift_risk.as_deref(), Some("Critical"))).unwrap_or(true));
+        let salad_score_improved = list.iter().any(|r| r.short_metrics.as_ref().and_then(|m| m.salad02_score_max).map(|s| s < 0.55).unwrap_or(false));
+        let morph_loop_reduced = list.iter().any(|r| r.short_metrics.as_ref().and_then(|m| m.salad04_score_max).map(|s| s < 0.55).unwrap_or(false));
+        let drift_score_improved = list.iter().any(|r| r.long_metrics.as_ref().and_then(|m| m.drift_score).map(|s| s < 0.30).unwrap_or(false));
+        let can_promote = fail_count == 0
+            && short_regression_pass
+            && backend_parity_pass
+            && long_horizon_pass
+            && !over_stop_regression
+            && !critical;
+        let candidate_grade = if fail_count > 0 || critical || backend_parity_regression || over_stop_regression {
+            "REJECT"
+        } else if can_promote && !speed_regression_warn {
+            "PROMOTE_TO_03G_CONTROLLED"
+        } else if can_promote {
+            "PROMOTE_TO_MORE_EVAL"
+        } else {
+            "HOLD"
+        }.to_string();
+        let mut denied = Vec::new();
+        let mut warnings = Vec::new();
+        if fail_count > 0 { denied.push("failed_run_present".to_string()); }
+        if critical { denied.push("hard_safety_regression_present".to_string()); }
+        if backend_parity_regression { denied.push("backend_parity_regression".to_string()); }
+        if over_stop_regression { denied.push("over_stop_regression".to_string()); }
+        if speed_regression_warn { warnings.push("speed_regression_warn_requires_monitoring".to_string()); }
+        warnings.push("default_enable_forbidden_in_eval03".to_string());
+        let candidate_profile_id = list.first().map(|r| r.candidate_profile_id.clone()).unwrap_or_else(|| format!("C03F_{}", candidate_id.to_ascii_lowercase()));
+        by_candidate.insert(candidate_id.clone(), Eval03CandidateStats {
+            candidate_id: candidate_id.clone(),
+            candidate_profile_id,
+            source_candidate_status: "PASS_WITH_WARNINGS".to_string(),
+            run_count,
+            pass_count,
+            warn_count,
+            fail_count,
+            not_comparable_count,
+            short_regression_pass,
+            backend_parity_pass,
+            long_horizon_pass,
+            salad_score_improved,
+            morph_loop_reduced,
+            drift_score_improved,
+            over_stop_regression,
+            backend_parity_regression,
+            speed_regression_warn,
+            candidate_grade,
+            promotion: Eval03PromotionDecision {
+                can_promote_to_decode03g: can_promote,
+                can_promote_to_default: false,
+                denied_reasons: denied,
+                warning_reasons: warnings,
+                required_next_steps: if can_promote { vec!["DECODE-03G controlled apply".to_string(), "EVAL-04 post-apply replay".to_string()] } else { vec!["Adjust DECODE-03F candidate".to_string(), "Rerun EVAL-03".to_string()] },
+            },
+        });
+    }
+    let ready = by_candidate.values().any(|c| c.promotion.can_promote_to_decode03g);
+    let status = if overall.fail_count > 0 { "FAIL" } else if overall.warn_count > 0 || overall.not_comparable_count > 0 { "PASS_WITH_WARNINGS" } else { "PASS" };
+    Eval03Summary {
+        patch_id: EVAL03_PATCH_ID.to_string(),
+        status: status.to_string(),
+        mode: Eval03Mode::from_env().as_str().to_string(),
+        candidates_seen,
+        candidates_evaluated: by_candidate.len(),
+        overall,
+        by_candidate,
+        acceptance: Eval03Acceptance {
+            ready_for_decode03g_controlled_apply: ready,
+            ready_for_default_guard_overlay: false,
+            ready_for_medusa00: false,
+            reason: if ready { "candidate replay passed without hard fail; default enable still forbidden".to_string() } else { "candidate replay not promotable yet".to_string() },
+        },
+    }
+}
