+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+pub enum Eval03Mode {
+    Off,
+    ManifestOnly,
+    ReplayCandidate,
+    CompareCandidate,
+    StrictCandidateGate,
+}
+
+impl Eval03Mode {
+    pub fn from_env() -> Self {
+        let value = env::var("ASH_EVAL03_MODE")
+            .unwrap_or_else(|_| "manifest_only".to_string())
+            .trim()
+            .to_ascii_lowercase();
+        match value.as_str() {
+            "off" | "false" | "0" | "disabled" => Self::Off,
+            "replay" | "replay_candidate" | "run" => Self::ReplayCandidate,
+            "compare" | "compare_candidate" => Self::CompareCandidate,
+            "strict" | "strict_candidate_gate" => Self::StrictCandidateGate,
+            _ => Self::ManifestOnly,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::ManifestOnly => "ManifestOnly",
+            Self::ReplayCandidate => "ReplayCandidate",
+            Self::CompareCandidate => "CompareCandidate",
+            Self::StrictCandidateGate => "StrictCandidateGate",
+        }
+    }
+
+    pub fn enabled(self) -> bool { !matches!(self, Self::Off) }
+    pub fn replays(self) -> bool { matches!(self, Self::ReplayCandidate | Self::CompareCandidate | Self::StrictCandidateGate) }
+}
