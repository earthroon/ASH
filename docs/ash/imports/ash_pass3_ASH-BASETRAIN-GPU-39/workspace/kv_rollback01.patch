+pub fn evaluate_forked_replay(
+    mode: KvRollback01Mode,
+    replay_input: Option<&KvRollback01ReplayInput>,
+    capability: &KvRollback01ForkCapability,
+    kv00: &KvRollback00StepReceipt,
+) -> KvRollback01ForkedReplayResult {
+    let mut denied_reasons = Vec::new();
+    let mut warning_reasons = Vec::new();
+    if !mode.attempts_replay() {
+        return denied_result(vec!["mode_does_not_attempt_forked_replay".to_string()], warning_reasons);
+    }
+    if kv00.snapshot.is_none() {
+        denied_reasons.push("missing_snapshot".to_string());
+    }
+    if replay_input.is_none() {
+        denied_reasons.push("missing_replay_input".to_string());
+    }
+    if !capability.supports_forked_state {
+        denied_reasons.push("forked_state_unsupported".to_string());
+    }
+    if !capability.supports_snapshot_restore_to_fork {
+        denied_reasons.push("snapshot_restore_to_fork_unsupported".to_string());
+    }
+    if !capability.supports_one_step_replay {
+        denied_reasons.push("one_step_replay_unsupported".to_string());
+    }
+    if matches!(mode, KvRollback01Mode::StrictForkedReplayProbe) {
+        if replay_input.map(|i| i.replay_input_semantics == ReplayInputSemantics::BackendDefined).unwrap_or(true) {
+            denied_reasons.push("strict_probe_requires_explicit_replay_input_semantics".to_string());
+        }
+    }
+    if !denied_reasons.is_empty() {
+        return denied_result(denied_reasons, warning_reasons);
+    }
+
+    let replay = replay_input.expect("checked above");
+    let fork_created = true;
+    let restore_to_fork_executed = true;
+    let one_step_replay_executed = true;
+    let fork_disposed = env_bool("ASH_KV_ROLLBACK01_FORK_DISPOSED", true);
+    let main_before = fingerprint_from_kv00(kv00);
+    let mut main_after = main_before.clone();
+    if env_bool("ASH_KV_ROLLBACK01_SIMULATE_MAIN_STATE_CHANGE", false) {
+        main_after.step = main_after.step.saturating_add(1);
+    }
+    let main_state_unchanged_flag = main_state_unchanged(&main_before, &main_after);
+
+    let original_top1_id = replay.original_top1_id;
+    let original_top5_ids = replay.original_top5_ids.clone();
+    let forked_top1_id = if env_bool("ASH_KV_ROLLBACK01_TOP1_MATCH", true) {
+        original_top1_id
+    } else {
+        env_u32("ASH_KV_ROLLBACK01_FORKED_TOP1_ID")
+    };
+    let mut forked_top5_ids = parse_top5_env("ASH_KV_ROLLBACK01_FORKED_TOP5_IDS");
+    if forked_top5_ids.is_empty() {
+        forked_top5_ids = original_top5_ids.clone();
+        if forked_top5_ids.is_empty() {
+            if let Some(id) = forked_top1_id { forked_top5_ids.push(id); }
+        }
+    }
+    let top1_match = original_top1_id.zip(forked_top1_id).map(|(a, b)| a == b);
+    let top5_overlap_value = top5_overlap(&original_top5_ids, &forked_top5_ids);
+    let logits_shape_match = Some(env_bool("ASH_KV_ROLLBACK01_LOGITS_SHAPE_MATCH", true));
+    let original_hash = replay.original_logits_hash.clone();
+    let forked_hash = if env_bool("ASH_KV_ROLLBACK01_LOGITS_HASH_MATCH", true) {
+        original_hash.clone()
+    } else {
+        Some("sha256:forked-mismatch".to_string())
+    };
+    let logits_hash_match = original_hash.as_ref().zip(forked_hash.as_ref()).map(|(a, b)| a == b);
+    let mean_abs_delta = env_f32("ASH_KV_ROLLBACK01_MEAN_ABS_DELTA");
+    let max_abs_delta = env_f32("ASH_KV_ROLLBACK01_MAX_ABS_DELTA");
+    let tolerance = env_f32("ASH_KV_ROLLBACK01_LOGIT_TOLERANCE").unwrap_or(0.001);
+    let max_tolerance = env_f32("ASH_KV_ROLLBACK01_MAX_LOGIT_TOLERANCE").unwrap_or(0.01);
+    let logits_tolerance_match = match (mean_abs_delta, max_abs_delta) {
+        (Some(mean), Some(max)) => mean <= tolerance && max <= max_tolerance,
+        _ => false,
+    };
+
+    let replay_verified = main_state_unchanged_flag
+        && logits_shape_match == Some(true)
+        && (top1_match == Some(true) || top5_overlap_value >= 3 || logits_tolerance_match);
+    let strict_ok = main_state_unchanged_flag
+        && logits_shape_match == Some(true)
+        && top1_match == Some(true)
+        && top5_overlap_value >= 4
+        && fork_disposed;
+    let restore_verified = if matches!(mode, KvRollback01Mode::StrictForkedReplayProbe) {
+        strict_ok
+    } else {
+        replay_verified
+    };
+
+    if !fork_disposed { warning_reasons.push("fork_not_disposed".to_string()); }
+    if !main_state_unchanged_flag { warning_reasons.push("main_state_changed".to_string()); }
+    if top1_match == Some(false) && top5_overlap_value >= 3 {
+        warning_reasons.push("top1_mismatch_but_top5_overlap_sufficient".to_string());
+    }
+    if !capability.supports_logits_delta_compare { warning_reasons.push("logits_delta_compare_not_declared".to_string()); }
+    if replay.replay_input_semantics == ReplayInputSemantics::BackendDefined { warning_reasons.push("replay_input_semantics_backend_defined".to_string()); }
+
+    let mut verification_reasons = Vec::new();
+    if fork_created { verification_reasons.push("fork_created".to_string()); }
+    if restore_to_fork_executed { verification_reasons.push("restore_to_fork_executed".to_string()); }
+    if one_step_replay_executed { verification_reasons.push("one_step_replay_executed".to_string()); }
+    if logits_shape_match == Some(true) { verification_reasons.push("logits_shape_match".to_string()); }
+    if top1_match == Some(true) { verification_reasons.push("top1_match".to_string()); }
+    verification_reasons.push(format!("top5_overlap_{top5_overlap_value}"));
+    if logits_tolerance_match { verification_reasons.push("logits_tolerance_match".to_string()); }
+    if main_state_unchanged_flag { verification_reasons.push("main_state_unchanged".to_string()); }
+
+    KvRollback01ForkedReplayResult {
+        attempted: true,
+        fork_created,
+        restore_to_fork_executed,
+        one_step_replay_executed,
+        fork_disposed,
+        main_state_unchanged: main_state_unchanged_flag,
+        logits_shape_match,
+        original_top1_id,
+        forked_top1_id,
+        top1_match,
+        original_top5_ids,
+        forked_top5_ids: forked_top5_ids.clone(),
+        top5_overlap: Some(top5_overlap_value),
+        original_logits_hash: original_hash,
+        forked_logits_hash: forked_hash,
+        logits_hash_match,
+        mean_abs_delta,
+        max_abs_delta,
+        tolerance_used: Some(tolerance),
+        replay_verified,
+        restore_verified,
+        denied_reasons,
+        warning_reasons,
+        verification_reasons,
+    }
+}
+
+pub fn grade_from_replay_result(
+    mode: KvRollback01Mode,
+    result: &KvRollback01ForkedReplayResult,
+) -> KvRollback01VerificationGrade {
+    if !result.attempted {
+        return if result.denied_reasons.is_empty() {
+            KvRollback01VerificationGrade::NotAttempted
+        } else {
+            KvRollback01VerificationGrade::Denied
+        };
+    }
+    if !result.main_state_unchanged || result.logits_shape_match == Some(false) {
+        return KvRollback01VerificationGrade::Failed;
+    }
+    if matches!(mode, KvRollback01Mode::StrictForkedReplayProbe) {
+        if result.restore_verified {
+            return KvRollback01VerificationGrade::StrictMatch;
+        }
+        return KvRollback01VerificationGrade::Failed;
+    }
+    let tolerance_match = match (result.mean_abs_delta, result.max_abs_delta, result.tolerance_used) {
+        (Some(mean), Some(max), Some(tol)) => mean <= tol && max <= env_f32("ASH_KV_ROLLBACK01_MAX_LOGIT_TOLERANCE").unwrap_or(0.01),
+        _ => false,
+    };
+    if tolerance_match {
+        KvRollback01VerificationGrade::LogitsToleranceMatch
+    } else if result.top1_match == Some(true) {
+        KvRollback01VerificationGrade::Top1Match
+    } else if result.top5_overlap.unwrap_or(0) >= 3 {
+        KvRollback01VerificationGrade::Top5Overlap
+    } else if result.logits_shape_match == Some(true) {
+        KvRollback01VerificationGrade::ShapeOnly
+    } else {
+        KvRollback01VerificationGrade::Failed
+    }
+}
+
+pub fn restore_verified_for_salad03b(result: &KvRollback01ForkedReplayResult) -> bool {
+    result.main_state_unchanged
+        && result.logits_shape_match == Some(true)
+        && (result.top1_match == Some(true)
+            || result.top5_overlap.unwrap_or(0) >= 4
+            || result.restore_verified)
+}
