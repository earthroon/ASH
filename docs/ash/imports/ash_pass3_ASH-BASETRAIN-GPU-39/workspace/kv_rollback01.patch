+pub fn fork_capability_from_env(backend: &str, kv00: &KvRollback00StepReceipt) -> KvRollback01ForkCapability {
+    let supports_forked_state = env_bool("ASH_KV_ROLLBACK01_SUPPORTS_FORKED_STATE", kv00.input.capability.supports_forked_restore);
+    let supports_snapshot_restore_to_fork = env_bool("ASH_KV_ROLLBACK01_SUPPORTS_SNAPSHOT_RESTORE_TO_FORK", kv00.input.capability.supports_forked_restore && kv00.input.capability.supports_restore);
+    let supports_one_step_replay = env_bool("ASH_KV_ROLLBACK01_SUPPORTS_ONE_STEP_REPLAY", supports_forked_state && supports_snapshot_restore_to_fork);
+    let supports_logits_topk_compare = env_bool("ASH_KV_ROLLBACK01_SUPPORTS_LOGITS_TOPK_COMPARE", supports_one_step_replay);
+    let supports_logits_hash_compare = env_bool("ASH_KV_ROLLBACK01_SUPPORTS_LOGITS_HASH_COMPARE", kv00.input.capability.supports_kv_hash);
+    let supports_logits_delta_compare = env_bool("ASH_KV_ROLLBACK01_SUPPORTS_LOGITS_DELTA_COMPARE", false);
+    let requires_gpu_readback = env_bool("ASH_KV_ROLLBACK01_REQUIRES_GPU_READBACK", kv00.input.capability.requires_gpu_readback);
+    let mut notes = Vec::new();
+    if !supports_forked_state { notes.push("forked_state_not_declared".to_string()); }
+    if !supports_snapshot_restore_to_fork { notes.push("snapshot_restore_to_fork_not_declared".to_string()); }
+    if !supports_one_step_replay { notes.push("one_step_replay_not_declared".to_string()); }
+    if requires_gpu_readback { notes.push("topk_or_hash_compare_may_require_gpu_readback".to_string()); }
+    KvRollback01ForkCapability {
+        backend: backend.to_string(),
+        supports_forked_state,
+        supports_snapshot_restore_to_fork,
+        supports_one_step_replay,
+        supports_logits_topk_compare,
+        supports_logits_hash_compare,
+        supports_logits_delta_compare,
+        requires_gpu_readback,
+        fork_cost_estimate: Some(env_string("ASH_KV_ROLLBACK01_FORK_COST", "unknown")),
+        notes,
+    }
+}
