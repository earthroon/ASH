+fn replay_input_from_kv00(kv00: &KvRollback00StepReceipt) -> Option<KvRollback01ReplayInput> {
+    let snapshot = kv00.snapshot.as_ref()?;
+    let snapshot_step = snapshot.step;
+    let semantics = ReplayInputSemantics::from_env();
+    let replay_token = env_u32("ASH_KV_ROLLBACK01_REPLAY_INPUT_TOKEN_ID")
+        .or(kv00.selected_id_current)
+        .or(Some(0));
+    let original_top1_id = env_u32("ASH_KV_ROLLBACK01_ORIGINAL_TOP1_ID")
+        .or_else(|| kv00.forked_replay.as_ref().and_then(|f| f.original_top1_id))
+        .or(replay_token);
+    let mut original_top5_ids = parse_top5_env("ASH_KV_ROLLBACK01_ORIGINAL_TOP5_IDS");
+    if original_top5_ids.is_empty() {
+        if let Some(fork) = &kv00.forked_replay {
+            original_top5_ids = fork.original_top5_ids.clone();
+        }
+    }
+    if original_top5_ids.is_empty() {
+        if let Some(top1) = original_top1_id {
+            original_top5_ids.push(top1);
+        }
+    }
+    Some(KvRollback01ReplayInput {
+        snapshot_id: snapshot.snapshot_id.clone(),
+        snapshot_step,
+        replay_input_semantics: semantics,
+        replay_input_token_id: replay_token,
+        replay_input_piece_preview: kv00.selected_piece_current.clone(),
+        expected_next_step: snapshot_step.saturating_add(1),
+        original_reference_available: original_top1_id.is_some() || !original_top5_ids.is_empty(),
+        original_top1_id,
+        original_top5_ids: original_top5_ids.clone(),
+        original_logits_hash: vec_u32_hash(&original_top5_ids),
+        original_logits_shape: Some(vec![env_usize("ASH_KV_ROLLBACK01_VOCAB_SIZE", 48259)]),
+    })
+}
