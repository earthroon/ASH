+    before.step == after.step
+        && before.token_ledger_len == after.token_ledger_len
+        && before.tail_token_hash == after.tail_token_hash
+        && before.sampler_state_hash == after.sampler_state_hash
+        && before.kv_ring_state_hash == after.kv_ring_state_hash
+}
