+fn parse_top5_env(name: &str) -> Vec<u32> {
+    env::var(name)
+        .ok()
+        .map(|raw| {
+            raw.split(',')
+                .filter_map(|v| v.trim().parse::<u32>().ok())
+                .take(5)
+                .collect::<Vec<_>>()
+        })
+        .unwrap_or_default()
