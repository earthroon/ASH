+pub fn receipt_from_kvrollback00(
+    mode: KvRollback01Mode,
+    kv00: &KvRollback00StepReceipt,
+) -> KvRollback01StepReceipt {
+    let replay_input = replay_input_from_kv00(kv00);
+    let capability = fork_capability_from_env(&kv00.backend, kv00);
+    let replay_result = evaluate_forked_replay(mode, replay_input.as_ref(), &capability, kv00);
+    let verification_grade = grade_from_replay_result(mode, &replay_result);
+    let restore_verified_for_salad03b = restore_verified_for_salad03b(&replay_result);
+    KvRollback01StepReceipt {
+        patch_id: KV_ROLLBACK01_PATCH_ID.to_string(),
+        input_patch: KV_ROLLBACK01_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: run_id_from_env(),
+        prompt_hash: kv00.prompt_hash.clone(),
+        seed: kv00.seed,
+        step: kv00.step,
+        backend: kv00.backend.clone(),
+        sampler_ssot: KV_ROLLBACK01_SSOT.to_string(),
+        mode,
+        behavior_change: false,
+        probe_only: true,
+        kv_rollback00_status_seen: Some("DERIVED_IN_MEMORY_FROM_KV_ROLLBACK00_RECEIPT".to_string()),
+        salad03_status_seen: kv00.salad03_status_seen.clone(),
+        salad02_status_seen: kv00.salad02_status_seen.clone(),
+        decode03d_status_seen: kv00.decode03d_status_seen.clone(),
+        snapshot_id: kv00.snapshot.as_ref().map(|s| s.snapshot_id.clone()),
+        snapshot_step: kv00.snapshot.as_ref().map(|s| s.step),
+        replay_input,
+        fork_capability: capability,
+        replay_result,
+        verification_grade,
+        restore_verified_for_salad03b,
+        selected_id_current: kv00.selected_id_current,
+        selected_piece_current: kv00.selected_piece_current.clone(),
+    }
+}
