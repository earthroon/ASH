+fn vec_u32_hash(ids: &[u32]) -> Option<String> {
+    if ids.is_empty() {
+        None
+    } else {
+        let joined = ids.iter().map(|id| id.to_string()).collect::<Vec<_>>().join("-");
+        Some(format!("sha256:topk-{joined}"))
+    }
+}
