+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+pub enum KvRollback01Mode {
+    Off,
+    PlanOnly,
+    ForkedReplayProbe,
+    StrictForkedReplayProbe,
+}
+
+impl KvRollback01Mode {
+    pub fn from_env() -> Self {
+        let value = env::var("ASH_KV_ROLLBACK01_MODE")
+            .or_else(|_| env::var("ASH_KV_ROLLBACK01_PROBE"))
+            .unwrap_or_else(|_| "plan_only".to_string())
+            .trim()
+            .to_ascii_lowercase();
+        match value.as_str() {
+            "off" | "0" | "false" | "disabled" => Self::Off,
+            "fork" | "forked" | "forked_replay" | "forked_replay_probe" | "true" | "1" => Self::ForkedReplayProbe,
+            "strict" | "strict_forked" | "strict_forked_replay" | "strict_forked_replay_probe" => Self::StrictForkedReplayProbe,
+            _ => Self::PlanOnly,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::PlanOnly => "PlanOnly",
+            Self::ForkedReplayProbe => "ForkedReplayProbe",
+            Self::StrictForkedReplayProbe => "StrictForkedReplayProbe",
+        }
+    }
+
+    pub fn requested(self) -> bool {
+        !matches!(self, Self::Off)
+    }
+
+    pub fn attempts_replay(self) -> bool {
+        matches!(self, Self::ForkedReplayProbe | Self::StrictForkedReplayProbe)
+    }
+}
