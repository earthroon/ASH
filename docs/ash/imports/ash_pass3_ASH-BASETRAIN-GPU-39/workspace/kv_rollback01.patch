+pub fn summary_from_receipts(receipts: &[KvRollback01StepReceipt]) -> KvRollback01Summary {
+    let mut forked_replay = KvRollback01ForkedReplayStats::default();
+    let mut verification = KvRollback01VerificationStats::default();
+    let mut grades = KvRollback01GradeStats::default();
+    let mut safety = KvRollback01SafetyStats::default();
+    let mut mode = KvRollback01Mode::PlanOnly.as_str().to_string();
+    let mut kv00_status_seen = None;
+
+    for receipt in receipts {
+        mode = receipt.mode.as_str().to_string();
+        kv00_status_seen = receipt.kv_rollback00_status_seen.clone();
+        if receipt.replay_result.attempted { forked_replay.attempted_count += 1; }
+        if receipt.replay_result.fork_created { forked_replay.fork_created_count += 1; }
+        if receipt.replay_result.restore_to_fork_executed { forked_replay.restore_to_fork_count += 1; }
+        if receipt.replay_result.one_step_replay_executed { forked_replay.one_step_replay_count += 1; }
+        if receipt.replay_result.fork_disposed { forked_replay.fork_disposed_count += 1; } else if receipt.replay_result.attempted { safety.fork_not_disposed_count += 1; }
+        if receipt.replay_result.top1_match == Some(true) { verification.top1_match_count += 1; }
+        if receipt.replay_result.top5_overlap.unwrap_or(0) >= 3 { verification.top5_overlap_ge_3_count += 1; }
+        if receipt.replay_result.top5_overlap.unwrap_or(0) >= 4 { verification.top5_overlap_ge_4_count += 1; }
+        if receipt.replay_result.logits_shape_match == Some(true) { verification.logits_shape_match_count += 1; }
+        if receipt.replay_result.logits_shape_match == Some(false) { safety.shape_mismatch_count += 1; }
+        if receipt.replay_result.main_state_unchanged { verification.main_state_unchanged_count += 1; } else { safety.main_state_changed_count += 1; }
+        if receipt.restore_verified_for_salad03b { verification.restore_verified_for_salad03b_count += 1; }
+        match receipt.verification_grade {
+            KvRollback01VerificationGrade::NotAttempted => grades.not_attempted_count += 1,
+            KvRollback01VerificationGrade::Denied => grades.denied_count += 1,
+            KvRollback01VerificationGrade::ShapeOnly => grades.shape_only_count += 1,
+            KvRollback01VerificationGrade::Top5Overlap => grades.top5_overlap_count += 1,
+            KvRollback01VerificationGrade::Top1Match => grades.top1_match_count += 1,
+            KvRollback01VerificationGrade::LogitsToleranceMatch => grades.logits_tolerance_match_count += 1,
+            KvRollback01VerificationGrade::StrictMatch => grades.strict_match_count += 1,
+            KvRollback01VerificationGrade::Failed => grades.failed_count += 1,
+        }
+    }
+
+    let steps_observed = receipts.len();
+    let behavior_change = receipts.iter().any(|r| r.behavior_change);
+    let probe_only = receipts.iter().all(|r| r.probe_only);
+    let status = if behavior_change || !probe_only || safety.main_state_changed_count > 0 || safety.fork_not_disposed_count > 0 || grades.failed_count > 0 {
+        "FAIL"
+    } else if grades.denied_count > 0 || grades.shape_only_count > 0 || verification.restore_verified_for_salad03b_count == 0 {
+        "PASS_WITH_WARNINGS"
+    } else {
+        "PASS"
+    }.to_string();
+    let ready_for_salad03b = steps_observed > 0
+        && verification.restore_verified_for_salad03b_count > 0
+        && safety.main_state_changed_count == 0
+        && safety.fork_not_disposed_count == 0;
+    KvRollback01Summary {
+        patch_id: KV_ROLLBACK01_PATCH_ID.to_string(),
+        input_patch: KV_ROLLBACK01_INPUT_PATCH_ID.to_string(),
+        status,
+        behavior_change,
+        probe_only,
+        mode,
+        requires_kv_rollback00: env_bool("ASH_KV_ROLLBACK01_REQUIRE_KV_ROLLBACK00", true),
+        kv_rollback00_status_seen: kv00_status_seen,
+        steps_observed,
+        forked_replay,
+        verification,
+        grades,
+        safety,
+        ready_for_salad03b_controlled_execute: ready_for_salad03b,
+        ready_for_default_rollback_execute: false,
+        reason: if ready_for_salad03b {
+            "forked replay restore verification sealed; SALAD-03B controlled execute may be considered".to_string()
+        } else {
+            "forked replay receipt sealed; restore_verified_for_salad03b not yet sufficient for execute".to_string()
+        },
+    }
+}
+
+pub fn write_kv_rollback01_summary_from_receipt_file() {
+    let summary = summary_from_receipts(&read_receipts(receipt_path()));
+    let path = summary_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(json) = serde_json::to_string_pretty(&summary) {
+        let _ = fs::write(path, json);
+    }
+}
