+use serde::{Deserialize, Serialize};
+
+use crate::TokenizerManifest;
+
+#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
+#[serde(rename_all = "snake_case")]
+pub enum DecodedPieceKind {
+    Text,
+    SentencePieceText,
+    Byte,
+    Control,
+    Unknown,
+    InvalidUtf8,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct DecodedPiece {
+    pub id: u32,
+    pub piece: String,
+    pub text: String,
+    pub kind: DecodedPieceKind,
+    pub suppressed_in_output: bool,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct DecodeProbe {
+    pub token_ids: Vec<u32>,
+    pub pieces: Vec<DecodedPiece>,
+    pub text: String,
+    pub mojibake_suspected: bool,
+    pub control_count: usize,
+    pub invalid_utf8_count: usize,
+}
+
+pub fn token_piece_from_manifest(manifest: &TokenizerManifest, id: u32) -> Option<String> {
+    manifest
+        .vocab
+        .iter()
+        .find(|entry| entry.id == id)
+        .map(|entry| entry.token.clone())
+        .or_else(|| {
+            manifest
+                .reserved_tokens
+                .iter()
+                .find(|entry| entry.id == id)
+                .map(|entry| entry.token.clone())
+        })
+}
+
+pub fn decode_manifest_token_sequence(manifest: &TokenizerManifest, token_ids: &[u32]) -> DecodeProbe {
+    decode_token_sequence_to_text(token_ids, |id| token_piece_from_manifest(manifest, id))
+}
+
+pub fn decode_piece_sequence_to_text(pieces: &[String]) -> DecodeProbe {
+    let ids: Vec<u32> = (0..pieces.len()).map(|idx| idx as u32).collect();
+    decode_token_sequence_to_text(&ids, |id| pieces.get(id as usize).cloned())
+}
+
+pub fn decode_single_token_fragment(
+    manifest: &TokenizerManifest,
+    token_id: u32,
+    at_text_start: bool,
+) -> Option<String> {
+    let piece = token_piece_from_manifest(manifest, token_id)?;
+    let probe = decode_token_sequence_to_text(&[token_id], |_| Some(piece.clone()));
+    let mut text = probe.text;
+    if !at_text_start && !text.is_empty() && !text.starts_with(' ') && piece.starts_with('▁') {
+        text.insert(0, ' ');
+    }
+    if text.is_empty() { None } else { Some(text) }
+}
+
+pub fn decode_piece_to_text(piece: &str) -> String {
+    decode_piece_sequence_to_text(&[piece.to_string()]).text
+}
+
+pub fn is_control_piece(piece: &str) -> bool {
+    if piece.is_empty() {
+        return true;
+    }
+
+    if matches!(
+        piece,
+        "<pad>" | "<bos>" | "<eos>" | "<unk>" | "<s>" | "</s>"
+    ) {
+        return true;
+    }
+
+    if piece.starts_with("<task:")
+        || piece.starts_with("<lang:")
+        || piece.starts_with("<glossary:")
+        || piece.starts_with("<tm:")
+        || piece.starts_with("<cue")
+        || piece.starts_with("</cue")
+        || piece.starts_with("<line")
+        || piece.starts_with("</line")
+        || piece.starts_with("<time")
+        || piece.starts_with("</time")
+        || piece.starts_with("<json:")
+        || piece.starts_with("<id:")
+        || piece.starts_with("<bridge:")
+        || piece.starts_with("<guard:")
+        || piece.starts_with("<style:")
+        || piece.starts_with("<qwave:")
+        || piece.starts_with("<delta_k:")
+        || piece.starts_with("<morph:")
+        || piece.starts_with("<cheon:")
+        || piece.starts_with("<ji:")
+        || piece.starts_with("<in:")
+        || piece.starts_with("<trace:")
+        || piece.starts_with("<probe:")
+    {
+        return true;
+    }
+
+    piece.starts_with("[SD24")
+        || piece.starts_with("▁[SD24")
+        || piece == "SYSTEM"
+        || piece == "PRO"
+        || piece == "MP"
+        || piece == "Runner"
+        || piece == "greedy-search-decoder"
+        || piece == "decode-file"
+        || piece == "lexicon"
+        || piece == "sherpa-onnx-wasm"
+}
+
+fn parse_byte_piece(piece: &str) -> Option<u8> {
+    if let Some(hex) = piece
+        .strip_prefix("<byte:")
+        .and_then(|s| s.strip_suffix('>'))
+    {
+        return u8::from_str_radix(hex, 16).ok();
+    }
+
+    if let Some(hex) = piece.strip_prefix("<0x").and_then(|s| s.strip_suffix('>')) {
+        return u8::from_str_radix(hex, 16).ok();
+    }
+
+    None
+}
+
+fn flush_pending_bytes(
+    out: &mut String,
+    pieces: &mut Vec<DecodedPiece>,
+    pending_bytes: &mut Vec<u8>,
+    pending_entries: &mut Vec<(u32, String)>,
+) -> usize {
+    if pending_bytes.is_empty() {
+        return 0;
+    }
+
+    match String::from_utf8(std::mem::take(pending_bytes)) {
+        Ok(text) => {
+            out.push_str(&text);
+            for (id, piece) in std::mem::take(pending_entries) {
+                pieces.push(DecodedPiece {
+                    id,
+                    piece,
+                    text: text.clone(),
+                    kind: DecodedPieceKind::Byte,
+                    suppressed_in_output: false,
+                });
+            }
+            0
+        }
+        Err(err) => {
+            let recovered = err.into_bytes();
+            let text = String::from_utf8_lossy(&recovered).to_string();
+            out.push_str(&text);
+            let invalid_count = pending_entries.len().max(1);
+            for (id, piece) in std::mem::take(pending_entries) {
+                pieces.push(DecodedPiece {
+                    id,
+                    piece,
+                    text: text.clone(),
+                    kind: DecodedPieceKind::InvalidUtf8,
+                    suppressed_in_output: false,
+                });
+            }
+            invalid_count
+        }
+    }
+}
+
+fn append_space_if_needed(out: &mut String) {
+    if !out.is_empty() && !out.ends_with(' ') && !out.ends_with('\n') {
+        out.push(' ');
+    }
+}
+
+pub fn decode_token_sequence_to_text(
+    token_ids: &[u32],
+    mut id_to_piece: impl FnMut(u32) -> Option<String>,
+) -> DecodeProbe {
+    let mut out = String::new();
+    let mut pieces = Vec::new();
+    let mut control_count = 0usize;
+    let mut invalid_utf8_count = 0usize;
+    let mut pending_bytes: Vec<u8> = Vec::new();
+    let mut pending_entries: Vec<(u32, String)> = Vec::new();
+
+    for &id in token_ids {
+        let piece = id_to_piece(id).unwrap_or_else(|| "<unk>".to_string());
+
+        if let Some(byte) = parse_byte_piece(&piece) {
+            pending_bytes.push(byte);
+            pending_entries.push((id, piece.clone()));
+            continue;
+        }
+
+        invalid_utf8_count += flush_pending_bytes(
+            &mut out,
+            &mut pieces,
+            &mut pending_bytes,
+            &mut pending_entries,
+        );
+
+        if is_control_piece(&piece) {
+            control_count += 1;
+            pieces.push(DecodedPiece {
+                id,
+                piece,
+                text: String::new(),
+                kind: DecodedPieceKind::Control,
+                suppressed_in_output: true,
+            });
+            continue;
+        }
+
+        let (text, kind) = if piece == "▁" {
+            append_space_if_needed(&mut out);
+            (String::new(), DecodedPieceKind::SentencePieceText)
+        } else if let Some(rest) = piece.strip_prefix('▁') {
+            let had_text = !out.is_empty();
+            if had_text {
+                append_space_if_needed(&mut out);
+            }
+            out.push_str(rest);
+            let text = if had_text { format!(" {}", rest) } else { rest.to_string() };
+            (text, DecodedPieceKind::SentencePieceText)
+        } else if piece == "<br>" {
+            out.push('\n');
+            ("\n".to_string(), DecodedPieceKind::Text)
+        } else {
+            out.push_str(&piece);
+            (piece.clone(), DecodedPieceKind::Text)
+        };
+
+        pieces.push(DecodedPiece {
+            id,
+            piece,
+            text,
+            kind,
+            suppressed_in_output: false,
+        });
+    }
+
+    invalid_utf8_count += flush_pending_bytes(
+        &mut out,
+        &mut pieces,
+        &mut pending_bytes,
+        &mut pending_entries,
+    );
+
+    let mut cleaned = out.trim().to_string();
+    while cleaned.contains("  ") {
+        cleaned = cleaned.replace("  ", " ");
+    }
+
+    DecodeProbe {
+        token_ids: token_ids.to_vec(),
+        pieces,
+        mojibake_suspected: mojibake_suspected(&cleaned),
+        text: cleaned,
+        control_count,
+        invalid_utf8_count,
+    }
+}
+
+pub fn mojibake_suspected(text: &str) -> bool {
+    const PATTERNS: &[&str] = &["�", "?댁", "媛", "怨", "Ã", "ì", "ê"];
+    PATTERNS.iter().any(|pattern| text.contains(pattern))
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn decodes_sentencepiece_and_suppresses_eos() {
+        let ids = [29899, 2];
+        let probe = decode_token_sequence_to_text(&ids, |id| match id {
+            29899 => Some("▁이어가고".to_string()),
+            2 => Some("<eos>".to_string()),
+            _ => None,
+        });
+        assert_eq!(probe.text, "이어가고");
+        assert_eq!(probe.control_count, 1);
+        assert!(probe.pieces[1].suppressed_in_output);
+    }
+
+    #[test]
+    fn decodes_utf8_byte_run() {
+        let ids = [10, 11, 12];
+        let bytes = ["<byte:EC>", "<byte:9D>", "<byte:B4>"];
+        let probe = decode_token_sequence_to_text(&ids, |id| bytes.get((id - 10) as usize).map(|s| s.to_string()));
+        assert_eq!(probe.text, "이");
+        assert_eq!(probe.invalid_utf8_count, 0);
+    }
+}
