+use serde::{Deserialize, Serialize};
+
+use crate::cpu_oracle_sampler::{
+    sample_with_cpu_oracle,
+    sample_with_cpu_oracle_with_semantic_prior,
+    CpuOracleContext,
+    SemanticPriorScores,
+};
+use crate::generation_sampling::{GenerationSamplingConfig, SemanticPriorConfig};
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct MinpC1aFixtureReceipt {
+    pub name: String,
+    pub status: String,
+    pub semantic_prior_effective: bool,
+    pub active_ids: Vec<u32>,
+    pub final_ids: Vec<u32>,
+    pub semantic_bias: Option<f32>,
+    pub weighted_logit: Option<f32>,
+    pub expected_note: String,
+}
+
+fn base_ctx() -> CpuOracleContext {
+    CpuOracleContext {
+        step: 0,
+        seed: 1,
+        eos_token_id: None,
+        pad_token_id: Some(0),
+        banned_token_ids: Vec::new(),
+        recent_token_ids: Vec::new(),
+        min_new_tokens: 0,
+    }
+}
+
+fn minp_cfg() -> GenerationSamplingConfig {
+    GenerationSamplingConfig {
+        temperature: 1.0,
+        top_k: 0,
+        top_p: 1.0,
+        min_p: 0.1,
+        ..Default::default()
+    }
+}
+
+fn semantic_cfg() -> GenerationSamplingConfig {
+    let mut cfg = minp_cfg();
+    cfg.semantic_prior = SemanticPriorConfig {
+        enabled: true,
+        qwave_weight: 0.20,
+        deltak_weight: 0.15,
+        cross_weight: 0.10,
+        bias_cap: 0.75,
+        apply_to_min_p: true,
+        apply_to_top_p: true,
+        apply_to_sampling_score: true,
+        require_sampler04_strict_ready: true,
+    };
+    cfg
+}
+
+pub fn semantic_bias_formula_fixture() -> MinpC1aFixtureReceipt {
+    let cfg = semantic_cfg();
+    let q = 0.8f32;
+    let k = 0.5f32;
+    let bias = cfg.semantic_prior.bias_from_scores(q, k);
+    MinpC1aFixtureReceipt {
+        name: "semantic_bias_formula".to_string(),
+        status: if (bias - 0.275).abs() < 1e-6 { "PASS" } else { "FAIL" }.to_string(),
+        semantic_prior_effective: true,
+        active_ids: Vec::new(),
+        final_ids: Vec::new(),
+        semantic_bias: Some(bias),
+        weighted_logit: Some(10.0 + bias),
+        expected_note: "0.2*0.8 + 0.15*0.5 + 0.1*0.8*0.5 = 0.275".to_string(),
+    }
+}
+
+pub fn zero_source_fallback_fixture() -> MinpC1aFixtureReceipt {
+    let logits = [10.0, 9.0, 8.0, 2.0];
+    let cfg = semantic_cfg();
+    let ctx = base_ctx();
+    let vanilla = sample_with_cpu_oracle(&logits, &minp_cfg(), &ctx);
+    let zero_source = sample_with_cpu_oracle_with_semantic_prior(
+        &logits,
+        &cfg,
+        &ctx,
+        SemanticPriorScores::default(),
+    );
+    let same_candidates = vanilla.trace.active_ids == zero_source.trace.active_ids
+        && vanilla.trace.final_ids == zero_source.trace.final_ids;
+    MinpC1aFixtureReceipt {
+        name: "zero_source_fallback".to_string(),
+        status: if same_candidates && !zero_source.trace.semantic_prior_effective { "PASS" } else { "FAIL" }.to_string(),
+        semantic_prior_effective: zero_source.trace.semantic_prior_effective,
+        active_ids: zero_source.trace.active_ids,
+        final_ids: zero_source.trace.final_ids,
+        semantic_bias: zero_source.trace.semantic_bias_mean,
+        weighted_logit: zero_source.trace.weighted_active_max,
+        expected_note: "no qwave/deltak source keeps weighted path identical to vanilla scaled logits".to_string(),
+    }
+}
+
+pub fn prior_rescue_fixture() -> MinpC1aFixtureReceipt {
+    let logits = [10.0, 7.6, 7.0];
+    let cfg = semantic_cfg();
+    let ctx = CpuOracleContext { pad_token_id: None, ..base_ctx() };
+    let qwave = [0.0, 1.0, 0.0];
+    let weighted = sample_with_cpu_oracle_with_semantic_prior(
+        &logits,
+        &cfg,
+        &ctx,
+        SemanticPriorScores { qwave_scores: Some(&qwave), deltak_scores: None },
+    );
+    let rescued = weighted.trace.active_ids.contains(&1);
+    MinpC1aFixtureReceipt {
+        name: "prior_rescue".to_string(),
+        status: if rescued { "PASS" } else { "FAIL" }.to_string(),
+        semantic_prior_effective: weighted.trace.semantic_prior_effective,
+        active_ids: weighted.trace.active_ids,
+        final_ids: weighted.trace.final_ids,
+        semantic_bias: weighted.trace.semantic_bias_max,
+        weighted_logit: weighted.trace.weighted_active_max,
+        expected_note: "token 1 moves from 7.6 to 7.8 and survives min_p=0.1".to_string(),
+    }
+}
+
+pub fn banned_token_cannot_resurrect_fixture() -> MinpC1aFixtureReceipt {
+    let logits = [10.0, 7.6];
+    let cfg = semantic_cfg();
+    let mut ctx = CpuOracleContext { pad_token_id: None, ..base_ctx() };
+    ctx.banned_token_ids = vec![1];
+    let qwave = [0.0, 10.0];
+    let deltak = [0.0, 10.0];
+    let result = sample_with_cpu_oracle_with_semantic_prior(
+        &logits,
+        &cfg,
+        &ctx,
+        SemanticPriorScores { qwave_scores: Some(&qwave), deltak_scores: Some(&deltak) },
+    );
+    let banned_absent = !result.trace.active_ids.contains(&1) && !result.trace.final_ids.contains(&1);
+    MinpC1aFixtureReceipt {
+        name: "banned_token_cannot_resurrect".to_string(),
+        status: if banned_absent { "PASS" } else { "FAIL" }.to_string(),
+        semantic_prior_effective: result.trace.semantic_prior_effective,
+        active_ids: result.trace.active_ids,
+        final_ids: result.trace.final_ids,
+        semantic_bias: result.trace.semantic_bias_max,
+        weighted_logit: result.trace.weighted_active_max,
+        expected_note: "ban/eos guard precedes semantic prior; token 1 must stay removed".to_string(),
+    }
+}
+
+pub fn run_minp_c1a_cpu_smoke_fixtures() -> Vec<MinpC1aFixtureReceipt> {
+    vec![
+        semantic_bias_formula_fixture(),
+        zero_source_fallback_fixture(),
+        prior_rescue_fixture(),
+        banned_token_cannot_resurrect_fixture(),
+    ]
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn minp_c1a_semantic_bias_formula() {
+        assert_eq!(semantic_bias_formula_fixture().status, "PASS");
+    }
+
+    #[test]
+    fn minp_c1a_zero_source_falls_back_to_vanilla() {
+        assert_eq!(zero_source_fallback_fixture().status, "PASS");
+    }
+
+    #[test]
+    fn minp_c1a_prior_can_rescue_near_threshold_token() {
+        assert_eq!(prior_rescue_fixture().status, "PASS");
+    }
+
+    #[test]
+    fn minp_c1a_banned_token_cannot_resurrect() {
+        assert_eq!(banned_token_cannot_resurrect_fixture().status, "PASS");
+    }
+}
