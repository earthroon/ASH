++pub fn build_safe_resample_config(input: &Salad03RollbackInput) -> Salad03SafeResampleConfig {
++    let critical = matches!(input.risk_stable, SaladRiskLevel::Critical) || input.numeric_risk;
++    let base_temperature = if critical { 0.08 } else { 0.14 };
++    let base_min_p = if critical { 0.16 } else { 0.12 };
++    let base_top_p = if critical { 0.76 } else { 0.82 };
++    Salad03SafeResampleConfig {
++        temperature: clamp_finite(input.current_temperature.min(base_temperature), 0.03, 1.20, base_temperature),
++        top_p: clamp_finite(input.current_top_p.min(base_top_p), 0.50, 1.00, base_top_p),
++        top_k: if env_bool("ASH_SALAD03_KEEP_TRANSITION_AWARE_TOPK", false) { input.current_top_k.min(1024) } else { 0 },
++        min_p: clamp_finite(input.current_min_p.max(base_min_p), 0.00, 0.25, base_min_p),
++        guard_strength: "Panic".to_string(),
++        repeat_penalty: Some(input.current_repeat_penalty.unwrap_or(1.0).max(1.12).min(1.30)),
++        no_repeat_ngram: Some(if critical { 4 } else { 3 }),
++        max_resample_attempts: env_usize("ASH_SALAD03_MAX_RESAMPLE_ATTEMPTS", 1).clamp(0, 4),
++        safe_stop_if_resample_fails: true,
++    }
