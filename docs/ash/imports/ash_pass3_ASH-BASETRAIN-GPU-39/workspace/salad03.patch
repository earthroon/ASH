+pub fn receipt_from_salad02(mode: Salad03Mode, receipt: &Salad02StepReceipt) -> Salad03StepReceipt {
+    let input = input_from_salad02(receipt, mode);
+    let plan = build_salad03_plan(&input);
+    let execution = execution_receipt_for_plan(&plan);
+    Salad03StepReceipt {
+        patch_id: SALAD03_PATCH_ID.to_string(),
+        input_patch: SALAD03_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: run_id_from_env(),
+        prompt_hash: receipt.prompt_hash.clone(),
+        seed: receipt.seed,
+        step: receipt.step,
+        backend: receipt.backend.clone(),
+        sampler_ssot: SALAD03_ROLLBACK_SSOT.to_string(),
+        mode,
+        behavior_change: plan.behavior_change,
+        salad02_status_seen: Some("DERIVED_IN_MEMORY_FROM_SALAD02_RECEIPT".to_string()),
+        decode03d_status_seen: receipt.decode03d_status_seen.clone(),
+        decode03c_status_seen: receipt.decode03c_status_seen.clone(),
+        decode03b_status_seen: receipt.decode03b_status_seen.clone(),
+        decode03a_status_seen: receipt.decode03a_status_seen.clone(),
+        sampler05_status_seen: receipt.sampler05_status_seen.clone(),
+        input,
+        plan,
+        execution,
+        selected_id_before: Some(receipt.selected_id),
+        selected_piece_before: receipt.selected_piece_preview.clone(),
+        selected_id_after: None,
+        selected_piece_after: None,
+    }
+}
