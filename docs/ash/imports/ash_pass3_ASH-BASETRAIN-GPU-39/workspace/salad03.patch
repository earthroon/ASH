+pub fn build_salad03_plan(input: &Salad03RollbackInput) -> Salad03RollbackPlan {
+    let mut denied_reasons = Vec::new();
+    let mut warning_reasons = Vec::new();
+    let mut plan_reasons = Vec::new();
+    let rollback_depth = compute_rollback_depth(input);
+    let rollback_target_step = if rollback_depth > 0 && input.token_ledger_len >= rollback_depth {
+        Some(input.token_ledger_len.saturating_sub(rollback_depth))
+    } else {
+        None
+    };
+
+    if matches!(input.mode, Salad03Mode::Off) {
+        denied_reasons.push("mode_off".to_string());
+    }
+    if !input.rollback_candidate && !matches!(input.risk_stable, SaladRiskLevel::High | SaladRiskLevel::Critical) {
+        plan_reasons.push("risk_below_high_no_rollback".to_string());
+    }
+    if input.rollback_candidate { plan_reasons.push("rollback_candidate_from_salad02".to_string()); }
+    if matches!(input.risk_stable, SaladRiskLevel::High) { plan_reasons.push("risk_high".to_string()); }
+    if matches!(input.risk_stable, SaladRiskLevel::Critical) { plan_reasons.push("risk_critical".to_string()); }
+    if input.repeat_3gram_count >= 2 { plan_reasons.push("repeat_3gram_detected".to_string()); }
+    if input.pci_bucket.as_deref() == Some("Unstable") { plan_reasons.push("pci_unstable".to_string()); }
+    if input.pci_bucket.as_deref() == Some("Collapsing") { plan_reasons.push("pci_collapsing".to_string()); }
+
+    let rollback_wanted = matches!(input.risk_stable, SaladRiskLevel::High | SaladRiskLevel::Critical)
+        && input.rollback_candidate
+        && rollback_depth > 0;
+
+    let safe_stop_candidate = input.safe_stop_candidate
+        || input.global_finite_fallback_seen
+        || input.numeric_risk
+        || input.empty_active_set_seen
+        || input.rollback_count_window >= env_usize("ASH_SALAD03_MAX_ROLLBACKS_PER_WINDOW", 1);
+
+    if rollback_wanted && input.token_ledger_len < rollback_depth {
+        denied_reasons.push("token_ledger_too_short".to_string());
+    }
+    if rollback_wanted && !input.kv_snapshot_available {
+        denied_reasons.push("kv_snapshot_missing".to_string());
+    }
+    if rollback_wanted && !input.kv_restore_supported {
+        denied_reasons.push("kv_restore_unsupported".to_string());
+    }
+    if rollback_wanted && input.kv_snapshot_available && input.kv_restore_supported && !input.kv_restore_verified {
+        warning_reasons.push("kv_restore_not_verified_plan_only".to_string());
+        if matches!(input.mode, Salad03Mode::StrictControlledExecute) && env_bool("ASH_SALAD03_FAIL_ON_UNVERIFIED_RESTORE", true) {
+            denied_reasons.push("kv_restore_unverified_strict".to_string());
+        }
+    }
+    if matches!(input.mode, Salad03Mode::ControlledExecute | Salad03Mode::StrictControlledExecute) && !input.behavior_change_allowed {
+        denied_reasons.push("behavior_change_not_allowed".to_string());
+    }
+    if input.global_finite_fallback_seen { warning_reasons.push("global_finite_fallback_prefers_safe_stop".to_string()); }
+    if input.numeric_risk { warning_reasons.push("numeric_risk_prefers_safe_stop".to_string()); }
+    if input.rollback_count_window >= env_usize("ASH_SALAD03_MAX_ROLLBACKS_PER_WINDOW", 1) {
+        warning_reasons.push("rollback_window_limit_reached".to_string());
+    }
+
+    let decision = if matches!(input.mode, Salad03Mode::Off) {
+        Salad03DecisionKind::NoAction
+    } else if matches!(input.mode, Salad03Mode::StrictControlledExecute) && !denied_reasons.is_empty() {
+        Salad03DecisionKind::StrictFail
+    } else if safe_stop_candidate && (!rollback_wanted || input.global_finite_fallback_seen || input.numeric_risk || input.rollback_count_window >= env_usize("ASH_SALAD03_MAX_ROLLBACKS_PER_WINDOW", 1)) {
+        Salad03DecisionKind::SafeStopCandidate
+    } else if !rollback_wanted {
+        Salad03DecisionKind::NoAction
+    } else if matches!(input.mode, Salad03Mode::PlanOnly) {
+        Salad03DecisionKind::PlanRollback
+    } else if !denied_reasons.is_empty() {
+        Salad03DecisionKind::Denied
+    } else {
+        Salad03DecisionKind::ExecuteRollbackResample
+    };
+
+    let behavior_change = matches!(decision, Salad03DecisionKind::ExecuteRollbackResample)
+        && matches!(input.mode, Salad03Mode::ControlledExecute | Salad03Mode::StrictControlledExecute)
+        && input.behavior_change_allowed;
+    let plan_only = !behavior_change;
+
+    Salad03RollbackPlan {
+        decision,
+        behavior_change,
+        plan_only,
+        rollback_depth: if rollback_wanted { rollback_depth } else { 0 },
+        rollback_target_step,
+        required_token_ledger: rollback_wanted,
+        required_kv_snapshot: rollback_wanted,
+        kv_restore_required: rollback_wanted,
+        kv_restore_available: input.kv_snapshot_available,
+        kv_restore_supported: input.kv_restore_supported,
+        kv_restore_verified: input.kv_restore_verified,
+        safe_resample_config: build_safe_resample_config(input),
+        safe_stop_candidate,
+        eos_bias_candidate: input.eos_bias_candidate,
+        denied_reasons,
+        warning_reasons,
+        plan_reasons,
+    }
+}
