+pub fn summary_from_receipts(receipts: &[Salad03StepReceipt]) -> Salad03Summary {
+    let mut decisions = Salad03DecisionCounts::default();
+    let mut rollback = Salad03RollbackStats::default();
+    let mut execution = Salad03ExecutionStats::default();
+    let mut temps = Vec::new();
+    let mut min_ps = Vec::new();
+    let mut top_ps = Vec::new();
+    let mut depths = Vec::new();
+    let mut contract_violation = false;
+    let mut mode_seen = "PlanOnly".to_string();
+
+    for receipt in receipts {
+        mode_seen = receipt.mode.as_str().to_string();
+        contract_violation |= receipt.execution.rollback_executed && !receipt.plan.kv_restore_available;
+        contract_violation |= receipt.execution.rollback_executed && receipt.input.token_ledger_len == 0;
+        contract_violation |= receipt.execution.safe_stop_executed && matches!(receipt.mode, Salad03Mode::PlanOnly);
+        match receipt.plan.decision {
+            Salad03DecisionKind::NoAction => decisions.no_action_count += 1,
+            Salad03DecisionKind::PlanRollback => decisions.plan_rollback_count += 1,
+            Salad03DecisionKind::ExecuteRollbackResample => decisions.execute_rollback_resample_count += 1,
+            Salad03DecisionKind::SafeStopCandidate => decisions.safe_stop_candidate_count += 1,
+            Salad03DecisionKind::Denied => decisions.denied_count += 1,
+            Salad03DecisionKind::StrictFail => decisions.strict_fail_count += 1,
+        }
+        if receipt.plan.rollback_depth > 0 {
+            depths.push(receipt.plan.rollback_depth as f32);
+        }
+        rollback.max_rollback_depth = rollback.max_rollback_depth.max(receipt.plan.rollback_depth);
+        if receipt.plan.required_kv_snapshot { rollback.kv_snapshot_required_count += 1; }
+        if receipt.plan.kv_restore_available { rollback.kv_snapshot_available_count += 1; }
+        if receipt.plan.kv_restore_verified { rollback.kv_restore_verified_count += 1; }
+        if receipt.execution.executed { execution.executed_count += 1; }
+        if receipt.execution.rollback_executed { execution.rollback_executed_count += 1; }
+        if receipt.execution.kv_restore_executed { execution.kv_restore_executed_count += 1; }
+        if receipt.execution.resample_executed { execution.resample_executed_count += 1; }
+        if receipt.execution.safe_stop_executed { execution.safe_stop_executed_count += 1; }
+        temps.push(receipt.plan.safe_resample_config.temperature);
+        min_ps.push(receipt.plan.safe_resample_config.min_p);
+        top_ps.push(receipt.plan.safe_resample_config.top_p);
+    }
+    rollback.mean_rollback_depth = mean(&depths);
+    let safe_resample = Salad03SafeResampleStats {
+        temperature_min: temps.iter().copied().reduce(f32::min),
+        temperature_mean: mean(&temps),
+        min_p_max: min_ps.iter().copied().reduce(f32::max),
+        top_p_min: top_ps.iter().copied().reduce(f32::min),
+    };
+    let steps_observed = receipts.len();
+    let status = if steps_observed == 0 {
+        "STATIC_BAKE_DEFINED_NOT_RUN"
+    } else if contract_violation {
+        "FAIL_CONTRACT_VIOLATION"
+    } else if decisions.strict_fail_count > 0 || decisions.denied_count > 0 || decisions.safe_stop_candidate_count > 0 || decisions.plan_rollback_count > 0 {
+        "PASS_WITH_WARNINGS"
+    } else {
+        "PASS"
+    }.to_string();
+    let ready_for_controlled = steps_observed > 0
+        && !contract_violation
+        && rollback.kv_snapshot_required_count > 0
+        && rollback.kv_snapshot_required_count == rollback.kv_snapshot_available_count
+        && rollback.kv_restore_verified_count == rollback.kv_snapshot_required_count;
+    Salad03Summary {
+        patch_id: SALAD03_PATCH_ID.to_string(),
+        input_patch: SALAD03_INPUT_PATCH_ID.to_string(),
+        status,
+        mode: mode_seen,
+        behavior_change: execution.executed_count > 0,
+        requires_salad02: env_bool("ASH_SALAD03_REQUIRE_SALAD02", true),
+        salad02_status_seen: if steps_observed > 0 { Some("DERIVED_IN_MEMORY_FROM_SALAD02_RECEIPT".to_string()) } else { None },
+        decode03d_status_seen: if steps_observed > 0 { Some("OBSERVED_OR_DERIVED".to_string()) } else { None },
+        steps_observed,
+        decisions,
+        rollback,
+        execution,
+        safe_resample,
+        ready_for_controlled_execute_trial: ready_for_controlled,
+        ready_for_salad04_korean_morph_loop_guard: steps_observed > 0 && !contract_violation,
+        reason: if steps_observed == 0 {
+            "static bake only; run ASH_SALAD03_MODE=plan_only after SALAD-02 detector evidence".to_string()
+        } else if ready_for_controlled {
+            "rollback plans sealed and KV restore verified; controlled execute trial may be considered".to_string()
+        } else {
+            "rollback plans sealed; KV restore verification not yet proven, so execute remains blocked".to_string()
+        },
+    }
+}
+
+pub fn write_salad03_summary_from_receipt_file() {
+    let path = receipt_path();
+    let mut receipts = Vec::new();
+    if let Ok(text) = fs::read_to_string(&path) {
+        for line in text.lines() {
+            if line.trim().is_empty() { continue; }
+            if let Ok(receipt) = serde_json::from_str::<Salad03StepReceipt>(line) {
+                receipts.push(receipt);
+            }
+        }
+    }
+    let summary = summary_from_receipts(&receipts);
+    let out = summary_path();
+    if let Some(parent) = out.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(text) = serde_json::to_string_pretty(&summary) {
+        let _ = fs::write(out, format!("{}\n", text));
+    }
+}
