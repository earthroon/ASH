+pub fn execution_receipt_for_plan(plan: &Salad03RollbackPlan) -> Salad03ExecutionReceipt {
+    // The static baked SALAD-03 line deliberately does not mutate token/KV state.
+    // Runtime backends may implement Salad03RollbackRuntime in a later controlled-execute patch.
+    Salad03ExecutionReceipt {
+        executed: false,
+        rollback_executed: false,
+        kv_restore_executed: false,
+        resample_executed: false,
+        original_tail_tokens: Vec::new(),
+        replacement_tokens: Vec::new(),
+        rollback_depth: plan.rollback_depth,
+        rollback_target_step: plan.rollback_target_step,
+        kv_snapshot_id: None,
+        resample_attempts: 0,
+        resample_success: false,
+        post_resample_risk: None,
+        safe_stop_executed: false,
+    }
+}
