+
+    fn base_input(risk: SaladRiskLevel) -> Salad03RollbackInput {
+        Salad03RollbackInput {
+            mode: Salad03Mode::PlanOnly,
+            behavior_change_allowed: false,
+            risk_raw: risk,
+            risk_stable: risk,
+            salad_score: 0.70,
+            rollback_candidate: matches!(risk, SaladRiskLevel::High | SaladRiskLevel::Critical),
+            safe_stop_candidate: false,
+            eos_bias_candidate: false,
+            same_token_streak: 1,
+            same_piece_streak: 1,
+            repeat_3gram_count: 0,
+            repeat_4gram_count: 0,
+            byte_piece_count: 0,
+            jamo_leak_count: 0,
+            symbol_noise_count: 0,
+            pci_raw: Some(0.30),
+            pci_bucket: Some("Unstable".to_string()),
+            global_finite_fallback_seen: false,
+            numeric_risk: false,
+            empty_active_set_seen: false,
+            current_temperature: 0.18,
+            current_top_p: 0.86,
+            current_top_k: 0,
+            current_min_p: 0.08,
+            current_repeat_penalty: Some(1.0),
+            token_ledger_len: 16,
+            kv_snapshot_available: true,
+            kv_restore_supported: true,
+            kv_restore_verified: false,
+            rollback_count_window: 0,
+        }
+    }
+
+    #[test]
+    fn salad03_plan_only_never_executes() {
+        let input = base_input(SaladRiskLevel::High);
+        let plan = build_salad03_plan(&input);
+        let exec = execution_receipt_for_plan(&plan);
+        assert_eq!(plan.decision, Salad03DecisionKind::PlanRollback);
+        assert!(!plan.behavior_change);
+        assert!(!exec.executed);
+        assert!(!exec.rollback_executed);
+    }
+
+    #[test]
+    fn salad03_high_risk_plans_rollback() {
+        let mut input = base_input(SaladRiskLevel::High);
+        input.repeat_3gram_count = 2;
+        let plan = build_salad03_plan(&input);
+        assert_eq!(plan.decision, Salad03DecisionKind::PlanRollback);
+        assert!(plan.rollback_depth >= 4);
+    }
+
+    #[test]
+    fn salad03_critical_risk_depth_increases() {
+        let mut input = base_input(SaladRiskLevel::Critical);
+        input.pci_bucket = Some("Collapsing".to_string());
+        let plan = build_salad03_plan(&input);
+        assert!(plan.rollback_depth >= 6);
+    }
+
+    #[test]
+    fn salad03_global_fallback_prefers_safe_stop() {
+        let mut input = base_input(SaladRiskLevel::Critical);
+        input.global_finite_fallback_seen = true;
+        let plan = build_salad03_plan(&input);
+        assert_eq!(plan.decision, Salad03DecisionKind::SafeStopCandidate);
+    }
+
+    #[test]
+    fn salad03_resample_config_clamped() {
+        let mut input = base_input(SaladRiskLevel::Critical);
+        input.current_temperature = f32::NAN;
+        input.current_top_p = 9.0;
+        input.current_min_p = -9.0;
+        let config = build_safe_resample_config(&input);
+        assert!((0.03..=1.20).contains(&config.temperature));
+        assert!((0.50..=1.00).contains(&config.top_p));
+        assert!((0.00..=0.25).contains(&config.min_p));
+    }
+}
