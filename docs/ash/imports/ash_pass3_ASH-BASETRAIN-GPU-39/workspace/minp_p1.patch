+    #[test]
+    fn model_generate_bridge_maps_prompt_to_infer_input_and_preserves_min_p() {
+        let payload = json!({
+            "session_id": "sess_p1",
+            "prompt": "안녕",
+            "max_new_tokens": 16,
+            "temperature": 0.8,
+            "top_p": 0.9,
+            "top_k": 64,
+            "min_p": 0.05
+        });
+        let bridged = model_generate_bridge_payload(&payload);
+
+        assert_eq!(bridged.get("kind").and_then(|v| v.as_str()), Some("infer"));
+        assert_eq!(bridged.get("input").and_then(|v| v.as_str()), Some("안녕"));
+        assert_eq!(bridged.get("maxNewTokens").and_then(|v| v.as_u64()), Some(16));
+        assert_eq!(bridged.get("model_generate_session_id").and_then(|v| v.as_str()), Some("sess_p1"));
+        assert_eq!(bridged.get("min_p").and_then(|v| v.as_f64()), Some(0.05));
+    }
+
+    #[test]
+    fn model_generate_bridge_normalizes_min_p_aliases_and_clamps() {
+        let aliases = ["minP", "min_p", "samplingMinP", "sampling_min_p"];
+        for alias in aliases {
+            let mut payload = serde_json::Map::new();
+            payload.insert(alias.to_string(), json!(2.0));
+            payload.insert("prompt".to_string(), json!("x"));
+            let bridged = model_generate_bridge_payload(&Value::Object(payload));
+            assert_eq!(bridged.get("min_p").and_then(|v| v.as_f64()), Some(0.95));
+        }
+    }
+}
