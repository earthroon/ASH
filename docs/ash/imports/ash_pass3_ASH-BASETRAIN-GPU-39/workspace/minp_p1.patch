+fn payload_f64_alias(payload: &Value, aliases: &[&str]) -> Option<f64> {
+    aliases
+        .iter()
+        .find_map(|key| payload.get(*key).and_then(|v| v.as_f64()))
+}
+
+fn model_generate_bridge_payload(payload: &Value) -> Value {
+    let mut bridged = payload.as_object().cloned().unwrap_or_default();
+
+    bridged.insert("kind".to_string(), json!("infer"));
+    bridged.insert("model_generate_bridge".to_string(), json!(true));
+
+    let session_id = payload
+        .get("session_id")
+        .and_then(|v| v.as_str())
+        .unwrap_or("session");
+    bridged.insert("model_generate_session_id".to_string(), json!(session_id));
+
+    if !bridged.contains_key("input") {
+        let prompt = payload
+            .get("prompt")
+            .and_then(|v| v.as_str())
+            .unwrap_or_default();
+        bridged.insert("input".to_string(), json!(prompt));
+    }
+
+    if !bridged.contains_key("maxNewTokens") {
+        if let Some(v) = payload
+            .get("max_new_tokens")
+            .or_else(|| payload.get("maxNewTokens"))
+            .and_then(|v| v.as_u64())
+        {
+            bridged.insert("maxNewTokens".to_string(), json!(v));
+        }
+    }
+
+    if let Some(v) = payload_f64_alias(payload, &["min_p", "minP", "samplingMinP", "sampling_min_p"]) {
+        bridged.insert("min_p".to_string(), json!(normalize_min_p(v as f32)));
+    } else {
+        bridged.insert("min_p".to_string(), json!(0.0));
+    }
+
+    Value::Object(bridged)
+}
