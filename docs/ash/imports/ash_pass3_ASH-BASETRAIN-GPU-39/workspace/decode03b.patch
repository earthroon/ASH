+pub fn sigmoid(x: f32) -> f32 {
+    if !x.is_finite() {
+        return 0.0;
+    }
+    1.0 / (1.0 + (-x).exp())
+}
+
+fn clamp01(value: f32) -> f32 {
+    if !value.is_finite() {
+        0.0
+    } else {
+        value.clamp(0.0, 1.0)
+    }
+}
+
+fn finite_or_default(value: Option<f32>, default: f32) -> f32 {
+    value.filter(|v| v.is_finite()).unwrap_or(default)
+}
+
+pub fn compute_active_component(active_count: usize) -> f32 {
+    match active_count {
+        0 => 0.0,
+        1 | 2 => 0.35,
+        3..=7 => 0.70,
+        8..=96 => 1.0,
+        97..=256 => 0.70,
+        _ => 0.45,
+    }
+}
+
+fn bool_f32(value: bool) -> f32 {
+    if value { 1.0 } else { 0.0 }
+}
+
+fn fallback_kind_counts(fallback_mode: &str, fallback_count_window: usize) -> (usize, usize, usize) {
+    let mode = fallback_mode.trim().to_ascii_lowercase();
+    if mode == "none" || mode.is_empty() {
+        (0, 0, 0)
+    } else if mode.contains("global") || mode.contains("finite") || mode.contains("valid_global_top1") {
+        (0, 0, fallback_count_window.max(1))
+    } else if mode.contains("eos") {
+        (0, fallback_count_window.max(1), 0)
+    } else {
+        (fallback_count_window.max(1), 0, 0)
+    }
+}
+
+pub fn compute_pci(input: &PciInput, config: &PciConfig) -> PciComponents {
+    let raw_entropy_confidence = 1.0 - clamp01(finite_or_default(input.h_raw_norm, input.h_final_norm.unwrap_or(0.5)));
+    let final_entropy_confidence = 1.0 - clamp01(finite_or_default(input.h_final_norm, 0.5));
+    let entropy_component = clamp01(0.35 * raw_entropy_confidence + 0.65 * final_entropy_confidence);
+
+    let margin = finite_or_default(input.top1_top2_margin, 0.0);
+    let margin_component = clamp01(sigmoid(config.margin_scale * (margin - config.margin_center)));
+
+    let rank_component = match input.selected_rank {
+        Some(rank) if rank > 0 => clamp01(1.0 / (rank as f32).sqrt()),
+        _ => 0.5,
+    };
+
+    let selected_logprob = finite_or_default(input.selected_logprob, config.logprob_center);
+    let logprob_component = clamp01(sigmoid(config.logprob_scale * (selected_logprob - config.logprob_center)));
+
+    let active_component = clamp01(compute_active_component(input.active_count_final));
+
+    let fallback_penalty = clamp01(
+        0.10 * input.cpu_oracle_fallback_count_window as f32
+            + 0.20 * input.eos_fallback_count_window as f32
+            + 0.35 * input.global_finite_fallback_count_window as f32,
+    )
+    .min(0.85);
+
+    let numeric_risk = input.nan_seen || input.inf_seen;
+    let risk_penalty = clamp01(
+        0.12 * bool_f32(input.entropy_spike)
+            + 0.18 * bool_f32(input.guard_entropy_inversion)
+            + 0.16 * bool_f32(input.min_p_overcompression)
+            + 0.12 * bool_f32(input.top_p_overcompression)
+            + 0.35 * bool_f32(input.empty_active_set_seen)
+            + 0.60 * bool_f32(numeric_risk),
+    )
+    .min(0.90);
+
+    let weight_sum = config.entropy_weight
+        + config.margin_weight
+        + config.rank_weight
+        + config.logprob_weight
+        + config.active_weight;
+    let base_unscaled = config.entropy_weight * entropy_component
+        + config.margin_weight * margin_component
+        + config.rank_weight * rank_component
+        + config.logprob_weight * logprob_component
+        + config.active_weight * active_component;
+    let mut base_pci = if weight_sum > 0.0 { base_unscaled / weight_sum } else { 0.0 };
+    base_pci = clamp01(base_pci);
+
+    let mut final_pci = clamp01(base_pci - fallback_penalty - risk_penalty);
+    if numeric_risk {
+        final_pci = 0.0;
+    }
+    if input.empty_active_set_seen {
+        final_pci = final_pci.min(0.20);
+    }
+    if input.global_finite_fallback_seen {
+        final_pci = final_pci.min(0.35);
+    }
+    if input.guard_entropy_inversion && input.selected_rank.map(|r| r > 5).unwrap_or(false) {
+        final_pci = final_pci.min(0.45);
+    }
+    if input.min_p_overcompression && input.active_count_final <= 2 {
+        final_pci = final_pci.min(0.50);
+    }
+
+    PciComponents {
+        entropy_component,
+        margin_component,
+        rank_component,
+        logprob_component,
+        active_component,
+        fallback_penalty,
+        risk_penalty,
+        base_pci,
+        final_pci,
+    }
+}
+
+pub fn bucket_from_pci(pci: f32) -> PciBucket {
+    let pci = clamp01(pci);
+    if pci >= 0.88 {
+        PciBucket::Confident
+    } else if pci >= 0.70 {
+        PciBucket::Stable
+    } else if pci >= 0.45 {
+        PciBucket::Uncertain
+    } else if pci >= 0.20 {
+        PciBucket::Unstable
+    } else {
+        PciBucket::Collapsing
+    }
+}
+
+fn bucket_score(bucket: PciBucket) -> i32 {
+    match bucket {
+        PciBucket::Collapsing => 0,
+        PciBucket::Unstable => 1,
+        PciBucket::Uncertain => 2,
+        PciBucket::Stable => 3,
+        PciBucket::Confident => 4,
+    }
+}
+
+fn required_upshift_confirm_steps(previous: PciBucket, raw: PciBucket) -> usize {
+    match (previous, raw) {
+        (PciBucket::Collapsing, PciBucket::Unstable) => 2,
+        (PciBucket::Unstable, PciBucket::Uncertain) => 2,
+        (PciBucket::Uncertain, PciBucket::Stable) => 3,
+        (PciBucket::Stable, PciBucket::Confident) => 4,
+        _ => 2,
+    }
+}
+
+pub fn apply_pci_hysteresis(
+    previous: Option<PciBucket>,
+    raw: PciBucket,
+    confirm_counter: usize,
+) -> (PciBucket, PciBucketTransition) {
+    let Some(previous_bucket) = previous else {
+        return (
+            raw,
+            PciBucketTransition {
+                previous_bucket: None,
+                raw_bucket: raw,
+                stable_bucket: raw,
+                direction: "initial".to_string(),
+                required_confirm_steps: 0,
+                observed_confirm_steps: confirm_counter,
+                transition_applied: true,
+            },
+        );
+    };
+    let previous_score = bucket_score(previous_bucket);
+    let raw_score = bucket_score(raw);
+    if raw_score == previous_score {
+        return (
+            previous_bucket,
+            PciBucketTransition {
+                previous_bucket: Some(previous_bucket),
+                raw_bucket: raw,
+                stable_bucket: previous_bucket,
+                direction: "same".to_string(),
+                required_confirm_steps: 0,
+                observed_confirm_steps: confirm_counter,
+                transition_applied: false,
+            },
+        );
+    }
+    if raw_score < previous_score {
+        return (
+            raw,
+            PciBucketTransition {
+                previous_bucket: Some(previous_bucket),
+                raw_bucket: raw,
+                stable_bucket: raw,
+                direction: "downshift".to_string(),
+                required_confirm_steps: 0,
+                observed_confirm_steps: confirm_counter,
+                transition_applied: true,
+            },
+        );
+    }
+    let required = required_upshift_confirm_steps(previous_bucket, raw);
+    let applied = confirm_counter >= required;
+    let stable = if applied { raw } else { previous_bucket };
+    (
+        stable,
+        PciBucketTransition {
+            previous_bucket: Some(previous_bucket),
+            raw_bucket: raw,
+            stable_bucket: stable,
+            direction: "upshift".to_string(),
+            required_confirm_steps: required,
+            observed_confirm_steps: confirm_counter,
+            transition_applied: applied,
+        },
+    )
+}
+
+fn normalized_entropy_for_stage(receipt: &Decode03AEntropyStepReceipt, stage_name: &str) -> Option<f32> {
+    receipt
+        .entropy_metrics
+        .iter()
+        .find(|metric| format!("{:?}", metric.stage) == stage_name)
+        .and_then(|metric| metric.normalized_entropy)
+}
+
+pub fn input_from_decode03a(receipt: &Decode03AEntropyStepReceipt) -> PciInput {
+    let fallback_count_window = receipt.confidence_seed_metrics.fallback_count_window;
+    let (cpu_oracle_fallback_count_window, eos_fallback_count_window, global_finite_fallback_count_window) =
+        fallback_kind_counts(&receipt.fallback_mode, fallback_count_window);
+    PciInput {
+        h_raw_norm: normalized_entropy_for_stage(receipt, "Raw"),
+        h_final_norm: normalized_entropy_for_stage(receipt, "FinalActive")
+            .or_else(|| normalized_entropy_for_stage(receipt, "AfterTopP")),
+        top1_top2_margin: receipt.confidence_seed_metrics.top1_top2_margin,
+        top1_top5_margin: None,
+        selected_rank: receipt.confidence_seed_metrics.selected_token_rank,
+        selected_prob: receipt.confidence_seed_metrics.selected_token_prob,
+        selected_logprob: receipt.confidence_seed_metrics.selected_token_logprob,
+        active_count_final: receipt.active_set_metrics.active_count_final,
+        compression_ratio_total: receipt.active_set_metrics.compression_ratio_total,
+        fallback_count_window,
+        cpu_oracle_fallback_count_window,
+        eos_fallback_count_window,
+        global_finite_fallback_count_window,
+        entropy_spike: receipt.risk_flags.entropy_spike,
+        guard_entropy_inversion: receipt.risk_flags.guard_entropy_inversion,
+        min_p_overcompression: receipt.risk_flags.min_p_overcompression,
+        top_p_overcompression: receipt.risk_flags.top_p_overcompression,
+        empty_active_set_seen: receipt.risk_flags.empty_active_set_seen,
+        global_finite_fallback_seen: receipt.risk_flags.global_finite_fallback_seen,
+        nan_seen: receipt.risk_flags.nan_seen,
+        inf_seen: receipt.risk_flags.inf_seen,
+    }
+}
+
+fn risk_flags_from_input(input: &PciInput, pci: f32) -> PciRiskFlags {
+    let entropy_conflict = input.h_raw_norm.map(|h| h <= 0.35).unwrap_or(false)
+        && input.h_final_norm.map(|h| h >= 0.65).unwrap_or(false);
+    let margin_collapse = input.top1_top2_margin.map(|m| m < 0.20).unwrap_or(false);
+    let selected_rank_risk = input.selected_rank.map(|rank| rank >= 6).unwrap_or(false);
+    let fallback_risk = input.fallback_count_window > 0 || input.global_finite_fallback_seen;
+    let overcompression_risk = input.min_p_overcompression
+        || input.top_p_overcompression
+        || input.active_count_final <= 2;
+    let numeric_risk = input.nan_seen || input.inf_seen;
+    PciRiskFlags {
+        low_confidence: pci < 0.45,
+        collapsing: pci < 0.20,
+        entropy_conflict,
+        margin_collapse,
+        selected_rank_risk,
+        fallback_risk,
+        overcompression_risk,
+        numeric_risk,
+        ready_for_dynamic_shadow: !numeric_risk,
+    }
+}
+
+pub fn receipt_from_decode03a(
+    mode: Decode03BMode,
+    entropy_receipt: &Decode03AEntropyStepReceipt,
+    previous_bucket: Option<PciBucket>,
+    confirm_counter: usize,
+) -> Decode03BPciStepReceipt {
+    let config = PciConfig::default();
+    let input = input_from_decode03a(entropy_receipt);
+    let components = compute_pci(&input, &config);
+    let pci_raw = components.final_pci;
+    let bucket_raw = bucket_from_pci(pci_raw);
+    let (bucket_stable, bucket_transition) = if config.enable_hysteresis {
+        apply_pci_hysteresis(previous_bucket, bucket_raw, confirm_counter)
+    } else {
+        (
+            bucket_raw,
+            PciBucketTransition {
+                previous_bucket,
+                raw_bucket: bucket_raw,
+                stable_bucket: bucket_raw,
+                direction: "disabled".to_string(),
+                required_confirm_steps: 0,
+                observed_confirm_steps: confirm_counter,
+                transition_applied: true,
+            },
+        )
+    };
+    let risk_flags = risk_flags_from_input(&input, pci_raw);
+    Decode03BPciStepReceipt {
+        patch_id: DECODE03B_PATCH_ID.to_string(),
+        input_patch: DECODE03B_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: run_id_from_env(),
+        prompt_hash: None,
+        seed: entropy_receipt.seed,
+        step: entropy_receipt.step,
+        backend: "decode03a_entropy_bridge".to_string(),
+        sampler_ssot: DECODE03B_SAMPLER_SSOT.to_string(),
+        behavior_change: false,
+        mode: mode.as_str().to_string(),
+        decode03a_status_seen: Some("DERIVED_IN_MEMORY_FROM_DECODE03A_RECEIPT".to_string()),
+        sampler05_status_seen: entropy_receipt.sampler05_parity_status.clone(),
+        input,
+        config,
+        components,
+        pci_raw,
+        pci_smoothed: None,
+        bucket_raw,
+        bucket_stable,
+        bucket_transition,
+        selected_id: entropy_receipt.selected_id,
+        selected_piece_preview: entropy_receipt.selected_piece_preview.clone(),
+        risk_flags,
+    }
+}
