+pub fn append_decode03b_receipt_from_sampler03(source: &SamplerParityReceipt) {
+    let mode = Decode03BMode::from_env();
+    if !mode.enabled() {
+        return;
+    }
+    if env_bool("ASH_DECODE03B_FAIL_ON_BEHAVIOR_CHANGE", true) {
+        // DECODE-03B is observe-only by contract. There is no mutation path here.
+    }
+    let entropy_receipt = receipt_from_sampler03(Decode03AMode::Receipt, source);
+    let receipt = receipt_from_decode03a(mode, &entropy_receipt, None, 0);
+    let path = receipt_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(line) = serde_json::to_string(&receipt) {
+        use std::io::Write;
+        if let Ok(mut file) = fs::OpenOptions::new().create(true).append(true).open(path) {
+            let _ = writeln!(file, "{}", line);
+        }
+    }
+}
+
+fn percentile(sorted: &[f32], q: f32) -> Option<f32> {
+    if sorted.is_empty() {
+        return None;
+    }
+    let q = q.clamp(0.0, 1.0);
+    let idx = ((sorted.len() - 1) as f32 * q).round() as usize;
+    sorted.get(idx).copied()
+}
+
+pub fn summary_from_receipts(receipts: &[Decode03BPciStepReceipt]) -> Decode03BPciSummary {
+    let steps_observed = receipts.len();
+    let mut values = receipts.iter().map(|r| r.pci_raw).filter(|v| v.is_finite()).collect::<Vec<_>>();
+    values.sort_by(|a, b| a.partial_cmp(b).unwrap_or(Ordering::Equal));
+    let mean = if values.is_empty() {
+        None
+    } else {
+        Some(values.iter().sum::<f32>() / values.len() as f32)
+    };
+    let pci = Decode03BPciStats {
+        mean,
+        min: values.first().copied(),
+        max: values.last().copied(),
+        p10: percentile(&values, 0.10),
+        p50: percentile(&values, 0.50),
+        p90: percentile(&values, 0.90),
+    };
+    let mut buckets = Decode03BBucketCounts::default();
+    let mut transitions = Decode03BTransitionCounts::default();
+    let mut risk = Decode03BRiskCounts::default();
+    for receipt in receipts {
+        match receipt.bucket_stable {
+            PciBucket::Confident => buckets.confident_count += 1,
+            PciBucket::Stable => buckets.stable_count += 1,
+            PciBucket::Uncertain => buckets.uncertain_count += 1,
+            PciBucket::Unstable => buckets.unstable_count += 1,
+            PciBucket::Collapsing => buckets.collapsing_count += 1,
+        }
+        match receipt.bucket_transition.direction.as_str() {
+            "downshift" => transitions.downshift_count += 1,
+            "upshift" if receipt.bucket_transition.transition_applied => transitions.upshift_count += 1,
+            "upshift" => transitions.hysteresis_hold_count += 1,
+            _ => {}
+        }
+        if receipt.risk_flags.low_confidence { risk.low_confidence_count += 1; }
+        if receipt.risk_flags.collapsing { risk.collapsing_count += 1; }
+        if receipt.risk_flags.entropy_conflict { risk.entropy_conflict_count += 1; }
+        if receipt.risk_flags.margin_collapse { risk.margin_collapse_count += 1; }
+        if receipt.risk_flags.selected_rank_risk { risk.selected_rank_risk_count += 1; }
+        if receipt.risk_flags.fallback_risk { risk.fallback_risk_count += 1; }
+        if receipt.risk_flags.overcompression_risk { risk.overcompression_risk_count += 1; }
+        if receipt.risk_flags.numeric_risk { risk.numeric_risk_count += 1; }
+    }
+    let numeric_clean = risk.numeric_risk_count == 0;
+    let ready_for_decode03c_shadow_policy = steps_observed > 0 && numeric_clean;
+    let status = if steps_observed == 0 {
+        "STATIC_BAKE_DEFINED_NOT_RUN"
+    } else if !numeric_clean {
+        "FAIL_NUMERIC_RISK"
+    } else if risk.low_confidence_count > 0 || risk.overcompression_risk_count > 0 {
+        "PASS_WITH_WARNINGS"
+    } else {
+        "PASS"
+    }
+    .to_string();
+
+    Decode03BPciSummary {
+        patch_id: DECODE03B_PATCH_ID.to_string(),
+        input_patch: DECODE03B_INPUT_PATCH_ID.to_string(),
+        status,
+        behavior_change: false,
+        requires_decode03a: require_decode03a(),
+        decode03a_status_seen: if steps_observed > 0 { Some("OBSERVED_OR_DERIVED".to_string()) } else { None },
+        sampler05_status_seen: receipts.iter().find_map(|r| r.sampler05_status_seen.clone()),
+        steps_observed,
+        pci,
+        buckets,
+        transitions,
+        risk,
+        ready_for_decode03c_shadow_policy,
+        ready_for_decode03d_controlled_enable: false,
+        reason: if steps_observed == 0 {
+            "static bake only; run ASH_DECODE03B_PCI=receipt with DECODE-03A/SAMPLER-05 to produce PCI evidence".to_string()
+        } else if ready_for_decode03c_shadow_policy {
+            "PCI receipt sealed; DECODE-03C shadow policy may consume bucket_stable and risk flags without changing decode behavior".to_string()
+        } else {
+            "numeric or missing-input risk blocks dynamic sampler shadow promotion".to_string()
+        },
+    }
+}
+
+pub fn write_decode03b_summary_from_receipt_file() {
+    let path = receipt_path();
+    let mut receipts = Vec::new();
+    if let Ok(text) = fs::read_to_string(&path) {
+        for line in text.lines() {
+            if line.trim().is_empty() {
+                continue;
+            }
+            if let Ok(receipt) = serde_json::from_str::<Decode03BPciStepReceipt>(line) {
+                receipts.push(receipt);
+            }
+        }
+    }
+    let summary = summary_from_receipts(&receipts);
+    let out = summary_path();
+    if let Some(parent) = out.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(text) = serde_json::to_string_pretty(&summary) {
+        let _ = fs::write(out, format!("{}\n", text));
+    }
+}
