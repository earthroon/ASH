+    fn readback_candidate_trace(
+        &self,
+        header_rb: &BackendBuffer,
+        entries_rb: &BackendBuffer,
+        trace_top_n: usize,
+    ) -> Result<GpuCandidateTrace> {
+        let header_bytes = map_readback_bytes(&self.device, header_rb)?;
+        if header_bytes.len() < std::mem::size_of::<GpuCandidateTraceHeaderRaw>() {
+            bail!("gpu sampling: short candidate trace header readback");
+        }
+        let header = *bytemuck::from_bytes::<GpuCandidateTraceHeaderRaw>(
+            &header_bytes[..std::mem::size_of::<GpuCandidateTraceHeaderRaw>()],
+        );
+
+        let entries_bytes = map_readback_bytes(&self.device, entries_rb)?;
+        let entry_size = std::mem::size_of::<GpuCandidateTraceEntryRaw>();
+        let max_entries = trace_top_n.saturating_mul(2).max(2);
+        let available_entries = entries_bytes.len() / entry_size;
+        let read_entries = available_entries.min(max_entries);
+        let raw_entries: &[GpuCandidateTraceEntryRaw] = bytemuck::cast_slice(&entries_bytes[..read_entries * entry_size]);
+
+        let mut active_ids = Vec::new();
+        let mut final_ids = Vec::new();
+        let mut entries = Vec::new();
+        for raw in raw_entries {
+            if raw.stage == 0 {
+                continue;
+            }
+            let entry = GpuCandidateTraceEntry {
+                stage: raw.stage,
+                rank: raw.rank,
+                token_id: raw.token_id,
+                flags: raw.flags,
+                logit: raw.logit,
+                prob: raw.prob,
+            };
+            if raw.stage == 1 {
+                active_ids.push(raw.token_id);
+            } else if raw.stage == 2 {
+                final_ids.push(raw.token_id);
+            }
+            entries.push(entry);
+        }
+
+        Ok(GpuCandidateTrace {
+            active_ids,
+            final_ids,
+            active_count_total: header.active_count_total,
+            final_count_total: header.final_count_total,
+            active_count_written: header.active_count_written,
+            final_count_written: header.final_count_written,
+            active_overflow: header.active_overflow != 0,
+            final_overflow: header.final_overflow != 0,
+            recovery_mode: Some(recovery_mode_label(header.recovery_mode).to_string()),
+            min_p_threshold: finite_option(header.min_p_threshold),
+            active_max: finite_option(header.active_max),
+            active_sum_exp: finite_option(header.active_sum_exp),
+            entries,
+        })
+    }
