+fn read_receipts(path: PathBuf) -> Vec<Stop01StepReceipt> {
+    let data = match fs::read_to_string(path) {
+        Ok(data) => data,
+        Err(_) => return Vec::new(),
+    };
+    data.lines().filter_map(|line| serde_json::from_str::<Stop01StepReceipt>(line).ok()).collect()
+}
+
+fn count_reason(stats: &mut Stop01ReasonStats, reason: Stop01Reason) {
+    match reason {
+        Stop01Reason::SaladCritical => stats.salad_critical_count += 1,
+        Stop01Reason::SaladHighPersistent => stats.salad_high_persistent_count += 1,
+        Stop01Reason::PostResampleCritical => stats.post_resample_critical_count += 1,
+        Stop01Reason::PostResampleHighUnimproved => stats.post_resample_high_unimproved_count += 1,
+        Stop01Reason::ResampleFailed => stats.resample_failed_count += 1,
+        Stop01Reason::RollbackDenied => stats.rollback_denied_count += 1,
+        Stop01Reason::NumericRisk => stats.numeric_risk_count += 1,
+        Stop01Reason::GlobalFiniteFallback => stats.global_finite_fallback_count += 1,
+        Stop01Reason::EmptyActiveSet => stats.empty_active_set_count += 1,
+        _ => {}
+    }
+}
