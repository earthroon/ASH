+pub fn summary_from_receipts(receipts: &[Stop01StepReceipt]) -> Stop01Summary {
+    let mut gate = Stop01GateStats::default();
+    let mut execution = Stop01ExecutionStats::default();
+    let mut reasons = Stop01ReasonStats::default();
+    let mut safety = Stop01SafetyStats::default();
+    let mut mode = Stop01Mode::Off.as_str().to_string();
+    let mut salad03b_status_seen = None;
+
+    for receipt in receipts {
+        mode = receipt.mode.as_str().to_string();
+        salad03b_status_seen = receipt.salad03b_status_seen.clone().or(salad03b_status_seen);
+        if receipt.gate.can_execute { gate.can_execute_count += 1; }
+        if !receipt.gate.denied_reasons.is_empty() { gate.denied_count += 1; }
+        if receipt.gate.strict_fail { gate.strict_fail_count += 1; }
+
+        if receipt.execution.executed { execution.executed_count += 1; }
+        if receipt.execution.runtime_stop_executed { execution.runtime_stop_executed_count += 1; }
+        if receipt.execution.eos_bias_stop_executed { execution.eos_bias_stop_executed_count += 1; }
+        if receipt.execution.generation_loop_stop_requested { execution.generation_loop_stop_requested_count += 1; }
+        if receipt.execution.output_tail_truncated { execution.output_tail_truncated_count += 1; }
+
+        count_reason(&mut reasons, receipt.gate.reason);
+
+        if receipt.execution.executed && !receipt.gate.can_execute { safety.stop_without_gate_count += 1; }
+        if receipt.execution.output_tail_truncated { safety.tail_truncate_count += 1; }
+        if receipt.execution.eos_bias_stop_executed { safety.eos_bias_stop_count += 1; }
+        if receipt.execution.executed && matches!(receipt.execution.stop_reason, Stop01Reason::None) { safety.stop_reason_none_executed_count += 1; }
+    }
+
+    let steps_observed = receipts.len();
+    let contract_fail = safety.stop_without_gate_count > 0
+        || safety.tail_truncate_count > 0
+        || safety.eos_bias_stop_count > 0
+        || safety.stop_reason_none_executed_count > 0;
+    let status = if steps_observed == 0 {
+        "STATIC_BAKE_DEFINED_NOT_RUN"
+    } else if contract_fail || gate.strict_fail_count > 0 {
+        "FAIL"
+    } else if gate.denied_count > 0 || execution.executed_count > 0 {
+        "PASS_WITH_WARNINGS"
+    } else {
+        "PASS"
+    }.to_string();
+
+    Stop01Summary {
+        patch_id: STOP01_PATCH_ID.to_string(),
+        input_patch: STOP01_INPUT_PATCH_ID.to_string(),
+        status,
+        mode,
+        controlled_execute: execution.executed_count > 0,
+        default_enable: false,
+        requires_salad03b: env_bool("ASH_STOP01_REQUIRE_SALAD03B", true),
+        salad03b_status_seen,
+        steps_observed,
+        gate,
+        execution,
+        reasons,
+        safety,
+        ready_for_stop02_eos_finalization: steps_observed > 0,
+        ready_for_default_safe_stop: false,
+        reason: if steps_observed == 0 {
+            "static bake only; run controlled stop fixtures before enabling safe stop".to_string()
+        } else if contract_fail {
+            "STOP-01 contract violation detected; safe stop must remain disabled".to_string()
+        } else {
+            "safe stop controlled execute sealed; EOS/output finalization remains separate".to_string()
+        },
+    }
+}
+
+pub fn write_stop01_summary_from_receipt_file() {
+    let summary = summary_from_receipts(&read_receipts(receipt_path()));
+    let path = summary_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(json) = serde_json::to_string_pretty(&summary) {
+        let _ = fs::write(path, format!("{}\n", json));
+    }
+}
