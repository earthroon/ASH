+pub fn input_from_salad03b(mode: Stop01Mode, receipt: &Salad03BStepReceipt) -> Stop01Input {
+    let post_risk = receipt.post_check.post_salad02_risk.clone();
+    let high_persistence_default = if is_high_or_critical(post_risk.as_deref()) || is_high_or_critical(Some(&receipt.input.salad02_risk_stable)) { 3 } else { 0 };
+    Stop01Input {
+        mode,
+        behavior_change_allowed: env_bool("ASH_STOP01_BEHAVIOR_CHANGE_ALLOWED", false),
+        run_id: env_string("ASH_STOP01_RUN_ID", "stop01_sampler03_bridge"),
+        prompt_hash: receipt.prompt_hash.clone(),
+        seed: receipt.seed,
+        step: receipt.step,
+        backend: receipt.backend.clone(),
+        runtime_supports_stop: env_bool("ASH_STOP01_RUNTIME_SUPPORTS_STOP", env_bool("ASH_STOP01_REQUIRE_RUNTIME_STOP_SUPPORT", false)),
+        runtime_supports_eos_bias: env_bool("ASH_STOP01_RUNTIME_SUPPORTS_EOS_BIAS", false),
+        salad02_risk_stable: Some(receipt.input.salad02_risk_stable.clone()),
+        salad02_score: Some(receipt.input.salad02_score),
+        salad03_decision: Some(receipt.input.salad03_decision.clone()),
+        salad03_safe_stop_candidate: receipt.execution.safe_stop_candidate,
+        salad03b_gate_denied: !receipt.gate.denied_reasons.is_empty(),
+        salad03b_resample_success: receipt.execution.replacement.as_ref().map(|r| r.success),
+        salad03b_post_risk: post_risk,
+        salad03b_risk_improved: receipt.post_check.risk_improved,
+        salad03b_risk_worsened: receipt.post_check.risk_worsened,
+        salad03b_safe_stop_recommended: receipt.post_check.safe_stop_recommended,
+        rollback_window_limit_reached: receipt.gate.denied_reasons.iter().any(|r| r == "rollback_window_limit_reached"),
+        numeric_risk: receipt.input.numeric_risk,
+        global_finite_fallback_seen: receipt.input.global_finite_fallback_seen,
+        empty_active_set_seen: env_bool("ASH_STOP01_EMPTY_ACTIVE_SET_SEEN", false),
+        high_risk_persistence_count: env_usize("ASH_STOP01_HIGH_RISK_PERSISTENCE_COUNT", high_persistence_default),
+        safe_stop_already_executed: env_bool("ASH_STOP01_ALREADY_EXECUTED", false),
+    }
+}
