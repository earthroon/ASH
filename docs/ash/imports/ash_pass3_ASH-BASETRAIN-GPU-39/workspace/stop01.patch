+pub fn execute_stop01_synthetic(
+    input: &Stop01Input,
+    gate: &Stop01GateDecision,
+    selected_id: Option<u32>,
+    selected_piece: Option<String>,
+) -> Stop01ExecutionReceipt {
+    if !gate.can_execute {
+        return Stop01ExecutionReceipt {
+            executed: false,
+            runtime_stop_executed: false,
+            eos_bias_stop_executed: false,
+            generation_loop_stop_requested: false,
+            stop_step: None,
+            stop_reason: gate.reason,
+            final_selected_token_id: selected_id,
+            final_piece_preview: selected_piece,
+            output_tail_preserved: true,
+            output_tail_truncated: false,
+            stop_message_code: None,
+            execution_reasons: gate.denied_reasons.clone(),
+            execution_warnings: gate.warning_reasons.clone(),
+        };
+    }
+    Stop01ExecutionReceipt {
+        executed: true,
+        runtime_stop_executed: true,
+        eos_bias_stop_executed: false,
+        generation_loop_stop_requested: true,
+        stop_step: Some(input.step),
+        stop_reason: gate.reason,
+        final_selected_token_id: selected_id,
+        final_piece_preview: selected_piece,
+        output_tail_preserved: true,
+        output_tail_truncated: false,
+        stop_message_code: Some(gate.reason.as_code().to_string()),
+        execution_reasons: vec!["generation_stop_requested".to_string()],
+        execution_warnings: gate.warning_reasons.clone(),
+    }
+}
+
+pub fn execute_stop01<R: Stop01Runtime>(
+    runtime: &mut R,
+    input: &Stop01Input,
+    gate: &Stop01GateDecision,
+) -> Stop01ExecutionReceipt {
+    if !gate.can_execute {
+        return execute_stop01_synthetic(input, gate, None, None);
+    }
+    let _pre = runtime.stop01_state_fingerprint();
+    let result = runtime.request_generation_stop(gate.reason);
+    let post = runtime.stop01_state_fingerprint();
+    let ok = result.is_ok() && post.generation_stopped;
+    let mut receipt = execute_stop01_synthetic(input, gate, None, None);
+    receipt.executed = ok;
+    receipt.runtime_stop_executed = ok;
+    receipt.generation_loop_stop_requested = ok;
+    if let Err(err) = result {
+        receipt.execution_warnings.push(format!("runtime_stop_error:{err}"));
+    }
+    receipt
+}
