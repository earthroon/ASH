+pub fn decide_stop01_gate(input: &Stop01Input) -> Stop01GateDecision {
+    let mut denied_reasons = Vec::new();
+    let mut warning_reasons = Vec::new();
+    let mut execute_reasons = Vec::new();
+    let mut strict_fail = false;
+
+    if matches!(input.mode, Stop01Mode::Off) {
+        denied_reasons.push("mode_off".to_string());
+    }
+    if input.safe_stop_already_executed {
+        denied_reasons.push("safe_stop_already_executed".to_string());
+    }
+
+    let (mut action, mut reason) = stop_need_from_input(input);
+
+    if matches!(input.mode, Stop01Mode::PlanOnly) {
+        if matches!(action, Stop01Action::ExecuteRuntimeStop) {
+            action = Stop01Action::PlanSafeStop;
+            execute_reasons.push("plan_only_safe_stop_candidate".to_string());
+        }
+        return Stop01GateDecision {
+            can_execute: false,
+            action,
+            reason,
+            strict_fail: false,
+            denied_reasons,
+            warning_reasons,
+            execute_reasons,
+        };
+    }
+
+    if !input.behavior_change_allowed {
+        denied_reasons.push("behavior_change_not_allowed".to_string());
+    }
+    if !input.runtime_supports_stop {
+        denied_reasons.push("runtime_stop_unsupported".to_string());
+    }
+    if matches!(reason, Stop01Reason::None) {
+        action = Stop01Action::NoAction;
+        denied_reasons.push("no_stop_trigger".to_string());
+    }
+
+    if input.runtime_supports_eos_bias && env_bool("ASH_STOP01_EOS_BIAS_EXECUTE", false) {
+        warning_reasons.push("eos_bias_supported_but_stop01_keeps_eos_bias_disabled_by_contract".to_string());
+    }
+    if env_bool("ASH_STOP01_TRUNCATE_OUTPUT_TAIL", false) {
+        denied_reasons.push("output_tail_truncate_forbidden".to_string());
+        if matches!(input.mode, Stop01Mode::StrictControlledExecute) {
+            strict_fail = true;
+        }
+    }
+    if matches!(input.mode, Stop01Mode::StrictControlledExecute)
+        && (input.numeric_risk || input.global_finite_fallback_seen || is_critical(input.salad03b_post_risk.as_deref()))
+    {
+        execute_reasons.push("strict_safety_stop_triggered".to_string());
+    }
+    if matches!(input.mode, Stop01Mode::StrictControlledExecute) && denied_reasons.iter().any(|r| r != "no_stop_trigger") {
+        strict_fail = true;
+    }
+
+    let can_execute = denied_reasons.is_empty()
+        && input.mode.can_mutate()
+        && matches!(action, Stop01Action::ExecuteRuntimeStop);
+    if can_execute {
+        execute_reasons.push("controlled_execute_enabled".to_string());
+        execute_reasons.push(reason.as_code().to_string());
+        execute_reasons.push("runtime_stop_supported".to_string());
+    } else if !denied_reasons.is_empty() && matches!(action, Stop01Action::ExecuteRuntimeStop) {
+        action = if strict_fail { Stop01Action::StrictFail } else { Stop01Action::Denied };
+    }
+
+    Stop01GateDecision {
+        can_execute,
+        action,
+        reason,
+        strict_fail,
+        denied_reasons,
+        warning_reasons,
+        execute_reasons,
+    }
+}
+
+fn stop_need_from_input(input: &Stop01Input) -> (Stop01Action, Stop01Reason) {
+    if input.numeric_risk {
+        return (Stop01Action::ExecuteRuntimeStop, Stop01Reason::NumericRisk);
+    }
+    if input.global_finite_fallback_seen {
+        return (Stop01Action::ExecuteRuntimeStop, Stop01Reason::GlobalFiniteFallback);
+    }
+    if input.empty_active_set_seen {
+        return (Stop01Action::ExecuteRuntimeStop, Stop01Reason::EmptyActiveSet);
+    }
+    if is_critical(input.salad03b_post_risk.as_deref()) {
+        return (Stop01Action::ExecuteRuntimeStop, Stop01Reason::PostResampleCritical);
+    }
+    if input.salad03b_resample_success == Some(false) && input.salad03b_safe_stop_recommended {
+        return (Stop01Action::ExecuteRuntimeStop, Stop01Reason::ResampleFailed);
+    }
+    if input.rollback_window_limit_reached {
+        return (Stop01Action::ExecuteRuntimeStop, Stop01Reason::RollbackWindowLimitReached);
+    }
+    if input.salad03b_gate_denied && input.salad03b_safe_stop_recommended {
+        return (Stop01Action::ExecuteRuntimeStop, Stop01Reason::RollbackDenied);
+    }
+    if input.salad03b_post_risk.as_deref().map(|r| matches!(r, "High" | "HIGH")).unwrap_or(false)
+        && input.salad03b_risk_improved == Some(false)
+    {
+        return (Stop01Action::ExecuteRuntimeStop, Stop01Reason::PostResampleHighUnimproved);
+    }
+    if is_critical(input.salad02_risk_stable.as_deref()) && !input.salad03_safe_stop_candidate {
+        return (Stop01Action::ExecuteRuntimeStop, Stop01Reason::SaladCritical);
+    }
+    if input.high_risk_persistence_count >= env_usize("ASH_STOP01_HIGH_RISK_PERSISTENCE_WINDOW", 3)
+        && is_high_or_critical(input.salad02_risk_stable.as_deref())
+    {
+        return (Stop01Action::ExecuteRuntimeStop, Stop01Reason::SaladHighPersistent);
+    }
+    (Stop01Action::NoAction, Stop01Reason::None)
+}
