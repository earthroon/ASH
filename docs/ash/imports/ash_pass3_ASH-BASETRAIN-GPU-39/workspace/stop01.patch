+            Self::SaladHighPersistent => "SAFE_STOP_SALAD_HIGH_PERSISTENT",
+            Self::PostResampleCritical => "SAFE_STOP_POST_RESAMPLE_CRITICAL",
+            Self::PostResampleHighUnimproved => "SAFE_STOP_POST_RESAMPLE_HIGH_UNIMPROVED",
+            Self::ResampleFailed => "SAFE_STOP_RESAMPLE_FAILED",
