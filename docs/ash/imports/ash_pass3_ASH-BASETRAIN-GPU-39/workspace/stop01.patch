+pub fn receipt_from_salad03b(mode: Stop01Mode, source: &Salad03BStepReceipt) -> Stop01StepReceipt {
+    let input = input_from_salad03b(mode, source);
+    let gate = decide_stop01_gate(&input);
+    let execution = execute_stop01_synthetic(&input, &gate, source.selected_id_after.or(source.selected_id_before), source.selected_piece_after.clone().or(source.selected_piece_before.clone()));
+    let pre_fingerprint = Some(state_fingerprint(input.step, source.input.token_ledger_len, false, None));
+    let post_fingerprint = Some(state_fingerprint(input.step, source.input.token_ledger_len, execution.generation_loop_stop_requested, if execution.executed { Some(gate.reason) } else { None }));
+    Stop01StepReceipt {
+        patch_id: STOP01_PATCH_ID.to_string(),
+        input_patch: STOP01_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: input.run_id.clone(),
+        prompt_hash: input.prompt_hash.clone(),
+        seed: input.seed,
+        step: input.step,
+        backend: input.backend.clone(),
+        sampler_ssot: STOP01_SSOT.to_string(),
+        mode,
+        behavior_change: execution.executed,
+        controlled_execute: mode.can_mutate(),
+        salad03b_status_seen: Some("DERIVED_IN_MEMORY_FROM_SALAD03B_RECEIPT".to_string()),
+        salad03_status_seen: source.salad03_status_seen.clone(),
+        salad02_status_seen: source.salad02_status_seen.clone(),
+        decode03d_status_seen: source.decode03d_status_seen.clone(),
+        kv_rollback01_status_seen: source.kv_rollback01_status_seen.clone(),
+        input,
+        gate,
+        execution,
+        pre_fingerprint,
+        post_fingerprint,
+        selected_id_current: source.selected_id_after.or(source.selected_id_before),
+        selected_piece_current: source.selected_piece_after.clone().or(source.selected_piece_before.clone()),
+    }
+}
