+fn is_hardblock(action: Option<u32>) -> bool { action == Some(2) }
+
+fn float_match(cpu: Option<f32>, gpu: Option<f32>, tol: f32) -> Option<bool> {
+    match (cpu, gpu) {
+        (Some(a), Some(b)) => Some((a - b).abs() <= tol),
+        (None, None) => None,
+        _ => Some(false),
+    }
+}
+
+fn status_is_pass(status: &str) -> bool { status == "PASS" }
+fn status_is_warn(status: &str) -> bool { status.starts_with("WARN_") }
+fn status_is_fail(status: &str) -> bool { status.starts_with("FAIL_") }
+fn status_is_partial(status: &str) -> bool { status.starts_with("PARTIAL_") }
+
+pub fn transition_validation_from_sampler_receipt(
+    mode: TransitionValidationMode,
+    receipt: &SamplerParityReceipt,
+) -> Decode02bTransitionValidationReceipt {
+    let candidate_trace_version_ok = receipt.gpu.candidate_trace_version >= 3;
+    let hint_trace_available = candidate_trace_version_ok
+        && receipt.gpu.selected_transition_action_code.is_some()
+        && receipt.gpu.selected_transition_reason_mask.is_some();
+
+    let action_match = match (receipt.cpu.selected_transition_action_code, receipt.gpu.selected_transition_action_code) {
+        (Some(c), Some(g)) => Some(c == g),
+        (None, None) => None,
+        _ => Some(false),
+    };
+    let reason_match = match (receipt.cpu.selected_transition_reason_mask, receipt.gpu.selected_transition_reason_mask) {
+        (Some(c), Some(g)) => Some(c == g),
+        (None, None) => None,
+        _ => Some(false),
+    };
+    let hardblock_match = match (receipt.cpu.selected_transition_action_code, receipt.gpu.selected_transition_action_code) {
+        (Some(_), Some(_)) => Some(is_hardblock(receipt.cpu.selected_transition_action_code) == is_hardblock(receipt.gpu.selected_transition_action_code)),
+        _ => None,
+    };
+    let risk_match = float_match(receipt.cpu.selected_transition_risk, receipt.gpu.selected_transition_risk, 1e-4);
+    let penalty_match = float_match(receipt.cpu.selected_transition_penalty, receipt.gpu.selected_transition_penalty, 1e-4);
+
+    let probe_mode = receipt.cpu.transition_guard_probe_only || receipt.gpu.transition_guard_probe_only;
+    let probe_integrity = TransitionProbeIntegrity {
+        probe_mode,
+        weighted_logit_before: None,
+        weighted_logit_after: None,
+        candidate_mask_before: None,
+        candidate_mask_after: None,
+        sampling_state_mutated: None,
+        status: if probe_mode { "PARTIAL_PROBE_INTEGRITY_COUNTER_NOT_AVAILABLE".to_string() } else { "NOT_PROBE_MODE".to_string() },
+    };
+
+    let (status, promotion_blocking) = if !candidate_trace_version_ok {
+        ("FAIL_CANDIDATE_TRACE_VERSION_NOT_V3".to_string(), true)
+    } else if !hint_trace_available {
+        ("FAIL_HINT_TABLE_MISSING".to_string(), true)
+    } else if action_match == Some(false) {
+        ("FAIL_ACTION_MISMATCH".to_string(), true)
+    } else if reason_match == Some(false) {
+        ("FAIL_REASON_MISMATCH".to_string(), true)
+    } else if hardblock_match == Some(false) {
+        ("FAIL_HARDBLOCK_MISMATCH".to_string(), true)
+    } else if probe_integrity.status.starts_with("PARTIAL_") {
+        (probe_integrity.status.clone(), true)
+    } else if risk_match == Some(false) || penalty_match == Some(false) {
+        ("WARN_RISK_ONLY".to_string(), false)
+    } else {
+        ("PASS".to_string(), false)
+    };
+
+    Decode02bTransitionValidationReceipt {
+        patch_id: "16AI-QW-38G-R6A-DECODE-02B".to_string(),
+        input_patch: receipt.patch_id.clone(),
+        step: receipt.step,
+        mode: mode.as_str().to_string(),
+        candidate_trace_version: receipt.gpu.candidate_trace_version,
+        cpu_transition: TransitionRuntimeSide {
+            selected_id: receipt.cpu.selected_id,
+            risk: receipt.cpu.selected_transition_risk,
+            penalty: receipt.cpu.selected_transition_penalty,
+            action_code: receipt.cpu.selected_transition_action_code,
+            reason_mask: receipt.cpu.selected_transition_reason_mask,
+        },
+        gpu_transition: TransitionRuntimeSide {
+            selected_id: receipt.gpu.selected_id,
+            risk: receipt.gpu.selected_transition_risk,
+            penalty: receipt.gpu.selected_transition_penalty,
+            action_code: receipt.gpu.selected_transition_action_code,
+            reason_mask: receipt.gpu.selected_transition_reason_mask,
+        },
+        probe_integrity,
+        parity: TransitionParityStatus {
+            action_match,
+            reason_match,
+            hardblock_match,
+            risk_match,
+            penalty_match,
+            hint_trace_available,
+            candidate_trace_version_ok,
+            status,
+            promotion_blocking,
+        },
+    }
+}
+
+pub fn append_transition_validation_receipt(receipt: &SamplerParityReceipt) {
+    let mode = TransitionValidationMode::from_env();
+    if !mode.enabled() { return; }
+    let validation = transition_validation_from_sampler_receipt(mode, receipt);
+    let path = transition_validation_receipt_path();
+    if let Some(parent) = path.parent() { let _ = fs::create_dir_all(parent); }
+    if let Ok(line) = serde_json::to_string(&validation) {
+        use std::io::Write;
+        if let Ok(mut file) = fs::OpenOptions::new().create(true).append(true).open(&path) {
+            let _ = writeln!(file, "{}", line);
+        }
+    }
+    write_transition_validation_summary(mode);
+}
+
+pub fn write_transition_validation_summary(mode: TransitionValidationMode) {
+    let receipt_path = transition_validation_receipt_path();
+    let summary_path = transition_validation_summary_path();
+    let mut checked = 0usize;
+    let mut pass = 0usize;
+    let mut warn = 0usize;
+    let mut fail = 0usize;
+    let mut partial = 0usize;
+    let mut blocked = false;
+
+    if let Ok(raw) = fs::read_to_string(&receipt_path) {
+        for line in raw.lines().filter(|line| !line.trim().is_empty()) {
+            if let Ok(item) = serde_json::from_str::<Decode02bTransitionValidationReceipt>(line) {
+                checked += 1;
+                if item.parity.promotion_blocking { blocked = true; }
+                let status = item.parity.status.as_str();
+                if status_is_pass(status) { pass += 1; }
+                else if status_is_warn(status) { warn += 1; }
+                else if status_is_partial(status) { partial += 1; blocked = true; }
+                else if status_is_fail(status) { fail += 1; blocked = true; }
+            }
+        }
+    }
+
+    let promotion_status = if checked == 0 {
+        "NOT_RUN"
+    } else if blocked || fail > 0 || partial > 0 {
+        "TRANSITION_ON_BLOCKED"
+    } else {
+        "TRANSITION_ON_CANDIDATE_READY"
+    };
+
+    let summary = Decode02bTransitionValidationSummary {
+        patch_id: "16AI-QW-38G-R6A-DECODE-02B".to_string(),
+        status: "TRANSITION_GUARD_RUNTIME_PROBE_AND_PROBE_TO_ON_GATE_DEFINED".to_string(),
+        input_patch: "16AI-QW-38G-R6A-DECODE-02A".to_string(),
+        transition_guard_ssot: "model_core::decode_transition_guard".to_string(),
+        candidate_piece_hint_ssot: "model_core::decode_candidate_piece_hints::CandidatePieceHintTable".to_string(),
+        default_mode: "off".to_string(),
+        validation_mode_default: "off".to_string(),
+        promotion_status: promotion_status.to_string(),
+        checked_steps: checked,
+        pass_steps: pass,
+        warn_steps: warn,
+        fail_steps: fail,
+        partial_steps: partial,
+        probe_mode_mutation_allowed: false,
+        receipt: receipt_path.to_string_lossy().to_string(),
+        non_scope: vec![
+            "transition_rule_redesign".to_string(),
+            "dynamic_context_qwave".to_string(),
+            "minp_formula_change".to_string(),
+            "semantic_prior_default_enable".to_string(),
+            "lora_training".to_string(),
+        ],
+    };
+
+    if let Some(parent) = summary_path.parent() { let _ = fs::create_dir_all(parent); }
+    if let Ok(text) = serde_json::to_string_pretty(&summary) { let _ = fs::write(summary_path, text); }
+}
