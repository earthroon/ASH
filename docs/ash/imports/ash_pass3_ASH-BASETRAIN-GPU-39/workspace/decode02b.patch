+pub fn transition_action_code(action: TransitionAction) -> u32 {
+    match action {
+        TransitionAction::Allow => 0,
+        TransitionAction::Penalize => 1,
+        TransitionAction::HardBlock => 2,
+        TransitionAction::ProbeOnly => 3,
+        TransitionAction::Unavailable => 4,
+    }
+}
+
+pub fn transition_reason_bit(reason: TransitionReason) -> u32 {
+    match reason {
+        TransitionReason::PadToken => 1 << 0,
+        TransitionReason::ControlToken => 1 << 1,
+        TransitionReason::EosBeforeMinNewTokens => 1 << 2,
+        TransitionReason::GenericContinuationImmediateEos => 1 << 3,
+        TransitionReason::InvalidByteToken => 1 << 4,
+        TransitionReason::ByteTextBoundaryRisk => 1 << 5,
+        TransitionReason::MojibakeSuspected => 1 << 6,
+        TransitionReason::DoubleParticleLike => 1 << 7,
+        TransitionReason::DoubleSentenceEndingLike => 1 << 8,
+        TransitionReason::RepeatedPunctuation => 1 << 9,
+        TransitionReason::UnknownToken => 1 << 10,
+        TransitionReason::RecentLoopRisk => 1 << 11,
+        TransitionReason::PieceContextUnavailable => 1 << 12,
+        TransitionReason::WhitespaceOnlyToken => 1 << 13,
+        TransitionReason::UnbalancedOpenCloseSymbol => 1 << 14,
+        TransitionReason::None => 0,
+    }
+}
+
+pub fn transition_reasons_mask(reasons: &[TransitionReason]) -> u32 {
+    reasons.iter().fold(0u32, |acc, reason| acc | transition_reason_bit(*reason))
+}
+
+pub fn transition_reason_string_mask(reasons: &[String]) -> u32 {
+    reasons.iter().fold(0u32, |acc, reason| {
+        let bit = match reason.as_str() {
+            "pad_token" | "PadToken" => 1 << 0,
+            "control_token" | "ControlToken" => 1 << 1,
+            "eos_before_min_new_tokens" | "EosBeforeMinNewTokens" => 1 << 2,
+            "generic_continuation_immediate_eos" | "GenericContinuationImmediateEos" => 1 << 3,
+            "invalid_byte_token" | "InvalidByteToken" => 1 << 4,
+            "byte_text_boundary_risk" | "ByteTextBoundaryRisk" => 1 << 5,
+            "mojibake_suspected" | "MojibakeSuspected" => 1 << 6,
+            "double_particle_like" | "DoubleParticleLike" => 1 << 7,
+            "double_sentence_ending_like" | "DoubleSentenceEndingLike" => 1 << 8,
+            "repeated_punctuation" | "RepeatedPunctuation" => 1 << 9,
+            "unknown_token" | "UnknownToken" => 1 << 10,
+            "recent_loop_risk" | "RecentLoopRisk" => 1 << 11,
+            "piece_context_unavailable" | "PieceContextUnavailable" => 1 << 12,
+            "whitespace_only_token" | "WhitespaceOnlyToken" => 1 << 13,
+            "unbalanced_open_close_symbol" | "UnbalancedOpenCloseSymbol" => 1 << 14,
+            _ => 0,
+        };
+        acc | bit
+    })
+}
