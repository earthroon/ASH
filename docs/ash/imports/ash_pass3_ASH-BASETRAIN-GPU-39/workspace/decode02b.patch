+#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
+pub enum TransitionValidationMode {
+    Off,
+    ValidateProbe,
+    PromoteOnCandidate,
+}
+
+impl TransitionValidationMode {
+    pub fn from_env() -> Self {
+        let enabled = env::var("ASH_DECODE_TRANSITION_VALIDATE")
+            .ok()
+            .map(|v| matches!(v.trim().to_ascii_lowercase().as_str(), "1" | "true" | "yes" | "on" | "validate"))
+            .unwrap_or(false);
+        if !enabled {
+            return Self::Off;
+        }
+        let promote = env::var("ASH_DECODE_TRANSITION_PROMOTE_ON")
+            .ok()
+            .map(|v| matches!(v.trim().to_ascii_lowercase().as_str(), "1" | "true" | "yes" | "on" | "promote"))
+            .unwrap_or(false);
+        if promote { Self::PromoteOnCandidate } else { Self::ValidateProbe }
+    }
+
+    pub fn as_str(&self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::ValidateProbe => "ValidateProbe",
+            Self::PromoteOnCandidate => "PromoteOnCandidate",
+        }
+    }
+
+    pub fn enabled(&self) -> bool { !matches!(self, Self::Off) }
+}
+
