+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+pub enum Decode03FMode {
+    Off,
+    AnalyzeOnly,
+    CandidateOnly,
+    StrictCandidateGate,
+}
+
+impl Decode03FMode {
+    pub fn from_env() -> Self {
+        let value = env::var("ASH_DECODE03F_MODE")
+            .unwrap_or_else(|_| "analyze_only".to_string())
+            .trim()
+            .to_ascii_lowercase();
+        match value.as_str() {
+            "off" | "false" | "0" | "disabled" => Self::Off,
+            "candidate" | "candidate_only" | "candidates" => Self::CandidateOnly,
+            "strict" | "strict_candidate_gate" => Self::StrictCandidateGate,
+            _ => Self::AnalyzeOnly,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::AnalyzeOnly => "AnalyzeOnly",
+            Self::CandidateOnly => "CandidateOnly",
+            Self::StrictCandidateGate => "StrictCandidateGate",
+        }
+    }
+
+    pub fn enabled(self) -> bool { !matches!(self, Self::Off) }
+    pub fn produces_candidate(self) -> bool { matches!(self, Self::CandidateOnly | Self::StrictCandidateGate) }
+}
