+pub fn clamp_guard_param_set(mut params: Decode03FGuardParamSet) -> Decode03FGuardParamSet {
+    fn clamp_loop(p: &mut Decode03FLoopParamSet) {
+        p.morph_penalty_weight = clamp_f32(p.morph_penalty_weight, 0.0, 0.50);
+        p.min_p_floor = clamp_f32(p.min_p_floor, 0.0, 0.20);
+        p.top_p_ceiling = clamp_f32(p.top_p_ceiling, 0.60, 0.98);
+        p.no_repeat_ngram = p.no_repeat_ngram.map(|n| clamp_usize(n, 0, 6));
+    }
+    clamp_loop(&mut params.josa_loop);
+    clamp_loop(&mut params.eomi_loop);
+    clamp_loop(&mut params.jamo_leak);
+    clamp_loop(&mut params.byte_jamo_leak);
+    clamp_loop(&mut params.syllable_fragment_loop);
+    clamp_loop(&mut params.eojeol_boundary_collapse);
+    clamp_loop(&mut params.punctuation_glue_loop);
+    clamp_loop(&mut params.mixed_morph_loop);
+    params.panic_morph_score_threshold = clamp_f32(params.panic_morph_score_threshold, 0.60, 0.95);
+    params.panic_salad_score_threshold = clamp_f32(params.panic_salad_score_threshold, 0.60, 0.95);
+    params.guard_escalation_pci_threshold = clamp_f32(params.guard_escalation_pci_threshold, 0.10, 0.60);
+    params.active_set_protection_min = clamp_usize(params.active_set_protection_min, 2, 12);
+    params
+}
