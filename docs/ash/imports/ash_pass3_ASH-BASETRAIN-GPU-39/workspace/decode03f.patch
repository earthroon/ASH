+fn clamp_f32(value: f32, lo: f32, hi: f32) -> f32 {
+    if value.is_finite() { value.max(lo).min(hi) } else { lo }
+}
+
+fn clamp_usize(value: usize, lo: usize, hi: usize) -> usize { value.max(lo).min(hi) }
