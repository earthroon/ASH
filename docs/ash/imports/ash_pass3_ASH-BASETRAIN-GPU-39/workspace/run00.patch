+        binding_layout_status: Run00CheckStatus::NotRun,
+        status: Run00CheckStatus::NotRun,
+        reason: Some("NO_WGPU_VALIDATOR_OR_RUNTIME".to_string()),
+    };
+
+    (check, test, wgsl)
+}
