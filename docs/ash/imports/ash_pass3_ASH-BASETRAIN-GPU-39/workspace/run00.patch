+pub fn run00_not_run_command_receipts() -> (Run00CargoCheckReceipt, Run00CargoTestReceipt, Run00WgslCompileReceipt) {
+    let reason = "RUN00_BAKE_ENVIRONMENT_HAS_NO_CARGO_OR_WGSL_RUNTIME";
+    let mut crates = BTreeMap::new();
+    for name in ["model_core", "runtime", "burn_webgpu_backend", "orchestrator_local"] {
+        crates.insert(name.to_string(), Run00CommandReceipt::not_run(format!("cargo check -p {name}"), reason));
+    }
+    let check = Run00CargoCheckReceipt {
+        patch_id: RUN00_PATCH_ID.to_string(),
+        workspace: Run00CommandReceipt::not_run("cargo check --workspace", reason),
+        crates,
+        status: Run00CheckStatus::NotRun,
+    };
+
+    let mut tests = BTreeMap::new();
+    for (name, cmd) in [
+        ("model_core_decode", "cargo test -p model_core decode"),
+        ("model_core_sampler", "cargo test -p model_core sampler"),
+        ("model_core_minp", "cargo test -p model_core minp"),
+        ("model_core_transition", "cargo test -p model_core transition"),
+        ("burn_webgpu_backend_gpu_sampling", "cargo test -p burn_webgpu_backend gpu_sampling"),
+    ] {
+        tests.insert(name.to_string(), Run00CommandReceipt::not_run(cmd, reason));
+    }
+    let test = Run00CargoTestReceipt {
+        patch_id: RUN00_PATCH_ID.to_string(),
+        tests,
+        status: Run00CheckStatus::NotRun,
+    };
+
+    let wgsl = Run00WgslCompileReceipt {
+        patch_id: RUN00_PATCH_ID.to_string(),
