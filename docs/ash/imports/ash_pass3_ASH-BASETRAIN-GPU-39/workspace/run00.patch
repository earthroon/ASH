+        sampler_strict_ready: sampler04_status == "STRICT_CANDIDATE_READY" && build_ready && runtime_ready,
+        transition_on_candidate_ready: decode02d_status == "TRANSITION_ON_CANDIDATE_READY" && build_ready && runtime_ready,
+        semantic_prior_enable_ready: minp_c2a_status == "PASS" && sampler04_status == "STRICT_CANDIDATE_READY" && build_ready,
+    }
+}
