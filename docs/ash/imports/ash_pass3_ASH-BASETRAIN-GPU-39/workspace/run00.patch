+#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
+pub enum Run00CheckStatus {
+    Pass,
+    Fail,
+    Blocked,
+    NotRun,
+}
+
+impl Run00CheckStatus {
+    pub fn as_str(&self) -> &'static str {
+        match self {
+            Self::Pass => "PASS",
+            Self::Fail => "FAIL",
+            Self::Blocked => "BLOCKED",
+            Self::NotRun => "NOT_RUN",
+        }
+    }
+
+    pub fn is_pass(&self) -> bool {
+        matches!(self, Self::Pass)
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct Run00CommandReceipt {
+    pub command: String,
+    pub status: Run00CheckStatus,
+    pub exit_code: Option<i32>,
+    pub stdout_tail: Vec<String>,
+    pub stderr_tail: Vec<String>,
+    pub reason: Option<String>,
+}
+
+impl Run00CommandReceipt {
+    pub fn not_run(command: impl Into<String>, reason: impl Into<String>) -> Self {
+        Self {
+            command: command.into(),
+            status: Run00CheckStatus::NotRun,
+            exit_code: None,
+            stdout_tail: Vec::new(),
+            stderr_tail: Vec::new(),
+            reason: Some(reason.into()),
+        }
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct Run00CargoCheckReceipt {
+    pub patch_id: String,
+    pub workspace: Run00CommandReceipt,
+    pub crates: BTreeMap<String, Run00CommandReceipt>,
+    pub status: Run00CheckStatus,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct Run00CargoTestReceipt {
+    pub patch_id: String,
+    pub tests: BTreeMap<String, Run00CommandReceipt>,
+    pub status: Run00CheckStatus,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
