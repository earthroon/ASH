+    pub default_modes_changed: bool,
+    pub blocking_reasons: Vec<String>,
+    pub non_scope: Vec<String>,
+}
+
+pub fn run00_evaluate_promotion_gates(
+    sampler04_status: &str,
+    decode02d_status: &str,
+    minp_c2a_status: &str,
+    cargo_check: Run00CheckStatus,
