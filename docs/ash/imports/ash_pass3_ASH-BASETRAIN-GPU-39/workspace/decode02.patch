@@ -0,0 +1,404 @@
+use serde::{Deserialize, Serialize};
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct TransitionGuardConfig {
+    pub enabled: bool,
+    pub probe_only: bool,
+    pub recent_window: usize,
+    pub soft_penalty_scale: f32,
+    pub max_soft_penalty: f32,
+    pub hard_block_control_tokens: bool,
+    pub hard_block_pad_token: bool,
+    pub hard_block_mojibake_tokens: bool,
+    pub hard_block_invalid_byte_tokens: bool,
+    pub penalize_generic_continuation_eos: bool,
+    pub penalize_double_particle_like: bool,
+    pub penalize_repeated_punctuation: bool,
+    pub penalize_byte_text_boundary: bool,
+    pub min_new_tokens_for_eos: usize,
+}
+
+impl Default for TransitionGuardConfig {
+    fn default() -> Self {
+        Self {
+            enabled: false,
+            probe_only: true,
+            recent_window: 8,
+            soft_penalty_scale: 1.0,
+            max_soft_penalty: 2.0,
+            hard_block_control_tokens: true,
+            hard_block_pad_token: true,
+            hard_block_mojibake_tokens: true,
+            hard_block_invalid_byte_tokens: true,
+            penalize_generic_continuation_eos: true,
+            penalize_double_particle_like: true,
+            penalize_repeated_punctuation: true,
+            penalize_byte_text_boundary: true,
+            min_new_tokens_for_eos: 8,
+        }
+    }
+}
+
+impl TransitionGuardConfig {
+    pub fn sanitized(mut self) -> Self {
+        if self.recent_window == 0 { self.recent_window = 8; }
+        if !self.soft_penalty_scale.is_finite() || self.soft_penalty_scale < 0.0 { self.soft_penalty_scale = 1.0; }
+        if !self.max_soft_penalty.is_finite() || self.max_soft_penalty < 0.0 { self.max_soft_penalty = 2.0; }
+        self.max_soft_penalty = self.max_soft_penalty.min(8.0);
+        self
+    }
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
+pub enum TransitionAction {
+    Allow,
+    Penalize,
+    HardBlock,
+    ProbeOnly,
+    Unavailable,
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
+pub enum TransitionReason {
+    None,
+    PieceContextUnavailable,
+    PadToken,
+    ControlToken,
+    EosBeforeMinNewTokens,
+    GenericContinuationImmediateEos,
+    InvalidByteToken,
+    ByteTextBoundaryRisk,
+    MojibakeSuspected,
+    DoubleParticleLike,
+    DoubleSentenceEndingLike,
+    RepeatedPunctuation,
+    UnbalancedOpenCloseSymbol,
+    WhitespaceOnlyToken,
+    UnknownToken,
+    RecentLoopRisk,
+}
+
+impl TransitionReason {
+    pub fn as_str(&self) -> &'static str {
+        match self {
+            Self::None => "none",
+            Self::PieceContextUnavailable => "piece_context_unavailable",
+            Self::PadToken => "pad_token",
+            Self::ControlToken => "control_token",
+            Self::EosBeforeMinNewTokens => "eos_before_min_new_tokens",
+            Self::GenericContinuationImmediateEos => "generic_continuation_immediate_eos",
+            Self::InvalidByteToken => "invalid_byte_token",
+            Self::ByteTextBoundaryRisk => "byte_text_boundary_risk",
+            Self::MojibakeSuspected => "mojibake_suspected",
+            Self::DoubleParticleLike => "double_particle_like",
+            Self::DoubleSentenceEndingLike => "double_sentence_ending_like",
+            Self::RepeatedPunctuation => "repeated_punctuation",
+            Self::UnbalancedOpenCloseSymbol => "unbalanced_open_close_symbol",
+            Self::WhitespaceOnlyToken => "whitespace_only_token",
+            Self::UnknownToken => "unknown_token",
+            Self::RecentLoopRisk => "recent_loop_risk",
+        }
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct TransitionDecision {
+    pub risk: f32,
+    pub penalty: f32,
+    pub action: TransitionAction,
+    pub reasons: Vec<TransitionReason>,
+}
+
+impl Default for TransitionDecision {
+    fn default() -> Self {
+        Self { risk: 0.0, penalty: 0.0, action: TransitionAction::Allow, reasons: vec![TransitionReason::None] }
+    }
+}
+
+impl TransitionDecision {
+    pub fn unavailable() -> Self {
+        Self { risk: 0.0, penalty: 0.0, action: TransitionAction::Unavailable, reasons: vec![TransitionReason::PieceContextUnavailable] }
+    }
+
+    pub fn reason_strings(&self) -> Vec<String> {
+        self.reasons.iter().map(|r| r.as_str().to_string()).collect()
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, Default)]
+pub struct TransitionRuntimeContext {
+    pub step: usize,
+    pub prev_token_id: Option<u32>,
+    pub prev_piece: Option<String>,
+    pub prev_text: Option<String>,
+    pub recent_token_ids: Vec<u32>,
+    pub recent_token_pieces: Vec<String>,
+}
+
+impl TransitionRuntimeContext {
+    pub fn from_recent_ids(step: usize, recent_token_ids: Vec<u32>, recent_window: usize) -> Self {
+        let prev_token_id = recent_token_ids.last().copied();
+        let start = recent_token_ids.len().saturating_sub(recent_window.max(1));
+        Self {
+            step,
+            prev_token_id,
+            prev_piece: None,
+            prev_text: None,
+            recent_token_ids: recent_token_ids[start..].to_vec(),
+            recent_token_pieces: Vec::new(),
+        }
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, Default)]
+pub struct TransitionContext {
+    pub step: usize,
+    pub prev_token_id: Option<u32>,
+    pub prev_piece: Option<String>,
+    pub prev_text: Option<String>,
+    pub recent_token_ids: Vec<u32>,
+    pub recent_token_pieces: Vec<String>,
+    pub eos_token_id: Option<u32>,
+    pub pad_token_id: Option<u32>,
+    pub min_new_tokens: usize,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, Default)]
+pub struct CandidateTokenView {
+    pub token_id: u32,
+    pub piece: Option<String>,
+    pub text: Option<String>,
+    pub is_eos: bool,
+    pub is_pad: bool,
+    pub is_control: bool,
+    pub is_byte: bool,
+    pub is_unknown: bool,
+    pub mojibake_suspected: bool,
+}
+
+pub fn piece_for_known_special(token_id: u32, eos_token_id: Option<u32>, pad_token_id: Option<u32>) -> Option<String> {
+    if pad_token_id == Some(token_id) { return Some("<pad>".to_string()); }
+    if eos_token_id == Some(token_id) { return Some("<eos>".to_string()); }
+    None
+}
+
+fn is_generic_continuation(text_or_piece: &str) -> bool {
+    let s = text_or_piece.trim().trim_start_matches('▁');
+    matches!(s, "이어가고" | "그리고" | "하지만" | "그러나" | "때문에" | "즉" | "그래서" | "따라서" | "그러므로" | "또한")
+}
+
+fn is_particle_like(s: &str) -> bool {
+    let s = s.trim().trim_start_matches('▁');
+    matches!(s, "은" | "는" | "이" | "가" | "을" | "를" | "에" | "에서" | "으로" | "로" | "와" | "과" | "도" | "만" | "의")
+}
+
+fn is_sentence_ending_like(s: &str) -> bool {
+    let s = s.trim().trim_start_matches('▁');
+    matches!(s, "다" | "요" | "죠" | "까" | "네" | "습니다" | "합니다" | "했다" | "한다")
+}
+
+fn is_punctuation_repeat_piece(s: &str) -> bool {
+    let t = s.trim();
+    matches!(t, "!" | "?" | "." | "," | "。" | "…")
+}
+
+fn is_korean_emotional_repeat_piece(s: &str) -> bool {
+    let t = s.trim();
+    matches!(t, "ㅋ" | "ㅠ" | "ㅜ" | ";")
+}
+
+fn looks_like_byte_piece(s: &str) -> bool {
+    s.starts_with("<byte:") || s.starts_with("<0x")
+}
+
+fn looks_like_control_piece(s: &str) -> bool {
+    matches!(s, "<pad>" | "<bos>" | "<eos>" | "<unk>" | "<s>" | "</s>")
+        || s.starts_with("<glossary:")
+        || s.starts_with("<task:")
+        || s.starts_with("<lang:")
+        || s.starts_with("<qwave:")
+        || s.starts_with("<delta_k:")
+}
+
+pub fn mojibake_suspected(piece_or_text: &str) -> bool {
+    let s = piece_or_text;
+    s.contains('�') || s.contains("?댁") || s.contains('媛') || s.contains('怨') || s.contains('Ã') || s.contains('ì') || s.contains('ê')
+}
+
+fn push_reason(reasons: &mut Vec<TransitionReason>, reason: TransitionReason) {
+    if !reasons.contains(&reason) {
+        reasons.push(reason);
+    }
+}
+
+pub fn evaluate_token_transition(
+    config: &TransitionGuardConfig,
+    ctx: &TransitionContext,
+    candidate: &CandidateTokenView,
+) -> TransitionDecision {
+    let cfg = config.clone().sanitized();
+    if !cfg.enabled {
+        return TransitionDecision::default();
+    }
+
+    let mut risk = 0.0f32;
+    let mut action = TransitionAction::Allow;
+    let mut reasons: Vec<TransitionReason> = Vec::new();
+
+    let candidate_piece = candidate.piece.as_deref().unwrap_or("");
+    let candidate_text = candidate.text.as_deref().unwrap_or(candidate_piece);
+    let prev_text = ctx.prev_text.as_deref().or(ctx.prev_piece.as_deref()).unwrap_or("");
+    let piece_available = !candidate_piece.is_empty() || candidate.is_eos || candidate.is_pad;
+
+    if !piece_available {
+        push_reason(&mut reasons, TransitionReason::PieceContextUnavailable);
+    }
+
+    if candidate.is_pad && cfg.hard_block_pad_token {
+        risk = risk.max(1.0);
+        action = TransitionAction::HardBlock;
+        push_reason(&mut reasons, TransitionReason::PadToken);
+    }
+
+    if candidate.is_eos && ctx.step < cfg.min_new_tokens_for_eos.max(ctx.min_new_tokens) {
+        risk = risk.max(1.0);
+        action = TransitionAction::HardBlock;
+        push_reason(&mut reasons, TransitionReason::EosBeforeMinNewTokens);
+    }
+
+    if candidate.is_control && !candidate.is_eos && !candidate.is_pad && cfg.hard_block_control_tokens {
+        risk = risk.max(1.0);
+        action = TransitionAction::HardBlock;
+        push_reason(&mut reasons, TransitionReason::ControlToken);
+    }
+
+    if (candidate.mojibake_suspected || mojibake_suspected(candidate_piece) || mojibake_suspected(candidate_text)) && cfg.hard_block_mojibake_tokens {
+        risk = risk.max(0.95);
+        action = TransitionAction::HardBlock;
+        push_reason(&mut reasons, TransitionReason::MojibakeSuspected);
+    }
+
+    if candidate.is_byte && cfg.hard_block_invalid_byte_tokens {
+        risk = risk.max(0.8);
+        if action != TransitionAction::HardBlock { action = TransitionAction::Penalize; }
+        push_reason(&mut reasons, TransitionReason::InvalidByteToken);
+    }
+
+    if cfg.penalize_generic_continuation_eos && candidate.is_eos && !prev_text.is_empty() && is_generic_continuation(prev_text) {
+        risk = risk.max(0.95);
+        if action != TransitionAction::HardBlock { action = TransitionAction::Penalize; }
+        push_reason(&mut reasons, TransitionReason::GenericContinuationImmediateEos);
+    }
+
+    if cfg.penalize_double_particle_like && !prev_text.is_empty() && is_particle_like(prev_text) && is_particle_like(candidate_text) {
+        risk = risk.max(0.65);
+        if action != TransitionAction::HardBlock { action = TransitionAction::Penalize; }
+        push_reason(&mut reasons, TransitionReason::DoubleParticleLike);
+    }
+
+    if !prev_text.is_empty() && is_sentence_ending_like(prev_text) && is_sentence_ending_like(candidate_text) {
+        risk = risk.max(0.55);
+        if action != TransitionAction::HardBlock { action = TransitionAction::Penalize; }
+        push_reason(&mut reasons, TransitionReason::DoubleSentenceEndingLike);
+    }
+
+    if cfg.penalize_byte_text_boundary && !prev_text.is_empty() && (looks_like_byte_piece(prev_text) || candidate.is_byte) {
+        risk = risk.max(0.6);
+        if action != TransitionAction::HardBlock { action = TransitionAction::Penalize; }
+        push_reason(&mut reasons, TransitionReason::ByteTextBoundaryRisk);
+    }
+
+    if cfg.penalize_repeated_punctuation && is_punctuation_repeat_piece(candidate_text) {
+        let repeated = ctx.recent_token_pieces.iter().rev().take(3).all(|p| p.trim() == candidate_text.trim());
+        if repeated && !is_korean_emotional_repeat_piece(candidate_text) {
+            risk = risk.max(0.7);
+            if action != TransitionAction::HardBlock { action = TransitionAction::Penalize; }
+            push_reason(&mut reasons, TransitionReason::RepeatedPunctuation);
+        }
+    }
+
+    if candidate_text.trim().is_empty() && !candidate.is_eos {
+        risk = risk.max(0.25);
+        if action == TransitionAction::Allow { action = TransitionAction::Penalize; }
+        push_reason(&mut reasons, TransitionReason::WhitespaceOnlyToken);
+    }
+
+    if candidate.is_unknown || candidate_piece == "<unk>" {
+        risk = risk.max(0.5);
+        if action != TransitionAction::HardBlock { action = TransitionAction::Penalize; }
+        push_reason(&mut reasons, TransitionReason::UnknownToken);
+    }
+
+    if reasons.is_empty() {
+        reasons.push(TransitionReason::None);
+    }
+
+    if action == TransitionAction::Allow && reasons.len() == 1 && reasons[0] == TransitionReason::PieceContextUnavailable {
+        return TransitionDecision { risk: 0.0, penalty: 0.0, action: TransitionAction::Unavailable, reasons };
+    }
+
+    if cfg.probe_only && action != TransitionAction::Allow {
+        let penalty = (risk * cfg.soft_penalty_scale).min(cfg.max_soft_penalty);
+        return TransitionDecision { risk, penalty, action: TransitionAction::ProbeOnly, reasons };
+    }
+
+    let penalty = match action {
+        TransitionAction::HardBlock => cfg.max_soft_penalty,
+        TransitionAction::Penalize => (risk * cfg.soft_penalty_scale).min(cfg.max_soft_penalty),
+        _ => 0.0,
+    };
+
+    TransitionDecision { risk, penalty, action, reasons }
+}
+
+pub fn transition_guard_config_from_env() -> TransitionGuardConfig {
+    let mode = std::env::var("ASH_DECODE_TRANSITION_GUARD").unwrap_or_else(|_| "off".to_string()).to_ascii_lowercase();
+    let parse_usize = |key: &str, default: usize| -> usize { std::env::var(key).ok().and_then(|v| v.parse::<usize>().ok()).unwrap_or(default) };
+    let parse_f32 = |key: &str, default: f32| -> f32 { std::env::var(key).ok().and_then(|v| v.parse::<f32>().ok()).unwrap_or(default) };
+    let enabled = matches!(mode.as_str(), "on" | "probe" | "1" | "true");
+    let probe_only = !matches!(mode.as_str(), "on" | "1" | "true");
+    TransitionGuardConfig {
+        enabled,
+        probe_only,
+        recent_window: parse_usize("ASH_DECODE_TRANSITION_RECENT_WINDOW", 8),
+        soft_penalty_scale: parse_f32("ASH_DECODE_TRANSITION_SOFT_PENALTY_SCALE", 1.0),
+        max_soft_penalty: parse_f32("ASH_DECODE_TRANSITION_MAX_PENALTY", 2.0),
+        min_new_tokens_for_eos: parse_usize("ASH_DECODE_TRANSITION_MIN_NEW_TOKENS", 8),
+        ..TransitionGuardConfig::default()
+    }.sanitized()
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    fn cfg_on() -> TransitionGuardConfig {
+        TransitionGuardConfig { enabled: true, probe_only: false, ..TransitionGuardConfig::default() }
+    }
+
+    #[test]
+    fn generic_continuation_eos_is_risky() {
+        let ctx = TransitionContext { step: 9, prev_text: Some("이어가고".to_string()), ..Default::default() };
+        let cand = CandidateTokenView { token_id: 2, piece: Some("<eos>".to_string()), text: Some(String::new()), is_eos: true, ..Default::default() };
+        let d = evaluate_token_transition(&cfg_on(), &ctx, &cand);
+        assert!(d.risk >= 0.9);
+        assert!(d.reasons.contains(&TransitionReason::GenericContinuationImmediateEos));
+    }
+
+    #[test]
+    fn eos_before_min_new_tokens_is_hard_blocked() {
+        let ctx = TransitionContext { step: 2, min_new_tokens: 8, ..Default::default() };
+        let cand = CandidateTokenView { token_id: 2, piece: Some("<eos>".to_string()), text: Some(String::new()), is_eos: true, ..Default::default() };
+        let d = evaluate_token_transition(&cfg_on(), &ctx, &cand);
+        assert_eq!(d.action, TransitionAction::HardBlock);
+        assert!(d.reasons.contains(&TransitionReason::EosBeforeMinNewTokens));
+    }
+
+    #[test]
+    fn korean_emotional_repeat_not_hard_blocked() {
+        let ctx = TransitionContext { recent_token_pieces: vec!["ㅠ".to_string(), "ㅠ".to_string(), "ㅠ".to_string()], ..Default::default() };
+        let cand = CandidateTokenView { token_id: 42, piece: Some("ㅠ".to_string()), text: Some("ㅠ".to_string()), ..Default::default() };
+        let d = evaluate_token_transition(&cfg_on(), &ctx, &cand);
+        assert_ne!(d.action, TransitionAction::HardBlock);
+    }
+}
