+use crate::generation_sampling::GenerationSamplingConfig;
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
+pub enum SamplerParityMode {
+    Off,
+    ProbeOnly,
+    Strict,
+}
+
+impl SamplerParityMode {
+    pub fn from_env() -> Self {
+        match env::var("ASH_SAMPLER_PARITY").unwrap_or_else(|_| "off".to_string()).to_ascii_lowercase().as_str() {
+            "probe" | "probe_only" | "probeonly" => Self::ProbeOnly,
+            "strict" => Self::Strict,
+            _ => Self::Off,
+        }
+    }
+
+    pub fn as_str(&self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::ProbeOnly => "ProbeOnly",
+            Self::Strict => "Strict",
+        }
+    }
+
+    pub fn enabled(&self) -> bool {
+        !matches!(self, Self::Off)
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct SamplerParityTolerance {
+    pub threshold_abs_tol: f32,
+    pub sum_exp_rel_tol: f32,
+    pub prob_abs_tol: f32,
+    pub logprob_abs_tol: f32,
+}
+
+impl Default for SamplerParityTolerance {
+    fn default() -> Self {
+        Self {
+            threshold_abs_tol: 1e-4,
+            sum_exp_rel_tol: 1e-3,
+            prob_abs_tol: 1e-4,
+            logprob_abs_tol: 1e-4,
+        }
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct GpuSamplerRuntimeTrace {
+    pub selected_id: u32,
+    pub selected_logprob: Option<f32>,
+    pub recovery_mode: Option<String>,
+    pub active_count: Option<usize>,
+    pub final_count: Option<usize>,
+    pub min_p_threshold: Option<f32>,
+    pub active_max: Option<f32>,
+    pub active_sum_exp: Option<f32>,
+    pub active_ids_head: Vec<u32>,
+    pub final_ids_head: Vec<u32>,
+    pub trace_completeness: String,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct CpuSamplerRuntimeTrace {
+    pub selected_id: u32,
+    pub selected_logprob: Option<f32>,
+    pub active_count: usize,
+    pub final_count: usize,
+    pub min_p_threshold: Option<f32>,
+    pub active_max: Option<f32>,
+    pub active_sum_exp: Option<f32>,
+    pub active_ids_head: Vec<u32>,
+    pub final_ids_head: Vec<u32>,
+    pub recovery_mode: String,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct SamplerParityStatus {
+    pub candidate_set_match: Option<bool>,
+    pub active_count_match: Option<bool>,
+    pub final_count_match: Option<bool>,
+    pub threshold_match: Option<bool>,
+    pub recovery_mode_match: Option<bool>,
+    pub selected_match: bool,
+    pub status: String,
+    pub reason: String,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct SamplerParityReceipt {
+    pub patch_id: String,
+    pub step: usize,
+    pub mode: String,
+    pub decode_config: SamplerParityDecodeConfig,
+    pub cpu: CpuSamplerRuntimeTrace,
+    pub gpu: GpuSamplerRuntimeTrace,
+    pub parity: SamplerParityStatus,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct SamplerParityDecodeConfig {
+    pub temperature: f32,
+    pub top_k: u32,
+    pub top_p: f32,
+    pub min_p: f32,
+}
+
+pub fn top_n_limit() -> usize {
+    env::var("ASH_SAMPLER_PARITY_TOP_N")
+        .ok()
+        .and_then(|v| v.parse::<usize>().ok())
+        .unwrap_or(64)
+}
+
+pub fn max_steps() -> usize {
+    env::var("ASH_SAMPLER_PARITY_MAX_STEPS")
+        .ok()
+        .and_then(|v| v.parse::<usize>().ok())
+        .unwrap_or(16)
+}
+
+pub fn receipt_path() -> PathBuf {
+    env::var("ASH_SAMPLER_PARITY_RECEIPT")
+        .map(PathBuf::from)
+        .unwrap_or_else(|_| PathBuf::from("workspace/sampler02_runtime_parity_receipt.jsonl"))
+}
+
+pub fn cpu_trace_from_result(result: &CpuOracleSampleResult, top_n: usize) -> CpuSamplerRuntimeTrace {
+    let trace: &CpuOracleCandidateTrace = &result.trace;
+    CpuSamplerRuntimeTrace {
+        selected_id: result.selected_id,
+        selected_logprob: Some(result.selected_logprob),
+        active_count: trace.active_count,
+        final_count: trace.final_count,
+        min_p_threshold: trace.min_p_threshold,
+        active_max: trace.active_max,
+        active_sum_exp: trace.active_sum_exp,
+        active_ids_head: trace.active_ids.iter().copied().take(top_n).collect(),
+        final_ids_head: trace.final_ids.iter().copied().take(top_n).collect(),
+        recovery_mode: trace.recovery_mode.as_str().to_string(),
+    }
+}
+
+pub fn compare_traces(
+    mode: SamplerParityMode,
+    config: &GenerationSamplingConfig,
+    step: usize,
+    cpu: CpuSamplerRuntimeTrace,
+    gpu: GpuSamplerRuntimeTrace,
+) -> SamplerParityReceipt {
+    let tol = SamplerParityTolerance::default();
+    let selected_match = cpu.selected_id == gpu.selected_id;
+    let active_count_match = gpu.active_count.map(|v| v == cpu.active_count);
+    let final_count_match = gpu.final_count.map(|v| v == cpu.final_count);
+    let threshold_match = match (cpu.min_p_threshold, gpu.min_p_threshold) {
+        (Some(a), Some(b)) => Some((a - b).abs() <= tol.threshold_abs_tol),
+        (None, None) => Some(true),
+        _ => None,
+    };
+    let candidate_set_match = if gpu.active_ids_head.is_empty() && gpu.final_ids_head.is_empty() {
+        None
+    } else {
+        Some(cpu.active_ids_head == gpu.active_ids_head && cpu.final_ids_head == gpu.final_ids_head)
+    };
+    let recovery_mode_match = gpu.recovery_mode.as_ref().map(|g| g == &cpu.recovery_mode);
+
+    let (status, reason) = if candidate_set_match == Some(false) || active_count_match == Some(false) || final_count_match == Some(false) || threshold_match == Some(false) {
+        ("FAIL_CANDIDATE_PARITY_MISMATCH".to_string(), "candidate/count/threshold mismatch".to_string())
+    } else if candidate_set_match.is_none() {
+        ("PARTIAL_GPU_CANDIDATE_TRACE_UNAVAILABLE".to_string(), "GPU candidate ID trace buffer not present; selected/recovery and CPU oracle trace recorded".to_string())
+    } else if !selected_match {
+        ("WARN_SELECTED_ONLY".to_string(), "candidate set matches but selected token differs".to_string())
+    } else {
+        ("PASS".to_string(), "candidate and selected token parity".to_string())
+    };
+
+    SamplerParityReceipt {
+        patch_id: "16AI-QW-38G-R6A-SAMPLER-02".to_string(),
+        step,
+        mode: mode.as_str().to_string(),
+        decode_config: SamplerParityDecodeConfig {
+            temperature: config.temperature,
+            top_k: config.top_k,
+            top_p: config.top_p,
+            min_p: config.min_p,
+        },
+        cpu,
+        gpu,
+        parity: SamplerParityStatus {
+            candidate_set_match,
+            active_count_match,
+            final_count_match,
+            threshold_match,
+            recovery_mode_match,
+            selected_match,
+            status,
+            reason,
+        },
+    }
+}
+
+pub fn append_receipt(receipt: &SamplerParityReceipt) {
+    let path = receipt_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(line) = serde_json::to_string(receipt) {
+        use std::io::Write;
+        if let Ok(mut file) = fs::OpenOptions::new().create(true).append(true).open(path) {
+            let _ = writeln!(file, "{}", line);
+        }
+    }
+}
