+        active_sum_exp,
+        final_mask_recovered,
+        recovery_mode,
+    }
+}
+
+fn active_stats(candidates: &[Candidate]) -> (Option<f32>, Option<f32>) {
+    if candidates.is_empty() {
+        return (None, None);
+    }
+    let max_scaled = candidates
+        .iter()
+        .map(|c| c.scaled)
+        .max_by(|a, b| a.total_cmp(b));
+    let Some(max_scaled) = max_scaled else { return (None, None); };
+    let mut sum = 0.0f32;
+    for cand in candidates {
+        sum += (cand.scaled - max_scaled).exp();
+    }
+    (Some(max_scaled), Some(sum))
+}
