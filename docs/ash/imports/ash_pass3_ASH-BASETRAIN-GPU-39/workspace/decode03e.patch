+pub fn decide_decode03e_gate(input: &Decode03EInput, capability: &Decode03EBackendCapability) -> Decode03EGateDecision {
+    let mut denied = Vec::new();
+    let mut warnings = Vec::new();
+    let mut apply = Vec::new();
+    let mut strict_fail = false;
+
+    match input.mode {
+        Decode03EMode::Off => denied.push("mode_off".to_string()),
+        Decode03EMode::ShadowOnly => denied.push("shadow_only_no_apply".to_string()),
+        Decode03EMode::ControlledApply | Decode03EMode::StrictControlledApply => apply.push("controlled_apply_enabled".to_string()),
+    }
+    if !input.behavior_change_allowed {
+        denied.push("behavior_change_not_allowed".to_string());
+    }
+    if !capability.supports_guard_overlay || !input.backend_supports_guard_overlay {
+        denied.push("backend_guard_overlay_unsupported".to_string());
+    }
+    if input.salad04_morph_risk_stable.is_none() {
+        warnings.push("salad04_status_missing".to_string());
+    }
+    if input.numeric_risk && matches!(input.mode, Decode03EMode::StrictControlledApply) {
+        strict_fail = true;
+        denied.push("numeric_risk_defer_to_stop_or_rollback".to_string());
+    }
+    if matches!(input.mode, Decode03EMode::StrictControlledApply) && input.eval01_backend_semantic_parity_ok != Some(true) {
+        strict_fail = true;
+        denied.push("eval01_semantic_parity_not_confirmed".to_string());
+    }
+    if matches!(input.mode, Decode03EMode::ControlledApply) && input.eval01_backend_strict_parity_ok != Some(true) {
+        warnings.push("eval01_strict_parity_not_confirmed_semantic_only".to_string());
+    }
+    if !capability.supports_morph_penalty && risk_rank(input.salad04_morph_risk_stable.as_deref()) >= 2 {
+        warnings.push("backend_morph_penalty_unsupported".to_string());
+    }
+    if input.global_finite_fallback_seen {
+        warnings.push("global_finite_fallback_seen_defer_to_stop".to_string());
+    }
+
+    Decode03EGateDecision {
+        can_apply: denied.is_empty() && matches!(input.mode, Decode03EMode::ControlledApply | Decode03EMode::StrictControlledApply),
+        strict_fail,
+        denied_reasons: denied,
+        warning_reasons: warnings,
+        apply_reasons: apply,
+    }
+}
