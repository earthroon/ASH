+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+pub enum Decode03EGuardStrength {
+    Relaxed,
+    Normal,
+    Strict,
+    Panic,
+}
+
+impl Decode03EGuardStrength {
+    pub fn from_str(value: &str) -> Self {
+        match value.trim().to_ascii_lowercase().as_str() {
+            "relaxed" => Self::Relaxed,
+            "strict" => Self::Strict,
+            "panic" => Self::Panic,
+            _ => Self::Normal,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Relaxed => "Relaxed",
+            Self::Normal => "Normal",
+            Self::Strict => "Strict",
+            Self::Panic => "Panic",
+        }
+    }
+
+    fn rank(self) -> u8 {
+        match self {
+            Self::Relaxed => 0,
+            Self::Normal => 1,
+            Self::Strict => 2,
+            Self::Panic => 3,
+        }
+    }
+
+    fn max(self, other: Self) -> Self {
+        if self.rank() >= other.rank() { self } else { other }
+    }
+}
