+fn append_jsonl<T: Serialize>(path: PathBuf, value: &T) {
+    if let Some(parent) = path.parent() { let _ = fs::create_dir_all(parent); }
+    if let Ok(line) = serde_json::to_string(value) {
+        use std::io::Write;
+        if let Ok(mut file) = fs::OpenOptions::new().create(true).append(true).open(path) {
+            let _ = writeln!(file, "{}", line);
+        }
+    }
+}
+
+pub fn append_decode03e_receipt_from_sampler03(source: &SamplerParityReceipt) {
+    let mode = Decode03EMode::from_env();
+    if !mode.enabled() { return; }
+    let entropy_receipt = decode03a_receipt_from_sampler03(Decode03AMode::Receipt, source);
+    let pci_receipt = decode03b_receipt_from_decode03a(Decode03BMode::Receipt, &entropy_receipt, None, 0);
+    let shadow_receipt = decode03c_receipt_from_decode03b(Decode03CMode::Receipt, &pci_receipt, Some(&entropy_receipt));
+    let mut decode03d_receipt = decode03d_receipt_from_decode03c(DynamicSamplerMode::from_env(), &shadow_receipt);
+    decode03d_receipt.selected_id_after_apply = Some(source.cpu.selected_id);
+    let salad02_receipt = salad02_receipt_from_decode03d(&decode03d_receipt);
+    let salad04_receipt = salad04_receipt_from_salad02(Salad04Mode::RiskOverlay, &salad02_receipt);
+    let receipt = receipt_from_salad04(mode, &salad04_receipt, Some(source));
+    append_jsonl(receipt_path(), &receipt);
+    let _ = write_decode03e_summary_from_receipt_file();
+}
+
+fn read_receipts(path: PathBuf) -> Vec<Decode03EStepReceipt> {
+    let Ok(content) = fs::read_to_string(path) else { return Vec::new(); };
+    content.lines().filter_map(|line| serde_json::from_str::<Decode03EStepReceipt>(line).ok()).collect()
+}
+
+pub fn summary_from_receipts(receipts: &[Decode03EStepReceipt]) -> Decode03ESummary {
+    let mut gate = Decode03EGateCounts::default();
+    let mut overlay = Decode03EOverlayCounts::default();
+    let mut targets = Decode03ETargetCounts::default();
+    let mut safety = Decode03ESafetyCounts::default();
+    for receipt in receipts {
+        if receipt.gate.can_apply { gate.can_apply_count += 1; } else if !matches!(receipt.mode, Decode03EMode::Off | Decode03EMode::ShadowOnly) { gate.denied_count += 1; }
+        if receipt.gate.strict_fail { gate.strict_fail_count += 1; }
+        if receipt.overlay.applied { overlay.applied_count += 1; }
+        if receipt.overlay.guard_strength_after == Decode03EGuardStrength::Strict { overlay.strict_guard_count += 1; }
+        if receipt.overlay.guard_strength_after == Decode03EGuardStrength::Panic { overlay.panic_guard_count += 1; }
+        if receipt.overlay.morph_penalty_enabled { overlay.morph_penalty_enabled_count += 1; }
+        if receipt.overlay.no_repeat_ngram_applied.is_some() { overlay.no_repeat_ngram_applied_count += 1; }
+        if receipt.overlay.min_p_floor_applied.is_some() { overlay.min_p_floor_applied_count += 1; }
+        if receipt.overlay.top_p_ceiling_applied.is_some() { overlay.top_p_ceiling_applied_count += 1; }
+        match receipt.overlay.morph_guard_target {
+            Decode03EMorphGuardTarget::JosaLoop => targets.josa_loop_count += 1,
+            Decode03EMorphGuardTarget::EomiLoop => targets.eomi_loop_count += 1,
+            Decode03EMorphGuardTarget::JamoLeak => targets.jamo_leak_count += 1,
+            Decode03EMorphGuardTarget::ByteJamoLeak => targets.byte_jamo_leak_count += 1,
+            Decode03EMorphGuardTarget::SyllableFragmentLoop => targets.syllable_fragment_loop_count += 1,
+            Decode03EMorphGuardTarget::EojeolBoundaryCollapse => targets.eojeol_boundary_collapse_count += 1,
+            Decode03EMorphGuardTarget::PunctuationGlueLoop => targets.punctuation_glue_loop_count += 1,
+            Decode03EMorphGuardTarget::MixedMorphLoop => targets.mixed_morph_loop_count += 1,
+            Decode03EMorphGuardTarget::None => {}
+        }
+        let unsupported_applied = receipt.overlay.applied && (!receipt.backend_capability.supports_guard_overlay || (!receipt.backend_capability.supports_morph_penalty && receipt.overlay.morph_penalty_enabled));
+        if unsupported_applied { safety.unsupported_applied_count += 1; }
+        if receipt.overlay.panic_candidate_executed { safety.panic_candidate_executed_count += 1; }
+        if receipt.overlay_warnings_contains("active_set_too_small_skip_extra_tighten") { safety.active_set_too_small_skip_count += 1; }
+        if receipt.overlay.morph_penalty_weight < 0.0 || receipt.overlay.morph_penalty_weight > 0.50 { safety.clamp_violation_count += 1; }
+        if receipt.overlay.min_p_floor_applied.map(|v| !(0.0..=0.20).contains(&v)).unwrap_or(false) { safety.clamp_violation_count += 1; }
+        if receipt.overlay.top_p_ceiling_applied.map(|v| !(0.60..=0.98).contains(&v)).unwrap_or(false) { safety.clamp_violation_count += 1; }
+    }
+    let contract_fail = safety.unsupported_applied_count > 0
+        || safety.panic_candidate_executed_count > 0
+        || safety.rollback_executed_count > 0
+        || safety.stop_executed_count > 0
+        || safety.base_config_mutation_count > 0
+        || safety.clamp_violation_count > 0;
+    Decode03ESummary {
+        patch_id: DECODE03E_PATCH_ID.to_string(),
+        input_patch: DECODE03E_INPUT_PATCH_ID.to_string(),
+        status: if contract_fail { "FAIL_STATIC_CONTRACT" } else if receipts.is_empty() { "STATIC_BAKE_DEFINED_NOT_RUN" } else { "PASS_WITH_WARNINGS" }.to_string(),
+        mode: Decode03EMode::from_env().as_str().to_string(),
+        default_enable: false,
+        steps_observed: receipts.len(),
+        gate,
+        overlay,
+        targets,
+        safety,
+        ready_for_eval02_long_horizon_soak: !contract_fail,
+        ready_for_default_guard_overlay: false,
+        ready_for_medusa00: false,
+        reason: if contract_fail {
+            "DECODE-03E guard overlay safety contract failed; do not promote.".to_string()
+        } else if receipts.is_empty() {
+            "guard overlay controlled apply schema baked; runtime receipt not yet collected".to_string()
+        } else {
+            "guard overlay controlled apply sealed; requires EVAL-00/01 rerun before default enable".to_string()
+        },
+    }
+}
+
+trait OverlayWarningContains {
+    fn overlay_warnings_contains(&self, needle: &str) -> bool;
+}
+
+impl OverlayWarningContains for Decode03EStepReceipt {
+    fn overlay_warnings_contains(&self, needle: &str) -> bool {
+        self.overlay.overlay_warnings.iter().any(|w| w == needle)
+    }
+}
+
+pub fn write_decode03e_summary_from_receipt_file() -> Result<Decode03ESummary, String> {
+    let summary = summary_from_receipts(&read_receipts(receipt_path()));
+    let path = summary_path();
+    if let Some(parent) = path.parent() { fs::create_dir_all(parent).map_err(|e| e.to_string())?; }
+    let json = serde_json::to_string_pretty(&summary).map_err(|e| e.to_string())?;
+    fs::write(&path, format!("{}\n", json)).map_err(|e| e.to_string())?;
+    Ok(summary)
+}
