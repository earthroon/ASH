+pub fn input_from_salad04(mode: Decode03EMode, receipt: &Salad04StepReceipt, source: Option<&SamplerParityReceipt>) -> Decode03EInput {
+    let config = source.map(|s| &s.decode_config);
+    let recommendation = &receipt.detection.overlay_recommendation;
+    Decode03EInput {
+        mode,
+        behavior_change_allowed: env_bool("ASH_DECODE03E_BEHAVIOR_CHANGE_ALLOWED", false),
+        run_id: run_id_from_env(),
+        prompt_hash: receipt.prompt_hash.clone(),
+        seed: receipt.seed.unwrap_or_else(|| env::var("ASH_DECODE03E_SEED").ok().and_then(|v| v.parse().ok()).unwrap_or(0)),
+        step: receipt.step,
+        backend: receipt.backend.clone(),
+        current_temperature: config.map(|c| c.temperature).unwrap_or_else(|| env_f32("ASH_DECODE03E_CURRENT_TEMPERATURE", 0.25)),
+        current_top_p: config.map(|c| c.top_p).unwrap_or_else(|| env_f32("ASH_DECODE03E_CURRENT_TOP_P", 0.88)),
+        current_top_k: config.map(|c| c.top_k as usize).unwrap_or_else(|| env_usize("ASH_DECODE03E_CURRENT_TOP_K", 0)),
+        current_min_p: config.map(|c| c.min_p).unwrap_or_else(|| env_f32("ASH_DECODE03E_CURRENT_MIN_P", 0.05)),
+        decode03d_guard_strength: receipt.input.decode03d_guard_strength.clone(),
+        salad04_morph_score: Some(receipt.detection.morph_score),
+        salad04_morph_risk_stable: Some(receipt.detection.morph_risk_stable.clone()),
+        salad04_dominant_loop_kind: Some(format!("{:?}", receipt.detection.dominant_loop_kind)),
+        salad04_raise_salad02_risk_candidate: recommendation.raise_salad02_risk_candidate,
+        salad04_rollback_candidate_boost: recommendation.rollback_candidate_boost,
+        salad04_safe_stop_candidate_boost: recommendation.safe_stop_candidate_boost,
+        suggested_min_p_floor: recommendation.suggested_min_p_floor,
+        suggested_top_p_ceiling: recommendation.suggested_top_p_ceiling,
+        suggested_guard_strength: recommendation.suggested_guard_strength.clone(),
+        no_repeat_ngram_hint: recommendation.no_repeat_ngram_hint,
+        active_count_after_min_p: source.map(|s| s.cpu.post_min_p_count),
+        pci_raw: receipt.input.pci_raw,
+        pci_bucket: receipt.input.pci_bucket.clone(),
+        entropy_spike: receipt.input.entropy_spike,
+        fallback_risk: receipt.input.fallback_risk,
+        numeric_risk: receipt.input.numeric_risk,
+        global_finite_fallback_seen: receipt.input.global_finite_fallback_seen,
+        eval01_backend_semantic_parity_ok: env::var("ASH_DECODE03E_EVAL01_SEMANTIC_PARITY_OK").ok().map(|v| matches!(v.trim().to_ascii_lowercase().as_str(), "1" | "true" | "yes" | "on")),
+        eval01_backend_strict_parity_ok: env::var("ASH_DECODE03E_EVAL01_STRICT_PARITY_OK").ok().map(|v| matches!(v.trim().to_ascii_lowercase().as_str(), "1" | "true" | "yes" | "on")),
+        backend_supports_guard_overlay: env_bool("ASH_DECODE03E_SUPPORTS_GUARD_OVERLAY", true),
+        backend_supports_morph_penalty: env_bool("ASH_DECODE03E_SUPPORTS_MORPH_PENALTY", true),
+        backend_supports_no_repeat_ngram: env_bool("ASH_DECODE03E_SUPPORTS_NO_REPEAT_NGRAM", true),
+    }
+}
+
+pub fn receipt_from_salad04(mode: Decode03EMode, salad04: &Salad04StepReceipt, source: Option<&SamplerParityReceipt>) -> Decode03EStepReceipt {
+    let input = input_from_salad04(mode, salad04, source);
+    let capability = backend_capability_from_env(&input.backend);
+    let gate = decide_decode03e_gate(&input, &capability);
+    let overlay = compute_decode03e_guard_overlay(&input, &capability, &gate);
+    let selected_after = source.map(|s| s.cpu.selected_id).or(Some(salad04.selected_id));
+    let before_count = input.active_count_after_min_p;
+    let after_count = if overlay.applied {
+        before_count.map(|v| {
+            let penalty = (overlay.morph_penalty_weight * 10.0).round() as usize;
+            v.saturating_sub(penalty).max(1)
+        })
+    } else {
+        before_count
+    };
+    Decode03EStepReceipt {
+        patch_id: DECODE03E_PATCH_ID.to_string(),
+        input_patch: DECODE03E_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: input.run_id.clone(),
+        prompt_hash: input.prompt_hash.clone(),
+        seed: input.seed,
+        step: input.step,
+        backend: input.backend.clone(),
+        sampler_ssot: DECODE03E_SSOT.to_string(),
+        mode,
+        controlled_apply: matches!(mode, Decode03EMode::ControlledApply | Decode03EMode::StrictControlledApply),
+        salad04_status_seen: Some("DERIVED_IN_MEMORY_FROM_SALAD04_RECEIPT".to_string()),
+        decode03d_status_seen: salad04.decode03d_status_seen.clone(),
+        eval01_status_seen: env::var("ASH_EVAL01_STATUS_SEEN").ok(),
+        input,
+        backend_capability: capability,
+        gate,
+        overlay,
+        selected_id_before_overlay: None,
+        selected_id_after_overlay: selected_after,
+        active_count_after_min_p_before: before_count,
+        active_count_after_min_p_after: after_count,
+        salad04_morph_score_before: Some(salad04.detection.morph_score),
+        salad04_morph_score_after: None,
+    }
+}
