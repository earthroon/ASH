+fn base_policy(target: Decode03EMorphGuardTarget, risk_rank: u8) -> (Decode03EGuardStrength, f32, Option<usize>, Option<f32>, Option<f32>, Option<f32>, Vec<String>) {
+    let mut reasons = Vec::new();
+    let policy = match target {
+        Decode03EMorphGuardTarget::JosaLoop => {
+            reasons.push("josa_loop_guard".to_string());
+            (Decode03EGuardStrength::Strict, 0.18, Some(3), Some(0.08), Some(0.86), Some(0.02))
+        }
+        Decode03EMorphGuardTarget::EomiLoop => {
+            reasons.push("eomi_loop_guard".to_string());
+            (Decode03EGuardStrength::Strict, 0.22, Some(3), Some(0.10), Some(0.84), Some(0.04))
+        }
+        Decode03EMorphGuardTarget::JamoLeak => {
+            reasons.push("jamo_leak_guard".to_string());
+            (Decode03EGuardStrength::Panic, 0.35, Some(3), Some(0.12), Some(0.82), Some(0.05))
+        }
+        Decode03EMorphGuardTarget::ByteJamoLeak => {
+            reasons.push("byte_jamo_leak_guard".to_string());
+            (Decode03EGuardStrength::Panic, 0.45, Some(4), Some(0.14), Some(0.78), Some(0.06))
+        }
+        Decode03EMorphGuardTarget::SyllableFragmentLoop => {
+            reasons.push("syllable_fragment_loop_guard".to_string());
+            (Decode03EGuardStrength::Strict, 0.16, Some(3), None, None, Some(0.02))
+        }
+        Decode03EMorphGuardTarget::EojeolBoundaryCollapse => {
+            reasons.push("eojeol_boundary_collapse_guard".to_string());
+            (Decode03EGuardStrength::Strict, 0.20, None, None, Some(0.84), Some(0.03))
+        }
+        Decode03EMorphGuardTarget::PunctuationGlueLoop => {
+            reasons.push("punctuation_glue_loop_guard".to_string());
+            (Decode03EGuardStrength::Strict, 0.18, Some(3), None, None, Some(0.02))
+        }
+        Decode03EMorphGuardTarget::MixedMorphLoop => {
+            reasons.push("mixed_morph_loop_guard".to_string());
+            (Decode03EGuardStrength::Strict, 0.20, Some(3), Some(0.10), Some(0.84), Some(0.03))
+        }
+        Decode03EMorphGuardTarget::None => (Decode03EGuardStrength::Normal, 0.0, None, None, None, None),
+    };
+    if risk_rank >= 3 {
+        reasons.push("critical_morph_risk_panic_floor".to_string());
+        (policy.0.max(Decode03EGuardStrength::Panic), policy.1.max(0.30), policy.2.or(Some(4)), policy.3.or(Some(0.14)), policy.4.or(Some(0.78)), policy.5.or(Some(0.05)), reasons)
+    } else if risk_rank == 2 {
+        reasons.push("high_morph_risk_strict_floor".to_string());
+        (policy.0.max(Decode03EGuardStrength::Strict), policy.1.max(0.15), policy.2.or(Some(3)), policy.3, policy.4, policy.5, reasons)
+    } else if risk_rank == 1 {
+        reasons.push("medium_morph_risk_normal_floor".to_string());
+        (policy.0.max(Decode03EGuardStrength::Normal), policy.1.max(0.05), None, None, None, None, reasons)
+    } else {
+        policy
+    }
+}
