+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+pub enum Decode03EMode {
+    Off,
+    ShadowOnly,
+    ControlledApply,
+    StrictControlledApply,
+}
+
+impl Decode03EMode {
+    pub fn from_env() -> Self {
+        let value = env::var("ASH_DECODE03E_MODE")
+            .or_else(|_| env::var("ASH_DECODE03E_GUARD_OVERLAY"))
+            .unwrap_or_else(|_| "off".to_string())
+            .trim()
+            .to_ascii_lowercase();
+        match value.as_str() {
+            "shadow" | "shadow_only" | "observe" | "observe_only" => Self::ShadowOnly,
+            "controlled" | "controlled_apply" | "apply" | "true" | "1" | "on" => Self::ControlledApply,
+            "strict" | "strict_controlled_apply" => Self::StrictControlledApply,
+            _ => Self::Off,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::ShadowOnly => "ShadowOnly",
+            Self::ControlledApply => "ControlledApply",
+            Self::StrictControlledApply => "StrictControlledApply",
+        }
+    }
+
+    pub fn enabled(self) -> bool { !matches!(self, Self::Off) }
+}
