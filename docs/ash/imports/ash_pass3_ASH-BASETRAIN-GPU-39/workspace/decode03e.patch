+pub fn compute_decode03e_guard_overlay(
+    input: &Decode03EInput,
+    capability: &Decode03EBackendCapability,
+    gate: &Decode03EGateDecision,
+) -> Decode03EGuardOverlay {
+    let before = input.decode03d_guard_strength.clone().unwrap_or_else(|| "Normal".to_string());
+    let before_strength = Decode03EGuardStrength::from_str(&before);
+    let target = target_from_string(input.salad04_dominant_loop_kind.as_deref());
+    let rank = risk_rank(input.salad04_morph_risk_stable.as_deref());
+    let (base_strength, mut penalty, mut ngram, mut min_p_floor, mut top_p_ceiling, mut repeat_delta, mut reasons) = base_policy(target, rank);
+    let suggested_strength = input.suggested_guard_strength.as_deref().map(Decode03EGuardStrength::from_str).unwrap_or(base_strength);
+    let mut after = base_strength.max(suggested_strength).max(before_strength);
+    if rank == 0 { after = before_strength; }
+    if input.entropy_spike { reasons.push("entropy_spike".to_string()); }
+    if matches!(input.pci_bucket.as_deref(), Some("Unstable") | Some("Collapsing")) {
+        reasons.push("pci_unstable_or_collapsing".to_string());
+        after = after.max(Decode03EGuardStrength::Strict);
+    }
+    if input.fallback_risk { reasons.push("fallback_risk_seen".to_string()); }
+    if input.salad04_rollback_candidate_boost { reasons.push("rollback_candidate_boost_seen".to_string()); }
+    if input.salad04_safe_stop_candidate_boost { reasons.push("safe_stop_candidate_boost_seen".to_string()); }
+    if let Some(hint) = input.no_repeat_ngram_hint { ngram = Some(ngram.unwrap_or(0).max(hint)); }
+    if let Some(hint) = input.suggested_min_p_floor { min_p_floor = Some(min_p_floor.unwrap_or(0.0).max(hint)); }
+    if let Some(hint) = input.suggested_top_p_ceiling { top_p_ceiling = Some(top_p_ceiling.map(|v| v.min(hint)).unwrap_or(hint)); }
+
+    let mut warnings = gate.warning_reasons.clone();
+    if matches!(input.active_count_after_min_p, Some(v) if v <= 3) {
+        min_p_floor = None;
+        top_p_ceiling = None;
+        warnings.push("active_set_too_small_skip_extra_tighten".to_string());
+    }
+    penalty = clamp(penalty, 0.0, 0.50);
+    min_p_floor = min_p_floor.map(|v| clamp(v, 0.0, 0.20)).filter(|v| *v > input.current_min_p);
+    top_p_ceiling = top_p_ceiling.map(|v| clamp(v, 0.60, 0.98)).filter(|v| *v < input.current_top_p);
+    ngram = ngram.map(|v| v.min(6)).filter(|v| *v > 0);
+    repeat_delta = repeat_delta.map(|v| clamp(v, 0.0, 0.25));
+
+    let can_apply = gate.can_apply;
+    let morph_penalty_enabled = can_apply && capability.supports_morph_penalty && penalty > 0.0;
+    if can_apply && !capability.supports_morph_penalty && penalty > 0.0 { warnings.push("morph_penalty_not_applied_backend_unsupported".to_string()); }
+    let no_repeat_ngram_applied = if can_apply && capability.supports_no_repeat_ngram { ngram } else { None };
+    if can_apply && !capability.supports_no_repeat_ngram && ngram.is_some() { warnings.push("no_repeat_ngram_not_applied_backend_unsupported".to_string()); }
+    let min_p_floor_applied = if can_apply && capability.supports_min_p_floor { min_p_floor } else { None };
+    if can_apply && !capability.supports_min_p_floor && min_p_floor.is_some() { warnings.push("min_p_floor_not_applied_backend_unsupported".to_string()); }
+    let top_p_ceiling_applied = if can_apply && capability.supports_top_p_ceiling { top_p_ceiling } else { None };
+    if can_apply && !capability.supports_top_p_ceiling && top_p_ceiling.is_some() { warnings.push("top_p_ceiling_not_applied_backend_unsupported".to_string()); }
+    let applied = can_apply && (after != before_strength || morph_penalty_enabled || no_repeat_ngram_applied.is_some() || min_p_floor_applied.is_some() || top_p_ceiling_applied.is_some());
+    if applied { reasons.push("step_local_guard_overlay_applied".to_string()); }
+
+    Decode03EGuardOverlay {
+        behavior_change: applied,
+        step_local_overlay: true,
+        applied,
+        guard_strength_before: before,
+        guard_strength_after: if applied { after } else { before_strength },
+        morph_guard_target: target,
+        morph_penalty_enabled,
+        morph_penalty_weight: if morph_penalty_enabled { penalty } else { 0.0 },
+        no_repeat_ngram_applied,
+        repeat_penalty_delta: if applied { repeat_delta } else { None },
+        min_p_floor_applied,
+        top_p_ceiling_applied,
+        rollback_candidate_boost_seen: input.salad04_rollback_candidate_boost,
+        safe_stop_candidate_boost_seen: input.salad04_safe_stop_candidate_boost,
+        panic_candidate_seen: matches!(after, Decode03EGuardStrength::Panic) || input.salad04_safe_stop_candidate_boost || input.numeric_risk || input.global_finite_fallback_seen,
+        panic_candidate_executed: false,
+        overlay_reasons: reasons,
+        overlay_warnings: warnings,
+    }
+}
