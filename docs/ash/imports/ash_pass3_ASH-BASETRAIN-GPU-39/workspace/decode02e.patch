+
+impl TransitionControlledEnableConfig {
+    pub fn sanitized(mut self) -> Self {
+        if !self.soft_penalty_scale.is_finite() || self.soft_penalty_scale < 0.0 {
+            self.soft_penalty_scale = 0.5;
+        }
+        if !self.max_soft_penalty.is_finite() || self.max_soft_penalty < 0.0 {
+            self.max_soft_penalty = 0.75;
+        }
+        self.soft_penalty_scale = self.soft_penalty_scale.min(2.0);
+        self.max_soft_penalty = self.max_soft_penalty.min(0.75);
+        // SafeV1 contract: these are never hard-blocked by the controlled profile.
+        self.hard_block_korean_text = false;
+        self.hard_block_emotional_repeat = false;
+        self.hard_block_particle_like = false;
+        self
+    }
+}
