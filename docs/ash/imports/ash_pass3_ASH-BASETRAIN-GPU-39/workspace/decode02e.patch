+pub fn decode02e_apply_for_receipt(
+    decision: &TransitionDecision,
+    weighted_logit: f32,
+    step: Option<usize>,
+) -> Decode02eControlledReceipt {
+    let cfg = transition_controlled_enable_config_from_env();
+    let gate = transition_controlled_gate_status_from_env(&cfg);
+    let apply = apply_transition_controlled_decision(&cfg, decision, weighted_logit);
+    Decode02eControlledReceipt {
+        patch_id: DECODE02E_PATCH_ID.to_string(),
+        mode: env::var("ASH_DECODE_TRANSITION_GUARD").unwrap_or_else(|_| "off".to_string()),
+        profile: match cfg.profile { TransitionControlledProfile::SafeV1 => "safe_v1" }.to_string(),
+        step,
+        gate: Decode02eGateReceipt {
+            ready_required: gate.ready_required,
+            status: gate.status,
+            reason: gate.reason,
+        },
+        transition_guard_effective: apply.effective,
+        controlled_apply: apply,
+    }
