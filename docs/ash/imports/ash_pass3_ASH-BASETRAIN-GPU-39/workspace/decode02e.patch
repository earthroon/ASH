+
+pub fn transition_controlled_enable_config_from_env() -> TransitionControlledEnableConfig {
+    let mode = std::env::var("ASH_DECODE_TRANSITION_GUARD").unwrap_or_else(|_| "off".to_string()).to_ascii_lowercase();
+    let controlled_enable = env_truthy("ASH_DECODE_TRANSITION_CONTROLLED_ENABLE");
+    let profile = match std::env::var("ASH_DECODE_TRANSITION_CONTROLLED_PROFILE").unwrap_or_else(|_| "safe_v1".to_string()).to_ascii_lowercase().as_str() {
+        _ => TransitionControlledProfile::SafeV1,
+    };
+    TransitionControlledEnableConfig {
+        enabled: mode == "controlled" && controlled_enable,
+        profile,
+        require_decode02d_ready: true,
+        soft_penalty_scale: env_f32("ASH_DECODE_TRANSITION_CONTROLLED_SOFT_PENALTY_SCALE", 0.5),
+        max_soft_penalty: env_f32("ASH_DECODE_TRANSITION_CONTROLLED_MAX_PENALTY", 0.75),
+        ..TransitionControlledEnableConfig::default()
+    }.sanitized()
+}
+
+pub fn transition_controlled_gate_status_from_env(config: &TransitionControlledEnableConfig) -> TransitionControlledGateStatus {
+    if !config.enabled {
+        return TransitionControlledGateStatus {
+            ready_required: config.require_decode02d_ready,
+            ready: false,
+            status: "BLOCKED".to_string(),
+            reason: Some("CONTROLLED_ENABLE_NOT_REQUESTED".to_string()),
+        };
+    }
+    if !config.require_decode02d_ready {
+        return TransitionControlledGateStatus {
+            ready_required: false,
+            ready: true,
+            status: "PASS".to_string(),
+            reason: None,
+        };
+    }
+
+    let decode02d_status = std::env::var("ASH_DECODE_TRANSITION_READY_STATUS")
+        .or_else(|_| std::env::var("ASH_DECODE02D_PROMOTION_STATUS"))
+        .unwrap_or_else(|_| "UNKNOWN".to_string());
+    let run01_transition_ready = env_truthy("ASH_RUN01_TRANSITION_READY")
+        || std::env::var("ASH_RUN01_TRANSITION_ON_CANDIDATE_READY").ok().map(|v| v == "true" || v == "1").unwrap_or(false);
+    let cargo_pass = std::env::var("ASH_RUN01_CARGO_STATUS").map(|v| v == "PASS").unwrap_or(false);
+    let wgsl_pass = std::env::var("ASH_RUN01_WGSL_STATUS").map(|v| v == "PASS").unwrap_or(false);
+
+    if decode02d_status == "TRANSITION_ON_CANDIDATE_READY" && run01_transition_ready && cargo_pass && wgsl_pass {
+        TransitionControlledGateStatus { ready_required: true, ready: true, status: "PASS".to_string(), reason: None }
+    } else if decode02d_status != "TRANSITION_ON_CANDIDATE_READY" {
+        TransitionControlledGateStatus { ready_required: true, ready: false, status: "BLOCKED".to_string(), reason: Some("DECODE02D_NOT_READY".to_string()) }
+    } else if !cargo_pass {
+        TransitionControlledGateStatus { ready_required: true, ready: false, status: "BLOCKED".to_string(), reason: Some("RUN01_CARGO_NOT_PASS".to_string()) }
+    } else if !wgsl_pass {
+        TransitionControlledGateStatus { ready_required: true, ready: false, status: "BLOCKED".to_string(), reason: Some("RUN01_WGSL_NOT_PASS".to_string()) }
+    } else {
+        TransitionControlledGateStatus { ready_required: true, ready: false, status: "BLOCKED".to_string(), reason: Some("RUN01_TRANSITION_READY_FALSE".to_string()) }
+    }
+}
+
+fn decision_has(decision: &TransitionDecision, reason: TransitionReason) -> bool {
+    decision.reasons.iter().any(|r| *r == reason)
+}
+
+fn controlled_hardblock_allowed(config: &TransitionControlledEnableConfig, decision: &TransitionDecision) -> bool {
+    (config.hard_block_pad && decision_has(decision, TransitionReason::PadToken))
+        || (config.hard_block_invalid_control && decision_has(decision, TransitionReason::ControlToken))
+        || (config.hard_block_mojibake && decision_has(decision, TransitionReason::MojibakeSuspected))
+        || (config.hard_block_invalid_byte && decision_has(decision, TransitionReason::InvalidByteToken))
+        || (config.hard_block_eos_before_min_new_tokens && decision_has(decision, TransitionReason::EosBeforeMinNewTokens))
+}
+
+fn controlled_observe_only(config: &TransitionControlledEnableConfig, decision: &TransitionDecision) -> bool {
+    (config.observe_emotional_repeat && decision_has(decision, TransitionReason::RecentLoopRisk))
+        || (config.observe_korean_ambiguous_transition
+            && (decision_has(decision, TransitionReason::DoubleParticleLike)
+                || decision_has(decision, TransitionReason::DoubleSentenceEndingLike)))
+}
+
+pub fn apply_transition_controlled_decision(
+    config: &TransitionControlledEnableConfig,
+    decision: &TransitionDecision,
+    weighted_logit: f32,
+) -> TransitionControlledApplyResult {
+    let cfg = config.clone().sanitized();
+    let gate = transition_controlled_gate_status_from_env(&cfg);
+    if !cfg.enabled || !gate.ready {
+        return TransitionControlledApplyResult {
+            effective: false,
+            action: TransitionControlledAction::GateBlocked,
+            candidate_removed: false,
+            penalty_applied: 0.0,
+            weighted_logit_before: weighted_logit,
+            weighted_logit_after: Some(weighted_logit),
+            reason: decision.reasons.iter().find(|r| **r != TransitionReason::None).copied(),
+            blocked_by_gate: true,
+            gate_reason: gate.reason,
+        };
+    }
+
+    if controlled_hardblock_allowed(&cfg, decision) {
+        return TransitionControlledApplyResult {
+            effective: true,
+            action: TransitionControlledAction::HardBlock,
+            candidate_removed: true,
+            penalty_applied: 0.0,
+            weighted_logit_before: weighted_logit,
+            weighted_logit_after: None,
+            reason: decision.reasons.iter().find(|r| **r != TransitionReason::None).copied(),
+            blocked_by_gate: false,
+            gate_reason: None,
+        };
+    }
+
+    // SafeV1 forbids hard-blocking generic EOS, Korean ambiguity, punctuation, and emotional repeats.
+    if controlled_observe_only(&cfg, decision) {
+        return TransitionControlledApplyResult {
+            effective: true,
+            action: TransitionControlledAction::Observe,
+            candidate_removed: false,
+            penalty_applied: 0.0,
+            weighted_logit_before: weighted_logit,
+            weighted_logit_after: Some(weighted_logit),
+            reason: decision.reasons.iter().find(|r| **r != TransitionReason::None).copied(),
+            blocked_by_gate: false,
+            gate_reason: None,
+        };
+    }
+
+    let soft_penalty_reason = decision_has(decision, TransitionReason::GenericContinuationImmediateEos)
+        || decision_has(decision, TransitionReason::ByteTextBoundaryRisk)
+        || decision_has(decision, TransitionReason::RepeatedPunctuation)
+        || decision_has(decision, TransitionReason::DoubleParticleLike)
+        || decision_has(decision, TransitionReason::DoubleSentenceEndingLike);
+
+    if soft_penalty_reason && decision.risk > 0.0 {
+        let penalty = (decision.risk * cfg.soft_penalty_scale).min(cfg.max_soft_penalty);
+        return TransitionControlledApplyResult {
+            effective: true,
+            action: TransitionControlledAction::SoftPenalty,
+            candidate_removed: false,
+            penalty_applied: penalty,
+            weighted_logit_before: weighted_logit,
+            weighted_logit_after: Some(weighted_logit - penalty),
+            reason: decision.reasons.iter().find(|r| **r != TransitionReason::None).copied(),
+            blocked_by_gate: false,
+            gate_reason: None,
+        };
+    }
+
+    TransitionControlledApplyResult {
+        effective: true,
+        action: TransitionControlledAction::None,
+        candidate_removed: false,
+        penalty_applied: 0.0,
+        weighted_logit_before: weighted_logit,
+        weighted_logit_after: Some(weighted_logit),
+        reason: decision.reasons.iter().find(|r| **r != TransitionReason::None).copied(),
+        blocked_by_gate: false,
+        gate_reason: None,
+    }
+}
