+#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
+pub enum Decode03AMode {
+    Off,
+    Receipt,
+    Strict,
+}
+
+impl Decode03AMode {
+    pub fn from_env() -> Self {
+        let value = env::var("ASH_DECODE03A_ENTROPY")
+            .or_else(|_| env::var("ASH_DECODE03A_RECEIPT_MODE"))
+            .unwrap_or_else(|_| "off".to_string())
+            .trim()
+            .to_ascii_lowercase();
+        match value.as_str() {
+            "1" | "true" | "yes" | "on" | "receipt" | "probe" | "observe" => Self::Receipt,
+            "strict" => Self::Strict,
+            _ => Self::Off,
+        }
+    }
+
+    pub fn enabled(self) -> bool {
+        !matches!(self, Self::Off)
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::Receipt => "Receipt",
+            Self::Strict => "Strict",
+        }
+    }
+}
