+        "static_prior_stage_entropy_not_available_from_sampler03_bridge",
+    );
+    let unavailable_transition = metric(
+        DecodeEntropyStage::AfterTransitionGuard,
+        None,
+        None,
+        Some(source.cpu.pre_min_p_count),
+        None,
+        None,
+        None,
+        None,
+        None,
+        None,
+        "transition_stage_entropy_not_available_from_sampler03_bridge",
+    );
+    let after_topp = metric(
+        DecodeEntropyStage::AfterTopP,
+        source.cpu.final_entropy,
+        source.cpu.final_normalized_entropy,
+        Some(source.cpu.final_count),
+        source.cpu.final_top1_id,
+        source.cpu.final_top1_score,
+        source.cpu.final_top1_prob,
+        source.cpu.final_top2_id,
+        source.cpu.final_top2_score,
+        source.cpu.final_top2_prob,
+        "cpu_oracle_after_top_p_distribution",
+    );
+
+    let entropy_metrics = vec![
+        unavailable_raw,
+        unavailable_scaled,
+        unavailable_prior,
+        unavailable_transition,
+        after_minp,
+        after_topp,
+        final_active,
+    ];
+
+    let nan_seen = entropy_metrics.iter().any(|m| m.nan_seen);
+    let inf_seen = entropy_metrics.iter().any(|m| m.inf_seen);
+    let high_guarded_entropy = source.cpu.final_normalized_entropy.map(|h| h >= 0.80).unwrap_or(false);
+    let min_p_overcompression = (source.cpu.pre_min_p_count >= 100 && source.cpu.post_min_p_count <= 3)
+        || compression_ratio_min_p.map(|r| r <= 0.01).unwrap_or(false);
+    let top_p_overcompression = (source.cpu.post_min_p_count >= 20 && source.cpu.post_top_p_count <= 2)
+        || compression_ratio_top_p.map(|r| r <= 0.10 && source.cpu.post_min_p_count >= 20).unwrap_or(false);
+    let empty_active_set_seen = source.cpu.final_count == 0;
+    let global_finite_fallback_seen = is_global_finite_fallback(&fallback_mode);
+    let partial_entropy_trace = entropy_metrics.iter().any(|m| m.entropy.is_none());
+
+    Decode03AEntropyStepReceipt {
+        patch_id: DECODE03A_PATCH_ID.to_string(),
+        input_patch: DECODE03A_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: run_id_from_env(),
+        seed: None,
+        step: source.step,
+        backend: "sampler03_cpu_oracle_bridge".to_string(),
+        sampler_ssot: DECODE03A_SAMPLER_SSOT.to_string(),
+        behavior_change: false,
+        mode: mode.as_str().to_string(),
+        decode_config: Decode03ADecodeConfig {
+            temperature: source.decode_config.temperature,
+            top_p: source.decode_config.top_p,
+            top_k_requested: source.decode_config.top_k,
+            top_k_effective: source.decode_config.top_k,
+            min_p: source.decode_config.min_p,
+        },
+        static_prior_enabled: source.cpu.semantic_prior_effective,
+        transition_guard_enabled: source.cpu.transition_guard_enabled,
+        sampler05_required,
+        sampler05_parity_status: None,
+        entropy_metrics,
+        entropy_deltas: DecodeEntropyDeltas {
+            d_min_p: source.cpu.active_entropy.zip(source.cpu.final_entropy).map(|(a, f)| f - a),
+            d_top_p: source.cpu.active_entropy.zip(source.cpu.final_entropy).map(|(a, f)| f - a),
+            ..Default::default()
+        },
+        active_set_metrics: DecodeActiveSetMetrics {
+            active_count_raw: None,
+            active_count_after_static_prior: None,
+            active_count_after_transition_guard: Some(source.cpu.pre_min_p_count),
+            active_count_after_min_p,
+            active_count_after_top_p,
+            active_count_final: source.cpu.final_count,
+            compression_ratio_min_p,
+            compression_ratio_top_p,
+            compression_ratio_total,
+        },
+        confidence_seed_metrics: DecodeConfidenceSeedMetrics {
+            weighted_top1_id: source.cpu.weighted_top1_id,
+            weighted_top1_prob: source.cpu.weighted_top1_prob,
+            weighted_top1_score: source.cpu.weighted_top1_score,
+            weighted_top2_id: source.cpu.weighted_top2_id,
+            weighted_top2_prob: source.cpu.weighted_top2_prob,
+            weighted_top2_score: source.cpu.weighted_top2_score,
+            top1_top2_margin: margin(source.cpu.weighted_top1_score, source.cpu.weighted_top2_score),
+            selected_token_rank: selected_rank_final,
+            selected_token_prob: source.cpu.selected_logprob.map(|lp| lp.exp()),
+            selected_token_logprob: source.cpu.selected_logprob,
+            fallback_count_window: if fallback_mode == "none" { 0 } else { 1 },
+        },
+        selected_id: source.cpu.selected_id,
+        selected_piece_preview: None,
+        selected_rank_final,
+        selected_logprob_final: source.cpu.selected_logprob,
+        fallback_mode,
+        fallback_reason: if source.cpu.recovery_mode == "none" { None } else { Some(source.cpu.recovery_mode.clone()) },
+        risk_flags: Decode03ARiskFlags {
+            high_raw_entropy: false,
+            high_guarded_entropy,
+            entropy_spike: false,
+            guard_entropy_inversion: false,
+            min_p_overcompression,
+            top_p_overcompression,
+            empty_active_set_seen,
+            global_finite_fallback_seen,
+            nan_seen,
+            inf_seen,
+            partial_entropy_trace,
+        },
+    }
+}
+
+pub fn append_decode03a_receipt_from_sampler03(source: &SamplerParityReceipt) {
+    let mode = Decode03AMode::from_env();
+    if !mode.enabled() {
+        return;
+    }
+    if env_bool("ASH_DECODE03A_FAIL_ON_BEHAVIOR_CHANGE", true) {
+        // DECODE-03A is observe-only by contract. There is no mutation path here.
+    }
+    let receipt = receipt_from_sampler03(mode, source);
+    let path = receipt_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(line) = serde_json::to_string(&receipt) {
+        use std::io::Write;
+        if let Ok(mut file) = fs::OpenOptions::new().create(true).append(true).open(&path) {
+            let _ = writeln!(file, "{}", line);
+        }
+    }
+    write_decode03a_summary_from_receipt_file();
+}
+
+fn classify_summary_status(receipts: &[Decode03AEntropyStepReceipt]) -> String {
+    if receipts.is_empty() {
+        "STATIC_BAKE_DEFINED_NOT_RUN".to_string()
+    } else if receipts.iter().any(|r| r.behavior_change || r.risk_flags.nan_seen || r.risk_flags.inf_seen) {
+        "FAIL".to_string()
+    } else if receipts.iter().any(|r| r.risk_flags.partial_entropy_trace || r.risk_flags.min_p_overcompression || r.risk_flags.global_finite_fallback_seen) {
+        "PASS_WITH_WARNINGS".to_string()
+    } else {
+        "PASS".to_string()
+    }
+}
+
+pub fn summary_from_receipts(receipts: &[Decode03AEntropyStepReceipt]) -> Decode03AEntropySummary {
+    let steps_observed = receipts.len();
+    let status = classify_summary_status(receipts);
+    let partial_entropy_trace_count = receipts.iter().filter(|r| r.risk_flags.partial_entropy_trace).count();
+    let entropy_spike_count = receipts.iter().filter(|r| r.risk_flags.entropy_spike).count();
+    let guard_entropy_inversion_count = receipts.iter().filter(|r| r.risk_flags.guard_entropy_inversion).count();
+    let high_guarded_entropy_count = receipts.iter().filter(|r| r.risk_flags.high_guarded_entropy).count();
+    let min_p_overcompression_count = receipts.iter().filter(|r| r.risk_flags.min_p_overcompression).count();
+    let top_p_overcompression_count = receipts.iter().filter(|r| r.risk_flags.top_p_overcompression).count();
+    let empty_active_set_count = receipts.iter().filter(|r| r.risk_flags.empty_active_set_seen).count();
+    let global_finite_fallback_count = receipts.iter().filter(|r| r.risk_flags.global_finite_fallback_seen).count();
+    let nan_count = receipts.iter().filter(|r| r.risk_flags.nan_seen).count();
+    let inf_count = receipts.iter().filter(|r| r.risk_flags.inf_seen).count();
+    let selected_rank_gt_5_count = receipts.iter().filter(|r| r.selected_rank_final.map(|rank| rank > 5).unwrap_or(false)).count();
+    let ready_for_decode03b_pci = steps_observed > 0 && nan_count == 0 && inf_count == 0;
+    Decode03AEntropySummary {
+        patch_id: DECODE03A_PATCH_ID.to_string(),
+        input_patch: DECODE03A_INPUT_PATCH_ID.to_string(),
+        status: status.clone(),
+        behavior_change: false,
+        sampler_ssot: DECODE03A_SAMPLER_SSOT.to_string(),
+        requires_sampler05_pass: require_sampler05(),
+        steps_observed,
+        partial_entropy_trace_count,
+        entropy_spike_count,
+        guard_entropy_inversion_count,
+        high_guarded_entropy_count,
+        min_p_overcompression_count,
+        top_p_overcompression_count,
+        empty_active_set_count,
+        global_finite_fallback_count,
+        nan_count,
+        inf_count,
+        selected_rank_gt_5_count,
+        ready_for_decode03b_pci,
+        ready_for_decode03c_shadow_policy: false,
+        reason: if steps_observed == 0 {
+            "static bake only; run ASH_DECODE03A_ENTROPY=receipt with sampler parity to produce entropy evidence".to_string()
+        } else if ready_for_decode03b_pci {
+            "entropy/confidence seed metrics are available for DECODE-03B PCI; shadow policy remains blocked until PCI is sealed".to_string()
+        } else {
+            "numeric or behavior-change failure blocks PCI promotion".to_string()
+        },
+    }
+}
+
+pub fn write_decode03a_summary_from_receipt_file() {
+    let path = receipt_path();
+    let mut receipts = Vec::new();
+    if let Ok(text) = fs::read_to_string(&path) {
+        for line in text.lines() {
+            if line.trim().is_empty() {
+                continue;
+            }
+            if let Ok(receipt) = serde_json::from_str::<Decode03AEntropyStepReceipt>(line) {
+                receipts.push(receipt);
+            }
+        }
+    }
+    let summary = summary_from_receipts(&receipts);
+    let out = summary_path();
+    if let Some(parent) = out.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(text) = serde_json::to_string_pretty(&summary) {
+        let _ = fs::write(out, format!("{}\n", text));
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn decode03a_entropy_logsumexp_stable() {
+        let h = logsumexp_entropy(&[1.0, 1.0]).unwrap();
+        assert!((h - std::f32::consts::LN_2).abs() < 1e-5);
+    }
+
+    #[test]
+    fn decode03a_summary_static_not_run() {
+        let summary = summary_from_receipts(&[]);
+        assert_eq!(summary.status, "STATIC_BAKE_DEFINED_NOT_RUN");
+        assert!(!summary.ready_for_decode03b_pci);
+    }
+}
