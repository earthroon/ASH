+#[derive(Debug, Clone, Default)]
+struct DistributionStats {
+    entropy: Option<f32>,
+    normalized_entropy: Option<f32>,
+    top1_id: Option<u32>,
+    top1_score: Option<f32>,
+    top1_prob: Option<f32>,
+    top2_id: Option<u32>,
+    top2_score: Option<f32>,
+    top2_prob: Option<f32>,
+}
+
+fn distribution_stats(candidates: &[Candidate]) -> DistributionStats {
+    if candidates.is_empty() {
+        return DistributionStats::default();
+    }
+    let mut ordered = candidates.to_vec();
+    ordered.sort_by(|a, b| b.prob.total_cmp(&a.prob));
+    let entropy = ordered.iter().filter_map(|c| {
+        if c.prob.is_finite() && c.prob > 0.0 {
+            Some(-c.prob * c.prob.ln())
+        } else {
+            None
+        }
+    }).sum::<f32>();
+    let normalized_entropy = if ordered.len() > 1 {
+        let denom = (ordered.len() as f32).ln();
+        if denom.is_finite() && denom > 0.0 { Some(entropy / denom) } else { None }
+    } else {
+        None
+    };
+    let top1 = ordered.get(0);
+    let top2 = ordered.get(1);
+    DistributionStats {
+        entropy: Some(entropy),
+        normalized_entropy,
+        top1_id: top1.map(|c| c.id),
+        top1_score: top1.map(|c| c.weighted),
+        top1_prob: top1.map(|c| c.prob),
+        top2_id: top2.map(|c| c.id),
+        top2_score: top2.map(|c| c.weighted),
+        top2_prob: top2.map(|c| c.prob),
+    }
+}
