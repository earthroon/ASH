+}
+
+fn margin(top1: Option<f32>, top2: Option<f32>) -> Option<f32> {
+    top1.zip(top2).map(|(a, b)| a - b)
+}
+
+fn finite_flags(values: &[Option<f32>]) -> (bool, bool) {
+    let mut nan_seen = false;
+    let mut inf_seen = false;
+    for value in values.iter().flatten().copied() {
+        if value.is_nan() {
+            nan_seen = true;
+        }
+        if value.is_infinite() {
+            inf_seen = true;
+        }
+    }
+    (nan_seen, inf_seen)
+}
+
+fn metric(
+    stage: DecodeEntropyStage,
+    entropy: Option<f32>,
+    normalized_entropy: Option<f32>,
+    active_count: Option<usize>,
+    top1_id: Option<u32>,
+    top1_score: Option<f32>,
+    top1_prob: Option<f32>,
+    top2_id: Option<u32>,
+    top2_score: Option<f32>,
+    top2_prob: Option<f32>,
+    status: &str,
+) -> DecodeEntropyMetric {
+    let top1_top2_margin = margin(top1_score, top2_score);
+    let (nan_seen, inf_seen) = finite_flags(&[
+        entropy,
+        normalized_entropy,
+        top1_score,
+        top1_prob,
+        top2_score,
+        top2_prob,
+        top1_top2_margin,
+    ]);
+    DecodeEntropyMetric {
+        stage,
+        entropy,
+        normalized_entropy,
+        active_count,
+        finite_count: active_count,
+        top1_id,
+        top1_score,
+        top1_prob,
+        top2_id,
+        top2_score,
+        top2_prob,
+        top1_top2_margin,
+        nan_seen,
+        inf_seen,
+        metric_status: status.to_string(),
+    }
+}
+
+fn selected_rank(final_ids: &[u32], selected_id: u32) -> Option<usize> {
+    final_ids.iter().position(|id| *id == selected_id).map(|idx| idx + 1)
+}
+
+fn ratio(num: usize, denom: usize) -> Option<f32> {
+    if denom == 0 { None } else { Some(num as f32 / denom as f32) }
+}
+
+pub fn logsumexp_entropy(scores: &[f32]) -> Option<f32> {
+    let finite = scores.iter().copied().filter(|v| v.is_finite()).collect::<Vec<_>>();
+    if finite.is_empty() {
+        return None;
+    }
+    let max_score = finite.iter().copied().reduce(f32::max)?;
+    let mut sum_exp = 0.0f32;
+    let mut sum_exp_score = 0.0f32;
+    for score in finite {
+        let e = (score - max_score).exp();
+        sum_exp += e;
+        sum_exp_score += e * score;
+    }
+    if !sum_exp.is_finite() || sum_exp <= 0.0 {
+        return None;
+    }
+    Some(sum_exp.ln() + max_score - (sum_exp_score / sum_exp))
+}
