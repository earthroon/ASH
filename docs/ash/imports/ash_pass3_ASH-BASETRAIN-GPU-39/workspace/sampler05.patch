+use serde::{Deserialize, Serialize};
+use std::{env, fs, path::PathBuf};
+
+use crate::sampler_parity::SamplerParityReceipt;
+
+pub const SAMPLER05_PATCH_ID: &str = "16AI-QW-38G-R6A-SAMPLER-05";
+pub const SAMPLER05_INPUT_PATCH_ID: &str = "16AI-QW-38G-R6A-SAMPLER-04";
+pub const SAMPLER05_CPU_SSOT: &str = "model_core::cpu_oracle_sampler";
+pub const SAMPLER05_GPU_PROJECTION: &str = "burn_webgpu_backend::gpu_sampling_topp_scan.wgsl";
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
+pub enum Sampler05Mode {
+    Off,
+    Receipt,
+    Strict,
+}
+
+impl Sampler05Mode {
+    pub fn from_env() -> Self {
+        let value = env::var("ASH_SAMPLER05_PARITY")
+            .or_else(|_| env::var("ASH_SAMPLER05_VALIDATE"))
+            .unwrap_or_else(|_| "off".to_string())
+            .trim()
+            .to_ascii_lowercase();
+        match value.as_str() {
+            "1" | "true" | "yes" | "on" | "receipt" | "probe" | "probe_only" => Self::Receipt,
+            "strict" => Self::Strict,
+            _ => Self::Off,
+        }
+    }
+
+    pub fn enabled(self) -> bool {
+        !matches!(self, Self::Off)
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::Receipt => "Receipt",
+            Self::Strict => "Strict",
+        }
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct Sampler05DecodeConfig {
+    pub temperature: f32,
+    pub top_k: u32,
+    pub top_p: f32,
+    pub min_p: f32,
+    pub top_k_policy: String,
+    pub forbid_global_fallback: bool,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct Sampler05TraceSide {
+    pub selected_id: u32,
+    pub selected_logprob: Option<f32>,
+    pub active_count: Option<usize>,
+    pub final_count: Option<usize>,
+    pub min_p_threshold: Option<f32>,
+    pub min_p_threshold_score_kind: String,
+    pub active_max: Option<f32>,
+    pub active_sum_exp: Option<f32>,
+    pub fallback_mode: Option<String>,
+    pub active_ids_head: Vec<u32>,
+    pub final_ids_head: Vec<u32>,
+    pub trace_completeness: String,
+    pub transition_guard_enabled: bool,
+    pub transition_guard_probe_only: bool,
+    pub selected_transition_action_code: Option<u32>,
+    pub selected_transition_reason_mask: Option<u32>,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct Sampler05ParityStatus {
+    pub threshold_kind_match: bool,
+    pub threshold_value_match: Option<bool>,
+    pub active_count_match: Option<bool>,
+    pub final_count_match: Option<bool>,
+    pub active_set_match: Option<bool>,
+    pub final_set_match: Option<bool>,
+    pub selected_id_match: bool,
+    pub fallback_match: Option<bool>,
+    pub transition_hardblock_safe: Option<bool>,
+    pub global_finite_fallback_forbidden: bool,
+    pub status: String,
+    pub reason: String,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct Sampler05ParityReceipt {
+    pub patch_id: String,
+    pub input_patch: String,
+    pub step: usize,
+    pub fixture_id: String,
+    pub mode: String,
+    pub semantic_reference: String,
+    pub gpu_projection: String,
+    pub behavior_change: bool,
+    pub decode_config: Sampler05DecodeConfig,
+    pub cpu: Sampler05TraceSide,
+    pub gpu: Sampler05TraceSide,
+    pub parity: Sampler05ParityStatus,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct Sampler05TopKPolicySummary {
+    pub policy: String,
+    pub transition_aware_topk: bool,
+    pub parity_safe_bypass_available: bool,
+    pub env_var: String,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct Sampler05Summary {
+    pub patch_id: String,
+    pub input_patch: String,
+    pub status: String,
+    pub cpu_oracle_is_sampler_ssot: bool,
+    pub semantic_reference: String,
+    pub gpu_projection: String,
+    pub behavior_change_default: bool,
+    pub receipt: String,
+    pub checked_steps: usize,
+    pub pass_steps: usize,
+    pub warn_steps: usize,
+    pub fail_steps: usize,
+    pub threshold_kind_cpu: String,
+    pub threshold_kind_gpu: String,
+    pub min_p_threshold_score_kind_match: bool,
+    pub top_k_policy: Sampler05TopKPolicySummary,
+    pub global_finite_fallback_count: usize,
+    pub ready_for_decode03a_entropy_receipt: bool,
+    pub ready_for_dynamic_sampler: bool,
+    pub reason: String,
+}
+
+pub fn receipt_path() -> PathBuf {
+    env::var("ASH_SAMPLER05_RECEIPT")
+        .map(PathBuf::from)
+        .unwrap_or_else(|_| PathBuf::from("workspace/sampler05_parity_steps.jsonl"))
+}
+
+pub fn summary_path() -> PathBuf {
+    env::var("ASH_SAMPLER05_SUMMARY")
+        .map(PathBuf::from)
+        .unwrap_or_else(|_| PathBuf::from("workspace/sampler05_summary.json"))
+}
+
+pub fn fixture_id() -> String {
+    env::var("ASH_SAMPLER05_FIXTURE")
+        .ok()
+        .filter(|v| !v.trim().is_empty())
+        .unwrap_or_else(|| "runtime_sampler03_bridge".to_string())
+}
+
+pub fn top_k_policy_from_env() -> String {
+    env::var("ASH_SAMPLER05_TOPK_POLICY")
+        .unwrap_or_else(|_| "observe_only".to_string())
+}
+
+pub fn forbid_global_fallback_from_env() -> bool {
+    env_bool("ASH_SAMPLER05_FORBID_GLOBAL_FALLBACK", true)
+}
+
+fn env_bool(name: &str, default: bool) -> bool {
+    env::var(name)
+        .ok()
+        .map(|v| matches!(v.trim().to_ascii_lowercase().as_str(), "1" | "true" | "yes" | "on"))
+        .unwrap_or(default)
+}
+
+fn sorted_equal(a: &[u32], b: &[u32]) -> bool {
+    let mut aa = a.to_vec();
+    let mut bb = b.to_vec();
+    aa.sort_unstable();
+    bb.sort_unstable();
+    aa == bb
+}
+
+fn threshold_value_match(a: Option<f32>, b: Option<f32>) -> Option<bool> {
+    match (a, b) {
+        (Some(x), Some(y)) => Some((x - y).abs() <= 1e-4),
+        (None, None) => Some(true),
+        _ => None,
+    }
+}
+
+fn is_global_finite_fallback(mode: Option<&str>) -> bool {
+    matches!(mode, Some("valid_global_top1") | Some("GLOBAL_FINITE_FALLBACK") | Some("global_finite_fallback"))
+}
+
+fn side_from_cpu(receipt: &SamplerParityReceipt) -> Sampler05TraceSide {
+    Sampler05TraceSide {
+        selected_id: receipt.cpu.selected_id,
+        selected_logprob: receipt.cpu.selected_logprob,
+        active_count: Some(receipt.cpu.active_count),
+        final_count: Some(receipt.cpu.final_count),
+        min_p_threshold: receipt.cpu.min_p_threshold,
+        // SAMPLER-05 SSOT: cpu_oracle_sampler applies min-p over weighted score
+        // after temperature/static-prior/transition-guard processing.
+        min_p_threshold_score_kind: "weighted".to_string(),
+        active_max: receipt.cpu.active_max,
+        active_sum_exp: receipt.cpu.active_sum_exp,
+        fallback_mode: Some(receipt.cpu.recovery_mode.clone()),
+        active_ids_head: receipt.cpu.active_ids_head.clone(),
+        final_ids_head: receipt.cpu.final_ids_head.clone(),
+        trace_completeness: "cpu_oracle_full_candidate_trace".to_string(),
+        transition_guard_enabled: receipt.cpu.transition_guard_enabled,
+        transition_guard_probe_only: receipt.cpu.transition_guard_probe_only,
+        selected_transition_action_code: receipt.cpu.selected_transition_action_code,
+        selected_transition_reason_mask: receipt.cpu.selected_transition_reason_mask,
+    }
+}
+
+fn side_from_gpu(receipt: &SamplerParityReceipt) -> Sampler05TraceSide {
+    Sampler05TraceSide {
+        selected_id: receipt.gpu.selected_id,
+        selected_logprob: receipt.gpu.selected_logprob,
+        active_count: receipt.gpu.active_count,
+        final_count: receipt.gpu.final_count,
+        min_p_threshold: receipt.gpu.min_p_threshold,
+        // SAMPLER-05 pairs this receipt layer with the WGSL patch that computes
+        // pre_minp_max via weighted_logit_at(index). If the shader is reverted,
+        // sampler05_static_checks must fail and this receipt must not promote.
+        min_p_threshold_score_kind: "weighted".to_string(),
+        active_max: receipt.gpu.active_max,
+        active_sum_exp: receipt.gpu.active_sum_exp,
+        fallback_mode: receipt.gpu.recovery_mode.clone(),
+        active_ids_head: receipt.gpu.active_ids_head.clone(),
+        final_ids_head: receipt.gpu.final_ids_head.clone(),
+        trace_completeness: receipt.gpu.trace_completeness.clone(),
+        transition_guard_enabled: receipt.gpu.transition_guard_enabled,
+        transition_guard_probe_only: receipt.gpu.transition_guard_probe_only,
+        selected_transition_action_code: receipt.gpu.selected_transition_action_code,
+        selected_transition_reason_mask: receipt.gpu.selected_transition_reason_mask,
+    }
+}
+
+pub fn receipt_from_sampler03(mode: Sampler05Mode, source: &SamplerParityReceipt) -> Sampler05ParityReceipt {
+    let cpu = side_from_cpu(source);
+    let gpu = side_from_gpu(source);
+    let threshold_kind_match = cpu.min_p_threshold_score_kind == gpu.min_p_threshold_score_kind;
+    let threshold_value_match = threshold_value_match(cpu.min_p_threshold, gpu.min_p_threshold);
+    let active_count_match = cpu.active_count.zip(gpu.active_count).map(|(c, g)| c == g);
+    let final_count_match = cpu.final_count.zip(gpu.final_count).map(|(c, g)| c == g);
+    let active_set_match = if !cpu.active_ids_head.is_empty() || !gpu.active_ids_head.is_empty() {
+        Some(sorted_equal(&cpu.active_ids_head, &gpu.active_ids_head))
+    } else {
+        None
+    };
+    let final_set_match = if !cpu.final_ids_head.is_empty() || !gpu.final_ids_head.is_empty() {
+        Some(sorted_equal(&cpu.final_ids_head, &gpu.final_ids_head))
+    } else {
+        None
+    };
+    let selected_id_match = cpu.selected_id == gpu.selected_id;
+    let fallback_match = match (cpu.fallback_mode.as_ref(), gpu.fallback_mode.as_ref()) {
+        (Some(c), Some(g)) => Some(c == g),
+        (None, None) => Some(true),
+        _ => None,
+    };
+    let transition_hardblock_safe = match (cpu.selected_transition_action_code, gpu.selected_transition_action_code) {
+        (Some(c), Some(g)) => Some(c == g || (c != 2 && g != 2)),
+        _ => None,
+    };
+    let global_finite_fallback_forbidden = forbid_global_fallback_from_env();
+    let global_fallback_seen = is_global_finite_fallback(cpu.fallback_mode.as_deref())
+        || is_global_finite_fallback(gpu.fallback_mode.as_deref());
+
+    let (status, reason) = if !threshold_kind_match {
+        ("FAIL_THRESHOLD_KIND_MISMATCH", "CPU/GPU min-p threshold score kind differs")
+    } else if threshold_value_match == Some(false) {
+        ("FAIL_THRESHOLD_VALUE_MISMATCH", "CPU/GPU min-p threshold value differs beyond tolerance")
+    } else if active_count_match == Some(false) {
+        ("FAIL_ACTIVE_COUNT_MISMATCH", "CPU/GPU active count differs")
+    } else if final_count_match == Some(false) {
+        ("FAIL_FINAL_COUNT_MISMATCH", "CPU/GPU final count differs")
+    } else if active_set_match == Some(false) {
+        ("FAIL_ACTIVE_SET_MISMATCH", "CPU/GPU active id head differs")
+    } else if final_set_match == Some(false) {
+        ("FAIL_FINAL_SET_MISMATCH", "CPU/GPU final id head differs")
+    } else if transition_hardblock_safe == Some(false) {
+        ("FAIL_TRANSITION_HARDBLOCK_UNSAFE", "GPU selected transition hardblock decision is unsafe")
+    } else if global_finite_fallback_forbidden && global_fallback_seen {
+        ("FAIL_GLOBAL_FINITE_FALLBACK", "global finite fallback is forbidden by SAMPLER-05")
+    } else if !selected_id_match {
+        ("WARN_SELECTED_ID_MISMATCH", "candidate evidence is compatible but selected id differs")
+    } else if active_set_match.is_none() || final_set_match.is_none() {
+        ("WARN_PARTIAL_TRACE", "candidate id trace is partial or unavailable")
+    } else {
+        ("PASS", "CPU oracle and GPU active-set evidence match")
+    };
+
+    Sampler05ParityReceipt {
+        patch_id: SAMPLER05_PATCH_ID.to_string(),
+        input_patch: SAMPLER05_INPUT_PATCH_ID.to_string(),
+        step: source.step,
+        fixture_id: fixture_id(),
+        mode: mode.as_str().to_string(),
+        semantic_reference: SAMPLER05_CPU_SSOT.to_string(),
+        gpu_projection: SAMPLER05_GPU_PROJECTION.to_string(),
+        behavior_change: false,
+        decode_config: Sampler05DecodeConfig {
+            temperature: source.decode_config.temperature,
+            top_k: source.decode_config.top_k,
+            top_p: source.decode_config.top_p,
+            min_p: source.decode_config.min_p,
+            top_k_policy: top_k_policy_from_env(),
+            forbid_global_fallback: global_finite_fallback_forbidden,
+        },
+        cpu,
+        gpu,
+        parity: Sampler05ParityStatus {
+            threshold_kind_match,
+            threshold_value_match,
+            active_count_match,
+            final_count_match,
+            active_set_match,
+            final_set_match,
+            selected_id_match,
+            fallback_match,
+            transition_hardblock_safe,
+            global_finite_fallback_forbidden,
+            status: status.to_string(),
+            reason: reason.to_string(),
+        },
+    }
+}
