++pub fn summary_from_receipts(receipts: &[Sampler05ParityReceipt]) -> Sampler05Summary {
++    let checked_steps = receipts.len();
++    let mut pass_steps = 0usize;
++    let mut warn_steps = 0usize;
++    let mut fail_steps = 0usize;
++    let mut global_finite_fallback_count = 0usize;
++    for receipt in receipts {
++        match classify_status(&receipt.parity.status) {
++            "fail" => fail_steps = fail_steps.saturating_add(1),
++            "warn" => warn_steps = warn_steps.saturating_add(1),
++            _ => pass_steps = pass_steps.saturating_add(1),
++        }
++        if is_global_finite_fallback(receipt.cpu.fallback_mode.as_deref())
++            || is_global_finite_fallback(receipt.gpu.fallback_mode.as_deref())
++        {
++            global_finite_fallback_count = global_finite_fallback_count.saturating_add(1);
++        }
++    }
++
++    let status = if checked_steps == 0 {
++        "STATIC_BAKE_DEFINED_NOT_RUN"
++    } else if fail_steps > 0 {
++        "FAIL"
++    } else if warn_steps > 0 {
++        "PASS_WITH_WARNINGS"
++    } else {
++        "PASS"
++    };
++    let ready_for_decode03a = checked_steps > 0 && fail_steps == 0;
++
++    Sampler05Summary {
++        patch_id: SAMPLER05_PATCH_ID.to_string(),
++        input_patch: SAMPLER05_INPUT_PATCH_ID.to_string(),
++        status: status.to_string(),
++        cpu_oracle_is_sampler_ssot: true,
++        semantic_reference: SAMPLER05_CPU_SSOT.to_string(),
++        gpu_projection: SAMPLER05_GPU_PROJECTION.to_string(),
++        behavior_change_default: false,
++        receipt: receipt_path().to_string_lossy().to_string(),
++        checked_steps,
++        pass_steps,
++        warn_steps,
++        fail_steps,
++        threshold_kind_cpu: "weighted".to_string(),
++        threshold_kind_gpu: "weighted".to_string(),
++        min_p_threshold_score_kind_match: true,
++        top_k_policy: Sampler05TopKPolicySummary {
++            policy: top_k_policy_from_env(),
++            transition_aware_topk: false,
++            parity_safe_bypass_available: true,
++            env_var: "ASH_SAMPLER05_TOPK_POLICY=bypass_if_not_transition_aware".to_string(),
++        },
++        global_finite_fallback_count,
++        ready_for_decode03a_entropy_receipt: ready_for_decode03a,
++        ready_for_dynamic_sampler: false,
++        reason: if ready_for_decode03a {
++            "SAMPLER-05 evidence has no fail steps; DECODE-03A may attach entropy metrics next".to_string()
++        } else if checked_steps == 0 {
++            "static bake only; runtime parity probe must be executed before dynamic sampler promotion".to_string()
++        } else {
++            "runtime parity failures block entropy/dynamic sampler promotion".to_string()
++        },
++    }
++}
