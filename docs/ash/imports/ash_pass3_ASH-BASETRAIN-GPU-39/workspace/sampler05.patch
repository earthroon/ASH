++pub fn receipt_from_sampler03(mode: Sampler05Mode, source: &SamplerParityReceipt) -> Sampler05ParityReceipt {
++    let cpu = side_from_cpu(source);
++    let gpu = side_from_gpu(source);
++    let threshold_kind_match = cpu.min_p_threshold_score_kind == gpu.min_p_threshold_score_kind;
++    let threshold_value_match = threshold_value_match(cpu.min_p_threshold, gpu.min_p_threshold);
++    let active_count_match = cpu.active_count.zip(gpu.active_count).map(|(c, g)| c == g);
++    let final_count_match = cpu.final_count.zip(gpu.final_count).map(|(c, g)| c == g);
++    let active_set_match = if !cpu.active_ids_head.is_empty() || !gpu.active_ids_head.is_empty() {
++        Some(sorted_equal(&cpu.active_ids_head, &gpu.active_ids_head))
++    } else {
++        None
++    };
++    let final_set_match = if !cpu.final_ids_head.is_empty() || !gpu.final_ids_head.is_empty() {
++        Some(sorted_equal(&cpu.final_ids_head, &gpu.final_ids_head))
++    } else {
++        None
++    };
++    let selected_id_match = cpu.selected_id == gpu.selected_id;
++    let fallback_match = match (cpu.fallback_mode.as_ref(), gpu.fallback_mode.as_ref()) {
++        (Some(c), Some(g)) => Some(c == g),
++        (None, None) => Some(true),
++        _ => None,
++    };
++    let transition_hardblock_safe = match (cpu.selected_transition_action_code, gpu.selected_transition_action_code) {
++        (Some(c), Some(g)) => Some(c == g || (c != 2 && g != 2)),
++        _ => None,
++    };
++    let global_finite_fallback_forbidden = forbid_global_fallback_from_env();
++    let global_fallback_seen = is_global_finite_fallback(cpu.fallback_mode.as_deref())
++        || is_global_finite_fallback(gpu.fallback_mode.as_deref());
++
++    let (status, reason) = if !threshold_kind_match {
++        ("FAIL_THRESHOLD_KIND_MISMATCH", "CPU/GPU min-p threshold score kind differs")
++    } else if threshold_value_match == Some(false) {
++        ("FAIL_THRESHOLD_VALUE_MISMATCH", "CPU/GPU min-p threshold value differs beyond tolerance")
++    } else if active_count_match == Some(false) {
++        ("FAIL_ACTIVE_COUNT_MISMATCH", "CPU/GPU active count differs")
++    } else if final_count_match == Some(false) {
++        ("FAIL_FINAL_COUNT_MISMATCH", "CPU/GPU final count differs")
++    } else if active_set_match == Some(false) {
++        ("FAIL_ACTIVE_SET_MISMATCH", "CPU/GPU active id head differs")
++    } else if final_set_match == Some(false) {
++        ("FAIL_FINAL_SET_MISMATCH", "CPU/GPU final id head differs")
++    } else if transition_hardblock_safe == Some(false) {
++        ("FAIL_TRANSITION_HARDBLOCK_UNSAFE", "GPU selected transition hardblock decision is unsafe")
++    } else if global_finite_fallback_forbidden && global_fallback_seen {
++        ("FAIL_GLOBAL_FINITE_FALLBACK", "global finite fallback is forbidden by SAMPLER-05")
++    } else if !selected_id_match {
++        ("WARN_SELECTED_ID_MISMATCH", "candidate evidence is compatible but selected id differs")
++    } else if active_set_match.is_none() || final_set_match.is_none() {
++        ("WARN_PARTIAL_TRACE", "candidate id trace is partial or unavailable")
++    } else {
++        ("PASS", "CPU oracle and GPU active-set evidence match")
++    };
++
++    Sampler05ParityReceipt {
++        patch_id: SAMPLER05_PATCH_ID.to_string(),
++        input_patch: SAMPLER05_INPUT_PATCH_ID.to_string(),
++        step: source.step,
++        fixture_id: fixture_id(),
++        mode: mode.as_str().to_string(),
++        semantic_reference: SAMPLER05_CPU_SSOT.to_string(),
++        gpu_projection: SAMPLER05_GPU_PROJECTION.to_string(),
++        behavior_change: false,
++        decode_config: Sampler05DecodeConfig {
++            temperature: source.decode_config.temperature,
++            top_k: source.decode_config.top_k,
++            top_p: source.decode_config.top_p,
++            min_p: source.decode_config.min_p,
++            top_k_policy: top_k_policy_from_env(),
++            forbid_global_fallback: global_finite_fallback_forbidden,
++        },
++        cpu,
++        gpu,
++        parity: Sampler05ParityStatus {
++            threshold_kind_match,
++            threshold_value_match,
++            active_count_match,
++            final_count_match,
++            active_set_match,
++            final_set_match,
++            selected_id_match,
++            fallback_match,
++            transition_hardblock_safe,
++            global_finite_fallback_forbidden,
++            status: status.to_string(),
++            reason: reason.to_string(),
++        },
++    }
++}
