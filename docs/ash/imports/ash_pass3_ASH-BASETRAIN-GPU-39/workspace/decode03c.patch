+pub fn append_decode03c_receipt_from_sampler03(source: &SamplerParityReceipt) {
+    let mode = Decode03CMode::from_env();
+    if !mode.enabled() {
+        return;
+    }
+    let entropy_receipt = receipt_from_sampler03(Decode03AMode::Receipt, source);
+    let pci_receipt = receipt_from_decode03a(Decode03BMode::Receipt, &entropy_receipt, None, 0);
+    let receipt = receipt_from_decode03b(mode, &pci_receipt, Some(&entropy_receipt));
+    let path = receipt_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(line) = serde_json::to_string(&receipt) {
+        use std::io::Write;
+        if let Ok(mut file) = fs::OpenOptions::new().create(true).append(true).open(path) {
+            let _ = writeln!(file, "{}", line);
+        }
+    }
+}
+
+fn stats(values: &[f32]) -> (Option<f32>, Option<f32>, Option<f32>) {
+    let values = values.iter().copied().filter(|v| v.is_finite()).collect::<Vec<_>>();
+    if values.is_empty() {
+        return (None, None, None);
+    }
+    let min = values.iter().copied().fold(f32::INFINITY, f32::min);
+    let max = values.iter().copied().fold(f32::NEG_INFINITY, f32::max);
+    let mean = values.iter().sum::<f32>() / values.len() as f32;
+    (Some(min), Some(mean), Some(max))
+}
+
+pub fn summary_from_receipts(receipts: &[Decode03CStepReceipt]) -> Decode03CShadowSummary {
+    let mut policy_buckets = Decode03CPolicyBucketCounts::default();
+    let mut policy_actions = Decode03CPolicyActionCounts::default();
+    let mut reasons: BTreeMap<String, usize> = BTreeMap::new();
+    let mut temp = Vec::new();
+    let mut minp = Vec::new();
+    let mut topp = Vec::new();
+    for receipt in receipts {
+        match receipt.shadow_policy.bucket {
+            DynamicSamplerBucket::ConfidentPath => policy_buckets.confident_path_count += 1,
+            DynamicSamplerBucket::StablePath => policy_buckets.stable_path_count += 1,
+            DynamicSamplerBucket::UncertainPath => policy_buckets.uncertain_path_count += 1,
+            DynamicSamplerBucket::UnstablePath => policy_buckets.unstable_path_count += 1,
+            DynamicSamplerBucket::CollapsingPath => policy_buckets.collapsing_path_count += 1,
+        }
+        if receipt.would_change_behavior { policy_actions.would_change_behavior_count += 1; }
+        if receipt.would_tighten { policy_actions.would_tighten_count += 1; }
+        if receipt.would_relax { policy_actions.would_relax_count += 1; }
+        if receipt.would_panic { policy_actions.would_panic_count += 1; }
+        if receipt.shadow_policy.rollback_candidate { policy_actions.rollback_candidate_count += 1; }
+        if receipt.shadow_policy.safe_stop_candidate { policy_actions.safe_stop_candidate_count += 1; }
+        if receipt.shadow_policy.eos_bias_candidate { policy_actions.eos_bias_candidate_count += 1; }
+        for reason in &receipt.shadow_policy.policy_reason {
+            *reasons.entry(reason.clone()).or_insert(0) += 1;
+        }
+        temp.push(receipt.shadow_policy.shadow_temperature);
+        minp.push(receipt.shadow_policy.shadow_min_p);
+        topp.push(receipt.shadow_policy.shadow_top_p);
+    }
+    let (temperature_shadow_min, temperature_shadow_mean, temperature_shadow_max) = stats(&temp);
+    let (min_p_shadow_min, min_p_shadow_mean, min_p_shadow_max) = stats(&minp);
+    let (top_p_shadow_min, top_p_shadow_mean, top_p_shadow_max) = stats(&topp);
+    let steps_observed = receipts.len();
+    let status = if steps_observed == 0 {
+        "STATIC_BAKE_DEFINED_NOT_RUN"
+    } else if receipts.iter().any(|r| r.behavior_change || !r.shadow_only) {
+        "FAIL_BEHAVIOR_CHANGE"
+    } else if policy_actions.would_panic_count > 0 || policy_actions.rollback_candidate_count > 0 {
+        "PASS_WITH_WARNINGS"
+    } else {
+        "PASS"
+    }
+    .to_string();
+    let ready_for_decode03d_controlled_enable = steps_observed > 0
+        && !receipts.iter().any(|r| r.behavior_change || !r.shadow_only);
+    Decode03CShadowSummary {
+        patch_id: DECODE03C_PATCH_ID.to_string(),
+        input_patch: DECODE03C_INPUT_PATCH_ID.to_string(),
+        status,
+        behavior_change: false,
+        shadow_only: true,
+        requires_decode03b: require_decode03b(),
+        decode03b_status_seen: if steps_observed > 0 { Some("OBSERVED_OR_DERIVED".to_string()) } else { None },
+        decode03a_status_seen: receipts.iter().find_map(|r| r.decode03a_status_seen.clone()),
+        sampler05_status_seen: receipts.iter().find_map(|r| r.sampler05_status_seen.clone()),
+        steps_observed,
+        policy_buckets,
+        policy_actions,
+        shadow_config_stats: Decode03CShadowConfigStats {
+            temperature_shadow_min,
+            temperature_shadow_mean,
+            temperature_shadow_max,
+            min_p_shadow_min,
+            min_p_shadow_mean,
+            min_p_shadow_max,
+            top_p_shadow_min,
+            top_p_shadow_mean,
+            top_p_shadow_max,
+        },
+        risk_policy_reasons: reasons,
+        ready_for_decode03d_controlled_enable,
+        ready_for_default_enable: false,
+        reason: if steps_observed == 0 {
+            "static bake only; run ASH_DECODE03C_SHADOW=receipt after DECODE-03B PCI to produce shadow policy evidence".to_string()
+        } else if ready_for_decode03d_controlled_enable {
+            "shadow policy sealed; DECODE-03D may consume shadow values only under controlled enable, not default-on".to_string()
+        } else {
+            "shadow policy failed observe-only contract; controlled enable is blocked".to_string()
+        },
+    }
+}
+
+pub fn write_decode03c_summary_from_receipt_file() {
+    let path = receipt_path();
+    let mut receipts = Vec::new();
+    if let Ok(text) = fs::read_to_string(&path) {
+        for line in text.lines() {
+            if line.trim().is_empty() {
+                continue;
+            }
+            if let Ok(receipt) = serde_json::from_str::<Decode03CStepReceipt>(line) {
+                receipts.push(receipt);
+            }
+        }
+    }
+    let summary = summary_from_receipts(&receipts);
+    let out = summary_path();
+    if let Some(parent) = out.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(text) = serde_json::to_string_pretty(&summary) {
+        let _ = fs::write(out, format!("{}\n", text));
+    }
+}
