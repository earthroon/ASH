+pub fn receipt_from_decode03b(
+    mode: Decode03CMode,
+    pci_receipt: &Decode03BPciStepReceipt,
+    entropy_receipt: Option<&Decode03AEntropyStepReceipt>,
+) -> Decode03CStepReceipt {
+    let input = input_from_decode03b(pci_receipt, entropy_receipt);
+    let shadow_policy = compute_shadow_policy(&input);
+    let effect = classify_shadow_effect(&input, &shadow_policy);
+    Decode03CStepReceipt {
+        patch_id: DECODE03C_PATCH_ID.to_string(),
+        input_patch: DECODE03C_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: run_id_from_env(),
+        prompt_hash: pci_receipt.prompt_hash.clone(),
+        seed: pci_receipt.seed,
+        step: pci_receipt.step,
+        backend: "decode03b_pci_bridge".to_string(),
+        sampler_ssot: DECODE03C_SAMPLER_SSOT.to_string(),
+        behavior_change: false,
+        shadow_only: true,
+        mode: mode.as_str().to_string(),
+        decode03a_status_seen: pci_receipt.decode03a_status_seen.clone(),
+        decode03b_status_seen: Some("DERIVED_IN_MEMORY_FROM_DECODE03B_RECEIPT".to_string()),
+        sampler05_status_seen: pci_receipt.sampler05_status_seen.clone(),
+        input,
+        shadow_policy,
+        would_change_behavior: effect.would_change_behavior,
+        would_tighten: effect.would_tighten,
+        would_relax: effect.would_relax,
+        would_panic: effect.would_panic,
+    }
+}
