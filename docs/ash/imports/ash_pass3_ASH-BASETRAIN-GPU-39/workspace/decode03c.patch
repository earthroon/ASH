+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    fn input_for(bucket: PciBucket) -> Decode03CShadowInput {
+        Decode03CShadowInput {
+            pci_raw: 0.75,
+            pci_smoothed: None,
+            bucket_raw: bucket,
+            bucket_stable: bucket,
+            h_raw_norm: Some(0.4),
+            h_final_norm: Some(0.35),
+            top1_top2_margin: Some(0.8),
+            selected_rank: Some(1),
+            selected_logprob: Some(-1.0),
+            active_count_final: 32,
+            compression_ratio_total: Some(0.01),
+            low_confidence: false,
+            collapsing: false,
+            entropy_conflict: false,
+            margin_collapse: false,
+            selected_rank_risk: false,
+            fallback_risk: false,
+            overcompression_risk: false,
+            numeric_risk: false,
+            current_temperature: 0.25,
+            current_top_p: 0.88,
+            current_top_k: 0,
+            current_min_p: 0.05,
+            static_prior_enabled: true,
+            transition_guard_enabled: true,
+        }
+    }
+
+    #[test]
+    fn decode03c_bucket_mapping() {
+        assert_eq!(bucket_to_dynamic_bucket(PciBucket::Confident), DynamicSamplerBucket::ConfidentPath);
+        assert_eq!(bucket_to_dynamic_bucket(PciBucket::Collapsing), DynamicSamplerBucket::CollapsingPath);
+    }
+
+    #[test]
+    fn decode03c_shadow_never_changes_behavior() {
+        let policy = compute_shadow_policy(&input_for(PciBucket::Stable));
+        assert!(policy.shadow_only);
+        assert!(!policy.behavior_change);
+    }
+
+    #[test]
+    fn decode03c_uncertain_tightens() {
+        let input = input_for(PciBucket::Uncertain);
+        let policy = compute_shadow_policy(&input);
+        assert!(policy.shadow_min_p >= input.current_min_p);
+        assert!(matches!(policy.guard_strength, ShadowGuardStrength::Strict | ShadowGuardStrength::Panic));
+    }
+
+    #[test]
+    fn decode03c_numeric_risk_forces_panic() {
+        let mut input = input_for(PciBucket::Stable);
+        input.numeric_risk = true;
+        let policy = compute_shadow_policy(&input);
+        assert!(matches!(policy.guard_strength, ShadowGuardStrength::Panic));
+        assert!(policy.safe_stop_candidate);
+        assert!(policy.eos_bias_candidate);
+    }
+
+    #[test]
+    fn decode03c_clamps_policy_values() {
+        let mut policy = base_policy_for_bucket(DynamicSamplerBucket::StablePath, &input_for(PciBucket::Stable));
+        policy.shadow_temperature = -100.0;
+        policy.shadow_min_p = 999.0;
+        policy.shadow_top_p = 999.0;
+        let policy = clamp_shadow_policy(policy);
+        assert!(policy.shadow_temperature >= 0.03 && policy.shadow_temperature <= 1.20);
+        assert!(policy.shadow_min_p >= 0.0 && policy.shadow_min_p <= 0.25);
+        assert!(policy.shadow_top_p >= 0.50 && policy.shadow_top_p <= 1.0);
+    }
+}
