++pub fn apply_risk_adjustments(
++    mut policy: Decode03CShadowPolicy,
++    input: &Decode03CShadowInput,
++) -> Decode03CShadowPolicy {
++    if input.numeric_risk {
++        policy.guard_strength = ShadowGuardStrength::Panic;
++        policy.rollback_candidate = true;
++        policy.safe_stop_candidate = true;
++        policy.eos_bias_candidate = true;
++        policy.shadow_temperature = 0.05;
++        policy.shadow_min_p = 0.18;
++        policy.shadow_top_p = 0.70;
++        policy.no_repeat_ngram_shadow = Some(3);
++        policy.repeat_penalty_shadow = Some(1.12);
++        policy.policy_reason.push("numeric_risk_safe_stop".to_string());
++        return policy;
++    }
++    if input.fallback_risk {
++        policy.guard_strength = ShadowGuardStrength::Panic;
++        policy.rollback_candidate = true;
++        policy.safe_stop_candidate = true;
++        policy.no_repeat_ngram_shadow = Some(3);
++        policy.repeat_penalty_shadow = Some(1.12);
++        policy.policy_reason.push("fallback_risk_panic".to_string());
++        return policy;
++    }
++    if input.collapsing {
++        policy.guard_strength = ShadowGuardStrength::Panic;
++        policy.rollback_candidate = true;
++        policy.safe_stop_candidate = true;
++        policy.eos_bias_candidate = true;
++        policy.shadow_temperature = policy.shadow_temperature.min(0.08);
++        policy.shadow_min_p = policy.shadow_min_p.max(0.16);
++        policy.shadow_top_p = policy.shadow_top_p.min(0.76);
++        policy.policy_reason.push("collapsing_safe_stop".to_string());
++    }
++    if input.entropy_conflict {
++        policy.shadow_min_p -= 0.02;
++        policy.shadow_top_p += 0.03;
++        policy.guard_strength = weaker_guard(policy.guard_strength);
++        policy.policy_reason.push("entropy_conflict_relax_guard".to_string());
++    }
++    if input.margin_collapse {
++        policy.shadow_temperature -= 0.03;
++        policy.shadow_min_p += 0.02;
++        policy.guard_strength = stronger_guard(policy.guard_strength, ShadowGuardStrength::Strict);
++        policy.policy_reason.push("margin_collapse_tighten".to_string());
++    }
++    if input.selected_rank_risk {
++        policy.shadow_temperature -= 0.04;
++        policy.shadow_top_p -= 0.04;
++        policy.shadow_min_p += 0.02;
++        policy.guard_strength = stronger_guard(policy.guard_strength, ShadowGuardStrength::Strict);
++        policy.policy_reason.push("selected_rank_risk_tighten".to_string());
++    }
++    if input.overcompression_risk {
++        policy.shadow_min_p -= 0.02;
++        policy.shadow_top_p += 0.04;
++        policy.policy_reason.push("overcompression_relax".to_string());
++    }
++    policy
++}
