+    receipt: &Decode03BPciStepReceipt,
+    entropy_receipt: Option<&Decode03AEntropyStepReceipt>,
+) -> Decode03CShadowInput {
+    Decode03CShadowInput {
+        pci_raw: receipt.pci_raw,
+        pci_smoothed: receipt.pci_smoothed,
+        bucket_raw: receipt.bucket_raw,
+        bucket_stable: receipt.bucket_stable,
+        h_raw_norm: receipt.input.h_raw_norm,
+        h_final_norm: receipt.input.h_final_norm,
+        top1_top2_margin: receipt.input.top1_top2_margin,
+        selected_rank: receipt.input.selected_rank,
+        selected_logprob: receipt.input.selected_logprob,
+        active_count_final: receipt.input.active_count_final,
+        compression_ratio_total: receipt.input.compression_ratio_total,
+        low_confidence: receipt.risk_flags.low_confidence,
+        collapsing: receipt.risk_flags.collapsing,
+        entropy_conflict: receipt.risk_flags.entropy_conflict,
+        margin_collapse: receipt.risk_flags.margin_collapse,
+        selected_rank_risk: receipt.risk_flags.selected_rank_risk,
+        fallback_risk: receipt.risk_flags.fallback_risk,
+        overcompression_risk: receipt.risk_flags.overcompression_risk,
+        numeric_risk: receipt.risk_flags.numeric_risk,
+        current_temperature: current_temperature_from_entropy(entropy_receipt),
+        current_top_p: current_top_p_from_entropy(entropy_receipt),
+        current_top_k: current_top_k_from_entropy(entropy_receipt),
+        current_min_p: current_min_p_from_entropy(entropy_receipt),
+        static_prior_enabled: entropy_receipt.map(|r| r.static_prior_enabled).unwrap_or_else(|| env_bool("ASH_DECODE03C_STATIC_PRIOR_ENABLED", true)),
+        transition_guard_enabled: entropy_receipt.map(|r| r.transition_guard_enabled).unwrap_or_else(|| env_bool("ASH_DECODE03C_TRANSITION_GUARD_ENABLED", true)),
+    }
+}
