+pub fn bucket_to_dynamic_bucket(bucket: PciBucket) -> DynamicSamplerBucket {
+    match bucket {
+        PciBucket::Confident => DynamicSamplerBucket::ConfidentPath,
+        PciBucket::Stable => DynamicSamplerBucket::StablePath,
+        PciBucket::Uncertain => DynamicSamplerBucket::UncertainPath,
+        PciBucket::Unstable => DynamicSamplerBucket::UnstablePath,
+        PciBucket::Collapsing => DynamicSamplerBucket::CollapsingPath,
+    }
+}
+
+fn stronger_guard(a: ShadowGuardStrength, b: ShadowGuardStrength) -> ShadowGuardStrength {
+    use ShadowGuardStrength::*;
+    let rank = |g| match g { Relaxed => 0, Normal => 1, Strict => 2, Panic => 3 };
+    if rank(a) >= rank(b) { a } else { b }
+}
+
+fn weaker_guard(a: ShadowGuardStrength) -> ShadowGuardStrength {
+    use ShadowGuardStrength::*;
+    match a {
+        Panic => Strict,
+        Strict => Normal,
+        Normal => Relaxed,
+        Relaxed => Relaxed,
+    }
+}
+
+pub fn base_policy_for_bucket(
+    bucket: DynamicSamplerBucket,
+    input: &Decode03CShadowInput,
+) -> Decode03CShadowPolicy {
+    let (shadow_temperature, shadow_min_p, shadow_top_p, guard_strength, rollback_candidate, safe_stop_candidate, eos_bias_candidate, reason) = match bucket {
+        DynamicSamplerBucket::ConfidentPath => (0.10, 0.01, 0.98, ShadowGuardStrength::Relaxed, false, false, false, "bucket_confident_path"),
+        DynamicSamplerBucket::StablePath => (0.25, 0.05, 0.90, ShadowGuardStrength::Normal, false, false, false, "bucket_stable_path"),
+        DynamicSamplerBucket::UncertainPath => (0.18, 0.08, 0.86, ShadowGuardStrength::Strict, false, false, false, "bucket_uncertain_path"),
+        DynamicSamplerBucket::UnstablePath => (0.14, 0.12, 0.82, ShadowGuardStrength::Panic, true, false, false, "bucket_unstable_path"),
+        DynamicSamplerBucket::CollapsingPath => (0.08, 0.16, 0.76, ShadowGuardStrength::Panic, true, true, true, "bucket_collapsing_path"),
+    };
+    Decode03CShadowPolicy {
+        shadow_only: true,
+        behavior_change: false,
+        bucket,
+        current_temperature: input.current_temperature,
+        current_top_p: input.current_top_p,
+        current_top_k: input.current_top_k,
+        current_min_p: input.current_min_p,
+        shadow_temperature,
+        shadow_top_p,
+        shadow_top_k: input.current_top_k,
+        shadow_min_p,
+        temperature_delta: 0.0,
+        top_p_delta: 0.0,
+        min_p_delta: 0.0,
+        guard_strength,
+        rollback_candidate,
+        safe_stop_candidate,
+        eos_bias_candidate,
+        no_repeat_ngram_shadow: if matches!(bucket, DynamicSamplerBucket::UnstablePath | DynamicSamplerBucket::CollapsingPath) { Some(3) } else { None },
+        repeat_penalty_shadow: if matches!(bucket, DynamicSamplerBucket::UnstablePath | DynamicSamplerBucket::CollapsingPath) { Some(1.10) } else { None },
+        policy_reason: vec![reason.to_string()],
+    }
+}
+
+pub fn apply_risk_adjustments(
+    mut policy: Decode03CShadowPolicy,
+    input: &Decode03CShadowInput,
+) -> Decode03CShadowPolicy {
+    if input.numeric_risk {
+        policy.guard_strength = ShadowGuardStrength::Panic;
+        policy.rollback_candidate = true;
+        policy.safe_stop_candidate = true;
+        policy.eos_bias_candidate = true;
+        policy.shadow_temperature = 0.05;
+        policy.shadow_min_p = 0.18;
+        policy.shadow_top_p = 0.70;
+        policy.no_repeat_ngram_shadow = Some(3);
+        policy.repeat_penalty_shadow = Some(1.12);
+        policy.policy_reason.push("numeric_risk_safe_stop".to_string());
+        return policy;
+    }
+    if input.fallback_risk {
+        policy.guard_strength = ShadowGuardStrength::Panic;
+        policy.rollback_candidate = true;
+        policy.safe_stop_candidate = true;
+        policy.no_repeat_ngram_shadow = Some(3);
+        policy.repeat_penalty_shadow = Some(1.12);
+        policy.policy_reason.push("fallback_risk_panic".to_string());
+        return policy;
+    }
+    if input.collapsing {
+        policy.guard_strength = ShadowGuardStrength::Panic;
+        policy.rollback_candidate = true;
+        policy.safe_stop_candidate = true;
+        policy.eos_bias_candidate = true;
+        policy.shadow_temperature = policy.shadow_temperature.min(0.08);
+        policy.shadow_min_p = policy.shadow_min_p.max(0.16);
+        policy.shadow_top_p = policy.shadow_top_p.min(0.76);
+        policy.policy_reason.push("collapsing_safe_stop".to_string());
+    }
+    if input.entropy_conflict {
+        policy.shadow_min_p -= 0.02;
+        policy.shadow_top_p += 0.03;
+        policy.guard_strength = weaker_guard(policy.guard_strength);
+        policy.policy_reason.push("entropy_conflict_relax_guard".to_string());
+    }
+    if input.margin_collapse {
+        policy.shadow_temperature -= 0.03;
+        policy.shadow_min_p += 0.02;
+        policy.guard_strength = stronger_guard(policy.guard_strength, ShadowGuardStrength::Strict);
+        policy.policy_reason.push("margin_collapse_tighten".to_string());
+    }
+    if input.selected_rank_risk {
+        policy.shadow_temperature -= 0.04;
+        policy.shadow_top_p -= 0.04;
+        policy.shadow_min_p += 0.02;
+        policy.guard_strength = stronger_guard(policy.guard_strength, ShadowGuardStrength::Strict);
+        policy.policy_reason.push("selected_rank_risk_tighten".to_string());
+    }
+    if input.overcompression_risk {
+        policy.shadow_min_p -= 0.02;
+        policy.shadow_top_p += 0.04;
+        policy.policy_reason.push("overcompression_relax".to_string());
+    }
+    policy
+}
+
+pub fn clamp_shadow_policy(mut policy: Decode03CShadowPolicy) -> Decode03CShadowPolicy {
+    policy.shadow_temperature = clamp_f32(policy.shadow_temperature, 0.03, 1.20);
+    policy.shadow_min_p = clamp_f32(policy.shadow_min_p, 0.00, 0.25);
+    policy.shadow_top_p = clamp_f32(policy.shadow_top_p, 0.50, 1.00);
+    policy.temperature_delta = policy.shadow_temperature - policy.current_temperature;
+    policy.top_p_delta = policy.shadow_top_p - policy.current_top_p;
+    policy.min_p_delta = policy.shadow_min_p - policy.current_min_p;
+    policy.shadow_only = true;
+    policy.behavior_change = false;
+    policy
+}
+
+pub fn compute_shadow_policy(input: &Decode03CShadowInput) -> Decode03CShadowPolicy {
+    let mut bucket = bucket_to_dynamic_bucket(input.bucket_stable);
+    if input.numeric_risk || input.fallback_risk || input.collapsing {
+        bucket = DynamicSamplerBucket::CollapsingPath;
+    }
+    let mut policy = base_policy_for_bucket(bucket, input);
+    if input.transition_guard_enabled && env_bool("ASH_SAMPLER05_TOPK_BYPASS_APPLIED", false) {
+        policy.shadow_top_k = 0;
+        policy.policy_reason.push("sampler05_topk_bypass_shadow".to_string());
+    }
+    policy = apply_risk_adjustments(policy, input);
+    clamp_shadow_policy(policy)
+}
+
+pub fn classify_shadow_effect(
+    input: &Decode03CShadowInput,
+    policy: &Decode03CShadowPolicy,
+) -> Decode03CShadowEffect {
+    let would_change_behavior = (policy.shadow_temperature - input.current_temperature).abs() > 0.001
+        || (policy.shadow_top_p - input.current_top_p).abs() > 0.001
+        || (policy.shadow_min_p - input.current_min_p).abs() > 0.001
+        || policy.shadow_top_k != input.current_top_k
+        || policy.rollback_candidate
+        || policy.safe_stop_candidate
+        || policy.eos_bias_candidate;
+    let would_tighten = policy.shadow_temperature < input.current_temperature
+        || policy.shadow_min_p > input.current_min_p
+        || policy.shadow_top_p < input.current_top_p
+        || matches!(policy.guard_strength, ShadowGuardStrength::Strict | ShadowGuardStrength::Panic);
+    let would_relax = policy.shadow_min_p < input.current_min_p
+        || policy.shadow_top_p > input.current_top_p
+        || matches!(policy.guard_strength, ShadowGuardStrength::Relaxed);
+    let would_panic = matches!(policy.guard_strength, ShadowGuardStrength::Panic)
+        || policy.rollback_candidate
+        || policy.safe_stop_candidate
+        || policy.eos_bias_candidate;
+    Decode03CShadowEffect { would_change_behavior, would_tighten, would_relax, would_panic }
+}
