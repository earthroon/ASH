+        hints[idx] = CandidatePieceHintRaw { token_id: *id, class_bits, risk_bits, reserved0: 0 };
+        if class_bits & CLASS_CONTROL_TOKEN != 0 { summary.control_count += 1; }
+        if class_bits & CLASS_PAD_TOKEN != 0 { summary.pad_count += 1; }
+        if class_bits & CLASS_EOS_TOKEN != 0 { summary.eos_count += 1; }
+        if class_bits & CLASS_BYTE_TOKEN != 0 { summary.byte_count += 1; }
+        if class_bits & CLASS_MOJIBAKE_SUSPECT != 0 { summary.mojibake_suspect_count += 1; }
+        if class_bits & CLASS_KOREAN_TEXT != 0 { summary.korean_text_count += 1; }
+        if class_bits & CLASS_GENERIC_CONTINUATION != 0 { summary.generic_continuation_count += 1; }
+        if class_bits & CLASS_PARTICLE_LIKE != 0 { summary.particle_like_count += 1; }
+        if class_bits & CLASS_ENDING_LIKE != 0 { summary.ending_like_count += 1; }
+    }
+    CandidatePieceHintTable { vocab_size, vocab_hash, hints, summary }
+}
+
+pub fn classify_piece_hint(
+    token_id: u32,
+    piece: &str,
+    eos_token_id: Option<u32>,
+    pad_token_id: Option<u32>,
+) -> (u32, u32) {
+    let mut class_bits = 0u32;
+    let mut risk_bits = 0u32;
+    let trimmed = piece.trim();
+    let bare = trimmed.trim_start_matches('▁');
+
+    if !trimmed.is_empty() { class_bits |= CLASS_TEXT; }
+    if trimmed.starts_with('▁') { class_bits |= CLASS_SENTENCEPIECE_TEXT; }
+    if contains_hangul(bare) { class_bits |= CLASS_KOREAN_TEXT; }
+    if trimmed.is_empty() { class_bits |= CLASS_WHITESPACE_ONLY; }
+
+    if pad_token_id == Some(token_id) || trimmed == "<pad>" {
+        class_bits |= CLASS_PAD_TOKEN | CLASS_CONTROL_TOKEN;
+        risk_bits |= RISK_HARD_BLOCK_CANDIDATE;
+    }
+    if eos_token_id == Some(token_id) || matches!(trimmed, "<eos>" | "</s>") {
+        class_bits |= CLASS_EOS_TOKEN | CLASS_CONTROL_TOKEN;
+    }
+    if matches!(trimmed, "<bos>" | "<s>") || trimmed.starts_with("<glossary:") || trimmed.starts_with("<task:") || trimmed.starts_with("<lang:") {
+        class_bits |= CLASS_CONTROL_TOKEN;
+        risk_bits |= RISK_HARD_BLOCK_CANDIDATE;
+    }
+    if trimmed == "<unk>" {
+        class_bits |= CLASS_UNKNOWN_TOKEN | CLASS_CONTROL_TOKEN;
+    }
+    if trimmed.starts_with("<byte:") || trimmed.starts_with("<0x") {
+        class_bits |= CLASS_BYTE_TOKEN;
+        risk_bits |= RISK_BYTE_BOUNDARY;
+    }
+    if mojibake_suspected(trimmed) {
+        class_bits |= CLASS_MOJIBAKE_SUSPECT;
+        risk_bits |= RISK_HARD_BLOCK_CANDIDATE;
+    }
+    if is_generic_continuation(bare) {
+        class_bits |= CLASS_GENERIC_CONTINUATION;
+        risk_bits |= RISK_GENERIC_EOS;
+    }
+    if is_particle_like(bare) {
+        class_bits |= CLASS_PARTICLE_LIKE;
+        risk_bits |= RISK_DOUBLE_PARTICLE;
+    }
+    if is_ending_like(bare) {
+        class_bits |= CLASS_ENDING_LIKE;
+        risk_bits |= RISK_DOUBLE_ENDING;
+    }
+    if is_punctuation(bare) {
+        class_bits |= CLASS_PUNCTUATION;
+        risk_bits |= RISK_PUNCTUATION_REPEAT;
+    }
+    if is_emotional_repeat(bare) {
+        class_bits |= CLASS_EMOTIONAL_REPEAT;
+        risk_bits &= !RISK_HARD_BLOCK_CANDIDATE;
+    }
+    (class_bits, risk_bits)
+}
+
+fn contains_hangul(s: &str) -> bool {
+    s.chars().any(|c| ('\u{AC00}'..='\u{D7A3}').contains(&c) || ('\u{3130}'..='\u{318F}').contains(&c))
+}
+
+fn is_generic_continuation(s: &str) -> bool {
+    matches!(s, "이어가고" | "그리고" | "하지만" | "그러나" | "때문에" | "즉" | "그래서" | "따라서" | "그러므로" | "또한")
+}
+
+fn is_particle_like(s: &str) -> bool {
+    matches!(s, "은" | "는" | "이" | "가" | "을" | "를" | "에" | "에서" | "으로" | "로" | "와" | "과" | "도" | "만" | "의")
+}
+
+fn is_ending_like(s: &str) -> bool {
+    matches!(s, "다" | "요" | "죠" | "까" | "네" | "습니다" | "합니다" | "했다" | "한다")
+}
+
+fn is_punctuation(s: &str) -> bool {
+    matches!(s, "!" | "?" | "." | "," | "。" | "…")
+}
+
+fn is_emotional_repeat(s: &str) -> bool {
+    matches!(s, "ㅋ" | "ㅠ" | "ㅜ" | ";")
+}
+
+pub fn mojibake_suspected(s: &str) -> bool {
+    s.contains('�') || s.contains("?댁") || s.contains('媛') || s.contains('怨') || s.contains('Ã') || s.contains('ì') || s.contains('ê')
+}
