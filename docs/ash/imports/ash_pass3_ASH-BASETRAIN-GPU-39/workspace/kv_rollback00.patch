+pub fn append_kv_rollback00_receipt_from_sampler03(source: &SamplerParityReceipt) {
+    let mode = KvRollback00Mode::from_env();
+    if !mode.probe_requested() {
+        return;
+    }
+    let entropy_receipt = receipt_from_sampler03(Decode03AMode::Receipt, source);
+    let pci_receipt = receipt_from_decode03a(Decode03BMode::Receipt, &entropy_receipt, None, 0);
+    let shadow_receipt = receipt_from_decode03b(Decode03CMode::Receipt, &pci_receipt, Some(&entropy_receipt));
+    let dynamic_mode = DynamicSamplerMode::from_env();
+    let mut decode03d_receipt = receipt_from_decode03c(dynamic_mode, &shadow_receipt);
+    decode03d_receipt.selected_id_after_apply = Some(source.cpu.selected_id);
+    let salad02_receipt = salad02_receipt_from_decode03d(&decode03d_receipt);
+    let salad03_mode = Salad03Mode::from_env();
+    let salad03_receipt = receipt_from_salad02(salad03_mode, &salad02_receipt);
+    let receipt = receipt_from_salad03(mode, &salad03_receipt);
+    let path = receipt_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(line) = serde_json::to_string(&receipt) {
+        use std::io::Write;
+        if let Ok(mut file) = fs::OpenOptions::new().create(true).append(true).open(path) {
+            let _ = writeln!(file, "{}", line);
+        }
+    }
+}
+
+fn read_receipts(path: PathBuf) -> Vec<KvRollback00StepReceipt> {
+    let data = match fs::read_to_string(path) {
+        Ok(data) => data,
+        Err(_) => return Vec::new(),
+    };
+    data.lines().filter_map(|line| serde_json::from_str::<KvRollback00StepReceipt>(line).ok()).collect()
+}
+
+pub fn summary_from_receipts(receipts: &[KvRollback00StepReceipt]) -> KvRollback00Summary {
+    let mut snapshot = KvRollback00SnapshotStats::default();
+    let mut probe = KvRollback00ProbeStats::default();
+    let mut safety = KvRollback00SafetyStats::default();
+    let mut mode = "SnapshotOnly".to_string();
+    let mut capability = backend_capability_from_env("unknown");
+    let mut salad03_status_seen = None;
+
+    for receipt in receipts {
+        mode = receipt.mode.as_str().to_string();
+        capability = receipt.input.capability.clone();
+        salad03_status_seen = receipt.salad03_status_seen.clone();
+        snapshot.ring_capacity = receipt.ring_state.capacity;
+        snapshot.evicted_count = snapshot.evicted_count.max(receipt.ring_state.evicted_count);
+        if receipt.result.snapshot_created { snapshot.created_count += 1; }
+        if receipt.result.target_snapshot_found { snapshot.target_found_count += 1; } else { snapshot.target_missing_count += 1; }
+        if receipt.result.shape_probe_passed { probe.shape_probe_passed_count += 1; } else if receipt.snapshot.is_some() { safety.shape_mismatch_count += 1; }
+        if receipt.result.hash_probe_passed == Some(true) { probe.hash_probe_passed_count += 1; }
+        if let Some(fork) = &receipt.forked_replay {
+            if fork.attempted { probe.forked_replay_attempted_count += 1; }
+            if receipt.result.forked_replay_passed == Some(true) { probe.forked_replay_passed_count += 1; }
+        }
+        if receipt.result.restore_verified { probe.restore_verified_count += 1; }
+        if !receipt.result.main_state_unchanged { safety.main_state_changed_count += 1; }
+        if receipt.result.restore_verified && !receipt.result.target_snapshot_found { safety.restore_without_snapshot_count += 1; }
+        if let Some(snapshot_ref) = &receipt.snapshot {
+            if snapshot_ref.position_state.position_index != receipt.input.target_position.position_index { safety.position_mismatch_count += 1; }
+        }
+    }
+    let steps_observed = receipts.len();
+    let behavior_change = safety.main_state_changed_count > 0;
+    let status = if steps_observed == 0 {
+        "STATIC_BAKE_DEFINED_NOT_RUN"
+    } else if behavior_change || safety.restore_without_snapshot_count > 0 || safety.position_mismatch_count > 0 {
+        "FAIL_CONTRACT_VIOLATION"
+    } else if snapshot.target_missing_count > 0 || probe.restore_verified_count == 0 || !capability.supports_forked_restore {
+        "PASS_WITH_WARNINGS"
+    } else {
+        "PASS"
+    }.to_string();
+    let ready_for_forked = steps_observed > 0 && safety.main_state_changed_count == 0 && probe.shape_probe_passed_count > 0;
+    let ready_for_salad03_execute = steps_observed > 0 && probe.restore_verified_count > 0 && safety.main_state_changed_count == 0;
+    KvRollback00Summary {
+        patch_id: KV_ROLLBACK00_PATCH_ID.to_string(),
+        input_patch: KV_ROLLBACK00_INPUT_PATCH_ID.to_string(),
+        status,
+        behavior_change,
+        probe_only: true,
+        mode,
+        requires_salad03: env_bool("ASH_KV_ROLLBACK00_REQUIRE_SALAD03", true),
+        salad03_status_seen,
+        steps_observed,
+        snapshot,
+        probe,
+        backend_capability: capability,
+        safety,
+        ready_for_salad03_controlled_execute: ready_for_salad03_execute,
+        ready_for_kv_rollback01_forked_replay: ready_for_forked,
+        reason: if ready_for_salad03_execute {
+            "restore verified; SALAD-03 controlled execute may be considered".to_string()
+        } else if ready_for_forked {
+            "shape restore probe available; forked replay verification not yet sealed".to_string()
+        } else {
+            "snapshot/probe receipt sealed; runtime verification pending".to_string()
+        },
+    }
+}
+
+pub fn write_kv_rollback00_summary_from_receipt_file() {
+    let summary = summary_from_receipts(&read_receipts(receipt_path()));
+    let path = summary_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(json) = serde_json::to_string_pretty(&summary) {
+        let _ = fs::write(path, json);
+    }
+}
