+fn snapshot_for_input(input: &KvRollback00ProbeInput) -> Option<KvRollbackSnapshotRef> {
+    if !input.capability.supports_snapshot {
+        return None;
+    }
+    let target = input.target_step;
+    let kv_shape = kv_shape_for_step(target);
+    let memory_bytes_estimate = env_u64("ASH_KV_ROLLBACK00_MEMORY_BYTES_ESTIMATE", 0);
+    Some(KvRollbackSnapshotRef {
+        snapshot_id: input.requested_snapshot_id.clone().unwrap_or_else(|| snapshot_id_for_step(target)),
+        step: target,
+        created_at_decode_step: target,
+        backend: input.backend.clone(),
+        device_kind: env_string("ASH_KV_ROLLBACK00_DEVICE_KIND", if input.backend.contains("gpu") { "gpu" } else { "cpu" }),
+        available: true,
+        restore_supported: input.capability.supports_restore,
+        restore_verified: false,
+        kv_shape,
+        kv_hash: if input.capability.supports_kv_hash { Some(format!("sha256:compact-kv-step-{target}")) } else { None },
+        position_state: input.target_position.clone(),
+        token_ledger_len: input.target_step,
+        sampler_state_hash: if input.capability.supports_sampler_state_restore { Some(format!("sha256:sampler-state-step-{target}")) } else { None },
+        memory_bytes_estimate: if memory_bytes_estimate > 0 { Some(memory_bytes_estimate) } else { None },
+    })
+}
+
+fn ring_state_for(input: &KvRollback00ProbeInput, target_found: bool) -> KvRollbackSnapshotRingState {
+    let capacity = env_usize("ASH_KV_ROLLBACK00_RING_CAPACITY", 16).max(1);
+    let len = input.step.saturating_add(1).min(capacity);
+    let newest_step = Some(input.step);
+    let oldest = input.step.saturating_add(1).saturating_sub(len);
+    let oldest_step = Some(oldest);
+    let evicted_count = input.step.saturating_add(1).saturating_sub(len);
+    KvRollbackSnapshotRingState {
+        capacity,
+        len,
+        oldest_step,
+        newest_step,
+        evicted_count,
+        missing_target_count: if target_found { 0 } else { 1 },
+    }
+}
+
+fn shape_probe(snapshot: &KvRollbackSnapshotRef, input: &KvRollback00ProbeInput) -> bool {
+    snapshot.available
+        && snapshot.kv_shape.seq_len == input.target_position.seq_len
+        && snapshot.position_state.position_index == input.target_position.position_index
+        && snapshot.token_ledger_len <= input.token_ledger_len
+}
+
+fn forked_replay_for(input: &KvRollback00ProbeInput, snapshot: Option<&KvRollbackSnapshotRef>) -> Option<KvRollback00ForkedReplayReceipt> {
+    if !matches!(input.mode, KvRollback00Mode::ForkedReplayProbe | KvRollback00Mode::StrictProbe) {
+        return None;
+    }
+    let attempted = input.capability.supports_forked_restore && snapshot.is_some();
+    let top1_match = if attempted { Some(env_bool("ASH_KV_ROLLBACK00_FORKED_TOP1_MATCH", false)) } else { None };
+    let original_top1_id = env::var("ASH_KV_ROLLBACK00_ORIGINAL_TOP1_ID").ok().and_then(|v| v.parse::<u32>().ok());
+    let forked_top1_id = if top1_match == Some(true) { original_top1_id } else { env::var("ASH_KV_ROLLBACK00_FORKED_TOP1_ID").ok().and_then(|v| v.parse::<u32>().ok()) };
+    Some(KvRollback00ForkedReplayReceipt {
+        attempted,
+        fork_created: attempted,
+        restore_to_fork_executed: attempted,
+        target_step: input.target_step,
+        replay_input_token_id: None,
+        logits_shape_match: if attempted { Some(env_bool("ASH_KV_ROLLBACK00_LOGITS_SHAPE_MATCH", true)) } else { None },
+        original_top1_id,
+        forked_top1_id,
+        top1_match,
+        original_top5_ids: Vec::new(),
+        forked_top5_ids: Vec::new(),
+        top5_overlap: if attempted { Some(env_usize("ASH_KV_ROLLBACK00_TOP5_OVERLAP", 0)) } else { None },
+        mean_abs_delta: None,
+        max_abs_delta: None,
+        tolerance_used: Some(env::var("ASH_KV_ROLLBACK00_LOGIT_TOLERANCE").ok().and_then(|v| v.parse::<f32>().ok()).unwrap_or(0.001)),
+    })
+}
