+fn kv_shape_for_step(step: usize) -> KvRollbackKvShape {
+    let num_layers = env_usize("ASH_KV_ROLLBACK00_NUM_LAYERS", 0);
+    let batch_size = env_usize("ASH_KV_ROLLBACK00_BATCH_SIZE", 1);
+    let num_kv_heads = env_usize("ASH_KV_ROLLBACK00_NUM_KV_HEADS", 0);
+    let num_heads = env_usize("ASH_KV_ROLLBACK00_NUM_HEADS", num_kv_heads);
+    let head_dim = env_usize("ASH_KV_ROLLBACK00_HEAD_DIM", 0);
+    let dtype = env_string("ASH_KV_ROLLBACK00_DTYPE", "unknown");
+    let layout_hint = env_string("ASH_KV_ROLLBACK00_LAYOUT_HINT", "unknown");
+    let key_shape = if num_layers > 0 && num_kv_heads > 0 && head_dim > 0 {
+        vec![num_layers, batch_size, num_kv_heads, step, head_dim]
+    } else {
+        vec![step]
+    };
+    let value_shape = key_shape.clone();
+    KvRollbackKvShape {
+        num_layers,
+        batch_size,
+        num_heads: if num_heads > 0 { Some(num_heads) } else { None },
+        num_kv_heads: if num_kv_heads > 0 { Some(num_kv_heads) } else { None },
+        head_dim: if head_dim > 0 { Some(head_dim) } else { None },
+        seq_len: step,
+        key_shape,
+        value_shape,
+        dtype,
+        layout_hint,
+    }
+}
