+pub fn backend_capability_from_env(backend: &str) -> KvRollbackBackendCapability {
+    let supports_snapshot = env_bool("ASH_KV_ROLLBACK00_SUPPORTS_SNAPSHOT", true);
+    let supports_restore = env_bool("ASH_KV_ROLLBACK00_SUPPORTS_RESTORE", false);
+    let supports_forked_restore = env_bool("ASH_KV_ROLLBACK00_SUPPORTS_FORKED_RESTORE", false);
+    let supports_kv_hash = env_bool("ASH_KV_ROLLBACK00_SUPPORTS_KV_HASH", false);
+    let supports_position_restore = env_bool("ASH_KV_ROLLBACK00_SUPPORTS_POSITION_RESTORE", supports_restore);
+    let supports_sampler_state_restore = env_bool("ASH_KV_ROLLBACK00_SUPPORTS_SAMPLER_STATE_RESTORE", false);
+    let requires_gpu_readback = env_bool("ASH_KV_ROLLBACK00_REQUIRES_GPU_READBACK", false);
+    let mut notes = Vec::new();
+    if !supports_restore { notes.push("restore_support_not_declared".to_string()); }
+    if !supports_forked_restore { notes.push("forked_restore_not_declared".to_string()); }
+    if requires_gpu_readback { notes.push("snapshot_hash_may_require_gpu_readback".to_string()); }
+    KvRollbackBackendCapability {
+        backend: backend.to_string(),
+        supports_snapshot,
+        supports_restore,
+        supports_forked_restore,
+        supports_kv_hash,
+        supports_position_restore,
+        supports_sampler_state_restore,
+        requires_gpu_readback,
+        snapshot_cost_estimate: Some(env_string("ASH_KV_ROLLBACK00_SNAPSHOT_COST", "unknown")),
+        notes,
+    }
+}
