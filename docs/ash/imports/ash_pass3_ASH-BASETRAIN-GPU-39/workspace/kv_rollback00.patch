++pub fn evaluate_kv_rollback00_probe(
++    input: &KvRollback00ProbeInput,
++    snapshot: Option<&KvRollbackSnapshotRef>,
++    forked_replay: Option<&KvRollback00ForkedReplayReceipt>,
