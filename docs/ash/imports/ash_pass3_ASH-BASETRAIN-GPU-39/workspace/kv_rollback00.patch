+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+pub enum KvRollback00Mode {
+    Off,
+    SnapshotOnly,
+    DryRunRestoreProbe,
+    ForkedReplayProbe,
+    StrictProbe,
+}
+
+impl KvRollback00Mode {
+    pub fn from_env() -> Self {
+        let value = env::var("ASH_KV_ROLLBACK00_MODE")
+            .or_else(|_| env::var("ASH_KV_ROLLBACK00_PROBE"))
+            .unwrap_or_else(|_| "snapshot_only".to_string())
+            .trim()
+            .to_ascii_lowercase();
+        match value.as_str() {
+            "off" | "0" | "false" | "disabled" => Self::Off,
+            "dry" | "dry_run" | "dry_run_restore_probe" | "restore_probe" => Self::DryRunRestoreProbe,
+            "fork" | "forked" | "forked_replay" | "forked_replay_probe" => Self::ForkedReplayProbe,
+            "strict" | "strict_probe" => Self::StrictProbe,
+            _ => Self::SnapshotOnly,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::SnapshotOnly => "SnapshotOnly",
+            Self::DryRunRestoreProbe => "DryRunRestoreProbe",
+            Self::ForkedReplayProbe => "ForkedReplayProbe",
+            Self::StrictProbe => "StrictProbe",
+        }
+    }
+
+    pub fn probe_requested(self) -> bool {
+        !matches!(self, Self::Off)
+    }
+}
