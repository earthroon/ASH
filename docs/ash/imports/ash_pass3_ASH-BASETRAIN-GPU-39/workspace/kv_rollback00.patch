+pub fn input_from_salad03(mode: KvRollback00Mode, salad03: &Salad03StepReceipt) -> KvRollback00ProbeInput {
+    let rollback_depth = salad03.plan.rollback_depth;
+    let target_step = salad03.plan.rollback_target_step.unwrap_or_else(|| salad03.step.saturating_sub(rollback_depth));
+    let backend = salad03.backend.clone();
+    let capability = backend_capability_from_env(&backend);
+    KvRollback00ProbeInput {
+        mode,
+        run_id: run_id_from_env(),
+        prompt_hash: salad03.prompt_hash.clone(),
+        seed: salad03.seed,
+        step: salad03.step,
+        backend,
+        target_step,
+        rollback_depth,
+        token_ledger_len: salad03.input.token_ledger_len,
+        requested_snapshot_id: Some(snapshot_id_for_step(target_step)),
+        salad03_decision: Some(format!("{:?}", salad03.plan.decision)),
+        salad03_rollback_depth: Some(rollback_depth),
+        salad02_risk_stable: Some(format!("{:?}", salad03.input.risk_stable)),
+        current_position: position_state_for_step(salad03.step),
+        target_position: position_state_for_step(target_step),
+        capability,
+    }
+}
+
+pub fn receipt_from_salad03(mode: KvRollback00Mode, salad03: &Salad03StepReceipt) -> KvRollback00StepReceipt {
+    let input = input_from_salad03(mode, salad03);
+    let mut snapshot = snapshot_for_input(&input);
+    let target_found = snapshot.is_some() && input.step >= input.target_step && input.step.saturating_sub(input.target_step) < env_usize("ASH_KV_ROLLBACK00_RING_CAPACITY", 16).max(1);
+    let ring_state = ring_state_for(&input, target_found);
+    let forked_replay = forked_replay_for(&input, snapshot.as_ref());
+    let result = evaluate_kv_rollback00_probe(&input, snapshot.as_ref(), forked_replay.as_ref());
+    if let Some(snapshot_ref) = snapshot.as_mut() {
+        snapshot_ref.restore_verified = result.restore_verified;
+    }
+    KvRollback00StepReceipt {
+        patch_id: KV_ROLLBACK00_PATCH_ID.to_string(),
+        input_patch: KV_ROLLBACK00_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: input.run_id.clone(),
+        prompt_hash: input.prompt_hash.clone(),
+        seed: input.seed,
+        step: input.step,
+        backend: input.backend.clone(),
+        sampler_ssot: KV_ROLLBACK00_SSOT.to_string(),
+        mode,
+        behavior_change: false,
+        probe_only: true,
+        salad03_status_seen: Some("DERIVED_IN_MEMORY_FROM_SALAD03_RECEIPT".to_string()),
+        salad02_status_seen: salad03.salad02_status_seen.clone(),
+        decode03d_status_seen: salad03.decode03d_status_seen.clone(),
+        input,
+        snapshot,
+        ring_state,
+        result,
+        forked_replay,
+        selected_id_current: salad03.selected_id_before,
+        selected_piece_current: salad03.selected_piece_before.clone(),
+    }
+}
