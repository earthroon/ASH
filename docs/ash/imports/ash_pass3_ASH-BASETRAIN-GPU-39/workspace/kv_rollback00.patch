+pub fn evaluate_kv_rollback00_probe(
+    input: &KvRollback00ProbeInput,
+    snapshot: Option<&KvRollbackSnapshotRef>,
+    forked_replay: Option<&KvRollback00ForkedReplayReceipt>,
+) -> KvRollback00ProbeResult {
+    let mut denied_reasons = Vec::new();
+    let mut warning_reasons = Vec::new();
+    let mut probe_reasons = Vec::new();
+    let snapshot_created = snapshot.is_some();
+    let snapshot_id = snapshot.map(|s| s.snapshot_id.clone());
+    if !input.capability.supports_snapshot {
+        denied_reasons.push("backend_snapshot_unsupported".to_string());
+    }
+    let target_snapshot_found = snapshot_created && input.step >= input.target_step && input.step.saturating_sub(input.target_step) < env_usize("ASH_KV_ROLLBACK00_RING_CAPACITY", 16).max(1);
+    if target_snapshot_found { probe_reasons.push("target_snapshot_found".to_string()); } else { warning_reasons.push("target_snapshot_missing_or_evicted".to_string()); }
+    let shape_probe_passed = snapshot.map(|s| shape_probe(s, input)).unwrap_or(false);
+    if shape_probe_passed { probe_reasons.push("shape_probe_passed".to_string()); } else if snapshot_created { denied_reasons.push("shape_or_position_probe_failed".to_string()); }
+    let hash_probe_passed = if input.capability.supports_kv_hash { Some(snapshot.and_then(|s| s.kv_hash.as_ref()).is_some()) } else { None };
+    if hash_probe_passed == Some(true) { probe_reasons.push("kv_hash_present".to_string()); }
+    let forked_replay_passed = forked_replay.and_then(|r| r.top1_match).or_else(|| forked_replay.and_then(|r| r.top5_overlap.map(|n| n >= 3)));
+    if matches!(input.mode, KvRollback00Mode::DryRunRestoreProbe) { warning_reasons.push("forked_replay_not_attempted".to_string()); }
+    if matches!(input.mode, KvRollback00Mode::ForkedReplayProbe | KvRollback00Mode::StrictProbe) && forked_replay.is_none() {
+        denied_reasons.push("forked_replay_receipt_missing".to_string());
+    }
+    if matches!(input.mode, KvRollback00Mode::ForkedReplayProbe | KvRollback00Mode::StrictProbe) && !input.capability.supports_forked_restore {
+        denied_reasons.push("backend_forked_restore_unsupported".to_string());
+    }
+    if input.capability.supports_restore && shape_probe_passed { probe_reasons.push("restore_dry_run_supported".to_string()); }
+    if !input.capability.supports_position_restore && matches!(input.mode, KvRollback00Mode::DryRunRestoreProbe | KvRollback00Mode::ForkedReplayProbe | KvRollback00Mode::StrictProbe) {
+        denied_reasons.push("position_restore_unsupported".to_string());
+    }
+    let restore_verified = match input.mode {
+        KvRollback00Mode::StrictProbe => forked_replay_passed == Some(true) && shape_probe_passed && input.capability.supports_restore,
+        KvRollback00Mode::ForkedReplayProbe => forked_replay_passed == Some(true) && shape_probe_passed && input.capability.supports_restore,
+        _ => false,
+    };
+    if matches!(input.mode, KvRollback00Mode::StrictProbe) && !restore_verified {
+        denied_reasons.push("strict_probe_restore_not_verified".to_string());
+    }
+    KvRollback00ProbeResult {
+        mode: input.mode,
+        snapshot_created,
+        snapshot_id,
+        target_snapshot_found,
+        shape_probe_passed,
+        hash_probe_passed,
+        forked_replay_passed,
+        restore_verified,
+        main_state_unchanged: true,
+        denied_reasons,
+        warning_reasons,
+        probe_reasons,
+    }
+}
