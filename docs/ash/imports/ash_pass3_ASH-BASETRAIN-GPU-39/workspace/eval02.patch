+pub fn write_eval02_manifests() -> Result<(), String> {
+    let suite_path = prompt_suite_path();
+    if let Some(parent) = suite_path.parent() { fs::create_dir_all(parent).map_err(|e| e.to_string())?; }
+    let suite = default_long_prompt_suite();
+    let mut suite_text = String::new();
+    for case in suite {
+        suite_text.push_str(&serde_json::to_string(&case).map_err(|e| e.to_string())?);
+        suite_text.push('\n');
+    }
+    fs::write(&suite_path, suite_text).map_err(|e| e.to_string())?;
+
+    let matrix = default_matrix();
+    let matrix_path = matrix_path();
+    if let Some(parent) = matrix_path.parent() { fs::create_dir_all(parent).map_err(|e| e.to_string())?; }
+    fs::write(&matrix_path, serde_json::to_string_pretty(&matrix).map_err(|e| e.to_string())?).map_err(|e| e.to_string())?;
+    Ok(())
+}
