+fn env_bool(name: &str, default: bool) -> bool {
+    env::var(name).ok().map(|v| matches!(v.trim().to_ascii_lowercase().as_str(), "1" | "true" | "yes" | "on")).unwrap_or(default)
+}
+
+fn env_usize(name: &str, default: usize) -> usize {
+    env::var(name).ok().and_then(|v| v.parse::<usize>().ok()).unwrap_or(default)
+}
+
+fn env_u64(name: &str, default: u64) -> u64 {
+    env::var(name).ok().and_then(|v| v.parse::<u64>().ok()).unwrap_or(default)
+}
+
+fn path_from_env(name: &str, default: &str) -> PathBuf {
