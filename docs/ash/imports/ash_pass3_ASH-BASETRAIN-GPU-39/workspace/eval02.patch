+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+pub enum Eval02DriftRisk {
+    Low,
+    Medium,
+    High,
+    Critical,
+}
+
+impl Eval02DriftRisk {
+    pub fn from_score(score: f32) -> Self {
+        let score = clamp01(score);
+        if score >= 0.80 { Self::Critical }
+        else if score >= 0.55 { Self::High }
+        else if score >= 0.30 { Self::Medium }
+        else { Self::Low }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Low => "Low",
+            Self::Medium => "Medium",
+            Self::High => "High",
+            Self::Critical => "Critical",
+        }
+    }
+}
