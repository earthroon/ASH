+pub fn append_eval02_receipt_from_sampler03(receipt: &SamplerParityReceipt) {
+    let mode = Eval02Mode::from_env();
+    if !mode.enabled() { return; }
+    let _ = write_eval02_manifests();
+    if matches!(mode, Eval02Mode::ManifestOnly) {
+        let _ = write_eval02_summary_from_receipt_file();
+        return;
+    }
+    let sample = sample_from_sampler03(receipt);
+    let sample_every = env_usize("ASH_EVAL02_SAMPLE_EVERY_N_STEPS", default_matrix().sample_every_n_steps).max(1);
+    if receipt.step % sample_every == 0 { append_jsonl(samples_path(), &sample); }
+    if matches!(mode, Eval02Mode::RunSoak | Eval02Mode::CompareProfiles | Eval02Mode::StrictSoakGate) {
+        let max_new_tokens = env_usize("ASH_EVAL02_MAX_NEW_TOKENS", default_matrix().max_new_tokens_default);
+        let run = build_eval02_run_from_samples(
+            sample.run_id.clone(),
+            sample.prompt_id.clone(),
+            sample.profile_id.clone(),
+            sample.backend.clone(),
+            sample.seed,
+            max_new_tokens,
+            default_matrix().horizon_buckets,
+            vec![sample.clone()],
+        );
+        append_jsonl(runs_path(), &run);
+    }
+    let _ = write_eval02_summary_from_receipt_file();
+}
