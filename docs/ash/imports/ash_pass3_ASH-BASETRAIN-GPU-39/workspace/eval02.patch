+pub fn compute_eval02_window_metrics(samples: &[Eval02StepSample], window_start_step: usize, window_end_step: usize) -> Eval02WindowMetrics {
+    let window: Vec<&Eval02StepSample> = samples.iter().filter(|s| s.step >= window_start_step && s.step <= window_end_step).collect();
+    let pci_values: Vec<Option<f32>> = window.iter().map(|s| s.pci_raw).collect();
+    let entropy_values: Vec<Option<f32>> = window.iter().map(|s| s.entropy_final).collect();
+    let salad02_values: Vec<Option<f32>> = window.iter().map(|s| s.salad02_score).collect();
+    let salad04_values: Vec<Option<f32>> = window.iter().map(|s| s.salad04_score).collect();
+    let first_pci = pci_values.iter().find_map(|v| *v);
+    let last_pci = pci_values.iter().rev().find_map(|v| *v);
+    let first_entropy = entropy_values.iter().find_map(|v| *v);
+    let last_entropy = entropy_values.iter().rev().find_map(|v| *v);
+    let mut selected_ids = Vec::new();
+    for s in &window { if let Some(id) = s.selected_id { selected_ids.push(id); } }
+    let repeat_3gram_rate = if selected_ids.len() >= 3 {
+        let mut total = 0usize;
+        let mut repeats = 0usize;
+        for idx in 3..selected_ids.len() {
+            total += 1;
+            if selected_ids[idx] == selected_ids[idx - 3] { repeats += 1; }
+        }
+        Some(repeats as f32 / total.max(1) as f32)
+    } else { None };
+    let distinct_2_ratio = if selected_ids.len() >= 2 {
+        let mut total = 0usize;
+        let mut bigrams = std::collections::BTreeSet::new();
+        for pair in selected_ids.windows(2) {
+            total += 1;
+            bigrams.insert((pair[0], pair[1]));
+        }
+        Some(bigrams.len() as f32 / total.max(1) as f32)
+    } else { None };
+    Eval02WindowMetrics {
+        window_start_step,
+        window_end_step,
+        token_count: window.len(),
+        pci_mean: option_mean(&pci_values),
+        pci_min: option_min(&pci_values),
+        pci_slope: slope(first_pci, last_pci, window.len()),
+        entropy_final_mean: option_mean(&entropy_values),
+        entropy_final_max: option_max(&entropy_values),
+        entropy_slope: slope(first_entropy, last_entropy, window.len()),
+        salad02_score_mean: option_mean(&salad02_values),
+        salad02_score_max: option_max(&salad02_values),
+        salad02_high_count: window.iter().filter(|s| matches!(s.salad02_risk.as_deref(), Some("High" | "Critical"))).count(),
+        salad02_critical_count: window.iter().filter(|s| s.salad02_risk.as_deref() == Some("Critical")).count(),
+        salad04_score_mean: option_mean(&salad04_values),
+        salad04_score_max: option_max(&salad04_values),
+        salad04_high_count: window.iter().filter(|s| matches!(s.salad04_risk.as_deref(), Some("High" | "Critical"))).count(),
+        salad04_critical_count: window.iter().filter(|s| s.salad04_risk.as_deref() == Some("Critical")).count(),
+        morph_loop_count: window.iter().filter(|s| matches!(s.salad04_risk.as_deref(), Some("Medium" | "High" | "Critical"))).count(),
+        josa_loop_count: 0,
+        eomi_loop_count: 0,
+        jamo_leak_count: 0,
+        byte_piece_count: 0,
+        repeat_3gram_rate,
+        distinct_2_ratio,
+        guard_strict_count: window.iter().filter(|s| s.guard_strength.as_deref() == Some("Strict")).count(),
+        guard_panic_count: window.iter().filter(|s| s.guard_strength.as_deref() == Some("Panic")).count(),
+        decode03e_overlay_applied_count: window.iter().filter(|s| s.decode03e_applied).count(),
+        rollback_candidate_count: 0,
+        rollback_execute_count: 0,
+        stop_candidate_count: window.iter().filter(|s| s.stop_reason.is_some()).count(),
+        stop_execute_count: window.iter().filter(|s| s.stop_reason.is_some()).count(),
+        fallback_count: window.iter().filter(|s| !matches!(s.fallback_mode.as_deref(), None | Some("None") | Some("NONE") | Some("PASS"))).count(),
+        global_finite_fallback_count: window.iter().filter(|s| matches!(s.fallback_mode.as_deref(), Some("GLOBAL_FINITE_FALLBACK"))).count(),
+        empty_active_set_count: 0,
+        tokens_per_second_mean: None,
+        latency_p95_ms: None,
+    }
+}
+
+pub fn compute_eval02_drift_metrics(windows: &[Eval02WindowMetrics]) -> Eval02DriftMetrics {
+    let first = windows.first();
+    let last = windows.last();
+    let pci_decay_rate = match (first.and_then(|w| w.pci_mean), last.and_then(|w| w.pci_mean)) {
+        (Some(a), Some(b)) => Some((a - b).max(0.0)),
+        _ => None,
+    };
+    let entropy_growth_rate = match (first.and_then(|w| w.entropy_final_mean), last.and_then(|w| w.entropy_final_mean)) {
+        (Some(a), Some(b)) => Some((b - a).max(0.0)),
+        _ => None,
+    };
+    let salad02_growth_rate = match (first.and_then(|w| w.salad02_score_mean), last.and_then(|w| w.salad02_score_mean)) {
+        (Some(a), Some(b)) => Some((b - a).max(0.0)),
+        _ => None,
+    };
+    let salad04_growth_rate = match (first.and_then(|w| w.salad04_score_mean), last.and_then(|w| w.salad04_score_mean)) {
+        (Some(a), Some(b)) => Some((b - a).max(0.0)),
+        _ => None,
+    };
+    let morph_loop_growth_rate = match (first.map(|w| w.morph_loop_count as f32), last.map(|w| w.morph_loop_count as f32)) {
+        (Some(a), Some(b)) => Some(((b - a) / 64.0).max(0.0)),
+        _ => None,
+    };
+    let repeat_growth_rate = match (first.and_then(|w| w.repeat_3gram_rate), last.and_then(|w| w.repeat_3gram_rate)) {
+        (Some(a), Some(b)) => Some((b - a).max(0.0)),
+        _ => None,
+    };
+    let stop_pressure_growth_rate = match (first.map(|w| w.stop_execute_count as f32), last.map(|w| w.stop_execute_count as f32)) {
+        (Some(a), Some(b)) => Some(((b - a) / 64.0).max(0.0)),
+        _ => None,
+    };
+    let fallback_pressure_growth_rate = match (first.map(|w| w.fallback_count as f32), last.map(|w| w.fallback_count as f32)) {
+        (Some(a), Some(b)) => Some(((b - a) / 64.0).max(0.0)),
+        _ => None,
+    };
+    let guard_panic_growth_rate = match (first.map(|w| w.guard_panic_count as f32), last.map(|w| w.guard_panic_count as f32)) {
+        (Some(a), Some(b)) => Some(((b - a) / 64.0).max(0.0)),
+        _ => None,
+    };
+    let score = 0.20 * pci_decay_rate.unwrap_or(0.0)
+        + 0.18 * entropy_growth_rate.unwrap_or(0.0)
+        + 0.20 * salad02_growth_rate.unwrap_or(0.0).max(salad04_growth_rate.unwrap_or(0.0))
+        + 0.14 * morph_loop_growth_rate.unwrap_or(0.0)
+        + 0.10 * repeat_growth_rate.unwrap_or(0.0)
+        + 0.08 * stop_pressure_growth_rate.unwrap_or(0.0)
+        + 0.06 * fallback_pressure_growth_rate.unwrap_or(0.0)
+        + 0.04 * guard_panic_growth_rate.unwrap_or(0.0);
+    Eval02DriftMetrics {
+        pci_decay_rate,
+        entropy_growth_rate,
+        salad02_growth_rate,
+        salad04_growth_rate,
+        morph_loop_growth_rate,
+        repeat_growth_rate,
+        stop_pressure_growth_rate,
+        fallback_pressure_growth_rate,
+        guard_panic_growth_rate,
+        long_horizon_drift_score: clamp01(score),
+    }
+}
+
+pub fn judge_eval02_run(run: &Eval02RunReceipt) -> Eval02RunJudgement {
+    let mut fail = Vec::new();
+    let mut warn = Vec::new();
+    let total_global_fallback: usize = run.windows.iter().map(|w| w.global_finite_fallback_count).sum();
+    let total_salad02_critical: usize = run.windows.iter().map(|w| w.salad02_critical_count).sum();
+    let total_salad04_critical: usize = run.windows.iter().map(|w| w.salad04_critical_count).sum();
+    let total_byte: usize = run.windows.iter().map(|w| w.byte_piece_count).sum();
+    let total_jamo: usize = run.windows.iter().map(|w| w.jamo_leak_count).sum();
+    let total_empty_active: usize = run.windows.iter().map(|w| w.empty_active_set_count).sum();
+    let total_stop: usize = run.windows.iter().map(|w| w.stop_execute_count).sum();
+    if total_global_fallback > 0 { fail.push("global_finite_fallback".to_string()); }
+    if total_salad02_critical > 0 { fail.push("salad02_critical".to_string()); }
+    if total_salad04_critical > 0 { fail.push("salad04_critical".to_string()); }
+    if total_byte >= 3 { fail.push("byte_piece_threshold_exceeded".to_string()); }
+    if total_jamo >= 5 { fail.push("jamo_leak_threshold_exceeded".to_string()); }
+    if total_empty_active > 0 { fail.push("active_set_empty".to_string()); }
+    if run.output_token_count < 64 && run.finish_reason == "length" { fail.push("too_short_without_stop_reason".to_string()); }
+    let drift_risk = Eval02DriftRisk::from_score(run.drift.long_horizon_drift_score);
+    if matches!(drift_risk, Eval02DriftRisk::High | Eval02DriftRisk::Critical) { warn.push(format!("drift_risk_{}", drift_risk.as_str())); }
+    if total_stop > 0 { warn.push("stop_executed_in_long_horizon".to_string()); }
+    if run.drift.pci_decay_rate.unwrap_or(0.0) > 0.20 { warn.push("pci_decay_warn".to_string()); }
+    if run.drift.entropy_growth_rate.unwrap_or(0.0) > 0.20 { warn.push("entropy_growth_warn".to_string()); }
+    let status = if !fail.is_empty() { "FAIL" } else if !warn.is_empty() { "PASS_WITH_WARNINGS" } else { "PASS" };
+    Eval02RunJudgement {
+        status: status.to_string(),
+        drift_risk,
+        fail_reasons: fail,
+        warn_reasons: warn,
+        ready_for_profile_promotion: status == "PASS",
+        ready_for_default_enable: false,
+    }
+}
+
+pub fn build_eval02_run_from_samples(
+    run_id: String,
+    prompt_id: String,
+    profile_id: String,
+    backend: String,
+    seed: u64,
+    max_new_tokens: usize,
+    horizon_buckets: Vec<usize>,
+    samples: Vec<Eval02StepSample>,
+) -> Eval02RunReceipt {
+    let matrix = default_matrix();
+    let window_size = matrix.window_size;
+    let mut windows = Vec::new();
+    let mut start = 0usize;
+    while start < max_new_tokens {
+        let end = (start + window_size - 1).min(max_new_tokens);
+        windows.push(compute_eval02_window_metrics(&samples, start, end));
+        start += window_size;
+    }
+    let drift = compute_eval02_drift_metrics(&windows);
+    let output_token_count = samples.len();
+    let output_sig = format!("{}:{}:{}:{}:{}", run_id, prompt_id, profile_id, backend, output_token_count);
+    let mut run = Eval02RunReceipt {
+        patch_id: EVAL02_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id,
+        prompt_hash: hash_string(&prompt_id),
+        prompt_id,
+        profile_id,
+        backend,
+        seed,
+        max_new_tokens,
+        horizon_buckets,
+        output_token_count,
+        output_hash: hash_string(&output_sig),
+        visible_output_hash: None,
+        finish_reason: if output_token_count >= max_new_tokens { "length".to_string() } else { "partial_soak_trace".to_string() },
+        windows,
+        drift,
+        judgement: Eval02RunJudgement { status: "PENDING".to_string(), drift_risk: Eval02DriftRisk::Low, fail_reasons: Vec::new(), warn_reasons: Vec::new(), ready_for_profile_promotion: false, ready_for_default_enable: false },
+    };
+    run.judgement = judge_eval02_run(&run);
+    run
+}
