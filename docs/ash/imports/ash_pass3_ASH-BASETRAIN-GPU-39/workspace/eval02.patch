+fn hash_string(input: &str) -> String {
+    let mut h: u64 = 0xcbf29ce484222325;
+    for b in input.as_bytes() {
+        h ^= *b as u64;
+        h = h.wrapping_mul(0x100000001b3);
+    }
+    format!("fnv64:{:016x}", h)
+}
+
+fn clamp01(v: f32) -> f32 {
+    if !v.is_finite() { return 1.0; }
+    v.clamp(0.0, 1.0)
+}
+
+fn option_mean(values: &[Option<f32>]) -> Option<f32> {
+    let finite: Vec<f32> = values.iter().filter_map(|v| *v).filter(|v| v.is_finite()).collect();
+    if finite.is_empty() { None } else { Some(finite.iter().sum::<f32>() / finite.len() as f32) }
+}
+
+fn option_max(values: &[Option<f32>]) -> Option<f32> {
+    values.iter().filter_map(|v| *v).filter(|v| v.is_finite()).fold(None, |acc: Option<f32>, v| Some(acc.map(|a| a.max(v)).unwrap_or(v)))
+}
+
+fn option_min(values: &[Option<f32>]) -> Option<f32> {
+    values.iter().filter_map(|v| *v).filter(|v| v.is_finite()).fold(None, |acc: Option<f32>, v| Some(acc.map(|a| a.min(v)).unwrap_or(v)))
+}
+
+fn slope(first: Option<f32>, last: Option<f32>, steps: usize) -> Option<f32> {
+    match (first, last) {
+        (Some(a), Some(b)) if steps > 1 => Some((b - a) / steps as f32),
+        _ => None,
+    }
+}
