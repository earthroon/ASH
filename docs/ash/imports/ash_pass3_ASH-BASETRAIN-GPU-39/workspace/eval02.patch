++pub fn compute_eval02_window_metrics(samples: &[Eval02StepSample], window_start_step: usize, window_end_step: usize) -> Eval02WindowMetrics {
++    let window: Vec<&Eval02StepSample> = samples.iter().filter(|s| s.step >= window_start_step && s.step <= window_end_step).collect();
++    let pci_values: Vec<Option<f32>> = window.iter().map(|s| s.pci_raw).collect();
++    let entropy_values: Vec<Option<f32>> = window.iter().map(|s| s.entropy_final).collect();
++    let salad02_values: Vec<Option<f32>> = window.iter().map(|s| s.salad02_score).collect();
++    let salad04_values: Vec<Option<f32>> = window.iter().map(|s| s.salad04_score).collect();
++    let first_pci = pci_values.iter().find_map(|v| *v);
++    let last_pci = pci_values.iter().rev().find_map(|v| *v);
++    let first_entropy = entropy_values.iter().find_map(|v| *v);
++    let last_entropy = entropy_values.iter().rev().find_map(|v| *v);
++    let mut selected_ids = Vec::new();
++    for s in &window { if let Some(id) = s.selected_id { selected_ids.push(id); } }
++    let repeat_3gram_rate = if selected_ids.len() >= 3 {
++        let mut total = 0usize;
++        let mut repeats = 0usize;
++        for idx in 3..selected_ids.len() {
++            total += 1;
++            if selected_ids[idx] == selected_ids[idx - 3] { repeats += 1; }
++        }
++        Some(repeats as f32 / total.max(1) as f32)
++    } else { None };
++    let distinct_2_ratio = if selected_ids.len() >= 2 {
++        let mut total = 0usize;
++        let mut bigrams = std::collections::BTreeSet::new();
++        for pair in selected_ids.windows(2) {
++            total += 1;
++            bigrams.insert((pair[0], pair[1]));
++        }
++        Some(bigrams.len() as f32 / total.max(1) as f32)
++    } else { None };
++    Eval02WindowMetrics {
++        window_start_step,
++        window_end_step,
++        token_count: window.len(),
++        pci_mean: option_mean(&pci_values),
++        pci_min: option_min(&pci_values),
++        pci_slope: slope(first_pci, last_pci, window.len()),
++        entropy_final_mean: option_mean(&entropy_values),
++        entropy_final_max: option_max(&entropy_values),
++        entropy_slope: slope(first_entropy, last_entropy, window.len()),
++        salad02_score_mean: option_mean(&salad02_values),
++        salad02_score_max: option_max(&salad02_values),
++        salad02_high_count: window.iter().filter(|s| matches!(s.salad02_risk.as_deref(), Some("High" | "Critical"))).count(),
++        salad02_critical_count: window.iter().filter(|s| s.salad02_risk.as_deref() == Some("Critical")).count(),
++        salad04_score_mean: option_mean(&salad04_values),
++        salad04_score_max: option_max(&salad04_values),
++        salad04_high_count: window.iter().filter(|s| matches!(s.salad04_risk.as_deref(), Some("High" | "Critical"))).count(),
++        salad04_critical_count: window.iter().filter(|s| s.salad04_risk.as_deref() == Some("Critical")).count(),
++        morph_loop_count: window.iter().filter(|s| matches!(s.salad04_risk.as_deref(), Some("Medium" | "High" | "Critical"))).count(),
++        josa_loop_count: 0,
++        eomi_loop_count: 0,
++        jamo_leak_count: 0,
++        byte_piece_count: 0,
++        repeat_3gram_rate,
++        distinct_2_ratio,
++        guard_strict_count: window.iter().filter(|s| s.guard_strength.as_deref() == Some("Strict")).count(),
++        guard_panic_count: window.iter().filter(|s| s.guard_strength.as_deref() == Some("Panic")).count(),
++        decode03e_overlay_applied_count: window.iter().filter(|s| s.decode03e_applied).count(),
++        rollback_candidate_count: 0,
++        rollback_execute_count: 0,
++        stop_candidate_count: window.iter().filter(|s| s.stop_reason.is_some()).count(),
++        stop_execute_count: window.iter().filter(|s| s.stop_reason.is_some()).count(),
++        fallback_count: window.iter().filter(|s| !matches!(s.fallback_mode.as_deref(), None | Some("None") | Some("NONE") | Some("PASS"))).count(),
++        global_finite_fallback_count: window.iter().filter(|s| matches!(s.fallback_mode.as_deref(), Some("GLOBAL_FINITE_FALLBACK"))).count(),
++        empty_active_set_count: 0,
++        tokens_per_second_mean: None,
++        latency_p95_ms: None,
++    }
++}
