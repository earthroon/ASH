+pub fn sample_from_sampler03(receipt: &SamplerParityReceipt) -> Eval02StepSample {
+    let profile_id = env::var("ASH_EVAL02_PROFILE_ID").unwrap_or_else(|_| "S05_decode03e_guard_overlay".to_string());
+    let backend = env::var("ASH_EVAL02_BACKEND").unwrap_or_else(|_| "sampler03_projection".to_string());
+    let seed = env_u64("ASH_EVAL02_SEED", 0);
+    let pci = receipt.cpu.final_normalized_entropy.map(|h| 1.0 - h.clamp(0.0, 1.0));
+    let entropy = receipt.cpu.final_entropy.or(receipt.cpu.active_entropy);
+    let salad02_score = env::var("ASH_EVAL02_SALAD02_SCORE").ok().and_then(|v| v.parse::<f32>().ok());
+    let salad04_score = env::var("ASH_EVAL02_SALAD04_SCORE").ok().and_then(|v| v.parse::<f32>().ok());
+    Eval02StepSample {
+        run_id: env::var("ASH_EVAL02_RUN_ID").unwrap_or_else(|_| "eval02_sampler03_soak".to_string()),
+        prompt_id: env::var("ASH_EVAL02_PROMPT_ID").unwrap_or_else(|_| format!("sampler03_step_{}", receipt.step)),
+        profile_id,
+        backend,
+        seed,
+        step: receipt.step,
+        selected_id: Some(receipt.cpu.selected_id),
+        selected_piece_preview: None,
+        pci_raw: pci,
+        entropy_final: entropy,
+        salad02_score,
+        salad02_risk: risk_from_score(salad02_score),
+        salad04_score,
+        salad04_risk: risk_from_score(salad04_score),
+        decode03e_applied: env_bool("ASH_EVAL02_DECODE03E_APPLIED", false),
+        guard_strength: env::var("ASH_EVAL02_GUARD_STRENGTH").ok(),
+        fallback_mode: Some(receipt.cpu.recovery_mode.clone()),
+        stop_reason: env::var("ASH_EVAL02_STOP_REASON").ok(),
+    }
+}
+
+fn risk_from_score(score: Option<f32>) -> Option<String> {
+    score.map(|s| {
+        let s = clamp01(s);
+        let risk = if s >= 0.80 { "Critical" }
+            else if s >= 0.55 { "High" }
+            else if s >= 0.30 { "Medium" }
+            else { "Low" };
+        risk.to_string()
+    })
+}
