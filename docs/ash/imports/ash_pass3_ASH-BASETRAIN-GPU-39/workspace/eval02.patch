+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+pub enum Eval02Mode {
+    Off,
+    ManifestOnly,
+    RunSoak,
+    CompareProfiles,
+    StrictSoakGate,
+}
+
+impl Eval02Mode {
+    pub fn from_env() -> Self {
+        let value = env::var("ASH_EVAL02_MODE")
+            .unwrap_or_else(|_| "manifest_only".to_string())
+            .trim()
+            .to_ascii_lowercase();
+        match value.as_str() {
+            "off" | "false" | "0" | "disabled" => Self::Off,
+            "run_soak" | "run" | "bench" => Self::RunSoak,
+            "compare" | "compare_profiles" => Self::CompareProfiles,
+            "strict" | "strict_soak_gate" => Self::StrictSoakGate,
+            _ => Self::ManifestOnly,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::ManifestOnly => "ManifestOnly",
+            Self::RunSoak => "RunSoak",
+            Self::CompareProfiles => "CompareProfiles",
+            Self::StrictSoakGate => "StrictSoakGate",
+        }
+    }
+
+    pub fn enabled(self) -> bool { !matches!(self, Self::Off) }
+}
