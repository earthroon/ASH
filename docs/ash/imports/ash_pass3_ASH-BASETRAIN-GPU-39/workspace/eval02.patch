+pub fn summarize_eval02_runs(runs: &[Eval02RunReceipt]) -> Eval02Summary {
+    let matrix = default_matrix();
+    let mut overall = Eval02OverallStats::default();
+    let mut by_profile_raw: BTreeMap<String, Vec<&Eval02RunReceipt>> = BTreeMap::new();
+    let mut long = Eval02LongHorizonStats::default();
+    for run in runs {
+        match run.judgement.status.as_str() {
+            "PASS" => overall.pass_count += 1,
+            "PASS_WITH_WARNINGS" => overall.warn_count += 1,
+            "FAIL" => overall.fail_count += 1,
+            _ => {}
+        }
+        if run.judgement.drift_risk == Eval02DriftRisk::Critical { long.critical_drift_count += 1; }
+        if run.judgement.drift_risk == Eval02DriftRisk::High { long.high_drift_count += 1; }
+        if run.drift.pci_decay_rate.unwrap_or(0.0) > 0.20 { long.pci_decay_warn_count += 1; }
+        if run.drift.entropy_growth_rate.unwrap_or(0.0) > 0.20 { long.entropy_growth_warn_count += 1; }
+        if run.drift.morph_loop_growth_rate.unwrap_or(0.0) > 0.10 { long.morph_loop_growth_warn_count += 1; }
+        if run.drift.guard_panic_growth_rate.unwrap_or(0.0) > 0.10 { long.guard_panic_growth_warn_count += 1; }
+        by_profile_raw.entry(run.profile_id.clone()).or_default().push(run);
+    }
+    let mut by_profile = BTreeMap::new();
+    for (profile, list) in by_profile_raw {
+        let count = list.len().max(1);
+        let pass = list.iter().filter(|r| r.judgement.status == "PASS").count();
+        let warn = list.iter().filter(|r| r.judgement.status == "PASS_WITH_WARNINGS").count();
+        let fail = list.iter().filter(|r| r.judgement.status == "FAIL").count();
+        let drift_mean = list.iter().map(|r| r.drift.long_horizon_drift_score).sum::<f32>() / count as f32;
+        let salad02_mean = list.iter().map(|r| r.windows.iter().filter_map(|w| w.salad02_score_max).fold(0.0, f32::max)).sum::<f32>() / count as f32;
+        let salad04_mean = list.iter().map(|r| r.windows.iter().filter_map(|w| w.salad04_score_max).fold(0.0, f32::max)).sum::<f32>() / count as f32;
+        let stop_count = list.iter().flat_map(|r| r.windows.iter()).map(|w| w.stop_execute_count).sum::<usize>();
+        by_profile.insert(profile, Eval02ProfileStats {
+            pass_rate: pass as f32 / count as f32,
+            run_count: list.len(),
+            fail_count: fail,
+            warn_count: warn,
+            drift_score_mean: drift_mean,
+            salad02_score_max_mean: salad02_mean,
+            salad04_score_max_mean: salad04_mean,
+            stop_execute_count: stop_count,
+            tokens_per_second_mean: 0.0,
+        });
+    }
+    let baseline_id = env::var("ASH_EVAL02_BASELINE_PROFILE").unwrap_or_else(|_| "S01_static_safe".to_string());
+    let candidate_id = env::var("ASH_EVAL02_CANDIDATE_PROFILE").unwrap_or_else(|_| "S05_decode03e_guard_overlay".to_string());
+    let baseline = by_profile.get(&baseline_id).cloned().unwrap_or_default();
+    let candidate = by_profile.get(&candidate_id).cloned().unwrap_or_default();
+    Eval02Summary {
+        patch_id: EVAL02_PATCH_ID.to_string(),
+        input_patch: EVAL02_INPUT_PATCH_ID.to_string(),
+        status: if overall.fail_count > 0 { "PASS_WITH_WARNINGS" } else { "PASS_STATIC_OR_EMPTY" }.to_string(),
+        mode: Eval02Mode::from_env().as_str().to_string(),
+        suite: Eval02SuiteStats {
+            prompt_count: 10,
+            profile_count: matrix.profiles.len(),
+            seed_count: matrix.seeds.len(),
+            backend_count: matrix.backends.len(),
+            expected_run_count: 10 * matrix.profiles.len() * matrix.seeds.len() * matrix.backends.len(),
+            completed_run_count: runs.len(),
+            not_comparable_count: 0,
+        },
+        overall,
+        by_profile,
+        long_horizon: long,
+        regression: Eval02RegressionJudgement {
+            baseline_profile: baseline_id,
+            candidate_profile: candidate_id,
+            drift_score_improved: candidate.drift_score_mean <= baseline.drift_score_mean || baseline.run_count == 0,
+            salad_score_improved: candidate.salad02_score_max_mean <= baseline.salad02_score_max_mean || baseline.run_count == 0,
+            morph_loop_reduced: candidate.salad04_score_max_mean <= baseline.salad04_score_max_mean || baseline.run_count == 0,
+            over_stop_regression: candidate.stop_execute_count > baseline.stop_execute_count && baseline.run_count > 0,
+            speed_regression_warn: false,
+        },
+        acceptance: Eval02Acceptance {
+            ready_for_decode03f_threshold_calibration: true,
+            ready_for_medusa00: false,
+            ready_for_default_guard_overlay: false,
+            reason: "long horizon soak harness sealed; runtime soak evidence required before default guard overlay or Medusa promotion".to_string(),
+        },
+    }
+}
