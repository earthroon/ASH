+fn controlled_on_decision(
+    integrity: &TransitionProbeIntegrityCounters,
+    parity: &Decode02dTransitionParity,
+    safety: &Decode02dSafetyCases,
+) -> Decode02dPromotionDecision {
+    let mut blocking = Vec::new();
+
+    if !parity.candidate_trace_version_ok { blocking.push("CANDIDATE_TRACE_VERSION_NOT_V4".to_string()); }
+    if !parity.hint_trace_available { blocking.push("HINT_TABLE_OR_GPU_TRANSITION_TRACE_MISSING".to_string()); }
+    if !probe_integrity_is_pass(&integrity.status) { blocking.push(integrity.status.clone()); }
+    if integrity.weighted_logit_changed_count > 0 { blocking.push("WEIGHTED_LOGIT_MUTATED".to_string()); }
+    if integrity.active_mask_changed_count > 0 { blocking.push("ACTIVE_MASK_MUTATED".to_string()); }
+    if integrity.final_mask_changed_count > 0 { blocking.push("FINAL_MASK_MUTATED".to_string()); }
+    if integrity.selected_id_changed { blocking.push("SELECTED_ID_MUTATED".to_string()); }
+    if parity.action_match == Some(false) { blocking.push("TRANSITION_ACTION_MISMATCH".to_string()); }
+    if parity.reason_match == Some(false) { blocking.push("TRANSITION_REASON_MISMATCH".to_string()); }
+    if parity.hardblock_match == Some(false) { blocking.push("TRANSITION_HARDBLOCK_MISMATCH".to_string()); }
+    if safety.normal_korean_hardblocked { blocking.push("NORMAL_KOREAN_HARDBLOCKED".to_string()); }
+    if safety.emotional_repeat_hardblocked { blocking.push("EMOTIONAL_REPEAT_HARDBLOCKED".to_string()); }
+
+    let eligible = blocking.is_empty();
+    Decode02dPromotionDecision {
+        eligible,
+        promotion_status: if eligible { "TRANSITION_ON_CANDIDATE_READY" } else { "TRANSITION_ON_BLOCKED" }.to_string(),
+        blocking_reasons: blocking,
+    }
+}
