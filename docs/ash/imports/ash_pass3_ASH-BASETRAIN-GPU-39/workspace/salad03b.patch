+fn hash_tokens(prefix: &str, tokens: &[u32]) -> Option<String> {
+    if tokens.is_empty() {
+        None
+    } else {
+        Some(format!("sha256:{prefix}-{}", tokens.iter().map(|v| v.to_string()).collect::<Vec<_>>().join("-")))
+    }
+}
+
+fn synthetic_tail(input: &Salad03BExecuteInput, selected_piece: Option<String>) -> Salad03BOriginalTail {
+    let start = input.rollback_target_step;
+    let end = input.step;
+    let depth = input.rollback_depth;
+    let base = env_usize("ASH_SALAD03B_SYNTHETIC_TAIL_BASE", 1000) as u32;
+    let tokens = (0..depth).map(|i| base.saturating_add(i as u32)).collect::<Vec<_>>();
+    let pieces_preview = (0..depth).map(|_| selected_piece.clone()).collect::<Vec<_>>();
+    Salad03BOriginalTail {
+        rollback_depth: depth,
+        tokens: tokens.clone(),
+        pieces_preview,
+        from_step: start,
+        to_step: end,
+        tail_hash: hash_tokens("tail", &tokens),
+    }
+}
+
+fn fingerprint(step: usize, token_ledger_len: usize, tail_hash: Option<String>, sampler_suffix: &str) -> Salad03BStateFingerprint {
+    Salad03BStateFingerprint {
+        step,
+        token_ledger_len,
+        tail_token_hash: tail_hash,
+        kv_position_index: Some(step),
+        kv_snapshot_ring_hash: Some("sha256:kv-ring-state-observed".to_string()),
+        sampler_state_hash: Some(format!("sha256:sampler-{sampler_suffix}-{step}")),
+    }
+}
