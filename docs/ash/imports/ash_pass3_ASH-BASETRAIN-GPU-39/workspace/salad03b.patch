+pub fn clamp_safe_resample_config(config: &Salad03BSafeResampleConfig) -> Salad03BSafeResampleConfig {
+    Salad03BSafeResampleConfig {
+        temperature: clamp_f32(config.temperature, 0.03, 0.50, 0.14),
+        top_p: clamp_f32(config.top_p, 0.50, 0.95, 0.82),
+        top_k: config.top_k.min(1024),
+        min_p: clamp_f32(config.min_p, 0.00, 0.25, 0.12),
+        guard_strength: if config.guard_strength.trim().is_empty() { "Panic".to_string() } else { config.guard_strength.clone() },
+        repeat_penalty: config.repeat_penalty.map(|v| clamp_f32(v, 1.00, 1.25, 1.12)),
+        no_repeat_ngram: config.no_repeat_ngram.map(|v| v.min(8)),
+        max_resample_attempts: config.max_resample_attempts.clamp(1, 2),
+        safe_stop_if_resample_fails: config.safe_stop_if_resample_fails,
+    }
+}
