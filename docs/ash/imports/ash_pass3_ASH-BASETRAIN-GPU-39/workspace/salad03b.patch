+fn risk_to_string_from_salad03(receipt: &Salad03StepReceipt) -> String {
+    match receipt.input.risk_stable {
+        crate::salad02_detector::SaladRiskLevel::Low => "Low",
+        crate::salad02_detector::SaladRiskLevel::Medium => "Medium",
+        crate::salad02_detector::SaladRiskLevel::High => "High",
+        crate::salad02_detector::SaladRiskLevel::Critical => "Critical",
