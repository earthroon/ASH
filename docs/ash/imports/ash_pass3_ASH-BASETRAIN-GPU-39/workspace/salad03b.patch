+fn safe_config_from_salad03(plan_config: &crate::salad03_rollback::Salad03SafeResampleConfig) -> Salad03BSafeResampleConfig {
+    clamp_safe_resample_config(&Salad03BSafeResampleConfig {
+        temperature: plan_config.temperature,
+        top_p: plan_config.top_p,
+        top_k: plan_config.top_k,
+        min_p: plan_config.min_p,
+        guard_strength: plan_config.guard_strength.clone(),
+        repeat_penalty: plan_config.repeat_penalty,
+        no_repeat_ngram: plan_config.no_repeat_ngram,
+        max_resample_attempts: plan_config.max_resample_attempts,
+        safe_stop_if_resample_fails: plan_config.safe_stop_if_resample_fails,
+    })
+}
