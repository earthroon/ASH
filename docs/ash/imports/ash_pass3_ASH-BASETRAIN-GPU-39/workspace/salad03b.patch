+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+pub enum Salad03BMode {
+    Off,
+    PlanOnly,
+    ControlledExecute,
+    StrictControlledExecute,
+}
+
+impl Salad03BMode {
+    pub fn from_env() -> Self {
+        let value = env::var("ASH_SALAD03B_MODE")
+            .or_else(|_| env::var("ASH_SALAD03B_EXECUTE"))
+            .unwrap_or_else(|_| "off".to_string())
+            .trim()
+            .to_ascii_lowercase();
+        match value.as_str() {
+            "plan" | "plan_only" | "dry" | "dry_run" => Self::PlanOnly,
+            "controlled" | "controlled_execute" | "execute" | "true" | "1" => Self::ControlledExecute,
+            "strict" | "strict_controlled" | "strict_controlled_execute" => Self::StrictControlledExecute,
+            _ => Self::Off,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::PlanOnly => "PlanOnly",
+            Self::ControlledExecute => "ControlledExecute",
+            Self::StrictControlledExecute => "StrictControlledExecute",
+        }
+    }
+
+    pub fn requested(self) -> bool {
+        !matches!(self, Self::Off)
+    }
+
+    pub fn can_mutate(self) -> bool {
+        matches!(self, Self::ControlledExecute | Self::StrictControlledExecute)
+    }
+}
