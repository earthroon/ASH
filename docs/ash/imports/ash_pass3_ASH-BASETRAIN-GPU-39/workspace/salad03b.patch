+pub fn decide_salad03b_gate(input: &Salad03BExecuteInput) -> Salad03BGateDecision {
+    let mut denied_reasons = Vec::new();
+    let mut warning_reasons = Vec::new();
+    let mut execute_reasons = Vec::new();
+    let mut strict_fail = false;
+
+    if matches!(input.mode, Salad03BMode::Off | Salad03BMode::PlanOnly) {
+        denied_reasons.push(if matches!(input.mode, Salad03BMode::Off) { "mode_off" } else { "mode_plan_only" }.to_string());
+    }
+    if !input.behavior_change_allowed {
+        denied_reasons.push("behavior_change_not_allowed".to_string());
+    }
+    if !risk_is_high_enough(&input.salad02_risk_stable) {
+        denied_reasons.push("risk_not_high_enough".to_string());
+    }
+    if input.salad03_decision != "PlanRollback" && input.salad03_decision != "ExecuteRollbackResample" {
+        denied_reasons.push("missing_salad03_plan".to_string());
+    }
+    if !input.restore_verified_for_salad03b {
+        denied_reasons.push("missing_verified_snapshot".to_string());
+    }
+    if input.rollback_depth == 0 {
+        denied_reasons.push("rollback_depth_zero".to_string());
+    }
+    if input.rollback_depth > env_usize("ASH_SALAD03B_MAX_ROLLBACK_DEPTH", 8) {
+        denied_reasons.push("rollback_depth_exceeds_max".to_string());
+    }
+    if input.token_ledger_len <= input.rollback_target_step {
+        denied_reasons.push("token_ledger_too_short".to_string());
+    }
+    if !input.kv_restore_supported {
+        denied_reasons.push("kv_restore_unsupported".to_string());
+    }
+    if !input.position_restore_supported {
+        denied_reasons.push("position_restore_unsupported".to_string());
+    }
+    if input.rollback_count_window >= input.max_rollback_per_window {
+        denied_reasons.push("rollback_window_limit_reached".to_string());
+    }
+    if input.snapshot_step != input.rollback_target_step {
+        warning_reasons.push("snapshot_step_mismatch_nearest_or_non_exact_snapshot".to_string());
+        if matches!(input.mode, Salad03BMode::StrictControlledExecute) {
+            denied_reasons.push("snapshot_step_mismatch".to_string());
+            strict_fail = true;
+        }
+    }
+    if matches!(input.mode, Salad03BMode::StrictControlledExecute) && input.numeric_risk {
+        denied_reasons.push("numeric_risk_unresolved".to_string());
+        strict_fail = true;
+    }
+    if input.global_finite_fallback_seen {
+        warning_reasons.push("global_finite_fallback_seen_safe_stop_may_be_preferred".to_string());
+    }
+    if denied_reasons.is_empty() {
+        execute_reasons.push("controlled_execute_enabled".to_string());
+        execute_reasons.push("salad_high_risk".to_string());
+        execute_reasons.push("restore_verified_for_salad03b".to_string());
+        execute_reasons.push("kv_restore_supported".to_string());
+    }
+    Salad03BGateDecision {
+        can_execute: denied_reasons.is_empty() && input.mode.can_mutate(),
+        strict_fail,
+        denied_reasons,
+        warning_reasons,
+        execute_reasons,
+    }
+}
