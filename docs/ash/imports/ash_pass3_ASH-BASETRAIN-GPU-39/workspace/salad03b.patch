+pub fn append_salad03b_receipt_from_sampler03(source: &SamplerParityReceipt) {
+    let mode = Salad03BMode::from_env();
+    if !mode.requested() {
+        return;
+    }
+    let entropy_receipt = receipt_from_sampler03(Decode03AMode::Receipt, source);
+    let pci_receipt = receipt_from_decode03a(Decode03BMode::Receipt, &entropy_receipt, None, 0);
+    let shadow_receipt = receipt_from_decode03b(Decode03CMode::Receipt, &pci_receipt, Some(&entropy_receipt));
+    let dynamic_mode = DynamicSamplerMode::from_env();
+    let mut decode03d_receipt = receipt_from_decode03c(dynamic_mode, &shadow_receipt);
+    decode03d_receipt.selected_id_after_apply = Some(source.cpu.selected_id);
+    let salad02_receipt = salad02_receipt_from_decode03d(&decode03d_receipt);
+    let salad03_mode = Salad03Mode::from_env();
+    let salad03_receipt = receipt_from_salad02(salad03_mode, &salad02_receipt);
+    let kv00_mode = match mode {
+        Salad03BMode::ControlledExecute | Salad03BMode::StrictControlledExecute => KvRollback00Mode::ForkedReplayProbe,
+        Salad03BMode::PlanOnly => KvRollback00Mode::SnapshotOnly,
+        Salad03BMode::Off => KvRollback00Mode::Off,
+    };
+    let kv00 = kv00_receipt_from_salad03(kv00_mode, &salad03_receipt);
+    let kv01_mode = match mode {
+        Salad03BMode::StrictControlledExecute => KvRollback01Mode::StrictForkedReplayProbe,
+        Salad03BMode::ControlledExecute => KvRollback01Mode::ForkedReplayProbe,
+        Salad03BMode::PlanOnly => KvRollback01Mode::PlanOnly,
+        Salad03BMode::Off => KvRollback01Mode::Off,
+    };
+    let kv01 = kv01_receipt_from_kvrollback00(kv01_mode, &kv00);
+    let receipt = receipt_from_salad03_and_kv01(mode, &salad03_receipt, &kv01);
+    let path = receipt_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(line) = serde_json::to_string(&receipt) {
+        use std::io::Write;
+        if let Ok(mut file) = fs::OpenOptions::new().create(true).append(true).open(path) {
+            let _ = writeln!(file, "{}", line);
+        }
+    }
+}
+
+fn read_receipts(path: PathBuf) -> Vec<Salad03BStepReceipt> {
+    let data = match fs::read_to_string(path) {
+        Ok(data) => data,
+        Err(_) => return Vec::new(),
+    };
+    data.lines().filter_map(|line| serde_json::from_str::<Salad03BStepReceipt>(line).ok()).collect()
+}
+
+pub fn summary_from_receipts(receipts: &[Salad03BStepReceipt]) -> Salad03BSummary {
+    let mut gate = Salad03BGateStats::default();
+    let mut execution = Salad03BExecutionStats::default();
+    let mut resample = Salad03BResampleStats::default();
+    let mut post_check = Salad03BPostCheckStats::default();
+    let mut safety = Salad03BSafetyStats::default();
+    let mut logprob_sum = 0.0f32;
+    let mut logprob_count = 0usize;
+    let mut mode = Salad03BMode::Off.as_str().to_string();
+
+    for receipt in receipts {
+        mode = receipt.mode.as_str().to_string();
+        if receipt.gate.can_execute { gate.can_execute_count += 1; }
+        if !receipt.gate.denied_reasons.is_empty() { gate.denied_count += 1; }
+        if receipt.gate.strict_fail { gate.strict_fail_count += 1; }
+
+        if receipt.execution.executed { execution.executed_count += 1; }
+        if receipt.execution.rollback_executed { execution.rollback_executed_count += 1; }
+        if receipt.execution.kv_restore_executed { execution.kv_restore_executed_count += 1; }
+        if receipt.execution.token_ledger_truncate_executed { execution.token_ledger_truncate_executed_count += 1; }
+        if receipt.execution.position_restore_executed { execution.position_restore_executed_count += 1; }
+        if receipt.execution.resample_executed { execution.resample_executed_count += 1; }
+        if receipt.execution.safe_stop_executed { execution.safe_stop_executed_count += 1; }
+
+        if let Some(replacement) = &receipt.execution.replacement {
+            if replacement.success { resample.success_count += 1; } else { resample.failure_count += 1; }
+            if let Some(lp) = replacement.selected_logprob {
+                logprob_sum += lp;
+                logprob_count += 1;
+            }
+        }
+        if receipt.post_check.risk_improved == Some(true) { post_check.risk_improved_count += 1; }
+        if receipt.post_check.risk_worsened == Some(true) { post_check.risk_worsened_count += 1; }
+        if receipt.post_check.safe_stop_recommended { post_check.safe_stop_recommended_count += 1; }
+        if receipt.post_check.replacement_rejected { post_check.replacement_rejected_count += 1; }
+
+        if receipt.execution.rollback_executed && !receipt.input.restore_verified_for_salad03b { safety.execute_without_verified_snapshot_count += 1; }
+        if receipt.execution.executed && !receipt.gate.can_execute { safety.execute_without_gate_count += 1; }
+        if receipt.execution.rollback_executed && (!receipt.execution.kv_restore_executed || !receipt.execution.token_ledger_truncate_executed) {
+            safety.string_only_rollback_count += 1;
+        }
+        if receipt.execution.executed && (!receipt.execution.kv_restore_executed || !receipt.execution.position_restore_executed || !receipt.execution.token_ledger_truncate_executed) {
+            safety.partial_failure_count += 1;
+        }
+    }
+    resample.mean_replacement_logprob = if logprob_count > 0 { Some(logprob_sum / logprob_count as f32) } else { None };
+    let steps_observed = receipts.len();
+    let contract_fail = safety.string_only_rollback_count > 0
+        || safety.execute_without_verified_snapshot_count > 0
+        || safety.execute_without_gate_count > 0
+        || safety.partial_failure_count > 0
+        || execution.safe_stop_executed_count > 0;
+    let status = if steps_observed == 0 {
+        "STATIC_BAKE_DEFINED_NOT_RUN"
+    } else if contract_fail || gate.strict_fail_count > 0 {
+        "FAIL"
+    } else if gate.denied_count > 0 || resample.failure_count > 0 || post_check.safe_stop_recommended_count > 0 {
+        "PASS_WITH_WARNINGS"
+    } else {
+        "PASS"
+    }.to_string();
+    Salad03BSummary {
+        patch_id: SALAD03B_PATCH_ID.to_string(),
+        input_patch: SALAD03B_INPUT_PATCH_ID.to_string(),
+        status,
+        mode,
+        controlled_execute: execution.executed_count > 0,
+        default_enable: false,
+        requires_salad03: env_bool("ASH_SALAD03B_REQUIRE_SALAD03", true),
+        requires_kv_rollback01: env_bool("ASH_SALAD03B_REQUIRE_KV_ROLLBACK01", true),
+        steps_observed,
+        gate,
+        execution,
+        resample,
+        post_check,
+        safety,
+        ready_for_salad03c_span_resample: false,
+        ready_for_stop01_safe_stop_execute: steps_observed > 0,
+        ready_for_default_enable: false,
+        reason: if steps_observed == 0 {
+            "static bake only; run controlled fixtures before enabling rollback execute".to_string()
+        } else if contract_fail {
+            "SALAD-03B contract violation detected; rollback execute must remain disabled".to_string()
+        } else {
+            "controlled rollback execute receipt sealed; default enable remains forbidden".to_string()
+        },
+    }
+}
+
+pub fn write_salad03b_summary_from_receipt_file() {
+    let summary = summary_from_receipts(&read_receipts(receipt_path()));
+    let path = summary_path();
+    if let Some(parent) = path.parent() {
+        let _ = fs::create_dir_all(parent);
+    }
+    if let Ok(json) = serde_json::to_string_pretty(&summary) {
+        let _ = fs::write(path, format!("{}\n", json));
+    }
+}
