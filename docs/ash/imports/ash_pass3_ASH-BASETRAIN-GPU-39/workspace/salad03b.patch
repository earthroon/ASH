+fn replacement_from_input(input: &Salad03BExecuteInput, selected_id: Option<u32>, selected_piece: Option<String>) -> Salad03BReplacement {
+    let replacement_id = env::var("ASH_SALAD03B_REPLACEMENT_TOKEN_ID")
+        .ok()
+        .and_then(|v| v.parse::<u32>().ok())
+        .or(selected_id)
+        .unwrap_or(0);
+    let piece = env::var("ASH_SALAD03B_REPLACEMENT_PIECE")
+        .ok()
+        .or(selected_piece)
+        .or(Some("<safe-resample>".to_string()));
+    let success = !env_bool("ASH_SALAD03B_FORCE_RESAMPLE_FAILURE", false);
+    Salad03BReplacement {
+        resample_attempts: if success { 1 } else { input.safe_resample_config.max_resample_attempts },
+        success,
+        replacement_tokens: if success { vec![replacement_id] } else { Vec::new() },
+        replacement_pieces_preview: if success { vec![piece] } else { Vec::new() },
+        selected_rank: if success { Some(1) } else { None },
+        selected_logprob: if success { Some(-1.11) } else { None },
+        replacement_hash: if success { hash_tokens("replacement", &[replacement_id]) } else { None },
+        failure_reason: if success { None } else { Some("simulated_or_runtime_resample_failure".to_string()) },
+    }
+}
