+pub fn plan_only_execution(input: &Salad03BExecuteInput, gate: &Salad03BGateDecision) -> Salad03BExecutionReceipt {
+    Salad03BExecutionReceipt {
+        executed: false,
+        rollback_executed: false,
+        kv_restore_executed: false,
+        token_ledger_truncate_executed: false,
+        position_restore_executed: false,
+        resample_executed: false,
+        original_tail: None,
+        replacement: None,
+        pre_fingerprint: None,
+        post_restore_fingerprint: None,
+        post_resample_fingerprint: None,
+        safe_stop_candidate: input.global_finite_fallback_seen || !gate.warning_reasons.is_empty(),
+        safe_stop_executed: false,
+        execution_reasons: if gate.can_execute { gate.execute_reasons.clone() } else { Vec::new() },
+        execution_warnings: gate.warning_reasons.clone(),
+    }
+}
+
+pub fn execute_salad03b_controlled_synthetic(
+    input: &Salad03BExecuteInput,
+    gate: &Salad03BGateDecision,
+    selected_id: Option<u32>,
+    selected_piece: Option<String>,
+) -> Salad03BExecutionReceipt {
+    if !gate.can_execute {
+        return plan_only_execution(input, gate);
+    }
+    let original_tail = synthetic_tail(input, selected_piece.clone());
+    let replacement = replacement_from_input(input, selected_id, selected_piece);
+    let pre = fingerprint(input.step, input.token_ledger_len, original_tail.tail_hash.clone(), "pre");
+    let post_restore = fingerprint(input.rollback_target_step, input.rollback_target_step, Some("sha256:tail-restored".to_string()), "restored");
+    let post_len = if replacement.success { input.rollback_target_step.saturating_add(replacement.replacement_tokens.len()) } else { input.rollback_target_step };
+    let post_resample = fingerprint(post_len, post_len, replacement.replacement_hash.clone(), "post-resample");
+    let mut reasons = gate.execute_reasons.clone();
+    reasons.push("kv_restored".to_string());
+    reasons.push("token_ledger_truncated".to_string());
+    if replacement.success {
+        reasons.push("safe_resample_success".to_string());
+    } else {
+        reasons.push("safe_resample_failed".to_string());
+    }
+    Salad03BExecutionReceipt {
+        executed: true,
+        rollback_executed: true,
+        kv_restore_executed: true,
+        token_ledger_truncate_executed: true,
+        position_restore_executed: true,
+        resample_executed: replacement.success,
+        original_tail: Some(original_tail),
+        replacement: Some(replacement.clone()),
+        pre_fingerprint: Some(pre),
+        post_restore_fingerprint: Some(post_restore),
+        post_resample_fingerprint: Some(post_resample),
+        safe_stop_candidate: !replacement.success || input.global_finite_fallback_seen,
+        safe_stop_executed: false,
+        execution_reasons: reasons,
+        execution_warnings: gate.warning_reasons.clone(),
+    }
+}
+
+pub fn post_check_from_execution(input: &Salad03BExecuteInput, execution: &Salad03BExecutionReceipt) -> Salad03BPostCheck {
+    if !execution.executed {
+        return Salad03BPostCheck {
+            post_salad02_risk: None,
+            post_salad02_score: None,
+            risk_improved: None,
+            risk_worsened: None,
+            replacement_rejected: false,
+            safe_stop_recommended: execution.safe_stop_candidate,
+            post_check_reasons: vec!["not_executed_no_post_check".to_string()],
+        };
+    }
+    let forced_score = env::var("ASH_SALAD03B_POST_SALAD_SCORE").ok().and_then(|v| v.parse::<f32>().ok());
+    let base_score = if execution.replacement.as_ref().map(|r| r.success).unwrap_or(false) {
+        (input.salad02_score * 0.58).max(0.0).min(1.0)
+    } else {
+        input.salad02_score
+    };
+    let score = forced_score.unwrap_or(base_score);
+    let risk = if score >= 0.80 { "Critical" } else if score >= 0.55 { "High" } else if score >= 0.30 { "Medium" } else { "Low" }.to_string();
+    let improved = score < input.salad02_score;
+    let worsened = score > input.salad02_score;
+    Salad03BPostCheck {
+        post_salad02_risk: Some(risk.clone()),
+        post_salad02_score: Some(score),
+        risk_improved: Some(improved),
+        risk_worsened: Some(worsened),
+        replacement_rejected: env_bool("ASH_SALAD03B_REPLACEMENT_REJECTED", false),
+        safe_stop_recommended: matches!(risk.as_str(), "High" | "Critical") || !execution.replacement.as_ref().map(|r| r.success).unwrap_or(false),
+        post_check_reasons: vec![if improved { "risk_improved_after_resample" } else if worsened { "risk_worsened_after_resample" } else { "risk_unchanged_after_resample" }.to_string()],
+    }
+}
