+pub fn input_from_salad03_and_kv01(
+    mode: Salad03BMode,
+    salad03: &Salad03StepReceipt,
+    kv01: &KvRollback01StepReceipt,
+) -> Salad03BExecuteInput {
+    let target_step = salad03.plan.rollback_target_step.unwrap_or_else(|| salad03.step.saturating_sub(salad03.plan.rollback_depth));
+    let snapshot_id = kv01.snapshot_id.clone().unwrap_or_else(|| format!("kv_{target_step:06}"));
+    let snapshot_step = kv01.snapshot_step.unwrap_or(target_step);
+    let max_rollback_per_window = env_usize("ASH_SALAD03B_MAX_ROLLBACKS_PER_WINDOW", 1);
+    let restore_supported = kv01.fork_capability.supports_snapshot_restore_to_fork || kv01.fork_capability.supports_forked_state;
+    Salad03BExecuteInput {
+        mode,
+        behavior_change_allowed: env_bool("ASH_SALAD03B_BEHAVIOR_CHANGE_ALLOWED", false),
+        run_id: env_string("ASH_SALAD03B_RUN_ID", "salad03b_sampler03_bridge"),
+        prompt_hash: salad03.prompt_hash.clone(),
+        seed: salad03.seed,
+        step: salad03.step,
+        backend: salad03.backend.clone(),
+        salad02_risk_stable: risk_to_string_from_salad03(salad03),
+        salad02_score: salad03.input.salad_score,
+        salad03_decision: format!("{:?}", salad03.plan.decision),
+        rollback_depth: salad03.plan.rollback_depth,
+        rollback_target_step: target_step,
+        snapshot_id,
+        snapshot_step,
+        restore_verified_for_salad03b: kv01.restore_verified_for_salad03b,
+        token_ledger_len: salad03.input.token_ledger_len,
+        kv_restore_supported: env_bool("ASH_SALAD03B_KV_RESTORE_SUPPORTED", restore_supported),
+        position_restore_supported: env_bool("ASH_SALAD03B_POSITION_RESTORE_SUPPORTED", true),
+        rollback_count_window: env_usize("ASH_SALAD03B_ROLLBACK_COUNT_WINDOW", salad03.input.rollback_count_window),
+        max_rollback_per_window,
+        current_temperature: salad03.input.current_temperature,
+        current_top_p: salad03.input.current_top_p,
+        current_top_k: salad03.input.current_top_k,
+        current_min_p: salad03.input.current_min_p,
+        safe_resample_config: safe_config_from_salad03(&salad03.plan.safe_resample_config),
+        numeric_risk: salad03.input.numeric_risk,
+        global_finite_fallback_seen: salad03.input.global_finite_fallback_seen,
+    }
+}
+
+pub fn receipt_from_salad03_and_kv01(
+    mode: Salad03BMode,
+    salad03: &Salad03StepReceipt,
+    kv01: &KvRollback01StepReceipt,
+) -> Salad03BStepReceipt {
+    let input = input_from_salad03_and_kv01(mode, salad03, kv01);
+    let gate = decide_salad03b_gate(&input);
+    let execution = if mode.can_mutate() {
+        execute_salad03b_controlled_synthetic(&input, &gate, salad03.selected_id_before, salad03.selected_piece_before.clone())
+    } else {
+        plan_only_execution(&input, &gate)
+    };
+    let post_check = post_check_from_execution(&input, &execution);
+    let selected_id_after = execution.replacement.as_ref().and_then(|r| r.replacement_tokens.first().copied()).or(salad03.selected_id_after);
+    let selected_piece_after = execution.replacement.as_ref().and_then(|r| r.replacement_pieces_preview.first().cloned().flatten()).or(salad03.selected_piece_after.clone());
+    Salad03BStepReceipt {
+        patch_id: SALAD03B_PATCH_ID.to_string(),
+        input_patch: SALAD03B_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: input.run_id.clone(),
+        prompt_hash: input.prompt_hash.clone(),
+        seed: input.seed,
+        step: input.step,
+        backend: input.backend.clone(),
+        sampler_ssot: SALAD03B_SSOT.to_string(),
+        mode,
+        behavior_change: execution.executed,
+        controlled_execute: mode.can_mutate(),
+        salad03_status_seen: Some("DERIVED_IN_MEMORY_FROM_SALAD03_RECEIPT".to_string()),
+        salad02_status_seen: salad03.salad02_status_seen.clone(),
+        kv_rollback00_status_seen: kv01.kv_rollback00_status_seen.clone(),
+        kv_rollback01_status_seen: Some("DERIVED_IN_MEMORY_FROM_KV_ROLLBACK01_RECEIPT".to_string()),
+        decode03d_status_seen: salad03.decode03d_status_seen.clone(),
+        input,
+        gate,
+        execution,
+        post_check,
+        selected_id_before: salad03.selected_id_before,
+        selected_piece_before: salad03.selected_piece_before.clone(),
+        selected_id_after,
+        selected_piece_after,
+    }
+}
