+#[cfg(test)]
+mod minp_p0_tests {
+    use super::{AppliedField, RuntimeSamplingConfig, normalize_min_p};
+
+    #[test]
+    fn minp_p0_normalize_min_p_clamps_and_rejects_non_finite() {
+        assert_eq!(normalize_min_p(-1.0), 0.0);
+        assert_eq!(normalize_min_p(0.0), 0.0);
+        assert_eq!(normalize_min_p(0.05), 0.05);
+        assert_eq!(normalize_min_p(0.95), 0.95);
+        assert_eq!(normalize_min_p(1.0), 0.95);
+        assert_eq!(normalize_min_p(f32::NAN), 0.0);
+        assert_eq!(normalize_min_p(f32::INFINITY), 0.0);
+    }
+
+    #[test]
+    fn minp_p0_runtime_sampling_config_defaults_to_disabled_min_p() {
+        let raw = r#"{
+            "temperature": { "Applied": 0.7 },
+            "top_p": { "Applied": 0.9 },
+            "top_k": { "Applied": 40 },
+            "repeat_penalty": { "Applied": 1.0 },
+            "repeat_last_n": { "Applied": 64 },
+            "token_bias": {
+                "enabled": false,
+                "strategy": "Disabled",
+                "role_profile": "default",
+                "cue_profile": "default",
+                "turn_memory_enabled": false,
+                "turn_memory_profile": "none",
+                "recent_role_profiles": [],
+                "recent_cue_profiles": [],
+                "deny_text_prefixes": [],
+                "deny_text_sequences": [],
+                "stop_text_sequences": [],
+                "prefer_text_prefixes": [],
+                "deny_text_terms": [],
+                "prefer_text_terms": [],
+                "memory_deny_terms": [],
+                "memory_prefer_terms": [],
+                "memory_reinforcement_terms": [],
+                "memory_contradiction_terms": [],
+                "memory_forget_terms": [],
+                "memory_overwrite_terms": [],
+                "memory_slot_profile": "none",
+                "memory_slots": [],
+                "memory_slot_prefer_terms": [],
+                "memory_slot_deny_terms": [],
+                "weighted_deny_terms": [],
+                "weighted_prefer_terms": [],
+                "memory_decay_factor": 1.0,
+                "memory_prefer_score_total": 0.0,
+                "memory_deny_score_total": 0.0,
+                "memory_reinforcement_score_total": 0.0,
+                "memory_contradiction_score_total": 0.0,
+                "memory_forget_score_total": 0.0,
+                "memory_overwrite_score_total": 0.0,
+                "memory_reinforcement_hits": 0,
+                "memory_contradiction_hits": 0,
+                "memory_forget_hits": 0,
+                "memory_overwrite_hits": 0,
+                "memory_slot_strength_total": 0.0,
+                "memory_slot_contradiction_total": 0.0,
+                "preferred_strength": 1.0
+            }
+        }"#;
+        let cfg: RuntimeSamplingConfig = serde_json::from_str(raw).expect("legacy config without min_p remains valid");
