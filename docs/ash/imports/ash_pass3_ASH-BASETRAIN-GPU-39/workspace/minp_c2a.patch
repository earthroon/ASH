+#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
+pub enum SemanticScoreAlignmentStatus {
+    Pass,
+    WarnMissingOptionalHash,
+    FailLengthMismatch,
+    FailNaNOrInf,
+    FailOutOfRange,
+    FailFixtureMismatch,
+    FailVocabMismatch,
+    NotRun,
+}
+
+impl SemanticScoreAlignmentStatus {
+    pub fn as_str(&self) -> &'static str {
+        match self {
+            Self::Pass => "PASS",
+            Self::WarnMissingOptionalHash => "WARN_MISSING_OPTIONAL_HASH",
+            Self::FailLengthMismatch => "FAIL_LENGTH_MISMATCH",
+            Self::FailNaNOrInf => "FAIL_NAN_OR_INF",
+            Self::FailOutOfRange => "FAIL_OUT_OF_RANGE",
+            Self::FailFixtureMismatch => "FAIL_FIXTURE_MISMATCH",
+            Self::FailVocabMismatch => "FAIL_VOCAB_MISMATCH",
+            Self::NotRun => "NOT_RUN",
+        }
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
+pub enum SemanticScoreFixtureStatus {
+    Pass,
+    Fail,
+    SkippedTokenNotFound,
+}
+
+impl SemanticScoreFixtureStatus {
+    pub fn as_str(&self) -> &'static str {
+        match self {
+            Self::Pass => "PASS",
+            Self::Fail => "FAIL",
+            Self::SkippedTokenNotFound => "SKIPPED_TOKEN_NOT_FOUND",
+        }
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct SemanticScoreFixtureResult {
+    pub fixture: String,
+    pub token: String,
+    pub token_id: Option<u32>,
+    pub qwave_score: Option<f32>,
+    pub deltak_score: Option<f32>,
+    pub status: SemanticScoreFixtureStatus,
+    pub reason: Option<String>,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct SemanticScoreSnapshotAlignmentReport {
+    pub vocab_size: usize,
+    pub qwave_len: usize,
+    pub deltak_len: usize,
+    pub vocab_hash: String,
+    pub expected_vocab_hash: String,
+    pub vocab_hash_present: bool,
+    pub vocab_hash_match: bool,
+    pub tokenizer_hash: Option<String>,
+    pub expected_tokenizer_hash: Option<String>,
+    pub tokenizer_hash_match: Option<bool>,
+    pub lm_head_vocab_size: Option<usize>,
+    pub lm_head_vocab_match: Option<bool>,
+    pub length_match: bool,
+    pub max_token_id_in_vocab: Option<u32>,
+    pub token_id_indexable: bool,
+    pub nan_count_qwave: usize,
+    pub inf_count_qwave: usize,
+    pub nan_count_deltak: usize,
+    pub inf_count_deltak: usize,
+    pub out_of_range_qwave: usize,
+    pub out_of_range_deltak: usize,
+    pub fixture_results: Vec<SemanticScoreFixtureResult>,
+    pub status: SemanticScoreAlignmentStatus,
+}
+
+impl SemanticScoreSnapshotAlignmentReport {
+    pub fn alignment_pass(&self) -> bool {
+        matches!(self.status, SemanticScoreAlignmentStatus::Pass | SemanticScoreAlignmentStatus::WarnMissingOptionalHash)
+            && self.length_match
+            && self.token_id_indexable
+            && self.nan_count_qwave == 0
+            && self.inf_count_qwave == 0
+            && self.nan_count_deltak == 0
+            && self.inf_count_deltak == 0
+            && self.out_of_range_qwave == 0
+            && self.out_of_range_deltak == 0
+            && self.fixture_results.iter().all(|r| !matches!(r.status, SemanticScoreFixtureStatus::Fail))
+    }
+}
+
+pub fn validate_semantic_score_snapshot_alignment(
+    snapshot: &SemanticPriorScoreSnapshot,
+    vocab: &[(u32, String)],
+    lm_head_vocab_size: Option<usize>,
+    tokenizer_hash: Option<&str>,
+) -> SemanticScoreSnapshotAlignmentReport {
+    let vocab_size = snapshot.vocab_size;
+    let qwave_len = snapshot.qwave_scores.len();
+    let deltak_len = snapshot.deltak_scores.len();
+    let expected_vocab_hash = stable_vocab_hash(vocab);
+    let vocab_hash_present = !snapshot.vocab_hash.trim().is_empty();
+    let vocab_hash_match = snapshot.vocab_hash == expected_vocab_hash;
+    let tokenizer_hash_match = tokenizer_hash.map(|expected| snapshot.tokenizer_hash.as_deref() == Some(expected));
+    let lm_head_vocab_match = lm_head_vocab_size.map(|size| size == vocab_size);
+    let length_match = qwave_len == vocab_size && deltak_len == vocab_size;
+    let max_token_id_in_vocab = vocab.iter().map(|(id, _)| *id).max();
+    let token_id_indexable = max_token_id_in_vocab.map(|id| (id as usize) < vocab_size).unwrap_or(true);
+
+    let nan_count_qwave = snapshot.qwave_scores.iter().filter(|v| v.is_nan()).count();
+    let inf_count_qwave = snapshot.qwave_scores.iter().filter(|v| v.is_infinite()).count();
+    let nan_count_deltak = snapshot.deltak_scores.iter().filter(|v| v.is_nan()).count();
+    let inf_count_deltak = snapshot.deltak_scores.iter().filter(|v| v.is_infinite()).count();
+    let out_of_range_qwave = snapshot.qwave_scores.iter().filter(|v| v.is_finite() && (**v < -1.0 || **v > 1.0)).count();
+    let out_of_range_deltak = snapshot.deltak_scores.iter().filter(|v| v.is_finite() && (**v < -1.0 || **v > 1.0)).count();
+    let fixture_results = semantic_score_alignment_fixture_results(snapshot, vocab);
+    let fixture_fail = fixture_results.iter().any(|r| matches!(r.status, SemanticScoreFixtureStatus::Fail));
+
+    let status = if !length_match || !token_id_indexable {
+        SemanticScoreAlignmentStatus::FailLengthMismatch
+    } else if !vocab_hash_match || lm_head_vocab_match == Some(false) || tokenizer_hash_match == Some(false) {
+        SemanticScoreAlignmentStatus::FailVocabMismatch
+    } else if nan_count_qwave + nan_count_deltak + inf_count_qwave + inf_count_deltak > 0 {
+        SemanticScoreAlignmentStatus::FailNaNOrInf
+    } else if out_of_range_qwave + out_of_range_deltak > 0 {
+        SemanticScoreAlignmentStatus::FailOutOfRange
+    } else if fixture_fail {
+        SemanticScoreAlignmentStatus::FailFixtureMismatch
+    } else if tokenizer_hash.is_none() || snapshot.tokenizer_hash.is_none() {
+        SemanticScoreAlignmentStatus::WarnMissingOptionalHash
+    } else {
+        SemanticScoreAlignmentStatus::Pass
+    };
+
+    SemanticScoreSnapshotAlignmentReport {
+        vocab_size,
+        qwave_len,
+        deltak_len,
+        vocab_hash: snapshot.vocab_hash.clone(),
+        expected_vocab_hash,
+        vocab_hash_present,
+        vocab_hash_match,
+        tokenizer_hash: snapshot.tokenizer_hash.clone(),
+        expected_tokenizer_hash: tokenizer_hash.map(ToOwned::to_owned),
+        tokenizer_hash_match,
+        lm_head_vocab_size,
+        lm_head_vocab_match,
+        length_match,
+        max_token_id_in_vocab,
+        token_id_indexable,
+        nan_count_qwave,
+        inf_count_qwave,
+        nan_count_deltak,
+        inf_count_deltak,
+        out_of_range_qwave,
+        out_of_range_deltak,
+        fixture_results,
+        status,
+    }
+}
+
+pub fn semantic_score_alignment_fixture_results(
+    snapshot: &SemanticPriorScoreSnapshot,
+    vocab: &[(u32, String)],
+) -> Vec<SemanticScoreFixtureResult> {
+    let mut results = Vec::new();
+    let control_tokens = ["<pad>", "<bos>", "<eos>", "<unk>", "<glossary:on>", "<glossary:off>"];
+    for token in control_tokens {
+        results.push(check_fixture_token(snapshot, vocab, "control_token_negative", token, |q, k| q <= -0.8 && k <= -0.8));
+    }
+    for token in ["<byte:EC>", "<0xEC>", "<byte:FF>"] {
+        results.push(check_fixture_token(snapshot, vocab, "byte_token_negative", token, |q, k| q < 0.0 && k < 0.0));
+    }
+    for token in ["?댁뼱媛怨?", "Ã", "ì", "ê", "媛", "怨"] {
+        results.push(check_fixture_token(snapshot, vocab, "mojibake_token_negative", token, |q, k| q < 0.0 && k < 0.0));
+    }
+    for token in ["▁이어가고", "합니다", "사람", "안녕"] {
+        results.push(check_fixture_token(snapshot, vocab, "normal_korean_non_negative", token, |q, k| q >= 0.0 && k >= 0.0));
+    }
+    results
+}
+
+fn check_fixture_token(
+    snapshot: &SemanticPriorScoreSnapshot,
+    vocab: &[(u32, String)],
+    fixture: &str,
+    token: &str,
+    predicate: fn(f32, f32) -> bool,
+) -> SemanticScoreFixtureResult {
+    let found = vocab.iter().find(|(_, piece)| piece == token);
+    let Some((token_id, _)) = found else {
+        return SemanticScoreFixtureResult {
+            fixture: fixture.to_string(),
+            token: token.to_string(),
+            token_id: None,
+            qwave_score: None,
+            deltak_score: None,
+            status: SemanticScoreFixtureStatus::SkippedTokenNotFound,
+            reason: Some("token not present in vocab; skipped, not pass".to_string()),
+        };
+    };
+    let idx = *token_id as usize;
+    let q = snapshot.qwave_scores.get(idx).copied();
+    let k = snapshot.deltak_scores.get(idx).copied();
+    match (q, k) {
+        (Some(q), Some(k)) if predicate(q, k) => SemanticScoreFixtureResult {
+            fixture: fixture.to_string(), token: token.to_string(), token_id: Some(*token_id), qwave_score: Some(q), deltak_score: Some(k), status: SemanticScoreFixtureStatus::Pass, reason: None,
+        },
+        (Some(q), Some(k)) => SemanticScoreFixtureResult {
+            fixture: fixture.to_string(), token: token.to_string(), token_id: Some(*token_id), qwave_score: Some(q), deltak_score: Some(k), status: SemanticScoreFixtureStatus::Fail, reason: Some("score did not satisfy fixture predicate".to_string()),
+        },
+        _ => SemanticScoreFixtureResult {
+            fixture: fixture.to_string(), token: token.to_string(), token_id: Some(*token_id), qwave_score: q, deltak_score: k, status: SemanticScoreFixtureStatus::Fail, reason: Some("token id is not indexable in score vectors".to_string()),
+        },
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct SemanticScoreBufferAlignmentReceipt {
+    pub cpu_score_source: String,
+    pub gpu_score_source: String,
+    pub same_snapshot_hash: bool,
+    pub qwave_buffer_len: usize,
+    pub deltak_buffer_len: usize,
+    pub buffer_len_matches_vocab: bool,
+    pub alignment_status: SemanticScoreAlignmentStatus,
+}
+
+pub fn semantic_score_buffer_alignment_receipt(
+    snapshot: &SemanticPriorScoreSnapshot,
+    report: &SemanticScoreSnapshotAlignmentReport,
+) -> SemanticScoreBufferAlignmentReceipt {
+    SemanticScoreBufferAlignmentReceipt {
+        cpu_score_source: "SemanticPriorScoreSnapshot".to_string(),
+        gpu_score_source: "SemanticPriorScoreSnapshot".to_string(),
+        same_snapshot_hash: report.vocab_hash_match,
+        qwave_buffer_len: snapshot.qwave_scores.len(),
+        deltak_buffer_len: snapshot.deltak_scores.len(),
+        buffer_len_matches_vocab: snapshot.qwave_scores.len() == snapshot.vocab_size && snapshot.deltak_scores.len() == snapshot.vocab_size,
+        alignment_status: report.status.clone(),
+    }
+}
+
+pub fn semantic_prior_application_allowed_by_alignment(
+    sampler04_status: Option<&str>,
+    c2a_status: Option<&str>,
+) -> bool {
+    sampler04_status == Some("STRICT_CANDIDATE_READY") && c2a_status == Some("PASS")
+}
+
+pub fn run_minp_c2a_snapshot_alignment_smoke() -> (SemanticScoreSnapshotAlignmentReport, SemanticScoreBufferAlignmentReceipt) {
+    let vocab = vec![
+        (0, "<pad>".to_string()),
+        (1, "▁이어가고".to_string()),
+        (2, "<eos>".to_string()),
+        (3, "<byte:EC>".to_string()),
+        (4, "?댁뼱媛怨?".to_string()),
+    ];
+    let cfg = SemanticPriorProviderConfig { enabled: true, ..Default::default() };
+    let snapshot = build_semantic_prior_score_snapshot(&vocab, &cfg);
+    let report = validate_semantic_score_snapshot_alignment(&snapshot, &vocab, Some(snapshot.vocab_size), None);
+    let buffer_receipt = semantic_score_buffer_alignment_receipt(&snapshot, &report);
+    (report, buffer_receipt)
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn c2a_alignment_smoke_reports_pass_or_optional_hash_warning() {
+        let (report, buffer) = run_minp_c2a_snapshot_alignment_smoke();
+        assert!(matches!(report.status, SemanticScoreAlignmentStatus::Pass | SemanticScoreAlignmentStatus::WarnMissingOptionalHash));
+        assert!(report.length_match);
+        assert!(buffer.buffer_len_matches_vocab);
+    }
+}
