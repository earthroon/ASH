++pub fn decide_decode03d_gate(input: &Decode03DGateInput) -> Decode03DGateDecision {
++    let mut denied_reasons = Vec::new();
++    let mut warning_reasons = Vec::new();
++    let mut strict_fail = false;
++
++    if matches!(input.mode, DynamicSamplerMode::Off) {
++        denied_reasons.push("mode_off".to_string());
++    }
++    if !input.mode.can_change_behavior() {
++        denied_reasons.push("mode_not_controlled".to_string());
++    }
++    if !input.behavior_change_allowed {
++        denied_reasons.push("behavior_change_not_allowed".to_string());
++    }
++    if matches!(input.sampler05_status_seen.as_deref(), Some("FAIL") | Some("FAIL_BEHAVIOR_CHANGE") | Some("FAIL_THRESHOLD_KIND")) {
++        denied_reasons.push("sampler05_failed".to_string());
++    }
++    if input.decode03c_status_seen.is_none() {
++        denied_reasons.push("missing_decode03c_status".to_string());
++    }
++    if !input.shadow_only_seen {
++        denied_reasons.push("decode03c_shadow_contract_missing".to_string());
++    }
++    if !input.backend_supports_temperature {
++        denied_reasons.push("backend_temperature_unsupported".to_string());
++    }
++    if !input.backend_supports_top_p {
++        denied_reasons.push("backend_top_p_unsupported".to_string());
++    }
++    if !input.backend_supports_min_p {
++        warning_reasons.push("backend_min_p_unsupported".to_string());
++    }
++    if !input.backend_supports_guard_strength {
++        warning_reasons.push("backend_guard_strength_unsupported".to_string());
++    }
++
++    if matches!(input.mode, DynamicSamplerMode::StrictControlled) && input.numeric_risk {
++        strict_fail = true;
++        denied_reasons.push("numeric_risk_in_strict_mode".to_string());
++    }
++    if matches!(input.mode, DynamicSamplerMode::StrictControlled) && input.fallback_risk {
++        strict_fail = true;
++        denied_reasons.push("fallback_risk_in_strict_mode".to_string());
++    }
++
++    Decode03DGateDecision {
++        can_apply: denied_reasons.is_empty() && input.mode.can_change_behavior(),
++        mode: input.mode,
++        denied_reasons,
++        warning_reasons,
++        requires_receipt: input.receipt_required,
++        strict_fail,
++    }
++}
