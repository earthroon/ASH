++pub fn apply_decode03d_controlled_config(
++    current: &Decode03DCurrentConfig,
++    shadow: &Decode03CShadowPolicy,
++    gate: &Decode03DGateDecision,
++    backend_supports_min_p: bool,
++) -> Decode03DAppliedConfig {
++    let mut apply_reason = Vec::new();
++    let mut applied_temperature = current.temperature;
++    let mut applied_top_p = current.top_p;
++    let mut applied_top_k = current.top_k;
++    let mut applied_min_p = current.min_p;
++    let mut applied_guard_strength = "Current".to_string();
++
++    if gate.can_apply {
++        apply_reason.push("controlled_enable".to_string());
++        apply_reason.push("shadow_policy_applied".to_string());
++        applied_temperature = clamp_f32(shadow.shadow_temperature, 0.03, 1.20);
++        applied_top_p = clamp_f32(shadow.shadow_top_p, 0.50, 1.00);
++        applied_top_k = shadow.shadow_top_k.min(env_usize("ASH_DECODE03D_TOP_K_MAX", 1024));
++        if backend_supports_min_p {
++            applied_min_p = clamp_f32(shadow.shadow_min_p, 0.00, 0.25);
++        } else {
++            apply_reason.push("backend_min_p_unsupported_min_p_not_applied".to_string());
++        }
++        applied_guard_strength = guard_strength_name(shadow.guard_strength);
++        apply_reason.extend(shadow.policy_reason.iter().cloned());
++    } else {
++        apply_reason.push("gate_denied".to_string());
++        apply_reason.extend(gate.denied_reasons.iter().cloned());
++    }
++
++    let temperature_changed = (applied_temperature - current.temperature).abs() > 0.001;
++    let top_p_changed = (applied_top_p - current.top_p).abs() > 0.001;
++    let top_k_changed = applied_top_k != current.top_k;
++    let min_p_changed = (applied_min_p - current.min_p).abs() > 0.001;
++    let guard_strength_changed = gate.can_apply && applied_guard_strength != "Current";
++    let behavior_change = gate.can_apply && (
++        temperature_changed || top_p_changed || top_k_changed || min_p_changed || guard_strength_changed
++    );
++
++    Decode03DAppliedConfig {
++        behavior_change,
++        current_temperature: current.temperature,
++        current_top_p: current.top_p,
++        current_top_k: current.top_k,
++        current_min_p: current.min_p,
++        shadow_temperature: shadow.shadow_temperature,
++        shadow_top_p: shadow.shadow_top_p,
++        shadow_top_k: shadow.shadow_top_k,
++        shadow_min_p: shadow.shadow_min_p,
++        applied_temperature,
++        applied_top_p,
++        applied_top_k,
++        applied_min_p,
++        applied_guard_strength,
++        temperature_changed,
++        top_p_changed,
++        top_k_changed,
++        min_p_changed,
++        guard_strength_changed,
++        rollback_candidate_seen: shadow.rollback_candidate,
++        rollback_candidate_applied: false,
++        safe_stop_candidate_seen: shadow.safe_stop_candidate,
++        safe_stop_candidate_applied: false,
++        eos_bias_candidate_seen: shadow.eos_bias_candidate,
++        eos_bias_candidate_applied: false,
++        apply_reason,
++    }
++}
