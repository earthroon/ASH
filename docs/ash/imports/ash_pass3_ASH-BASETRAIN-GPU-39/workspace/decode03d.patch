+    fn current() -> Decode03DCurrentConfig {
+        current_config_from_shadow(&shadow_policy())
+    }
+
+    fn gate(mode: DynamicSamplerMode, allow: bool) -> Decode03DGateDecision {
+        decide_decode03d_gate(&Decode03DGateInput {
+            mode,
+            behavior_change_allowed: allow,
+            receipt_required: true,
+            sampler05_status_seen: Some("PASS_WITH_WARNINGS".to_string()),
+            decode03a_status_seen: Some("PASS_WITH_WARNINGS".to_string()),
+            decode03b_status_seen: Some("PASS_WITH_WARNINGS".to_string()),
+            decode03c_status_seen: Some("PASS_WITH_WARNINGS".to_string()),
+            backend: "unit".to_string(),
+            backend_supports_min_p: true,
+            backend_supports_top_p: true,
+            backend_supports_temperature: true,
+            backend_supports_guard_strength: true,
+            numeric_risk: false,
+            fallback_risk: false,
+            shadow_only_seen: true,
+        })
+    }
+
+    #[test]
+    fn decode03d_gate_denies_mode_off() {
+        let decision = gate(DynamicSamplerMode::Off, true);
+        assert!(!decision.can_apply);
+    }
+
+    #[test]
+    fn decode03d_gate_denies_without_behavior_permission() {
+        let decision = gate(DynamicSamplerMode::Controlled, false);
+        assert!(!decision.can_apply);
+    }
+
+    #[test]
+    fn decode03d_applies_shadow_when_controlled() {
+        let decision = gate(DynamicSamplerMode::Controlled, true);
+        let applied = apply_decode03d_controlled_config(&current(), &shadow_policy(), &decision, true);
+        assert!(applied.behavior_change);
+        assert!(applied.min_p_changed);
+        assert!(applied.temperature_changed);
+    }
+
+    #[test]
+    fn decode03d_does_not_apply_minp_when_unsupported() {
+        let decision = gate(DynamicSamplerMode::Controlled, true);
+        let applied = apply_decode03d_controlled_config(&current(), &shadow_policy(), &decision, false);
+        assert_eq!(applied.applied_min_p, applied.current_min_p);
+        assert!(!applied.min_p_changed);
+    }
+
+    #[test]
+    fn decode03d_does_not_execute_rollback_candidate() {
+        let mut shadow = shadow_policy();
+        shadow.rollback_candidate = true;
+        shadow.safe_stop_candidate = true;
+        shadow.eos_bias_candidate = true;
+        let decision = gate(DynamicSamplerMode::Controlled, true);
+        let applied = apply_decode03d_controlled_config(&current(), &shadow, &decision, true);
+        assert!(applied.rollback_candidate_seen);
+        assert!(!applied.rollback_candidate_applied);
+        assert!(applied.safe_stop_candidate_seen);
+        assert!(!applied.safe_stop_candidate_applied);
+        assert!(applied.eos_bias_candidate_seen);
+        assert!(!applied.eos_bias_candidate_applied);
+    }
+}
