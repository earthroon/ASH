+#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
+pub enum DynamicSamplerMode {
+    Off,
+    ShadowOnly,
+    Controlled,
+    StrictControlled,
+}
+
+impl DynamicSamplerMode {
+    pub fn from_env() -> Self {
+        let enabled = env_bool("ASH_DECODE03D_CONTROLLED_ENABLE", false)
+            || env_bool("ASH_DECODE03D_ENABLE", false);
+        let raw = env::var("ASH_DECODE03D_MODE")
+            .unwrap_or_else(|_| if enabled { "controlled".to_string() } else { "off".to_string() })
+            .trim()
+            .to_ascii_lowercase();
+        match raw.as_str() {
+            "shadow" | "shadow_only" | "shadow-only" | "observe" | "receipt" => Self::ShadowOnly,
+            "controlled" | "control" | "on" | "true" | "1" => if enabled { Self::Controlled } else { Self::Off },
+            "strict" | "strict_controlled" | "strict-controlled" => if enabled { Self::StrictControlled } else { Self::Off },
+            _ => Self::Off,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::ShadowOnly => "ShadowOnly",
+            Self::Controlled => "Controlled",
+            Self::StrictControlled => "StrictControlled",
+        }
+    }
+
+    pub fn can_change_behavior(self) -> bool {
+        matches!(self, Self::Controlled | Self::StrictControlled)
+    }
+}
