+pub fn gate_input_from_shadow(mode: DynamicSamplerMode, shadow_receipt: &Decode03CStepReceipt) -> Decode03DGateInput {
+    Decode03DGateInput {
+        mode,
+        behavior_change_allowed: env_bool("ASH_DECODE03D_BEHAVIOR_CHANGE_ALLOWED", false),
+        receipt_required: env_bool("ASH_DECODE03D_RECEIPT_REQUIRED", true),
+        sampler05_status_seen: shadow_receipt.sampler05_status_seen.clone(),
+        decode03a_status_seen: shadow_receipt.decode03a_status_seen.clone(),
+        decode03b_status_seen: shadow_receipt.decode03b_status_seen.clone(),
+        decode03c_status_seen: shadow_receipt.decode03b_status_seen.as_ref().map(|_| "DERIVED_IN_MEMORY_FROM_DECODE03C_RECEIPT".to_string()),
+        backend: shadow_receipt.backend.clone(),
+        backend_supports_min_p: backend_supports_min_p_from_env(),
+        backend_supports_top_p: env_bool("ASH_DECODE03D_BACKEND_SUPPORTS_TOP_P", true),
+        backend_supports_temperature: env_bool("ASH_DECODE03D_BACKEND_SUPPORTS_TEMPERATURE", true),
+        backend_supports_guard_strength: env_bool("ASH_DECODE03D_BACKEND_SUPPORTS_GUARD_STRENGTH", true),
+        numeric_risk: shadow_receipt.input.numeric_risk,
+        fallback_risk: shadow_receipt.input.fallback_risk,
+        shadow_only_seen: shadow_receipt.shadow_only && !shadow_receipt.behavior_change,
+    }
+}
+
+pub fn receipt_from_decode03c(mode: DynamicSamplerMode, shadow_receipt: &Decode03CStepReceipt) -> Decode03DStepReceipt {
+    let gate_input = gate_input_from_shadow(mode, shadow_receipt);
+    let gate = decide_decode03d_gate(&gate_input);
+    let current_config = current_config_from_shadow(&shadow_receipt.shadow_policy);
+    let applied_config = apply_decode03d_controlled_config(
+        &current_config,
+        &shadow_receipt.shadow_policy,
+        &gate,
+        gate_input.backend_supports_min_p,
+    );
+    let risk_flags = Decode03DRiskFlags {
+        applied_without_gate: applied_config.behavior_change && !gate.can_apply,
+        missing_shadow_policy: false,
+        min_p_unsupported_but_requested: !gate_input.backend_supports_min_p && (shadow_receipt.shadow_policy.shadow_min_p - current_config.min_p).abs() > 0.001,
+        min_p_unsupported_but_applied: !gate_input.backend_supports_min_p && (applied_config.applied_min_p - current_config.min_p).abs() > 0.001,
+        panic_candidate_seen: matches!(shadow_receipt.shadow_policy.guard_strength, ShadowGuardStrength::Panic)
+            || shadow_receipt.shadow_policy.rollback_candidate
+            || shadow_receipt.shadow_policy.safe_stop_candidate
+            || shadow_receipt.shadow_policy.eos_bias_candidate,
+        panic_candidate_executed: applied_config.rollback_candidate_applied
+            || applied_config.safe_stop_candidate_applied
+            || applied_config.eos_bias_candidate_applied,
+        numeric_risk_seen: shadow_receipt.input.numeric_risk,
+        fallback_risk_seen: shadow_receipt.input.fallback_risk,
+        behavior_change_without_controlled_mode: applied_config.behavior_change && !mode.can_change_behavior(),
+    };
+    Decode03DStepReceipt {
+        patch_id: DECODE03D_PATCH_ID.to_string(),
+        input_patch: DECODE03D_INPUT_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: run_id_from_env(),
+        prompt_hash: shadow_receipt.prompt_hash.clone(),
+        seed: shadow_receipt.seed,
+        step: shadow_receipt.step,
+        backend: shadow_receipt.backend.clone(),
+        sampler_ssot: DECODE03D_SAMPLER_SSOT.to_string(),
+        mode,
+        controlled_enable: mode.can_change_behavior(),
+        gate,
+        pci_raw: Some(shadow_receipt.input.pci_raw),
+        pci_smoothed: shadow_receipt.input.pci_smoothed,
+        bucket_stable: Some(format!("{:?}", shadow_receipt.input.bucket_stable)),
+        shadow_policy_seen: true,
+        shadow_policy: Some(shadow_receipt.shadow_policy.clone()),
+        current_config,
+        applied_config,
+        selected_id_before_apply: None,
+        selected_id_after_apply: None,
+        selected_piece_preview: None,
+        risk_flags,
+    }
+}
