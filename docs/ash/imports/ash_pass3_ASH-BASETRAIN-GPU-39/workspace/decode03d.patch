++pub fn summary_from_receipts(receipts: &[Decode03DStepReceipt]) -> Decode03DSummary {
++    let mut gate = Decode03DGateCounts::default();
++    let mut applied = Decode03DAppliedCounts::default();
++    let mut candidates = Decode03DShadowCandidateCounts::default();
++    let mut backend = Decode03DBackendSupportCounts::default();
++    let mut risk = Decode03DRiskCounts::default();
++    let mut any_controlled = false;
++    let mut mode_seen = "Off".to_string();
++
++    for receipt in receipts {
++        mode_seen = receipt.mode.as_str().to_string();
++        any_controlled |= receipt.controlled_enable;
++        if receipt.gate.can_apply { gate.can_apply_count += 1; } else { gate.denied_count += 1; }
++        if receipt.gate.strict_fail { gate.strict_fail_count += 1; }
++        if !receipt.shadow_policy_seen || receipt.risk_flags.missing_shadow_policy { gate.missing_shadow_policy_count += 1; }
++        if receipt.applied_config.behavior_change { applied.behavior_change_count += 1; }
++        if receipt.applied_config.temperature_changed { applied.temperature_changed_count += 1; }
++        if receipt.applied_config.min_p_changed { applied.min_p_changed_count += 1; }
++        if receipt.applied_config.top_p_changed { applied.top_p_changed_count += 1; }
++        if receipt.applied_config.top_k_changed { applied.top_k_changed_count += 1; }
++        if receipt.applied_config.guard_strength_changed { applied.guard_strength_changed_count += 1; }
++        if receipt.applied_config.rollback_candidate_seen { candidates.rollback_candidate_seen_count += 1; }
++        if receipt.applied_config.rollback_candidate_applied { candidates.rollback_candidate_applied_count += 1; }
++        if receipt.applied_config.safe_stop_candidate_seen { candidates.safe_stop_candidate_seen_count += 1; }
++        if receipt.applied_config.safe_stop_candidate_applied { candidates.safe_stop_candidate_applied_count += 1; }
++        if receipt.applied_config.eos_bias_candidate_seen { candidates.eos_bias_candidate_seen_count += 1; }
++        if receipt.applied_config.eos_bias_candidate_applied { candidates.eos_bias_candidate_applied_count += 1; }
++        if receipt.risk_flags.min_p_unsupported_but_requested { backend.min_p_unsupported_count += 1; }
++        if receipt.risk_flags.min_p_unsupported_but_applied { backend.min_p_unsupported_but_applied_count += 1; }
++        if receipt.risk_flags.applied_without_gate { risk.applied_without_gate_count += 1; }
++        if receipt.risk_flags.panic_candidate_seen { risk.panic_candidate_seen_count += 1; }
++        if receipt.risk_flags.panic_candidate_executed { risk.panic_candidate_executed_count += 1; }
++        if receipt.risk_flags.numeric_risk_seen { risk.numeric_risk_seen_count += 1; }
++        if receipt.risk_flags.fallback_risk_seen { risk.fallback_risk_seen_count += 1; }
++        if receipt.risk_flags.behavior_change_without_controlled_mode { risk.behavior_change_without_controlled_mode_count += 1; }
++    }
++
++    let steps_observed = receipts.len();
++    let fail = backend.min_p_unsupported_but_applied_count > 0
++        || risk.applied_without_gate_count > 0
++        || risk.panic_candidate_executed_count > 0
++        || risk.behavior_change_without_controlled_mode_count > 0
++        || candidates.rollback_candidate_applied_count > 0
++        || candidates.safe_stop_candidate_applied_count > 0
++        || candidates.eos_bias_candidate_applied_count > 0;
++    let status = if steps_observed == 0 {
++        "STATIC_BAKE_DEFINED_NOT_RUN"
++    } else if fail {
++        "FAIL_CONTRACT_VIOLATION"
++    } else if gate.denied_count > 0 || risk.panic_candidate_seen_count > 0 || backend.min_p_unsupported_count > 0 {
++        "PASS_WITH_WARNINGS"
++    } else {
++        "PASS"
++    }
++    .to_string();
++    let ready_for_salad02_online_detector = steps_observed > 0 && !fail;
++    Decode03DSummary {
++        patch_id: DECODE03D_PATCH_ID.to_string(),
++        input_patch: DECODE03D_INPUT_PATCH_ID.to_string(),
++        status,
++        controlled_enable: any_controlled,
++        mode: mode_seen,
++        default_enable: false,
++        requires_decode03c: env_bool("ASH_DECODE03D_REQUIRE_DECODE03C", true),
++        decode03c_status_seen: if steps_observed > 0 { Some("DERIVED_IN_MEMORY_FROM_DECODE03C_RECEIPT".to_string()) } else { None },
++        decode03b_status_seen: receipts.iter().find_map(|r| r.shadow_policy.as_ref()).map(|_| "OBSERVED_OR_DERIVED".to_string()),
++        decode03a_status_seen: None,
++        sampler05_status_seen: None,
++        steps_observed,
++        gate,
++        applied,
++        shadow_candidate_not_executed: candidates,
++        backend_support: backend,
++        risk,
++        ready_for_salad02_online_detector,
++        ready_for_decode03d_default_enable: false,
++        ready_for_salad03_rollback: false,
++        reason: if steps_observed == 0 {
++            "static bake only; run ASH_DECODE03D_CONTROLLED_ENABLE=true with ASH_DECODE03D_MODE=controlled after DECODE-03C shadow evidence".to_string()
++        } else if ready_for_salad02_online_detector {
++            "controlled enable receipt sealed; rollback/safe-stop/EOS candidates remain unexecuted and should be handled by SALAD-02/03".to_string()
++        } else {
++            "DECODE-03D contract violation detected; dynamic default enable remains blocked".to_string()
++        },
++    }
++}
