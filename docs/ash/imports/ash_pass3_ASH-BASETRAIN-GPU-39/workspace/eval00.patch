+pub fn compare_eval00_profiles_named(
+    baseline_name: &str,
+    candidate_name: &str,
+    baseline: &Eval00ProfileStats,
+    candidate: &Eval00ProfileStats,
+) -> Eval00RegressionJudgement {
+    let base_salad = baseline.salad02_score_mean.or(baseline.salad04_score_mean).unwrap_or(1.0);
+    let cand_salad = candidate.salad02_score_mean.or(candidate.salad04_score_mean).unwrap_or(base_salad);
+    let base_tps = baseline.tokens_per_second_mean.unwrap_or(0.0);
+    let cand_tps = candidate.tokens_per_second_mean.unwrap_or(base_tps);
+    Eval00RegressionJudgement {
+        baseline_profile: baseline_name.to_string(),
+        candidate_profile: candidate_name.to_string(),
+        salad_score_improved: cand_salad <= base_salad * 0.90,
+        critical_fail_regression: candidate.fail_count > baseline.fail_count,
+        speed_regression_warn: base_tps > 0.0 && cand_tps < base_tps * 0.70,
+        over_stop_regression: candidate.stop_execute_count > baseline.stop_execute_count,
+    }
+}
+
+pub fn compare_eval00_profiles(
+    baseline: &Eval00ProfileStats,
+    candidate: &Eval00ProfileStats,
+) -> Eval00RegressionJudgement {
+    compare_eval00_profiles_named("baseline", "candidate", baseline, candidate)
+}
