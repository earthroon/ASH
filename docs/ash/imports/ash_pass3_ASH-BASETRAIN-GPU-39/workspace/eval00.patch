+pub fn summarize_eval00_runs(runs: &[Eval00RunReceipt]) -> Eval00Summary {
+    let mut overall = Eval00OverallStats::default();
+    let mut by_profile: BTreeMap<String, Vec<&Eval00RunReceipt>> = BTreeMap::new();
+    for run in runs {
+        match run.pass_fail.status.as_str() {
+            "PASS" => overall.pass_count += 1,
+            "PASS_WITH_WARNINGS" => overall.warn_count += 1,
+            "FAIL" => overall.fail_count += 1,
+            _ => overall.not_comparable_count += 1,
+        }
+        by_profile.entry(run.profile_id.clone()).or_default().push(run);
+    }
+    let mut stats_by_profile = BTreeMap::new();
+    for (profile, profile_runs) in by_profile.iter() {
+        let run_count = profile_runs.len();
+        let pass_count = profile_runs.iter().filter(|r| r.pass_fail.status == "PASS").count();
+        let warn_count = profile_runs.iter().filter(|r| r.pass_fail.status == "PASS_WITH_WARNINGS").count();
+        let fail_count = profile_runs.iter().filter(|r| r.pass_fail.status == "FAIL").count();
+        let salad02_values: Vec<f32> = profile_runs.iter().filter_map(|r| r.metrics.salad02_score_max).collect();
+        let salad04_values: Vec<f32> = profile_runs.iter().filter_map(|r| r.metrics.salad04_score_max).collect();
+        let tps_values: Vec<f32> = profile_runs.iter().filter_map(|r| r.metrics.tokens_per_second).collect();
+        stats_by_profile.insert(profile.clone(), Eval00ProfileStats {
+            run_count,
+            pass_count,
+            warn_count,
+            fail_count,
+            pass_rate: if run_count == 0 { 0.0 } else { pass_count as f32 / run_count as f32 },
+            salad02_score_mean: mean(&salad02_values),
+            salad04_score_mean: mean(&salad04_values),
+            tokens_per_second_mean: mean(&tps_values),
+            stop_execute_count: profile_runs.iter().map(|r| r.metrics.stop_execute_count).sum(),
+            rollback_execute_count: profile_runs.iter().map(|r| r.metrics.rollback_execute_count).sum(),
+            global_finite_fallback_count: profile_runs.iter().map(|r| r.metrics.global_finite_fallback_count).sum(),
+        });
+    }
+    let baseline_profile = env::var("ASH_EVAL00_BASELINE_PROFILE").unwrap_or_else(|_| "M01_static_safe".to_string());
+    let candidate_profile = env::var("ASH_EVAL00_CANDIDATE_PROFILE").unwrap_or_else(|_| "M04_dynamic_controlled".to_string());
+    let baseline = stats_by_profile.get(&baseline_profile).cloned().unwrap_or_default();
+    let candidate = stats_by_profile.get(&candidate_profile).cloned().unwrap_or_default();
+    let regression = compare_eval00_profiles_named(&baseline_profile, &candidate_profile, &baseline, &candidate);
+    Eval00Summary {
+        patch_id: EVAL00_PATCH_ID.to_string(),
+        input_patch: EVAL00_INPUT_PATCH_ID.to_string(),
+        status: if overall.fail_count > 0 { "PASS_WITH_WARNINGS" } else { "PASS_STATIC_OR_EMPTY" }.to_string(),
+        suite: Eval00SuiteStats {
+            prompt_count: default_prompt_suite().len(),
+            profile_count: default_matrix().profiles.len(),
+            seed_count: default_matrix().seeds.len(),
