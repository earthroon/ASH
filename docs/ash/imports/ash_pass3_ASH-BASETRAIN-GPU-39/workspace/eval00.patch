+pub fn append_eval00_receipt_from_sampler03(receipt: &SamplerParityReceipt) {
+    let mode = Eval00Mode::from_env();
+    if !mode.enabled() { return; }
+    let _ = write_default_manifests();
+    if matches!(mode, Eval00Mode::ManifestOnly) {
+        let _ = write_eval00_summary_from_receipt_file();
+        return;
+    }
+    let run = synthetic_run_from_sampler03(receipt);
+    let path = runs_path();
+    if let Some(parent) = path.parent() { let _ = fs::create_dir_all(parent); }
+    if let Ok(line) = serde_json::to_string(&run) {
+        use std::io::Write;
+        if let Ok(mut file) = fs::OpenOptions::new().create(true).append(true).open(&path) {
+            let _ = writeln!(file, "{}", line);
+        }
+    }
+    let _ = write_eval00_summary_from_receipt_file();
+}
+
+pub fn write_eval00_summary_from_receipt_file() -> Result<Eval00Summary, String> {
+    let path = runs_path();
+    let runs = if path.exists() {
+        let text = fs::read_to_string(&path).map_err(|e| e.to_string())?;
+        let mut out = Vec::new();
+        for line in text.lines().filter(|line| !line.trim().is_empty()) {
+            if let Ok(run) = serde_json::from_str::<Eval00RunReceipt>(line) { out.push(run); }
+        }
+        out
+    } else {
+        Vec::new()
+    };
+    let summary = summarize_eval00_runs(&runs);
+    let path = summary_path();
+    if let Some(parent) = path.parent() { fs::create_dir_all(parent).map_err(|e| e.to_string())?; }
+    fs::write(&path, serde_json::to_string_pretty(&summary).map_err(|e| e.to_string())?).map_err(|e| e.to_string())?;
+    Ok(summary)
+}
