+pub fn write_default_manifests() -> Result<(), String> {
+    let prompt_path = prompt_suite_path();
+    if let Some(parent) = prompt_path.parent() { fs::create_dir_all(parent).map_err(|e| e.to_string())?; }
+    let mut suite_lines = String::new();
+    for case in default_prompt_suite() {
+        suite_lines.push_str(&serde_json::to_string(&case).map_err(|e| e.to_string())?);
+        suite_lines.push('\n');
+    }
+    fs::write(&prompt_path, suite_lines).map_err(|e| e.to_string())?;
+    let matrix_path = matrix_path();
+    if let Some(parent) = matrix_path.parent() { fs::create_dir_all(parent).map_err(|e| e.to_string())?; }
+    fs::write(&matrix_path, serde_json::to_string_pretty(&default_matrix()).map_err(|e| e.to_string())?).map_err(|e| e.to_string())?;
+    Ok(())
+}
