++pub fn judge_eval00_run(receipt: &Eval00RunReceipt) -> Eval00RunJudgement {
++    let mut fail_reasons = Vec::new();
++    let mut warn_reasons = Vec::new();
++    if receipt.metrics.global_finite_fallback_count > 0 { fail_reasons.push("global_finite_fallback".to_string()); }
++    if receipt.metrics.byte_piece_count >= 3 { fail_reasons.push("byte_piece_leak_ge_3".to_string()); }
++    if receipt.metrics.jamo_leak_count >= 5 { fail_reasons.push("jamo_leak_ge_5".to_string()); }
++    if receipt.metrics.salad02_high_or_critical_count > 0 && receipt.metrics.salad02_score_max.unwrap_or(0.0) >= 0.80 { fail_reasons.push("salad02_critical".to_string()); }
++    if receipt.metrics.salad04_high_or_critical_count > 0 && receipt.metrics.salad04_score_max.unwrap_or(0.0) >= 0.80 { fail_reasons.push("salad04_critical".to_string()); }
++    if receipt.output.token_count == 0 { fail_reasons.push("empty_output".to_string()); }
++    if receipt.metrics.salad02_high_or_critical_count > 0 { warn_reasons.push("salad02_high_or_critical_seen".to_string()); }
++    if receipt.metrics.salad04_high_or_critical_count > 0 { warn_reasons.push("salad04_high_or_critical_seen".to_string()); }
++    if receipt.metrics.premature_stop { warn_reasons.push("premature_stop".to_string()); }
++    let status = if !fail_reasons.is_empty() { "FAIL" } else if !warn_reasons.is_empty() { "PASS_WITH_WARNINGS" } else { "PASS" };
++    Eval00RunJudgement { status: status.to_string(), fail_reasons, warn_reasons }
++}
