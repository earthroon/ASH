+fn synthetic_run_from_sampler03(receipt: &SamplerParityReceipt) -> Eval00RunReceipt {
+    let profile_id = env::var("ASH_EVAL00_PROFILE_ID").unwrap_or_else(|_| "M_sampler03_observation".to_string());
+    let prompt_id = env::var("ASH_EVAL00_PROMPT_ID").unwrap_or_else(|_| format!("sampler03_step_{}", receipt.step));
+    let output_preview = format!("selected_id={}", receipt.cpu.selected_id);
+    let decode_config = Eval00DecodeConfig {
+        temperature: receipt.decode_config.temperature,
+        top_p: receipt.decode_config.top_p,
+        top_k: receipt.decode_config.top_k as usize,
+        min_p: receipt.decode_config.min_p,
+        dynamic_sampler_enabled: env_bool("ASH_DECODE03D_CONTROLLED_ENABLE", false),
+        salad02_enabled: env_bool("ASH_SALAD02_DETECTOR_ONLY", false) || env_bool("ASH_SALAD02_DETECTOR", false),
+        salad04_enabled: matches!(crate::salad04_korean_morph_guard::Salad04Mode::from_env(), crate::salad04_korean_morph_guard::Salad04Mode::RiskOverlay | crate::salad04_korean_morph_guard::Salad04Mode::StrictRiskOverlay),
+        rollback_enabled: env_bool("ASH_SALAD03B_BEHAVIOR_CHANGE_ALLOWED", false),
+        stop_enabled: env_bool("ASH_STOP01_BEHAVIOR_CHANGE_ALLOWED", false),
+        profile_id: profile_id.clone(),
+    };
+    let mut run = Eval00RunReceipt {
+        patch_id: EVAL00_PATCH_ID.to_string(),
+        schema_version: 1,
+        run_id: run_id_from_env(),
+        prompt_id: prompt_id.clone(),
+        prompt_hash: hash_string(&prompt_id),
+        profile_id,
+        backend: receipt.mode.clone(),
+        seed: env::var("ASH_EVAL00_SEED").ok().and_then(|v| v.parse().ok()).unwrap_or(0),
+        max_new_tokens: env::var("ASH_EVAL00_MAX_NEW_TOKENS").ok().and_then(|v| v.parse().ok()).unwrap_or(96),
+        decode_config,
+        output: Eval00OutputReceipt {
+            output_text_preview: output_preview.clone(),
+            output_hash: hash_string(&output_preview),
+            token_count: receipt.step.saturating_add(1),
+            finish_reason: "sampler03_observation".to_string(),
+            stopped_by_stop01: false,
+            finalized_by_stop02: false,
+            visible_output_hash: None,
+            raw_output_hash: None,
+        },
+        metrics: Eval00Metrics {
+            pci_mean: receipt.cpu.final_normalized_entropy.map(|h| 1.0 - h.clamp(0.0, 1.0)),
+            pci_min: None,
+            entropy_spike_count: 0,
+            salad02_score_max: None,
+            salad02_high_or_critical_count: 0,
+            salad04_score_max: None,
+            salad04_high_or_critical_count: 0,
+            repeat_3gram_rate: None,
+            distinct_2_ratio: None,
+            byte_piece_count: 0,
+            jamo_leak_count: 0,
+            symbol_noise_count: 0,
+            fallback_count: if receipt.cpu.recovery_mode != "None" { 1 } else { 0 },
+            global_finite_fallback_count: if receipt.cpu.recovery_mode == "GlobalFiniteFallback" { 1 } else { 0 },
+            rollback_candidate_count: 0,
+            rollback_execute_count: 0,
+            stop_execute_count: 0,
+            premature_stop: false,
+            tokens_per_second: None,
+            mean_step_latency_ms: None,
+        },
+        receipts_seen: Eval00ReceiptStatus {
+            sampler05_seen: true,
+            decode03a_seen: true,
+            decode03b_seen: true,
+            decode03c_seen: true,
+            decode03d_seen: true,
+            salad02_seen: true,
+            salad04_seen: true,
+            salad03_seen: true,
+            salad03b_seen: true,
+            kv_rollback00_seen: true,
+            kv_rollback01_seen: true,
+            stop01_seen: true,
+            stop02_seen: true,
+        },
+        pass_fail: Eval00RunJudgement { status: "PASS".to_string(), fail_reasons: Vec::new(), warn_reasons: Vec::new() },
+    };
+    run.pass_fail = judge_eval00_run(&run);
+    run
+}
