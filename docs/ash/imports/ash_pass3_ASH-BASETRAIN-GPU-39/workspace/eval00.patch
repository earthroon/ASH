+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+pub enum Eval00Mode {
+    Off,
+    ManifestOnly,
+    RunBench,
+    CompareBaseline,
+    StrictRegressionGate,
+}
+
+impl Eval00Mode {
+    pub fn from_env() -> Self {
+        let value = env::var("ASH_EVAL00_MODE")
+            .unwrap_or_else(|_| "manifest_only".to_string())
+            .trim()
+            .to_ascii_lowercase();
+        match value.as_str() {
+            "off" | "false" | "0" | "disabled" => Self::Off,
+            "run" | "run_bench" | "bench" => Self::RunBench,
+            "compare" | "compare_baseline" => Self::CompareBaseline,
+            "strict" | "strict_regression_gate" => Self::StrictRegressionGate,
+            _ => Self::ManifestOnly,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Off => "Off",
+            Self::ManifestOnly => "ManifestOnly",
+            Self::RunBench => "RunBench",
+            Self::CompareBaseline => "CompareBaseline",
+            Self::StrictRegressionGate => "StrictRegressionGate",
+        }
+    }
+
+    pub fn enabled(self) -> bool { !matches!(self, Self::Off) }
+}
