+#[derive(Debug, Clone, Copy, Serialize, Deserialize)]
+pub struct SemanticPriorConfig {
+    pub enabled: bool,
+    pub qwave_weight: f32,
+    pub deltak_weight: f32,
+    pub cross_weight: f32,
+    pub bias_cap: f32,
+    pub apply_to_min_p: bool,
+    pub apply_to_top_p: bool,
+    pub apply_to_sampling_score: bool,
+    pub require_sampler04_strict_ready: bool,
+}
+
+impl Default for SemanticPriorConfig {
+    fn default() -> Self {
+        Self {
+            enabled: false,
+            qwave_weight: 0.20,
+            deltak_weight: 0.15,
+            cross_weight: 0.10,
+            bias_cap: 0.75,
+            apply_to_min_p: true,
+            apply_to_top_p: true,
+            apply_to_sampling_score: true,
+            require_sampler04_strict_ready: true,
+        }
+    }
+}
+
+impl SemanticPriorConfig {
+    pub fn sanitized(mut self) -> Self {
+        if !self.qwave_weight.is_finite() { self.qwave_weight = 0.0; }
+        if !self.deltak_weight.is_finite() { self.deltak_weight = 0.0; }
+        if !self.cross_weight.is_finite() { self.cross_weight = 0.0; }
+        if !self.bias_cap.is_finite() || self.bias_cap < 0.0 { self.bias_cap = 0.0; }
+        self.bias_cap = self.bias_cap.min(0.75);
+        self
+    }
+
+    pub fn bias_from_scores(&self, qwave: f32, deltak: f32) -> f32 {
+        let cfg = self.sanitized();
+        if !cfg.enabled { return 0.0; }
+        let q = if qwave.is_finite() { qwave.clamp(-1.0, 1.0) } else { 0.0 };
+        let k = if deltak.is_finite() { deltak.clamp(-1.0, 1.0) } else { 0.0 };
+        let raw = cfg.qwave_weight * q + cfg.deltak_weight * k + cfg.cross_weight * q * k;
+        if raw.is_finite() { raw.clamp(-cfg.bias_cap, cfg.bias_cap) } else { 0.0 }
+    }
+}
+
+impl From<SemanticPriorConfig> for GpuSemanticPriorConfig {
+    fn from(value: SemanticPriorConfig) -> Self {
+        let cfg = value.sanitized();
+        Self {
+            enabled: cfg.enabled,
+            qwave_weight: cfg.qwave_weight,
+            deltak_weight: cfg.deltak_weight,
+            cross_weight: cfg.cross_weight,
+            bias_cap: cfg.bias_cap,
+            qwave_source_available: false,
+            deltak_source_available: false,
+        }
+    }
+}
