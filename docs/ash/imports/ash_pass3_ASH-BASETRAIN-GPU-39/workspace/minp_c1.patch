+#[derive(Debug, Clone, Copy)]
+pub struct GpuSemanticPriorConfig {
+    pub enabled: bool,
+    pub qwave_weight: f32,
+    pub deltak_weight: f32,
+    pub cross_weight: f32,
+    pub bias_cap: f32,
+    pub qwave_source_available: bool,
+    pub deltak_source_available: bool,
+}
+
+impl Default for GpuSemanticPriorConfig {
+    fn default() -> Self {
+        Self {
+            enabled: false,
+            qwave_weight: 0.20,
+            deltak_weight: 0.15,
+            cross_weight: 0.10,
+            bias_cap: 0.75,
+            qwave_source_available: false,
+            deltak_source_available: false,
+        }
+    }
+}
+
+impl GpuSemanticPriorConfig {
+    pub fn sanitized(self) -> Self {
+        let mut out = self;
+        if !out.qwave_weight.is_finite() { out.qwave_weight = 0.0; }
+        if !out.deltak_weight.is_finite() { out.deltak_weight = 0.0; }
+        if !out.cross_weight.is_finite() { out.cross_weight = 0.0; }
+        if !out.bias_cap.is_finite() || out.bias_cap < 0.0 { out.bias_cap = 0.0; }
+        out.bias_cap = out.bias_cap.min(0.75);
+        out
+    }
+
+    pub fn effective(&self) -> bool {
+        let cfg = self.sanitized();
+        cfg.enabled && (cfg.qwave_source_available || cfg.deltak_source_available) && cfg.bias_cap > 0.0
+    }
+
+    pub fn source_mask(&self) -> u32 {
+        (if self.qwave_source_available { 1 } else { 0 }) | (if self.deltak_source_available { 2 } else { 0 })
+    }
+}
