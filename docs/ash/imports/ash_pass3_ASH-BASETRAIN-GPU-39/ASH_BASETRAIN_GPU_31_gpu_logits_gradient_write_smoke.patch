+fn build_state_tile(candidate: &CandidateInput, candidate_stats: &CandidateStats, runtime: &GpuWriteReceipts, violation_mask: u32, verdict: &str, pass: bool) -> Value {
+    let mut tile = base_tile(pass);
+    ins(&mut tile, "state_kind", "gpu_logits_gradient_write_smoke_state");
+    ins(&mut tile, "title", TITLE);
+    ins(&mut tile, "source_patch", "ASH-BASETRAIN-GPU-30");
+    ins(&mut tile, "source_30_pass", true);
+    ins(&mut tile, "source_30_violation_mask", 0);
+    ins(&mut tile, "source_30_verdict_lut_index", 0);
+    ins(&mut tile, "source_30_cpu_candidate_digest_hex", SOURCE_CPU_CANDIDATE_DIGEST_HEX);
+    ins(&mut tile, "gpu_buffer_handle_reused_from_28", false);
+    ins(&mut tile, "gpu_buffer_handle_reused_from_29", false);
+    ins(&mut tile, "runtime_buffer_object_persistence_claimed", false);
+    ins(&mut tile, "buffer_contract_reconstructed_from_receipts", true);
+    ins(&mut tile, "cpu_candidate_materialization_source", candidate.materialization_source.clone());
+    ins(&mut tile, "cpu_candidate_path", candidate.path.clone());
+    ins(&mut tile, "cpu_candidate_digest_hex", candidate.digest_hex.clone());
+    ins(&mut tile, "cpu_candidate_digest_match", candidate.digest_hex == SOURCE_CPU_CANDIDATE_DIGEST_HEX);
+    ins(&mut tile, "cpu_candidate_finite_count", candidate_stats.finite_count);
+    ins(&mut tile, "cpu_candidate_nan_count", candidate_stats.nan_count);
+    ins(&mut tile, "cpu_candidate_inf_count", candidate_stats.inf_count);
+    ins(&mut tile, "cpu_candidate_sum_close_to_zero", candidate_stats.sum.abs() <= 0.0001);
+    ins(&mut tile, "gpu_runtime_available", runtime.gpu_runtime_available);
+    ins(&mut tile, "new_wgpu_device_acquired", runtime.gpu_device_acquired);
