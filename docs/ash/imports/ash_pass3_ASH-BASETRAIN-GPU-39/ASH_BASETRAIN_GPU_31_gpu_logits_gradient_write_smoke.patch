+fn read_cpu_candidate_input() -> Result<CandidateInput, String> {
+    env::var(CANDIDATE_ENV_KEY)
+        .ok()
+        .and_then(|path| fs::read(&path).ok().map(|bytes| (path, bytes)))
+        .map_or_else(
+            || recompute_cpu_candidate_from_logits(),
+            |(path, bytes)| build_candidate_input("file_input", &path, bytes),
+        )
+}
+
+fn recompute_cpu_candidate_from_logits() -> Result<CandidateInput, String> {
+    let path = env::var(RAW_LOGITS_ENV_KEY).map_err(|err| format!("{RAW_LOGITS_ENV_KEY} missing for fallback recompute: {err}"))?;
+    let bytes = fs::read(&path).map_err(|err| format!("raw logits read failed: {err}"))?;
+    (bytes.len() == GRADIENT_BYTES)
+        .then_some(())
+        .ok_or_else(|| format!("raw logits byte length mismatch: got {}, expected {GRADIENT_BYTES}", bytes.len()))?;
+    let digest_hex = sha256_hex(&bytes);
+    (digest_hex == SOURCE_PAYLOAD_DIGEST_HEX)
+        .then_some(())
+        .ok_or_else(|| format!("raw logits digest mismatch: got {digest_hex}, expected {SOURCE_PAYLOAD_DIGEST_HEX}"))?;
+    let logits = bytes_to_f32_values(&bytes)?;
+    let candidate_bytes = compute_candidate_bytes_from_logits(&logits)?;
+    build_candidate_input("recomputed_from_logits_with_30_digest_revalidation", &path, candidate_bytes)
+}
+
+fn build_candidate_input(source: &str, path: &str, bytes: Vec<u8>) -> Result<CandidateInput, String> {
+    (bytes.len() == GRADIENT_BYTES)
+        .then_some(())
+        .ok_or_else(|| format!("candidate byte length mismatch: got {}, expected {GRADIENT_BYTES}", bytes.len()))?;
+    let digest_hex = sha256_hex(&bytes);
+    (digest_hex == SOURCE_CPU_CANDIDATE_DIGEST_HEX)
+        .then_some(())
+        .ok_or_else(|| format!("candidate digest mismatch: got {digest_hex}, expected {SOURCE_CPU_CANDIDATE_DIGEST_HEX}"))?;
+    let values = bytes_to_f32_values(&bytes)?;
+    Ok(CandidateInput { materialization_source: source.to_string(), path: path.to_string(), bytes, digest_hex, values })
+}
+
+fn compute_candidate_bytes_from_logits(values: &[f32]) -> Result<Vec<u8>, String> {
+    (values.len() == WINDOW_SIZE)
+        .then_some(())
+        .ok_or_else(|| format!("window size mismatch: got {}, expected {WINDOW_SIZE}", values.len()))?;
+    let max_logit = values.iter().copied().fold(f32::NEG_INFINITY, f32::max);
+    max_logit
+        .is_finite()
+        .then_some(())
+        .ok_or_else(|| "max logit is not finite".to_string())?;
+    let exp_values = values
+        .iter()
+        .map(|value| ((*value as f64) - (max_logit as f64)).exp())
+        .collect::<Vec<f64>>();
+    let sum_exp = exp_values.iter().copied().sum::<f64>();
+    (sum_exp.is_finite() && sum_exp > 0.0)
+        .then_some(())
+        .ok_or_else(|| format!("sum_exp invalid: {sum_exp}"))?;
+    let mut candidate_bytes = Vec::with_capacity(GRADIENT_BYTES);
+    exp_values
+        .iter()
+        .enumerate()
+        .map(|(index, exp_value)| {
+            let probability = (*exp_value / sum_exp) as f32;
+            probability - ((index == TARGET_INDEX) as u8 as f32)
+        })
+        .for_each(|value| candidate_bytes.extend_from_slice(&value.to_le_bytes()));
+    Ok(candidate_bytes)
+}
+
+async fn execute_gpu_logits_gradient_write_smoke(candidate_bytes: &[u8]) -> Result<GpuWriteReceipts, String> {
+    use wgpu26 as wgpu;
+
+    let instance = wgpu::Instance::default();
+    let adapter = instance
+        .request_adapter(&wgpu::RequestAdapterOptions {
+            power_preference: wgpu::PowerPreference::HighPerformance,
+            compatible_surface: None,
+            force_fallback_adapter: false,
+        })
+        .await
+        .map_err(|err| format!("request_adapter failed: {err}"))?;
+
+    let device_queue = adapter
+        .request_device(&wgpu::DeviceDescriptor {
+            label: Some("ash-basetrain-gpu-31-logits-gradient-write-smoke-device"),
+            required_features: wgpu::Features::empty(),
+            required_limits: wgpu::Limits::downlevel_defaults(),
+            memory_hints: wgpu::MemoryHints::Performance,
+            ..Default::default()
+        })
+        .await
+        .map_err(|err| format!("request_device failed: {err}"))?;
+    let (device, queue) = device_queue;
+
+    let gradient_buffer = device.create_buffer(&wgpu::BufferDescriptor {
+        label: Some(BUFFER_LABEL),
+        size: GRADIENT_BYTES as u64,
+        usage: wgpu::BufferUsages::STORAGE | wgpu::BufferUsages::COPY_SRC | wgpu::BufferUsages::COPY_DST,
+        mapped_at_creation: false,
+    });
+
+    queue.write_buffer(&gradient_buffer, 0, candidate_bytes);
+
+    let readback_buffer = device.create_buffer(&wgpu::BufferDescriptor {
+        label: Some(READBACK_BUFFER_LABEL),
+        size: GRADIENT_BYTES as u64,
+        usage: wgpu::BufferUsages::COPY_DST | wgpu::BufferUsages::MAP_READ,
+        mapped_at_creation: false,
+    });
+
+    let mut encoder = device.create_command_encoder(&wgpu::CommandEncoderDescriptor {
+        label: Some("ash-basetrain-gpu-31-written-candidate-readback-copy-encoder"),
+    });
+    encoder.copy_buffer_to_buffer(&gradient_buffer, 0, &readback_buffer, 0, GRADIENT_BYTES as u64);
+    queue.submit(Some(encoder.finish()));
+
+    let buffer_slice = readback_buffer.slice(..);
+    let (sender, receiver) = mpsc::channel();
+    buffer_slice.map_async(wgpu::MapMode::Read, move |result| {
+        let _ = sender.send(result);
+    });
+    let _ = device.poll(wgpu::PollType::Wait);
+    let map_status = receiver
+        .recv()
+        .map_err(|err| format!("map_async receiver failed: {err}"))
+        .and_then(|result| result.map_err(|err| format!("map_async failed: {err}")));
+    map_status?;
+
+    let mapped = buffer_slice.get_mapped_range();
+    let readback_bytes_vec = mapped.to_vec();
+    drop(mapped);
+    readback_buffer.unmap();
+
+    let values = bytes_to_f32_values(&readback_bytes_vec)?;
+    let written_stats = compute_candidate_stats(&values)?;
+    let written_digest_hex = sha256_hex(&readback_bytes_vec);
+
+    Ok(GpuWriteReceipts {
+        gpu_runtime_available: true,
+        gpu_adapter_acquired: true,
+        gpu_device_acquired: true,
+        gpu_queue_acquired: true,
+        runtime_logits_gradient_buffer_created: true,
+        runtime_buffer_size_bytes: GRADIENT_BYTES as u64,
+        runtime_buffer_label: BUFFER_LABEL.to_string(),
+        queue_write_buffer_executed: true,
+        queue_submit_executed_for_write_readback: true,
+        queue_submit_used_for_compute: false,
+        copy_buffer_to_buffer_for_readback_executed: true,
+        readback_buffer_created: true,
+        readback_map_async_executed: true,
+        readback_size_bytes: readback_bytes_vec.len(),
+        readback_element_count: values.len(),
+        written_digest_hex,
+        written_bytes_match_cpu: readback_bytes_vec == candidate_bytes,
+        written_stats,
+        gpu_compute_dispatch_executed: false,
+        gpu_shader_dispatch_executed: false,
+        backward_executed: false,
+        optimizer_step_executed: false,
+        runtime_error: None,
+    })
+}
+
+fn bytes_to_f32_values(bytes: &[u8]) -> Result<Vec<f32>, String> {
+    (bytes.len() % 4 == 0)
+        .then_some(())
+        .ok_or_else(|| "bytes not divisible by f32 width".to_string())?;
+    Ok(bytes
+        .chunks_exact(4)
+        .map(|chunk| {
+            let mut word = [0u8; 4];
+            word.copy_from_slice(chunk);
+            f32::from_le_bytes(word)
+        })
+        .collect::<Vec<f32>>())
+}
+
+fn compute_candidate_stats(values: &[f32]) -> Result<CandidateStats, String> {
+    (values.len() == WINDOW_SIZE)
+        .then_some(())
+        .ok_or_else(|| format!("candidate value length mismatch: got {}, expected {WINDOW_SIZE}", values.len()))?;
+    let finite_count = values.iter().filter(|value| value.is_finite()).count();
+    let nan_count = values.iter().filter(|value| value.is_nan()).count();
+    let inf_count = values.iter().filter(|value| value.is_infinite()).count();
+    let sum = values.iter().map(|value| *value as f64).sum::<f64>();
+    let min = values.iter().copied().fold(f32::INFINITY, f32::min);
+    let max = values.iter().copied().fold(f32::NEG_INFINITY, f32::max);
+    let abs_max = values.iter().fold(0.0_f32, |acc, value| acc.max(value.abs()));
+    let target_gradient = values[TARGET_INDEX];
+    let non_target_gradient_expected_non_negative = values
+        .iter()
+        .enumerate()
+        .all(|(index, value)| (index == TARGET_INDEX) || *value >= 0.0);
+    Ok(CandidateStats {
+        finite_count,
+        nan_count,
+        inf_count,
+        sum,
+        min,
+        max,
+        abs_max,
+        target_gradient,
+        target_index_gradient_expected_negative: target_gradient < 0.0,
+        non_target_gradient_expected_non_negative,
+    })
+}
+
+fn sha256_hex(bytes: &[u8]) -> String {
+    let mut hasher = Sha256::new();
+    hasher.update(bytes);
+    format!("{:x}", hasher.finalize())
+}
