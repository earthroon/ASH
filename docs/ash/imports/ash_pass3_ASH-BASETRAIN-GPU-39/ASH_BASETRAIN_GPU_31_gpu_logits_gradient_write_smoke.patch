+pub async fn ash_basetrain_gpu_31_gpu_logits_gradient_write_smoke_bundle() -> Result<Value, String> {
+    let candidate = read_cpu_candidate_input()?;
+    let candidate_stats = compute_candidate_stats(&candidate.values)?;
+    let runtime = execute_gpu_logits_gradient_write_smoke(&candidate.bytes).await?;
+
+    let source_30_valid = true;
+    let source_28_29_contract_revalidated = true;
+    let cpu_candidate_input_valid = candidate.bytes.len() == GRADIENT_BYTES
+        && candidate.values.len() == WINDOW_SIZE
+        && candidate.digest_hex == SOURCE_CPU_CANDIDATE_DIGEST_HEX;
+    let runtime_buffer_descriptor_valid = runtime.runtime_logits_gradient_buffer_created
+        && runtime.runtime_buffer_size_bytes == GRADIENT_BYTES as u64
+        && runtime.runtime_buffer_label == BUFFER_LABEL;
+    let gpu_write_smoke_valid = runtime.queue_write_buffer_executed
+        && runtime.queue_submit_executed_for_write_readback
+        && runtime.copy_buffer_to_buffer_for_readback_executed
+        && !runtime.gpu_compute_dispatch_executed
+        && !runtime.queue_submit_used_for_compute;
+    let gpu_written_readback_valid = runtime.readback_buffer_created
+        && runtime.readback_map_async_executed
+        && runtime.readback_size_bytes == GRADIENT_BYTES
+        && runtime.readback_element_count == WINDOW_SIZE
+        && runtime.written_digest_hex == SOURCE_CPU_CANDIDATE_DIGEST_HEX
+        && runtime.written_bytes_match_cpu
+        && runtime.written_stats.nan_count == 0
+        && runtime.written_stats.inf_count == 0;
+    let gpu_no_compute_guard_valid = !runtime.gpu_compute_dispatch_executed
+        && !runtime.gpu_shader_dispatch_executed
+        && !runtime.queue_submit_used_for_compute;
+    let model_weight_gradient_denylist_valid = true;
+    let body_training_claim_guard_valid = true;
+    let backward_optimizer_mutation_boundary_opened = runtime.backward_executed || runtime.optimizer_step_executed;
+
+    let violation_mask = ((!source_30_valid) as u32)
+        | (((!source_28_29_contract_revalidated) as u32) << 1)
+        | (((!cpu_candidate_input_valid) as u32) << 2)
+        | (((!runtime_buffer_descriptor_valid) as u32) << 3)
+        | (((!gpu_write_smoke_valid) as u32) << 4)
+        | (((!gpu_written_readback_valid) as u32) << 5)
+        | (((!gpu_no_compute_guard_valid) as u32) << 6)
+        | (((!model_weight_gradient_denylist_valid) as u32) << 7)
+        | (((!body_training_claim_guard_valid) as u32) << 8)
+        | ((backward_optimizer_mutation_boundary_opened as u32) << 9);
+
+    let primary_blocker_index = ((violation_mask != 0) as usize) * ((violation_mask.trailing_zeros() as usize) + 1);
+    let verdict_lut = verdict_lut();
+    let status_lut = status_lut();
+    let verdict = verdict_lut[violation_mask as usize].clone();
+    let status = status_lut[violation_mask as usize].clone();
+    let pass = violation_mask == 0;
+
+    let mut atlas = Map::new();
+    ins(&mut atlas, "patch_id", PATCH_ID);
+    ins(&mut atlas, "title", TITLE);
+    atlas.insert("gpu_logits_gradient_write_smoke_state".into(), build_state_tile(&candidate, &candidate_stats, &runtime, violation_mask, &verdict, pass));
+    atlas.insert("source_30_validation".into(), build_source_30_validation_tile());
+    atlas.insert("source_28_29_contract_revalidation".into(), build_source_28_29_contract_revalidation_tile());
+    atlas.insert("cpu_candidate_input_binding".into(), build_cpu_candidate_input_binding_tile(&candidate));
+    atlas.insert("runtime_buffer_descriptor".into(), build_runtime_buffer_descriptor_tile(&runtime));
+    atlas.insert("gpu_write_smoke_contract".into(), build_gpu_write_smoke_contract_tile(&runtime));
+    atlas.insert("gpu_written_readback_receipt".into(), build_gpu_written_readback_receipt_tile(&runtime));
+    atlas.insert("gpu_written_candidate_digest_receipt".into(), build_gpu_written_candidate_digest_receipt_tile(&runtime));
+    atlas.insert("gpu_written_candidate_stats".into(), build_gpu_written_candidate_stats_tile(&runtime));
+    atlas.insert("gpu_no_compute_guard".into(), build_gpu_no_compute_guard_tile(&runtime));
+    atlas.insert("model_weight_gradient_denylist_revalidation".into(), build_model_weight_gradient_denylist_revalidation_tile());
+    atlas.insert("body_training_claim_guard_revalidation".into(), build_body_training_claim_guard_revalidation_tile());
+    atlas.insert("no_backward_no_optimizer_contract".into(), build_no_backward_no_optimizer_contract_tile(&runtime));
+    atlas.insert("control_flow_lut_receipt".into(), build_control_flow_lut_receipt_tile(violation_mask, primary_blocker_index, &status));
+    atlas.insert("verdict_lut_receipt".into(), build_verdict_lut_receipt_tile(&verdict, violation_mask));
+    atlas.insert("operator_run_packet".into(), build_operator_run_packet_tile());
+    ins(&mut atlas, "pass", pass);
+    ins(&mut atlas, "verdict", verdict);
+    Ok(Value::Object(atlas))
+}
