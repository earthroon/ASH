+    pub fn capture_module_io_padded_batch(
+        &self,
+        token_ids: &[u32],
+        lengths: &[usize],
+        max_seq_len: usize,
+        target_key: &str,
+    ) -> Result<Vec<CapturedModuleIo>> {
+        if lengths.is_empty() {
+            return Ok(Vec::new());
+        }
+        let batch_size = lengths.len();
+        let padded_seq_len = max_seq_len.max(1);
+        ensure!(
+            token_ids.len() == batch_size * padded_seq_len,
+            "module-local prepadded token buffer mismatch: batch_size={} max_seq_len={} token_ids_len={} expected={}",
+            batch_size,
+            max_seq_len,
+            token_ids.len(),
+            batch_size * padded_seq_len,
+        );
+        let mut active_mask = vec![0.0f32; token_ids.len()];
+        for (batch_idx, length) in lengths.iter().copied().enumerate() {
+            ensure!(
+                length <= max_seq_len,
+                "module-local prepadded length exceeds max_seq_len: batch_idx={} length={} max_seq_len={}",
+                batch_idx,
+                length,
+                max_seq_len,
+            );
+            let row_offset = batch_idx * padded_seq_len;
+            for token_idx in 0..length {
+                active_mask[row_offset + token_idx] = 1.0;
+            }
+        }
+        let padded = PaddedTokenBatch {
+            batch_size,
+            max_seq_len,
+            lengths: lengths.to_vec(),
+            token_ids: token_ids.to_vec(),
+            active_mask,
+        };
+        self.capture_module_io_from_padded_batch(&padded, target_key)
+    }
+
