+fn run(args: &Args) -> Output {
+    let f38 = match load_json(&args.forward_candidate_receipt_path, BLOCK_38_NOT_FOUND, BLOCK_38_READ, BLOCK_38_PARSE) {
+        Ok(receipt) => receipt,
+        Err((code, reason)) => return blocked_with(None, None, None, None, None, None, None, None, code, reason),
+    };
+    match validate_38(&f38.value) {
+        Err((code, reason)) => return blocked_with(Some(f38), None, None, None, None, None, None, None, code, reason),
+        Ok(()) => (),
+    }
+    let r37 = match load_json(&args.reduction_parity_receipt_path, BLOCK_37R_NOT_FOUND, BLOCK_37R_READ, BLOCK_37R_PARSE) {
+        Ok(receipt) => receipt,
+        Err((code, reason)) => return blocked_with(Some(f38), None, None, None, None, None, None, None, code, reason),
+    };
+    match validate_37r_r2(&r37.value) {
+        Err((code, reason)) => return blocked_with(Some(f38), Some(r37), None, None, None, None, None, None, code, reason),
+        Ok(()) => (),
+    }
+    let q37 = match load_json(&args.multi_workgroup_reduction_receipt_path, BLOCK_37Q_NOT_FOUND, BLOCK_37Q_READ, BLOCK_37Q_PARSE) {
+        Ok(receipt) => receipt,
+        Err((code, reason)) => return blocked_with(Some(f38), Some(r37), None, None, None, None, None, None, code, reason),
+    };
+    match validate_37q_r1(&q37.value) {
+        Err((code, reason)) => return blocked_with(Some(f38), Some(r37), Some(q37), None, None, None, None, None, code, reason),
+        Ok(()) => (),
+    }
+    let p37 = match load_json(&args.parallel_reduction_receipt_path, BLOCK_37P_NOT_FOUND, BLOCK_37P_READ, BLOCK_37P_PARSE) {
+        Ok(receipt) => receipt,
+        Err((code, reason)) => return blocked_with(Some(f38), Some(r37), Some(q37), None, None, None, None, None, code, reason),
+    };
+    match validate_37p_r1(&p37.value) {
+        Err((code, reason)) => return blocked_with(Some(f38), Some(r37), Some(q37), Some(p37), None, None, None, None, code, reason),
+        Ok(()) => (),
+    }
+    let f37 = match load_json(&args.gpu_upload_readback_smoke_receipt_path, BLOCK_37F_NOT_FOUND, BLOCK_37F_READ, BLOCK_37F_PARSE) {
+        Ok(receipt) => receipt,
+        Err((code, reason)) => return blocked_with(Some(f38), Some(r37), Some(q37), Some(p37), None, None, None, None, code, reason),
+    };
+    match validate_37f(&f37.value) {
+        Err((code, reason)) => return blocked_with(Some(f38), Some(r37), Some(q37), Some(p37), Some(f37), None, None, None, code, reason),
+        Ok(()) => (),
+    }
+    let row_block = match read_row_block_payload(&f37.value, args) {
+        Ok(payload) => payload,
+        Err((code, reason)) => return blocked_with(Some(f38), Some(r37), Some(q37), Some(p37), Some(f37), None, None, None, code, reason),
+    };
+    match validate_ring_args(args, &row_block) {
+        Err((code, reason)) => return blocked_with(Some(f38), Some(r37), Some(q37), Some(p37), Some(f37), Some(row_block), None, None, code, reason),
+        Ok(()) => (),
+    }
+    match payload_matches_38(&f38.value, &row_block) {
+        false => return blocked_with(Some(f38), Some(r37), Some(q37), Some(p37), Some(f37), Some(row_block), None, None, BLOCK_SLOT_DIGEST, "39 slot payload digest did not match 38 selected row-block digest."),
+        true => (),
+    }
+    let cpu = cpu_reference(&row_block.weights, args.input_vector_len, args.row_count);
+    let runtime = pollster::block_on(actual_matvec_dispatch(args, &row_block, &cpu.input_vector));
+    pass_or_block(args, f38, r37, q37, p37, f37, row_block, cpu, runtime)
+}
+
+fn load_json(path: &str, not_found: &'static str, read_failed: &'static str, parse_failed: &'static str) -> Result<LoadedReceipt, (&'static str, &'static str)> {
+    match Path::new(path).exists() {
+        false => Err((not_found, "required receipt was not found.")),
+        true => match fs::read(path) {
+            Err(_) => Err((read_failed, "required receipt could not be read.")),
+            Ok(bytes) => match serde_json::from_slice::<Value>(&bytes) {
+                Err(_) => Err((parse_failed, "required receipt could not be parsed as JSON.")),
+                Ok(value) => Ok(LoadedReceipt { path: path.to_string(), digest: sha256_hex(&bytes), value }),
+            },
+        },
+    }
+}
+
+fn validate_38(v: &Value) -> Result<(), (&'static str, &'static str)> {
+    let status = str_value(v, "status").unwrap_or("");
+    match (
+        str_value(v, "patch_id") == Some("ASH-BASETRAIN-GPU-38"),
+        bool_value(v, "pass") == Some(true) && str_value(v, "verdict") == Some("PASS") && status.starts_with("PASS_ASH_BASETRAIN_GPU_38"),
+        bool_path(v, &["artifact_write", "runtime_receipt_written"]) == Some(true),
+        bool_path(v, &["atlas_weight_stream", "selected_row_block_only"]) == Some(true),
+        bool_path(v, &["atlas_weight_stream", "full_tensor_load_executed"]) == Some(false),
+        u64_path(v, &["atlas_weight_stream", "payload_bytes_read"]).unwrap_or(0) > 0,
+        str_path(v, &["atlas_weight_stream", "payload_digest_hex"]).unwrap_or("") != "",
+        bool_path(v, &["bounded_matvec_candidate", "actual_dispatch_executed"]) == Some(true),
+        bool_path(v, &["bounded_matvec_candidate", "actual_readback_executed"]) == Some(true),
+        bool_path(v, &["bounded_matvec_candidate", "finite_check_passed"]) == Some(true),
+        bool_path(v, &["bounded_matvec_candidate", "gpu_cpu_output_parity_passed"]) == Some(true),
+        u64_path(v, &["bounded_matvec_candidate", "mismatched_value_count"]) == Some(0),
+    ) {
+        (false, _, _, _, _, _, _, _, _, _, _, _) => Err((BLOCK_38_NOT_PASS, "38 receipt patch_id was not accepted.")),
+        (_, false, _, _, _, _, _, _, _, _, _, _) => Err((BLOCK_38_NOT_PASS, "38 receipt was not PASS.")),
+        (_, _, false, _, _, _, _, _, _, _, _, _) => Err((BLOCK_38_INVALID, "38 runtime receipt artifact write was not confirmed.")),
+        (_, _, _, false, _, _, _, _, _, _, _, _) => Err((BLOCK_38_INVALID, "38 selected row-block flag was not true.")),
+        (_, _, _, _, false, _, _, _, _, _, _, _) => Err((BLOCK_38_INVALID, "38 full tensor load guard was not sealed.")),
+        (_, _, _, _, _, false, _, _, _, _, _, _) => Err((BLOCK_38_INVALID, "38 payload byte count was empty.")),
+        (_, _, _, _, _, _, false, _, _, _, _, _) => Err((BLOCK_38_INVALID, "38 payload digest was empty.")),
+        (_, _, _, _, _, _, _, false, _, _, _, _) => Err((BLOCK_38_INVALID, "38 dispatch was not executed.")),
+        (_, _, _, _, _, _, _, _, false, _, _, _) => Err((BLOCK_38_INVALID, "38 readback was not executed.")),
+        (_, _, _, _, _, _, _, _, _, false, _, _) => Err((BLOCK_38_INVALID, "38 finite check failed.")),
+        (_, _, _, _, _, _, _, _, _, _, false, _) => Err((BLOCK_38_INVALID, "38 output parity did not pass.")),
+        (_, _, _, _, _, _, _, _, _, _, _, false) => Err((BLOCK_38_INVALID, "38 output mismatch count was non-zero.")),
+        _ => Ok(()),
+    }
+}
