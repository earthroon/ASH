+fn validate_37p_r1(v: &Value) -> Result<(), (&'static str, &'static str)> {
+    let status = str_value(v, "status").unwrap_or("");
+    let summary = v.get("parallel_reduction_diagnostic_summary").or_else(|| v.get("parallel_reduction_diagnostic_summary_ref")).unwrap_or(&Value::Null);
+    match (
+        str_value(v, "patch_id") == Some("ASH-BASETRAIN-GPU-37P-R1"),
+        bool_value(v, "pass") == Some(true) && str_value(v, "verdict") == Some("PASS") && status.starts_with("PASS_ASH_BASETRAIN_GPU_37P_R1"),
+        u64_value(summary, "matched_word_count") == Some(8),
+        u64_value(summary, "mismatched_word_count") == Some(0),
+    ) {
+        (false, _, _, _) => Err((BLOCK_37P_NOT_PASS, "37P-R1 receipt patch_id was not accepted.")),
+        (_, false, _, _) => Err((BLOCK_37P_NOT_PASS, "37P-R1 receipt was not PASS.")),
+        (_, _, false, _) => Err((BLOCK_37P_SUMMARY, "37P-R1 matched word count was not 8.")),
+        (_, _, _, false) => Err((BLOCK_37P_SUMMARY, "37P-R1 mismatched word count was not zero.")),
+        _ => Ok(()),
+    }
+}
+
+fn validate_37f(v: &Value) -> Result<(), (&'static str, &'static str)> {
+    let digest = v.get("gpu_readback_digest_receipt").unwrap_or(&Value::Null);
+    let cpu = str_value(digest, "cpu_source_payload_raw_sha256_hex").unwrap_or("");
+    let gpu = str_value(digest, "gpu_readback_raw_sha256_hex").or_else(|| str_value(digest, "gpu_readback_byte_digest_hex")).unwrap_or("");
+    match (
+        str_value(v, "patch_id") == Some("ASH-BASETRAIN-GPU-37F"),
+        bool_value(v, "pass") == Some(true) && str_value(v, "verdict") == Some("PASS"),
+        !cpu.is_empty() && cpu == gpu,
+    ) {
+        (false, _, _) => Err((BLOCK_37F_NOT_PASS, "37F receipt patch_id was not accepted.")),
+        (_, false, _) => Err((BLOCK_37F_NOT_PASS, "37F receipt was not PASS.")),
+        (_, _, false) => Err((BLOCK_37F_DIGEST, "37F CPU source and GPU readback digests did not match.")),
+        _ => Ok(()),
+    }
+}
+
+fn validate_ring_args(args: &Args, row_block: &RowBlockPayload) -> Result<(), (&'static str, &'static str)> {
+    match (
+        args.slot_count >= 2,
+        args.selected_slot_index < args.slot_count,
+        args.slot_size_bytes >= row_block.bytes_read,
+    ) {
+        (false, _, _) => Err((BLOCK_RING_SLOT_COUNT, "39 ring slot_count must be at least 2.")),
+        (_, false, _) => Err((BLOCK_SLOT_LEASE, "39 selected slot index was outside ring slot_count.")),
+        (_, _, false) => Err((BLOCK_RING_SLOT_SIZE, "39 slot_size_bytes was smaller than selected row-block payload.")),
+        _ => Ok(()),
+    }
+}
+
+fn payload_matches_38(v: &Value, row_block: &RowBlockPayload) -> bool {
+    match str_path(v, &["atlas_weight_stream", "payload_digest_hex"]) {
+        Some(digest) => digest == row_block.digest,
+        None => false,
+    }
+}
+
+fn read_row_block_payload(v: &Value, args: &Args) -> Result<RowBlockPayload, (&'static str, &'static str)> {
+    let candidate = v.get("candidate_ref").ok_or((BLOCK_SOURCE_READ, "37F candidate_ref was missing."))?;
+    let source_path = str_value(candidate, "source_shard_path").ok_or((BLOCK_SOURCE_READ, "37F source_shard_path was missing."))?.to_string();
+    let segments = v.get("representative_gpu_readback_source_read_results").and_then(Value::as_array).ok_or((BLOCK_SOURCE_READ, "37F source read results were missing."))?;
+    let first = segments.first().ok_or((BLOCK_SOURCE_READ, "37F source segment list was empty."))?;
+    let first_start = u64_value(first, "source_file_offset_start").ok_or((BLOCK_SOURCE_READ, "37F first segment start was missing."))?;
+    let first_len = u64_value(first, "bytes_read").ok_or((BLOCK_SOURCE_READ, "37F first segment byte length was missing."))?;
+    let requested = (args.row_count as u64).saturating_mul(args.input_vector_len as u64).saturating_mul(4);
+    let byte_len = match (args.row_count == ROW_COUNT, args.input_vector_len == INPUT_VECTOR_LEN, requested > 0, requested <= first_len) {
+        (true, true, true, true) => requested,
+        _ => return Err((BLOCK_SOURCE_READ, "39 first candidate supports only row_count=256/input_vector_len=256 within the first 37F source segment.")),
+    };
+    let byte_offset = first_start.saturating_add((args.row_start as u64).saturating_mul(args.input_vector_len as u64).saturating_mul(4));
+    let mut file = File::open(&source_path).map_err(|_| (BLOCK_SOURCE_READ, "selected row-block source file could not be opened."))?;
+    file.seek(SeekFrom::Start(byte_offset)).map_err(|_| (BLOCK_SOURCE_READ, "selected row-block source seek failed."))?;
+    let mut bytes = vec![0u8; byte_len as usize];
+    file.read_exact(&mut bytes).map_err(|_| (BLOCK_SOURCE_READ, "selected row-block source bytes could not be read."))?;
+    match bytes.is_empty() {
+        true => Err((BLOCK_SOURCE_EMPTY, "selected row-block payload was empty.")),
+        false => {
+            let weights = bytes.chunks_exact(4).map(|chunk| f32::from_le_bytes([chunk[0], chunk[1], chunk[2], chunk[3]])).collect::<Vec<f32>>();
+            Ok(RowBlockPayload { source_path, source_file_offset_start: byte_offset, source_file_offset_end: byte_offset + byte_len, bytes_read: byte_len, digest: sha256_hex(&bytes), weights, weight_bytes: bytes })
+        }
+    }
+}
+
+fn cpu_reference(weights: &[f32], input_len: u32, row_count: u32) -> CpuReference {
+    let input_vector = (0..input_len).map(|i| ((i % 17) as f32 - 8.0) / 17.0).collect::<Vec<f32>>();
+    let mut output = Vec::with_capacity(row_count as usize);
+    let mut nan_count = 0usize;
+    let mut inf_count = 0usize;
+    for row in 0..row_count as usize {
+        let base = row * input_len as usize;
+        let mut acc = 0.0f32;
+        for k in 0..input_len as usize {
+            acc += weights[base + k] * input_vector[k];
+        }
+        match acc.is_nan() { true => nan_count += 1, false => () }
+        match acc.is_infinite() { true => inf_count += 1, false => () }
+        output.push(acc);
+    }
+    CpuReference { digest: f32_digest(&output), input_vector, output, nan_count, inf_count }
+}
+
+async fn actual_matvec_dispatch(args: &Args, row_block: &RowBlockPayload, input_vector: &[f32]) -> MatVecRuntime {
+    use wgpu26 as wgpu;
+    let instance = wgpu::Instance::default();
+    let adapter_result = instance.request_adapter(&wgpu::RequestAdapterOptions { power_preference: power_preference_from_env(), compatible_surface: None, force_fallback_adapter: false }).await;
+    let adapter = match adapter_result {
+        Ok(adapter) => adapter,
+        Err(_) => return MatVecRuntime::blocked(args.backend.clone(), BLOCK_GPU_DEVICE),
+    };
+    let info = adapter.get_info();
+    let device_result = adapter.request_device(&wgpu::DeviceDescriptor {
+        label: Some("ash-basetrain-gpu-39-bounded-matvec-device"),
+        required_features: wgpu::Features::empty(),
+        required_limits: wgpu::Limits::downlevel_defaults(),
+        memory_hints: wgpu::MemoryHints::Performance,
+        ..Default::default()
+    }).await;
+    let (device, queue) = match device_result {
+        Ok(pair) => pair,
+        Err(_) => return MatVecRuntime::blocked_with_info(args.backend.clone(), &info, BLOCK_GPU_DEVICE),
+    };
+    device.push_error_scope(wgpu::ErrorFilter::Validation);
+    let wgsl = wgsl_source();
+    let shader_module = device.create_shader_module(wgpu::ShaderModuleDescriptor { label: Some("ASH_BASETRAIN_GPU_39_BOUNDED_MATVEC_SHADER"), source: wgpu::ShaderSource::Wgsl(Cow::Borrowed(&wgsl)) });
+    let bind_group_layout = device.create_bind_group_layout(&wgpu::BindGroupLayoutDescriptor {
+        label: Some("ASH_BASETRAIN_GPU_39_BOUNDED_MATVEC_BIND_GROUP_LAYOUT"),
+        entries: &[
+            wgpu::BindGroupLayoutEntry { binding: 0, visibility: wgpu::ShaderStages::COMPUTE, ty: wgpu::BindingType::Buffer { ty: wgpu::BufferBindingType::Storage { read_only: true }, has_dynamic_offset: false, min_binding_size: NonZeroU64::new(WEIGHT_BYTES) }, count: None },
+            wgpu::BindGroupLayoutEntry { binding: 1, visibility: wgpu::ShaderStages::COMPUTE, ty: wgpu::BindingType::Buffer { ty: wgpu::BufferBindingType::Storage { read_only: true }, has_dynamic_offset: false, min_binding_size: NonZeroU64::new((INPUT_VECTOR_LEN as u64) * 4) }, count: None },
+            wgpu::BindGroupLayoutEntry { binding: 2, visibility: wgpu::ShaderStages::COMPUTE, ty: wgpu::BindingType::Buffer { ty: wgpu::BufferBindingType::Storage { read_only: false }, has_dynamic_offset: false, min_binding_size: NonZeroU64::new(OUTPUT_BYTES) }, count: None },
+        ],
+    });
+    let pipeline_layout = device.create_pipeline_layout(&wgpu::PipelineLayoutDescriptor { label: Some("ASH_BASETRAIN_GPU_39_BOUNDED_MATVEC_PIPELINE_LAYOUT"), bind_group_layouts: &[&bind_group_layout], push_constant_ranges: &[] });
+    let compute_pipeline = device.create_compute_pipeline(&wgpu::ComputePipelineDescriptor { label: Some("ASH_BASETRAIN_GPU_39_BOUNDED_MATVEC_PIPELINE"), layout: Some(&pipeline_layout), module: &shader_module, entry_point: Some("main"), compilation_options: wgpu::PipelineCompilationOptions::default(), cache: None });
+    let weight_buffer = device.create_buffer(&wgpu::BufferDescriptor { label: Some("ASH_BASETRAIN_GPU_39_SELECTED_ROW_BLOCK_WEIGHT_BUFFER"), size: WEIGHT_BYTES, usage: wgpu::BufferUsages::STORAGE | wgpu::BufferUsages::COPY_DST, mapped_at_creation: false });
+    let input_buffer = device.create_buffer(&wgpu::BufferDescriptor { label: Some("ASH_BASETRAIN_GPU_39_BOUNDED_INPUT_VECTOR_BUFFER"), size: (INPUT_VECTOR_LEN as u64) * 4, usage: wgpu::BufferUsages::STORAGE | wgpu::BufferUsages::COPY_DST, mapped_at_creation: false });
+    let output_buffer = device.create_buffer(&wgpu::BufferDescriptor { label: Some("ASH_BASETRAIN_GPU_39_BOUNDED_OUTPUT_BUFFER"), size: OUTPUT_BYTES, usage: wgpu::BufferUsages::STORAGE | wgpu::BufferUsages::COPY_SRC | wgpu::BufferUsages::COPY_DST, mapped_at_creation: false });
+    let readback_buffer = device.create_buffer(&wgpu::BufferDescriptor { label: Some("ASH_BASETRAIN_GPU_39_BOUNDED_OUTPUT_READBACK_BUFFER"), size: OUTPUT_BYTES, usage: wgpu::BufferUsages::COPY_DST | wgpu::BufferUsages::MAP_READ, mapped_at_creation: false });
+    queue.write_buffer(&weight_buffer, 0, &row_block.weight_bytes);
+    queue.write_buffer(&input_buffer, 0, bytemuck::cast_slice(input_vector));
+    let bind_group = device.create_bind_group(&wgpu::BindGroupDescriptor {
+        label: Some("ASH_BASETRAIN_GPU_39_BOUNDED_MATVEC_BIND_GROUP"),
+        layout: &bind_group_layout,
+        entries: &[
+            wgpu::BindGroupEntry { binding: 0, resource: weight_buffer.as_entire_binding() },
+            wgpu::BindGroupEntry { binding: 1, resource: input_buffer.as_entire_binding() },
+            wgpu::BindGroupEntry { binding: 2, resource: output_buffer.as_entire_binding() },
+        ],
+    });
+    let mut encoder = device.create_command_encoder(&wgpu::CommandEncoderDescriptor { label: Some("ASH_BASETRAIN_GPU_39_BOUNDED_MATVEC_COMMAND_ENCODER") });
+    {
+        let mut pass = encoder.begin_compute_pass(&wgpu::ComputePassDescriptor { label: Some("ASH_BASETRAIN_GPU_39_BOUNDED_MATVEC_COMPUTE_PASS"), timestamp_writes: None });
+        pass.set_pipeline(&compute_pipeline);
+        pass.set_bind_group(0, &bind_group, &[]);
+        pass.dispatch_workgroups(DISPATCH_X, 1, 1);
+    }
+    encoder.copy_buffer_to_buffer(&output_buffer, 0, &readback_buffer, 0, OUTPUT_BYTES);
+    queue.submit(Some(encoder.finish()));
+    let slice = readback_buffer.slice(..);
+    let (sender, receiver) = mpsc::channel();
+    slice.map_async(wgpu::MapMode::Read, move |result| { let _ = sender.send(result); });
+    let _ = device.poll(wgpu::PollType::Wait);
+    let map_status = receiver.recv().map_err(|err| format!("map_async receiver failed: {err}")).and_then(|result| result.map_err(|err| format!("map_async failed: {err}")));
+    let validation_error = device.pop_error_scope().await;
+    match (validation_error, map_status) {
+        (None, Ok(())) => {
+            let mapped = slice.get_mapped_range();
+            let bytes = mapped.to_vec();
+            drop(mapped);
+            readback_buffer.unmap();
+            let gpu_output = bytes.chunks_exact(4).map(|c| f32::from_le_bytes([c[0], c[1], c[2], c[3]])).collect::<Vec<f32>>();
+            MatVecRuntime::pass(args.backend.clone(), &info, gpu_output, bytes.len() as u64)
+        }
+        _ => MatVecRuntime::blocked_with_info(args.backend.clone(), &info, BLOCK_DISPATCH),
+    }
+}
+
+
+
+fn pass_or_block(args: &Args, f38: LoadedReceipt, r37: LoadedReceipt, q37: LoadedReceipt, p37: LoadedReceipt, f37: LoadedReceipt, row_block: RowBlockPayload, cpu: CpuReference, runtime: MatVecRuntime) -> Output {
+    let shape_ok = runtime.gpu_output.len() == args.row_count as usize;
+    let finite_ok = runtime.gpu_output.iter().all(|v| v.is_finite()) && cpu.nan_count == 0 && cpu.inf_count == 0;
+    let parity = compare_outputs(&cpu.output, &runtime.gpu_output);
+    let dispatch_ok = runtime.dispatch_executed && runtime.readback_executed && runtime.status == "PASS";
+    let (pass, code, reason) = match (dispatch_ok, shape_ok, finite_ok, parity.0) {
+        (false, _, _, _) => (false, BLOCK_SLOT_OUTPUT_READBACK, "39 leased slot bounded MatVec GPU dispatch or readback did not complete."),
+        (_, false, _, _) => (false, BLOCK_SHAPE, "39 leased slot bounded MatVec output shape did not match row_count."),
+        (_, _, false, _) => (false, BLOCK_NONFINITE, "39 leased slot bounded MatVec output contained NaN or Inf."),
+        (_, _, _, false) => (false, BLOCK_SLOT_OUTPUT_PARITY, "39 leased slot bounded MatVec GPU output did not match CPU reference."),
+        _ => (true, "none", ""),
+    };
+    Output {
+        status: match pass { true => PASS_STATUS.to_string(), false => code.to_string() },
+        verdict: match pass { true => "PASS".to_string(), false => "BLOCKED".to_string() },
+        pass,
+        blocked_reason_code: code.to_string(),
+        blocked_reason: match pass { true => None, false => Some(reason.to_string()) },
+        f38: Some(f38), r37: Some(r37), q37: Some(q37), p37: Some(p37), f37: Some(f37), row_block: Some(row_block), cpu_reference: Some(cpu), runtime: Some(runtime),
+    }
+}
