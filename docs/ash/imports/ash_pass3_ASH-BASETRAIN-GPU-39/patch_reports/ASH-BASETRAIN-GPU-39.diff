+fn gpu_upload_json(args: &Args, runtime: Option<&MatVecRuntime>) -> Value {
+    json!({
+        "staging_buffer_created": runtime.map(|r| r.staging_buffer_created).unwrap_or(false),
+        "gpu_weight_buffer_created": runtime.map(|r| r.gpu_weight_buffer_created).unwrap_or(false),
