+fn validate_37q_r1(v: &Value) -> Result<(), (&'static str, &'static str)> {
+    let status = str_value(v, "status").unwrap_or("");
+    let summary = v.get("multi_workgroup_reduction_diagnostic_summary").unwrap_or(&Value::Null);
+    match (
+        str_value(v, "patch_id") == Some("ASH-BASETRAIN-GPU-37Q-R1"),
+        bool_value(v, "pass") == Some(true) && str_value(v, "verdict") == Some("PASS") && status.starts_with("PASS_ASH_BASETRAIN_GPU_37Q_R1"),
+        u64_value(summary, "matched_word_count") == Some(32),
+        u64_value(summary, "mismatched_word_count") == Some(0),
+    ) {
+        (false, _, _, _) => Err((BLOCK_37Q_NOT_PASS, "37Q-R1 receipt patch_id was not accepted.")),
+        (_, false, _, _) => Err((BLOCK_37Q_NOT_PASS, "37Q-R1 receipt was not PASS.")),
+        (_, _, false, _) => Err((BLOCK_37Q_SUMMARY, "37Q-R1 matched word count was not 32.")),
+        (_, _, _, false) => Err((BLOCK_37Q_SUMMARY, "37Q-R1 mismatched word count was not zero.")),
+        _ => Ok(()),
+    }
+}
