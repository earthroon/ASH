+fn validate_37r_r2(v: &Value) -> Result<(), (&'static str, &'static str)> {
+    match (
+        str_value(v, "patch_id") == Some("ASH-BASETRAIN-GPU-37R-R2"),
+        bool_value(v, "pass") == Some(true) && str_value(v, "verdict") == Some("PASS"),
+        bool_path(v, &["reduction_parity_matrix", "parity_passed"]) == Some(true),
+        bool_path(v, &["promotion_gate_matrix", "forward_candidate_allowed_next"]) == Some(true),
+    ) {
+        (false, _, _, _) => Err((BLOCK_37R_NOT_PASS, "37R-R2 receipt patch_id was not accepted.")),
+        (_, false, _, _) => Err((BLOCK_37R_NOT_PASS, "37R-R2 receipt was not PASS.")),
+        (_, _, false, _) => Err((BLOCK_37R_PARITY, "37R-R2 parity did not pass.")),
+        (_, _, _, false) => Err((BLOCK_37R_FORWARD_NOT_ALLOWED, "37R-R2 did not allow forward candidate.")),
+        _ => Ok(()),
+    }
+}
