+// 16AI-QW-38G-R3 — Native Forward Stage Map / Executed Path Discovery Seal
+static QW38G_R3_STAGE_MAP: OnceLock<Mutex<BTreeMap<String, usize>>> = OnceLock::new();
+
+fn qw38g_r3_enabled() -> bool {
+    env_flag("ASH_FORWARD_STAGE_MAP") || env_flag("ASH_QW38G_R3_STAGE_MAP")
+}
+
+fn qw38g_r3_verbose() -> bool {
+    env_flag("ASH_FORWARD_STAGE_MAP_VERBOSE") || env_flag("ASH_QW38G_R3_VERBOSE")
+}
+
+fn qw38g_r3_now_ms() -> u128 {
+    SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .map(|d| d.as_millis())
+        .unwrap_or(0)
+}
+
+fn qw38g_r3_stage_map_path() -> String {
+    std::env::var("ASH_FORWARD_STAGE_MAP_OUT")
+        .unwrap_or_else(|_| "workspace/qw38g_r3_forward_stage_map.json".to_string())
+}
+
+fn qw38g_r3_stage_map() -> &'static Mutex<BTreeMap<String, usize>> {
+    QW38G_R3_STAGE_MAP.get_or_init(|| Mutex::new(BTreeMap::new()))
+}
+
+fn qw38g_r3_write_stage_map_locked(map: &BTreeMap<String, usize>) {
+    let path = qw38g_r3_stage_map_path();
+    if let Some(parent) = std::path::Path::new(&path).parent() {
+        let _ = std::fs::create_dir_all(parent);
+    }
+    let get = |name: &str| -> usize { *map.get(name).unwrap_or(&0) };
+    let raw_topk = get("raw_topk_trace_hook") > 0;
+    let hidden_projection = get("hidden_projection_trace_hook") > 0;
+    let forward_hidden = get("NativeWgpuModel::forward_hidden_for_generation_input") > 0;
+    let layerwise = get("layerwise_reserved_trace_hook") > 0;
+    let native_generation = get("NativeWgpuModel::forward_logits_for_generation") > 0
+        || get("NativeWgpuModel::project_last_hidden_to_logits_vocab_atlas") > 0;
+    let actual_traceable_boundary = if layerwise {
+        "layerwise_residual"
+    } else if hidden_projection {
+        "final_hidden_projection"
+    } else if raw_topk {
+        "raw_topk_projection"
+    } else if native_generation {
+        "native_generation"
+    } else {
+        "unknown"
+    };
+    let recommended_next_patch = if layerwise {
+        "16AI-QW-38G-R4_LAYER_RESIDUAL_PROJECTION_TAP"
+    } else {
+        "16AI-QW-38G-R4_GPU_DEBUG_TAP_OR_FORWARD_HOOK_RELOCATION"
+    };
+    let stages = map.iter()
+        .map(|(name, count)| serde_json::json!({"name": name, "count": count}))
+        .collect::<Vec<_>>();
+    let payload = serde_json::json!({
+        "patch_id": "16AI-QW-38G-R3",
+        "status": "PASS_STAGE_MAP",
+        "timestamp_unix_ms": qw38g_r3_now_ms(),
+        "stages": stages,
+        "reachability": {
+            "native_generation_entered": native_generation,
+            "forward_hidden_for_generation_input_reached": forward_hidden,
+            "vocab_atlas_projection_reached": get("vocab_atlas_projection") > 0,
+            "raw_topk_hook_reached": raw_topk,
+            "hidden_projection_hook_reached": hidden_projection,
+            "layerwise_reserved_trace_hook_reached": layerwise,
+            "final_hidden_projection_boundary_reached": hidden_projection,
+            "layerwise_residual_boundary_reached": layerwise
+        },
+        "actual_traceable_boundary": actual_traceable_boundary,
+        "layerwise_trace_possible_from_current_hook": layerwise,
+        "recommended_next_patch": recommended_next_patch,
+        "warning_codes": if layerwise { Vec::<String>::new() } else { vec!["LAYERWISE_TRACE_HOOK_NOT_REACHED".to_string(), "RUST_LAYERWISE_RESIDUAL_UNAVAILABLE".to_string()] },
+    });
+    if let Ok(text) = serde_json::to_string_pretty(&payload) {
+        let _ = std::fs::write(path, text);
+    }
+}
+
+fn qw38g_r3_stage_enter(name: &str, note: impl Into<String>) {
+    if !qw38g_r3_enabled() {
+        return;
+    }
+    let note = note.into();
+    if qw38g_r3_verbose() {
+        eprintln!("[16AI-QW-38G-R3][stage_enter] name={} note={}", name, note);
+    }
+    let map = qw38g_r3_stage_map();
+    if let Ok(mut guard) = map.lock() {
+        *guard.entry(name.to_string()).or_insert(0) += 1;
+        qw38g_r3_write_stage_map_locked(&guard);
+    }
+}
