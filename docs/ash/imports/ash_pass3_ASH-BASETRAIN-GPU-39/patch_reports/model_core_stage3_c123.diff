+    pub fn submit_module_trace_padded_batch(
+        &mut self,
+        batch_index: u64,
+        padded_token_ids: &[u32],
+        request: ModuleTraceTapRequest,
+        sample_ids: Vec<u64>,
+        record_ids: Vec<Option<String>>,
+    ) -> Result<usize> {
+        let target_key = request.target_key.clone();
+        let (expected_in, expected_out) =
+            resolve_runtime_lora_target_module_dims(&self.spec, &target_key)?;
+        ensure!(
+            sample_ids.len() == request.batch_size,
+            "native module trace submit sample_ids mismatch: batch_size={} sample_ids={}",
+            request.batch_size,
+            sample_ids.len(),
+        );
+        ensure!(
+            record_ids.len() == request.batch_size,
+            "native module trace submit record_ids mismatch: batch_size={} record_ids={}",
+            request.batch_size,
+            record_ids.len(),
+        );
+
+        let slot_id = self
+            .trace_ring
+            .try_acquire_idle_slot()
+            .ok_or_else(|| anyhow!("no idle native trace slot available for target_key={}", target_key))?;
+
+        let meta = PendingTraceBatchMeta {
+            batch_index,
+            target_key: target_key.clone(),
+            seq_lens: request.seq_lens.clone(),
+            sample_ids,
+            record_ids,
+            batch_size: request.batch_size,
+            max_seq_len: request.max_seq_len,
+            expected_in,
+            expected_out,
+        };
+        self.trace_ring.slots[slot_id].state = TraceSlotState::Submitted { meta: meta.clone() };
+
+        match self.capture_module_io_native_padded_batch(&request, padded_token_ids) {
+            Ok(captures) => {
+                self.trace_ring.slots[slot_id].state = TraceSlotState::Ready { meta, captures };
+                Ok(slot_id)
+            }
+            Err(err) => {
+                self.trace_ring.slots[slot_id].state = TraceSlotState::Idle;
+                Err(err)
+            }
+        }
+    }
+
+    pub fn try_collect_ready_module_trace(
+        &mut self,
+        slot_id: usize,
+    ) -> Result<Option<(PendingTraceBatchMeta, Vec<CapturedModuleIo>)>> {
+        let slot = self
+            .trace_ring
+            .slots
+            .get_mut(slot_id)
+            .ok_or_else(|| anyhow!("invalid native trace slot id: {}", slot_id))?;
+
+        let prev = std::mem::replace(&mut slot.state, TraceSlotState::Idle);
+        match prev {
+            TraceSlotState::Ready { meta, captures } => Ok(Some((meta, captures))),
+            other => {
+                slot.state = other;
+                Ok(None)
+            }
+        }
+    }
+
+    pub fn try_collect_any_ready_module_trace(
+        &mut self,
+    ) -> Result<Option<(usize, PendingTraceBatchMeta, Vec<CapturedModuleIo>)>> {
+        for slot in &mut self.trace_ring.slots {
+            let prev = std::mem::replace(&mut slot.state, TraceSlotState::Idle);
+            match prev {
+                TraceSlotState::Ready { meta, captures } => {
+                    return Ok(Some((slot.slot_id, meta, captures)));
+                }
+                other => {
+                    slot.state = other;
+                }
+            }
+        }
+        Ok(None)
+    }
