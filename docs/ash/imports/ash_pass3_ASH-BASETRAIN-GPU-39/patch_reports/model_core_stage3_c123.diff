 #[derive(Debug, Clone)]
+pub struct PendingTraceBatchMeta {
+    pub batch_index: u64,
+    pub target_key: String,
+    pub seq_lens: Vec<usize>,
+    pub sample_ids: Vec<u64>,
+    pub record_ids: Vec<Option<String>>,
+    pub batch_size: usize,
+    pub max_seq_len: usize,
+    pub expected_in: usize,
+    pub expected_out: usize,
+}
+
+#[derive(Debug, Clone)]
+pub enum TraceSlotState {
+    Idle,
+    Submitted {
+        meta: PendingTraceBatchMeta,
+    },
+    Ready {
+        meta: PendingTraceBatchMeta,
+        captures: Vec<CapturedModuleIo>,
+    },
+}
+
+#[derive(Debug, Clone)]
+pub struct NativeTraceSlot {
+    pub slot_id: usize,
+    pub state: TraceSlotState,
+}
+
+#[derive(Debug, Clone)]
+pub struct NativeTraceRing {
+    pub slots: Vec<NativeTraceSlot>,
+    pub next_submit_slot: usize,
+}
+
+impl NativeTraceRing {
+    pub fn new(slot_count: usize) -> Self {
+        let count = slot_count.max(2);
+        let mut slots = Vec::with_capacity(count);
+        for slot_id in 0..count {
+            slots.push(NativeTraceSlot {
+                slot_id,
+                state: TraceSlotState::Idle,
+            });
+        }
+        Self {
+            slots,
+            next_submit_slot: 0,
+        }
+    }
+
+    pub fn try_acquire_idle_slot(&mut self) -> Option<usize> {
+        let len = self.slots.len();
+        for offset in 0..len {
+            let idx = (self.next_submit_slot + offset) % len;
+            if matches!(self.slots[idx].state, TraceSlotState::Idle) {
+                self.next_submit_slot = (idx + 1) % len;
+                return Some(idx);
+            }
+        }
+        None
+    }
+}
