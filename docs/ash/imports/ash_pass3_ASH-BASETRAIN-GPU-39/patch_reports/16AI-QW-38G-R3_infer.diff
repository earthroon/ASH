+
+fn q38g_r3_heartbeat(stage: &str, extra: serde_json::Value) {
+    let text = serde_json::to_string(&extra).unwrap_or_else(|_| "{}".to_string());
+    eprintln!("[16AI-QW-38G-R3][stage_enter] name={} note={}", stage, text);
+}
+
+fn q38g_r3_write_receipt(status: &str, last_stage: &str, extra: serde_json::Value) {
+    let stage_map_path = q38g_r3_stage_map_path();
+    let receipt_path = q38g_r3_receipt_path();
+    let (layer_trace_path, _summary_path, _r2_receipt_path, raw_topk_path, hidden_proj_path) =
+        q38g_r2_receipt_paths();
+    let stage_map_written = q38g_r2_path_written(&stage_map_path);
+    let raw_topk_trace_written = q38g_r2_path_written(&raw_topk_path);
+    let hidden_projection_trace_written = q38g_r2_path_written(&hidden_proj_path);
+    let layerwise_trace_written = q38g_r2_path_written(&layer_trace_path);
+    let warning_codes = if layerwise_trace_written {
+        Vec::<String>::new()
+    } else {
+        vec!["LAYERWISE_TRACE_HOOK_NOT_REACHED".to_string()]
+    };
+    let payload = serde_json::json!({
+        "patch_id": "16AI-QW-38G-R3",
+        "status": status,
+        "last_stage": last_stage,
+        "timestamp_unix_ms": current_unix_ms(),
+        "stage_map_path": stage_map_path,
+        "stage_map_written": stage_map_written,
+        "receipt_path": receipt_path,
+        "receipt_written": true,
+        "raw_topk_trace_path": raw_topk_path,
+        "raw_topk_trace_written": raw_topk_trace_written,
+        "hidden_projection_trace_path": hidden_proj_path,
+        "hidden_projection_trace_written": hidden_projection_trace_written,
+        "layerwise_trace_jsonl_path": layer_trace_path,
+        "layerwise_trace_written": layerwise_trace_written,
+        "actual_traceable_boundary": if layerwise_trace_written { "layerwise_residual" } else if hidden_projection_trace_written { "final_hidden_projection" } else if raw_topk_trace_written { "raw_topk_projection" } else { "unknown" },
+        "layerwise_trace_possible_from_current_hook": layerwise_trace_written,
+        "recommended_next_patch": if layerwise_trace_written { "16AI-QW-38G-R4_LAYER_RESIDUAL_PROJECTION_TAP" } else { "16AI-QW-38G-R4_GPU_DEBUG_TAP_OR_FORWARD_HOOK_RELOCATION" },
+        "warning_codes": warning_codes,
+        "extra": extra,
+    });
+    eprintln!("[16AI-QW-38G-R3][receipt] status={} last_stage={} path={}", status, last_stage, receipt_path);
+    q38g_r2_write_json(&receipt_path, &payload);
+}
