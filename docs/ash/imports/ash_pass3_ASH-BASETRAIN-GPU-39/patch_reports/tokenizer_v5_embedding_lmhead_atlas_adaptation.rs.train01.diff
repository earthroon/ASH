+fn resolve_focus_pieces(vocab: Option<&Value>) -> Vec<QwTokTrain01FocusTokenResolution> {
+    default_focus_tokens()
+        .into_iter()
+        .map(|(token_id, expected_piece, reason)| {
+            let resolved_piece = vocab.and_then(|v| piece_for_token_id(v, token_id));
+            let piece_match = resolved_piece.as_ref().map(|p| p == expected_piece);
+            QwTokTrain01FocusTokenResolution {
+                token_id,
+                expected_piece: expected_piece.to_string(),
+                resolved_piece,
+                piece_match,
+                reason: reason.to_string(),
+            }
+        })
+        .collect()
+}
+
+fn piece_for_token_id(vocab: &Value, token_id: usize) -> Option<String> {
+    if let Some(arr) = vocab.as_array() {
+        if let Some(item) = arr.get(token_id) {
+            if let Some(s) = item.as_str() { return Some(s.to_string()); }
+            for key in ["piece", "token", "text", "surface"] {
+                if let Some(s) = item.get(key).and_then(Value::as_str) { return Some(s.to_string()); }
+            }
+        }
+        for item in arr {
+            let id = item.get("id").or_else(|| item.get("token_id")).and_then(Value::as_u64)? as usize;
+            if id == token_id {
+                for key in ["piece", "token", "text", "surface"] {
+                    if let Some(s) = item.get(key).and_then(Value::as_str) { return Some(s.to_string()); }
+                }
+            }
+        }
+    }
+    None
+}
