+fn read_model_spec_ssot(cfg: &QwTokTrain01Config) -> QwTokTrain01ModelSpecSsot {
+    let path = Path::new(&cfg.model_spec_path);
+    let exists = path.exists();
+    let mut out = QwTokTrain01ModelSpecSsot {
+        path: cfg.model_spec_path.clone(),
+        exists,
+        readable: false,
+        model_spec_id: None,
+        model_name: None,
+        vocab_size: None,
+        hidden_size: None,
+        expected_model_spec_id: cfg.expected_model_spec_id.clone(),
+        expected_vocab_size: cfg.expected_vocab_size,
+        expected_hidden_size: cfg.expected_hidden_size,
+        model_spec_id_match: false,
+        vocab_size_match: false,
+        hidden_size_match: false,
+        v4_residue_detected: false,
+        failures: Vec::new(),
+        warnings: Vec::new(),
+    };
+    if !exists {
+        out.failures.push("model_spec_missing".to_string());
+        return out;
+    }
+    let text = match fs::read_to_string(path) {
+        Ok(t) => t,
+        Err(err) => {
+            out.failures.push(format!("model_spec_unreadable:{err}"));
+            return out;
+        }
+    };
+    out.readable = true;
+    out.v4_residue_detected = text.contains("1p1b_v4") || text.contains("V4") || text.contains("56832");
+    match text.parse::<toml::Value>() {
+        Ok(value) => {
+            out.model_spec_id = value.get("model_spec_id").and_then(|v| v.as_str()).map(str::to_string);
+            out.model_name = value.get("model_name").and_then(|v| v.as_str()).map(str::to_string);
+            out.vocab_size = value.get("model").and_then(|m| m.get("vocab_size")).and_then(|v| v.as_integer()).or_else(|| value.get("vocab_size").and_then(|v| v.as_integer())).map(|v| v as usize);
+            out.hidden_size = value.get("model").and_then(|m| m.get("hidden_size")).and_then(|v| v.as_integer()).or_else(|| value.get("hidden_size").and_then(|v| v.as_integer())).map(|v| v as usize);
+        }
+        Err(err) => out.failures.push(format!("model_spec_toml_parse_failed:{err}")),
+    }
+    out.model_spec_id_match = out.model_spec_id.as_deref() == Some(cfg.expected_model_spec_id.as_str());
+    out.vocab_size_match = out.vocab_size == Some(cfg.expected_vocab_size);
+    out.hidden_size_match = out.hidden_size == Some(cfg.expected_hidden_size);
+    if !out.model_spec_id_match { out.failures.push("model_spec_id_mismatch".to_string()); }
+    if !out.vocab_size_match { out.failures.push("vocab_size_mismatch".to_string()); }
+    if !out.hidden_size_match { out.failures.push("hidden_size_mismatch".to_string()); }
+    if out.v4_residue_detected { out.warnings.push("v4_residue_detected_in_model_spec_text".to_string()); }
+    out
+}
