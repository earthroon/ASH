+pub fn qw_tok_train01_config_from_args(args: &[String]) -> QwTokTrain01Config {
+    let mut cfg = QwTokTrain01Config::default();
+    let mut iter = args.iter();
+    while let Some(arg) = iter.next() {
+        match arg.as_str() {
+            "--model-spec" => if let Some(v) = iter.next() { cfg.model_spec_path = v.clone(); },
+            "--tokenizer" | "--tokenizer-manifest" => if let Some(v) = iter.next() { cfg.tokenizer_manifest_path = v.clone(); },
+            "--checkpoint" => if let Some(v) = iter.next() { cfg.checkpoint_path = v.clone(); },
+            "--corpus" => if let Some(v) = iter.next() { cfg.corpus_path = v.clone(); },
+            "--candidate-out" | "--out-checkpoint" => if let Some(v) = iter.next() { cfg.candidate_checkpoint_path = v.clone(); },
+            "--report-out" | "--out" => if let Some(v) = iter.next() { cfg.report_out_path = v.clone(); },
+            "--dry-run" => cfg.dry_run = true,
+            "--train-lm-head-only" => {
+                cfg.train_lm_head_only = true;
+                cfg.dry_run = false;
+            },
+            "--enable-embedding-row-calibration" => cfg.enable_embedding_row_calibration = true,
+            "--approve-write-new-checkpoint" => cfg.approve_write_new_checkpoint = true,
+            "--allow-transformer-block-update" => cfg.allow_transformer_block_update = true,
+            "--max-steps" => if let Some(v) = iter.next() { cfg.max_steps = v.parse().unwrap_or(cfg.max_steps); },
+            "--seq-len" => if let Some(v) = iter.next() { cfg.seq_len = v.parse().unwrap_or(cfg.seq_len); },
+            "--micro-batch" => if let Some(v) = iter.next() { cfg.micro_batch = v.parse().unwrap_or(cfg.micro_batch); },
+            "--grad-accum" => if let Some(v) = iter.next() { cfg.grad_accum = v.parse().unwrap_or(cfg.grad_accum); },
+            "--vocab-tile-size" => if let Some(v) = iter.next() { cfg.vocab_tile_size = v.parse().unwrap_or(cfg.vocab_tile_size); },
+            "--hidden-tile-size" => if let Some(v) = iter.next() { cfg.hidden_tile_size = v.parse().unwrap_or(cfg.hidden_tile_size); },
+            _ => {}
+        }
+    }
+    cfg
+}
