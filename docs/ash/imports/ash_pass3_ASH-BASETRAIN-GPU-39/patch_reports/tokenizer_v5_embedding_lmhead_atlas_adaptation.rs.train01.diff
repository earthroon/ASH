+pub fn run_qw_tok_train01_embedding_lmhead_atlas_adaptation(
+    cfg: QwTokTrain01Config,
+) -> Result<QwTokTrain01Report> {
+    let model_spec_ssot = read_model_spec_ssot(&cfg);
+    let tokenizer_ssot = read_tokenizer_ssot(&cfg);
+    let tensor_key_probe = read_safetensors_tensor_probe(&cfg);
+    let repeat_focus_row_probe = build_repeat_focus_row_probe();
+    let lmhead_atlas_training_plan = build_training_plan(&cfg, &tensor_key_probe);
+    let training_receipt = build_training_receipt(&cfg);
+    let no_transformer_update_receipt = build_no_transformer_update_receipt(&cfg);
+    let checkpoint_write_receipt = build_checkpoint_write_receipt(&cfg, &training_receipt);
+    let before_after_smoke_matrix = build_smoke_matrix(&cfg);
+
+    let mut failures = Vec::new();
+    let mut warnings = Vec::new();
+    failures.extend(model_spec_ssot.failures.clone());
+    failures.extend(tokenizer_ssot.failures.clone());
+    failures.extend(tensor_key_probe.failures.clone());
+    warnings.extend(model_spec_ssot.warnings.clone());
+    warnings.extend(tokenizer_ssot.warnings.clone());
+    warnings.extend(tensor_key_probe.warnings.clone());
+
+    if cfg.allow_transformer_block_update {
+        failures.push("allow_transformer_block_update must remain false for QW-TOK-TRAIN-01".to_string());
+    }
+
+    let status = if !failures.is_empty() {
+        "FAIL_QW_TOK_TRAIN01_PRECONDITION".to_string()
+    } else if cfg.train_lm_head_only {
+        "PARTIAL_QW_TOK_TRAIN01_GPU_ATLAS_UPDATE_PENDING_NO_CHECKPOINT_WRITE".to_string()
+    } else {
+        "PASS_QW_TOK_TRAIN01_DRY_RUN_PLAN_ONLY".to_string()
+    };
+
+    Ok(QwTokTrain01Report {
+        patch_id: QW_TOK_TRAIN01_PATCH_ID.to_string(),
+        title: QW_TOK_TRAIN01_TITLE.to_string(),
+        status,
+        model_spec_ssot,
+        tokenizer_ssot,
+        tensor_key_probe,
+        lmhead_atlas_training_plan,
+        repeat_focus_row_probe,
+        training_receipt,
+        no_transformer_update_receipt,
+        checkpoint_write_receipt,
+        before_after_smoke_matrix,
+        failures,
+        warnings,
+    })
+}
