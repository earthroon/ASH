+fn read_tokenizer_ssot(cfg: &QwTokTrain01Config) -> QwTokTrain01TokenizerSsot {
+    let path = Path::new(&cfg.tokenizer_manifest_path);
+    let exists = path.exists();
+    let mut out = QwTokTrain01TokenizerSsot {
+        path: cfg.tokenizer_manifest_path.clone(),
+        exists,
+        readable: false,
+        tokenizer_id: None,
+        manifest_id: None,
+        tokenizer_spec_id: None,
+        hashes_manifest_hash: None,
+        vocab_hash: None,
+        sentencepiece_model_hash: None,
+        sentencepiece_vocab_hash: None,
+        top_level_manifest_hash_present: false,
+        vocab_len: None,
+        vocab_size_match: false,
+        focus_piece_resolution: Vec::new(),
+        failures: Vec::new(),
+        warnings: Vec::new(),
+    };
+    if !exists {
+        out.failures.push("tokenizer_manifest_missing".to_string());
+        return out;
+    }
+    let text = match fs::read_to_string(path) {
+        Ok(t) => t,
+        Err(err) => {
+            out.failures.push(format!("tokenizer_manifest_unreadable:{err}"));
+            return out;
+        }
+    };
+    out.readable = true;
+    let value: Value = match serde_json::from_str(&text) {
+        Ok(v) => v,
+        Err(err) => {
+            out.failures.push(format!("tokenizer_manifest_json_parse_failed:{err}"));
+            return out;
+        }
+    };
+    out.top_level_manifest_hash_present = value.get("manifest_hash").is_some();
+    if out.top_level_manifest_hash_present {
+        out.failures.push("top_level_manifest_hash_present".to_string());
+    }
+    out.tokenizer_id = value.get("tokenizer_id").and_then(Value::as_str).map(str::to_string);
+    out.manifest_id = value.get("manifest_id").and_then(Value::as_str).map(str::to_string);
+    out.tokenizer_spec_id = value.get("tokenizer_spec_id").and_then(Value::as_str).map(str::to_string);
+    if let Some(hashes) = value.get("hashes") {
+        out.hashes_manifest_hash = hashes.get("manifest_hash").and_then(Value::as_str).map(str::to_string);
+        out.vocab_hash = hashes.get("vocab_hash").and_then(Value::as_str).map(str::to_string);
+        out.sentencepiece_model_hash = hashes.get("sentencepiece_model_hash").and_then(Value::as_str).map(str::to_string);
+        out.sentencepiece_vocab_hash = hashes.get("sentencepiece_vocab_hash").and_then(Value::as_str).map(str::to_string);
+    }
+    out.vocab_len = value.get("vocab").and_then(Value::as_array).map(|arr| arr.len());
+    out.vocab_size_match = out.vocab_len == Some(cfg.expected_vocab_size);
+    if !out.vocab_size_match {
+        out.warnings.push("tokenizer_vocab_len_unavailable_or_mismatch".to_string());
+    }
+    out.focus_piece_resolution = resolve_focus_pieces(value.get("vocab"));
+    out
+}
