+fn read_safetensors_tensor_probe(cfg: &QwTokTrain01Config) -> QwTokTrain01TensorKeyProbeReceipt {
+    let path = Path::new(&cfg.checkpoint_path);
+    let exists = path.exists();
+    let mut out = QwTokTrain01TensorKeyProbeReceipt {
+        checkpoint_path: cfg.checkpoint_path.clone(),
+        exists,
+        readable: false,
+        file_size_bytes: None,
+        header_length_bytes: None,
+        tensor_key_count: 0,
+        tensor_keys_first_32: Vec::new(),
+        embedding_key: None,
+        lm_head_key: None,
+        embedding_shape: None,
+        lm_head_shape: None,
+        embedding_lmhead_tied: None,
+        vocab_size_match: false,
+        hidden_size_match: false,
+        tensor_payload_loaded: false,
+        tensor_payload_decoded: false,
+        tensor_infos: Vec::new(),
+        failures: Vec::new(),
+        warnings: Vec::new(),
+    };
+    if !exists {
+        out.failures.push("checkpoint_missing".to_string());
+        return out;
+    }
+    let mut file = match File::open(path) {
+        Ok(f) => f,
+        Err(err) => {
+            out.failures.push(format!("checkpoint_unreadable:{err}"));
+            return out;
+        }
+    };
+    out.readable = true;
+    out.file_size_bytes = file.metadata().ok().map(|m| m.len());
+    let mut len_buf = [0u8; 8];
+    if let Err(err) = file.read_exact(&mut len_buf) {
+        out.failures.push(format!("safetensors_header_len_read_failed:{err}"));
+        return out;
+    }
+    let header_len = u64::from_le_bytes(len_buf);
+    out.header_length_bytes = Some(header_len);
+    let mut header_bytes = vec![0u8; header_len as usize];
+    if let Err(err) = file.read_exact(&mut header_bytes) {
+        out.failures.push(format!("safetensors_header_read_failed:{err}"));
+        return out;
+    }
+    let header: Value = match serde_json::from_slice(&header_bytes) {
+        Ok(v) => v,
+        Err(err) => {
+            out.failures.push(format!("safetensors_header_json_parse_failed:{err}"));
+            return out;
+        }
+    };
+    let obj = match header.as_object() {
+        Some(o) => o,
+        None => {
+            out.failures.push("safetensors_header_not_object".to_string());
+            return out;
+        }
+    };
+
+    let mut infos = Vec::new();
+    for (key, value) in obj {
+        if key == "__metadata__" { continue; }
+        let shape = value.get("shape").and_then(Value::as_array)
+            .map(|arr| arr.iter().filter_map(|v| v.as_u64().map(|n| n as usize)).collect::<Vec<_>>())
+            .unwrap_or_default();
+        let dtype = value.get("dtype").and_then(Value::as_str).map(str::to_string);
+        let data_offsets = value.get("data_offsets").and_then(Value::as_array).and_then(|arr| {
+            if arr.len() == 2 {
+                Some([arr[0].as_u64()?, arr[1].as_u64()?])
+            } else { None }
+        });
+        let byte_len = data_offsets.map(|o| o[1].saturating_sub(o[0]));
+        let lower = key.to_lowercase();
+        let shape_match = shape.len() == 2 && shape[0] == cfg.expected_vocab_size && shape[1] == cfg.expected_hidden_size;
+        let is_lm_head_candidate = shape_match && (lower.contains("lm_head") || lower.contains("output") || lower.contains("head"));
+        let is_embedding_candidate = shape_match && (lower.contains("embed") || lower.contains("tok_embeddings") || lower.contains("wte"));
+        infos.push(QwTokTrain01TensorInfo { key: key.clone(), dtype, shape, data_offsets, byte_len, is_embedding_candidate, is_lm_head_candidate });
+    }
+    infos.sort_by(|a, b| a.key.cmp(&b.key));
+    out.tensor_key_count = infos.len();
+    out.tensor_keys_first_32 = infos.iter().take(32).map(|i| i.key.clone()).collect();
+    out.lm_head_key = infos.iter().find(|i| i.is_lm_head_candidate).map(|i| i.key.clone());
+    out.embedding_key = infos.iter().find(|i| i.is_embedding_candidate).map(|i| i.key.clone());
+    out.lm_head_shape = out.lm_head_key.as_ref().and_then(|k| infos.iter().find(|i| &i.key == k).map(|i| i.shape.clone()));
+    out.embedding_shape = out.embedding_key.as_ref().and_then(|k| infos.iter().find(|i| &i.key == k).map(|i| i.shape.clone()));
+    out.embedding_lmhead_tied = match (&out.embedding_key, &out.lm_head_key) {
+        (Some(a), Some(b)) => Some(a == b),
+        _ => None,
+    };
+    out.vocab_size_match = out.lm_head_shape.as_ref().map(|s| s.first() == Some(&cfg.expected_vocab_size)).unwrap_or(false)
+        && out.embedding_shape.as_ref().map(|s| s.first() == Some(&cfg.expected_vocab_size)).unwrap_or(false);
+    out.hidden_size_match = out.lm_head_shape.as_ref().map(|s| s.get(1) == Some(&cfg.expected_hidden_size)).unwrap_or(false)
+        && out.embedding_shape.as_ref().map(|s| s.get(1) == Some(&cfg.expected_hidden_size)).unwrap_or(false);
+    if out.lm_head_key.is_none() { out.failures.push("lm_head_tensor_key_not_found".to_string()); }
+    if out.embedding_key.is_none() { out.failures.push("embedding_tensor_key_not_found".to_string()); }
+    if !out.vocab_size_match { out.failures.push("embedding_or_lm_head_vocab_size_mismatch".to_string()); }
+    if !out.hidden_size_match { out.failures.push("embedding_or_lm_head_hidden_size_mismatch".to_string()); }
+    out.tensor_infos = infos;
+    let _ = file.seek(SeekFrom::Current(0));
+    out
+}
