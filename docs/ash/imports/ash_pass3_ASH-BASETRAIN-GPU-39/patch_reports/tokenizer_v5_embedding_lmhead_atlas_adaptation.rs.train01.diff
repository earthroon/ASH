+fn build_training_plan(cfg: &QwTokTrain01Config, probe: &QwTokTrain01TensorKeyProbeReceipt) -> QwTokTrain01AtlasTrainingPlan {
+    let vocab_tile_count = div_ceil(cfg.expected_vocab_size, cfg.vocab_tile_size.max(1));
+    let hidden_tile_count = div_ceil(cfg.expected_hidden_size, cfg.hidden_tile_size.max(1));
+    QwTokTrain01AtlasTrainingPlan {
+        backend_target: "Rust + WebGPU/WGPU atlas micro-training".to_string(),
+        memory_profile: "lowmem_10gb_guarded".to_string(),
+        train_lm_head_only_requested: cfg.train_lm_head_only,
+        dry_run: cfg.dry_run || !cfg.train_lm_head_only,
+        max_steps: cfg.max_steps,
+        seq_len: cfg.seq_len,
+        micro_batch: cfg.micro_batch,
+        grad_accum: cfg.grad_accum,
+        vocab_tile_size: cfg.vocab_tile_size,
+        hidden_tile_size: cfg.hidden_tile_size,
+        vocab_tile_count,
+        hidden_tile_count,
+        optimizer: "SGD_or_shard_local_AdamW_candidate_no_state_created_in_train01_bake".to_string(),
+        precision_policy: "f16_weights_f32_accumulate_candidate".to_string(),
+        update_scope: if cfg.train_lm_head_only { vec!["lm_head.weight".to_string()] } else { vec!["plan_only".to_string()] },
+        frozen_scope: vec![
+            "transformer.blocks.*".to_string(),
+            "attention.qkv_o".to_string(),
+            "ffn.gate_up_down".to_string(),
+            "norms".to_string(),
+            "rotary".to_string(),
+        ],
+        corpus_path: cfg.corpus_path.clone(),
+        corpus_exists: Path::new(&cfg.corpus_path).exists(),
+        gpu_update_kernel_status: "PENDING_NOT_EXECUTED_BY_TRAIN01_BAKE".to_string(),
+        execution_policy: if probe.failures.is_empty() { "probe_passed_training_plan_emitted".to_string() } else { "probe_failed_training_blocked".to_string() },
+    }
+}
