+// 16AI-QW-38D — Hidden State to Reserved Row Projection Audit / Final Norm Direction Seal
+static QW38D_HIDDEN_PROJECTION_STEP: AtomicUsize = AtomicUsize::new(0);
+
+fn qw38d_l2_norm(values: &[f32]) -> f32 {
+    values
+        .iter()
+        .map(|v| (*v as f64) * (*v as f64))
+        .sum::<f64>()
+        .sqrt() as f32
+}
+
+fn qw38d_dot(a: &[f32], b: &[f32]) -> f32 {
+    a.iter()
+        .zip(b.iter())
+        .map(|(x, y)| (*x as f64) * (*y as f64))
+        .sum::<f64>() as f32
+}
+
+fn qw38d_cosine(dot: f32, a_norm: f32, b_norm: f32) -> Option<f32> {
+    if a_norm.is_finite() && b_norm.is_finite() && a_norm > 0.0 && b_norm > 0.0 {
+        Some(dot / (a_norm * b_norm))
+    } else {
+        None
+    }
+}
+
+fn qw38d_token_row_from_atlas(atlas: &NativeVocabAtlas, token_id: usize) -> Option<Vec<f32>> {
+    let tile = atlas
+        .tiles
+        .iter()
+        .find(|tile| token_id >= tile.token_start && token_id < tile.token_start + tile.token_len)?;
+    let local = token_id.saturating_sub(tile.token_start);
+    let tile_rows = tile
+        .weight
+        .clone()
+        .into_data()
+        .to_vec::<f32>()
+        .ok()?;
+    let start = local.checked_mul(atlas.hidden_size)?;
+    let end = start.checked_add(atlas.hidden_size)?;
+    if end <= tile_rows.len() {
+        Some(tile_rows[start..end].to_vec())
+    } else {
+        None
+    }
+}
+
+fn qw38d_projection_metric(
+    token_id: usize,
+    logit: Option<f32>,
+    hidden_vec: &[f32],
+    hidden_norm: f32,
+    atlas: &NativeVocabAtlas,
+    meta: &Qw38ATokenMeta,
+) -> serde_json::Value {
+    if let Some(row) = qw38d_token_row_from_atlas(atlas, token_id) {
+        let row_norm = qw38d_l2_norm(&row);
+        let dot = qw38d_dot(hidden_vec, &row);
+        let cosine = qw38d_cosine(dot, hidden_norm, row_norm);
+        serde_json::json!({
+            "token_id": token_id,
+            "piece": qw38a_piece(meta, token_id),
+            "is_reserved": qw38a_is_reserved(meta, token_id),
+            "logit": logit,
+            "dot": dot,
+            "cosine": cosine,
+            "lm_head_row_norm": row_norm,
+            "hidden_norm": hidden_norm,
+        })
+    } else {
+        serde_json::json!({
+            "token_id": token_id,
+            "piece": qw38a_piece(meta, token_id),
+            "is_reserved": qw38a_is_reserved(meta, token_id),
+            "logit": logit,
+            "dot": null,
+            "cosine": null,
+            "lm_head_row_norm": null,
+            "hidden_norm": hidden_norm,
+            "warning": "LM_HEAD_ROW_UNAVAILABLE",
+        })
+    }
+}
