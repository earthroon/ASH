--- /dev/null	2026-06-04 03:59:11.999036156 +0000
+++ crates/model_core/src/bin/qw_tok_train01_embedding_lmhead_atlas_adapt.rs	2026-06-04 04:02:11.261027873 +0000
@@ -0,0 +1,27 @@
+use model_core::{
+    qw_tok_train01_config_from_args,
+    run_qw_tok_train01_embedding_lmhead_atlas_adaptation,
+    write_qw_tok_train01_artifacts,
+};
+use std::{env, path::Path};
+
+fn main() {
+    let args: Vec<String> = env::args().skip(1).collect();
+    let cfg = qw_tok_train01_config_from_args(&args);
+    match run_qw_tok_train01_embedding_lmhead_atlas_adaptation(cfg) {
+        Ok(report) => {
+            if let Err(err) = write_qw_tok_train01_artifacts(Path::new("."), &report) {
+                eprintln!("failed to write QW-TOK-TRAIN-01 artifacts: {}", err);
+                std::process::exit(2);
+            }
+            println!("{}", report.status);
+            if report.status.starts_with("FAIL_") {
+                std::process::exit(1);
+            }
+        }
+        Err(err) => {
+            eprintln!("QW-TOK-TRAIN-01 embedding/lm_head atlas adaptation failed: {}", err);
+            std::process::exit(2);
+        }
+    }
+}
