+fn capture_module_from_native_hidden(
+    target_key: &str,
+    expected_in: usize,
+    expected_out: usize,
+    lengths: &[usize],
+    input: Tensor<NativeInferenceBackend, 3>,
+    output: Tensor<NativeInferenceBackend, 3>,
+) -> Result<Vec<CapturedModuleIo>> {
+    let [batch, seq, input_dim] = input.dims();
+    let [out_batch, out_seq, output_dim] = output.dims();
+    ensure!(
+        batch == out_batch && seq == out_seq,
+        "native module-local trace batch/seq mismatch: target_key={} input=[{}, {}, {}] output=[{}, {}, {}]",
+        target_key,
+        batch,
+        seq,
+        input_dim,
+        out_batch,
+        out_seq,
+        output_dim,
+    );
+    ensure!(
+        lengths.len() == batch,
+        "native module-local trace lengths mismatch: target_key={} batch={} lengths={}",
+        target_key,
+        batch,
+        lengths.len(),
+    );
+    ensure!(
+        input_dim == expected_in,
+        "native module-local trace input dim mismatch: target_key={} expected_in={} actual_in={}",
+        target_key,
+        expected_in,
+        input_dim,
+    );
+    ensure!(
+        output_dim == expected_out,
+        "native module-local trace output dim mismatch: target_key={} expected_out={} actual_out={}",
+        target_key,
+        expected_out,
+        output_dim,
+    );
+
+    let flat_input = input
+        .into_data()
+        .to_vec::<f32>()
+        .map_err(|err| anyhow!("failed to materialize native module trace input: {err}"))?;
+    let flat_output = output
+        .into_data()
+        .to_vec::<f32>()
+        .map_err(|err| anyhow!("failed to materialize native module trace output: {err}"))?;
+
+    let mut captures = Vec::with_capacity(batch);
+    for (batch_idx, &seq_len) in lengths.iter().enumerate() {
+        ensure!(
+            seq_len <= seq,
+            "native module-local trace seq len exceeds padded seq: target_key={} batch_idx={} seq_len={} padded_seq={}",
+            target_key,
+            batch_idx,
+            seq_len,
+            seq,
+        );
+        let mut module_input = Vec::with_capacity(seq_len * input_dim);
+        let mut module_output = Vec::with_capacity(seq_len * output_dim);
+        for token_idx in 0..seq_len {
+            let in_start = ((batch_idx * seq) + token_idx) * input_dim;
+            let in_end = in_start + input_dim;
+            module_input.extend_from_slice(&flat_input[in_start..in_end]);
+            let out_start = ((batch_idx * seq) + token_idx) * output_dim;
+            let out_end = out_start + output_dim;
+            module_output.extend_from_slice(&flat_output[out_start..out_end]);
+        }
+        captures.push(CapturedModuleIo {
+            target_key: target_key.to_string(),
+            input_dim,
+            output_dim,
+            seq_len,
+            module_input,
+            module_output,
+        });
+    }
+    Ok(captures)
+}
