 impl NativeWgpuModel {
+    pub fn capture_module_io_native_padded_batch(
+        &self,
+        request: &ModuleTraceTapRequest,
+        token_ids: &[u32],
+    ) -> Result<Vec<CapturedModuleIo>> {
+        let target_key = request.target_key.as_str();
+        let (expected_in, expected_out) = resolve_runtime_lora_target_module_dims(&self.spec, target_key)?;
+        let parts: Vec<&str> = target_key.split('.').collect();
+        if parts.len() != 4 || parts[0] != "layers" {
+            bail!("unsupported native module-local target_key format: {}", target_key);
+        }
+        let layer_idx: usize = parts[1]
+            .parse()
+            .map_err(|_| anyhow!("invalid native module-local layer index in target_key: {}", target_key))?;
+        let suffix = format!("{}.{}", parts[2], parts[3]);
+        if !matches!(suffix.as_str(), "attn.q_proj" | "attn.o_proj" | "ffn.up_proj") {
+            bail!(
+                "native module-local trace currently supports attn.q_proj, attn.o_proj, and ffn.up_proj only: target_key={} expected_in={} expected_out={}",
+                target_key,
+                expected_in,
+                expected_out,
+            );
+        }
+
+        if request.batch_size == 0 || request.max_seq_len == 0 {
+            return Ok((0..request.batch_size)
+                .map(|_| CapturedModuleIo {
+                    target_key: target_key.to_string(),
+                    input_dim: expected_in,
+                    output_dim: expected_out,
+                    seq_len: 0,
+                    module_input: Vec::new(),
+                    module_output: Vec::new(),
+                })
+                .collect());
+        }
+
+        ensure!(
+            request.seq_lens.len() == request.batch_size,
+            "native module-local trace request lengths mismatch: batch_size={} seq_lens={}",
+            request.batch_size,
+            request.seq_lens.len(),
+        );
+        ensure!(
+            token_ids.len() == request.batch_size * request.max_seq_len,
+            "native module-local padded token buffer mismatch: batch_size={} max_seq_len={} token_ids_len={} expected={}",
+            request.batch_size,
+            request.max_seq_len,
+            token_ids.len(),
+            request.batch_size * request.max_seq_len,
+        );
+
+        let input = Tensor::<NativeInferenceBackend, 2, Int>::from_data(
+            TensorData::new(
+                token_ids.to_vec(),
+                [request.batch_size, request.max_seq_len],
+            ),
+            &self.device,
+        );
+
+        let mut x = self.model.embed(input);
+        let active_loras = self.active_attached_loras();
+
+        for (idx, layer) in self.model.layers.iter().enumerate() {
+            let residual = x.clone();
+            let normed = layer.input_norm.forward(x);
+            let q = layer.q_proj.forward(normed.clone(), &active_loras, &[]);
+            if idx == layer_idx && suffix == "attn.q_proj" {
+                return capture_module_from_native_hidden(
+                    target_key,
+                    expected_in,
+                    expected_out,
+                    &request.seq_lens,
+                    normed,
+                    q,
+                );
+            }
+
+            let k = layer.k_proj.forward(normed.clone(), &active_loras, &[]);
+            let v = layer.v_proj.forward(normed, &active_loras, &[]);
+            let [batch, seq, hidden] = q.dims();
+            let heads = layer.num_heads.max(1);
+            let head_dim = layer.head_dim.max(1);
+            let kv_hidden = k.dims()[2];
+            let kv_heads = if kv_hidden >= head_dim {
+                (kv_hidden / head_dim).max(1)
+            } else {
+                layer.num_kv_heads.max(1)
+            };
+            let q = q.reshape([batch, seq, heads, head_dim]).swap_dims(1, 2);
+            let k_cache = k.reshape([batch, seq, kv_heads, head_dim]).swap_dims(1, 2);
+            let v_cache = v.reshape([batch, seq, kv_heads, head_dim]).swap_dims(1, 2);
+            let ctx = match self.try_grouped_query_attention_via_atlas(
+                q.clone(),
+                k_cache.clone(),
+                v_cache.clone(),
+                heads,
+                kv_heads,
+                head_dim,
+            )? {
+                Some(ctx) => ctx,
+                None => grouped_query_attention(q, k_cache, v_cache, heads, kv_heads, head_dim),
+            }
+            .swap_dims(1, 2)
+            .reshape([batch, seq, hidden]);
+
+            let attn_out = layer.o_proj.forward(ctx.clone(), &active_loras, &[]);
+            if idx == layer_idx && suffix == "attn.o_proj" {
+                return capture_module_from_native_hidden(
+                    target_key,
+                    expected_in,
+                    expected_out,
+                    &request.seq_lens,
+                    ctx,
+                    attn_out,
+                );
+            }
+
+            let after_attn = residual + attn_out;
+            let residual = after_attn.clone();
+            let normed_ffn = layer.post_attn_norm.forward(after_attn);
+            let up = layer.up_proj.forward(normed_ffn.clone(), &active_loras, &[]);
+            if idx == layer_idx && suffix == "ffn.up_proj" {
+                return capture_module_from_native_hidden(
+                    target_key,
+                    expected_in,
+                    expected_out,
+                    &request.seq_lens,
+                    normed_ffn,
+                    up,
+                );
+            }
+
+            let gate = sigmoid(layer.gate_proj.forward(normed_ffn.clone(), &active_loras, &[]));
+            let ff = layer.down_proj.forward(gate * up, &active_loras, &[]);
+            x = residual + ff;
+        }
+
+        bail!(
+            "failed to capture native module-local trace for target_key={} layer_idx={} (layer not reached)",
+            target_key,
+            layer_idx
+        )
+    }
