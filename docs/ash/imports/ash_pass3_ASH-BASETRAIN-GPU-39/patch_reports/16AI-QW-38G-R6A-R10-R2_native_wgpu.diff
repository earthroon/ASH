+fn qw38g_r6a_r10_r2_jsonl_first_matching(path: &str, target_ids: &[u32]) -> Option<serde_json::Value> {
+    let text = std::fs::read_to_string(path).ok()?;
+    let mut first_valid: Option<serde_json::Value> = None;
+    for line in text.lines() {
+        let line = line.trim();
+        if line.is_empty() {
+            continue;
+        }
+        let parsed = serde_json::from_str::<serde_json::Value>(line).ok()?;
+        if first_valid.is_none() {
+            first_valid = Some(parsed.clone());
+        }
+        let token = parsed
+            .get("target_token_id")
+            .and_then(|v| v.as_u64())
+            .map(|v| v as u32);
+        if token.map(|id| target_ids.contains(&id)).unwrap_or(false) {
+            return Some(parsed);
+        }
+    }
+    first_valid
+}
