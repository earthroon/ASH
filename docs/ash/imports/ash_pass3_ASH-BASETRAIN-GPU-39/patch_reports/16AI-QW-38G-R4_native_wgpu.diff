+// 16AI-QW-38G-R4 — GPU Debug Tap Candidate / Bounded Intermediate Activation Readback Seal
+static QW38G_R4_TAP_STEP: AtomicUsize = AtomicUsize::new(0);
+
+fn qw38g_r4_enabled() -> bool {
+    env_flag("ASH_GPU_DEBUG_TAP") || env_flag("ASH_QW38G_R4_GPU_DEBUG_TAP")
+}
+
+fn qw38g_r4_scalar_only() -> bool {
+    std::env::var("ASH_GPU_DEBUG_TAP_SCALAR_ONLY")
+        .ok()
+        .map(|v| !matches!(v.as_str(), "0" | "false" | "FALSE" | "no" | "NO"))
+        .unwrap_or(true)
+}
+
+fn qw38g_r4_trace_path() -> String {
+    std::env::var("ASH_GPU_DEBUG_TAP_OUT")
+        .unwrap_or_else(|_| "workspace/qw38g_r4_gpu_debug_tap_trace.jsonl".to_string())
+}
+
+fn qw38g_r4_summary_path() -> String {
+    std::env::var("ASH_GPU_DEBUG_TAP_SUMMARY")
+        .unwrap_or_else(|_| "workspace/qw38g_r4_gpu_debug_tap_summary.json".to_string())
+}
+
+fn qw38g_r4_receipt_path() -> String {
+    std::env::var("ASH_GPU_DEBUG_TAP_RECEIPT")
+        .unwrap_or_else(|_| "workspace/qw38g_r4_gpu_debug_tap_receipt.json".to_string())
+}
+
+fn qw38g_r4_split_env(name: &str, default: &str) -> Vec<String> {
+    std::env::var(name)
+        .unwrap_or_else(|_| default.to_string())
+        .split(',')
+        .map(|s| s.trim().to_string())
+        .filter(|s| !s.is_empty())
+        .collect()
+}
+
+fn qw38g_r4_target_ids() -> Vec<usize> {
+    qw38g_r4_split_env("ASH_GPU_DEBUG_TAP_TARGET_IDS", "13")
+        .into_iter()
+        .filter_map(|s| s.parse::<usize>().ok())
+        .collect::<Vec<_>>()
+}
+
+fn qw38g_r4_path_written(path: &str) -> bool {
+    std::path::Path::new(path)
+        .metadata()
+        .map(|m| m.len() > 0)
+        .unwrap_or(false)
+}
+
+fn qw38g_r4_write_json(path: &str, value: &serde_json::Value) {
+    if let Some(parent) = std::path::Path::new(path).parent() {
+        let _ = std::fs::create_dir_all(parent);
+    }
+    if let Ok(text) = serde_json::to_string_pretty(value) {
+        let _ = std::fs::write(path, text);
+    }
+}
+
+fn qw38g_r4_append_jsonl(path: &str, value: &serde_json::Value) {
+    if let Some(parent) = std::path::Path::new(path).parent() {
+        let _ = std::fs::create_dir_all(parent);
+    }
+    if let Ok(mut file) = OpenOptions::new().create(true).append(true).open(path) {
+        let _ = writeln!(file, "{}", value);
+    }
+}
+
+fn qw38g_r4_write_summary_and_receipt(
+    status: &str,
+    total_events: usize,
+    tap_reached: bool,
+    post_final_norm_tap_reached: bool,
+    total_readback_bytes: usize,
+    warnings: Vec<String>,
+    extra: serde_json::Value,
+) {
+    let trace_path = qw38g_r4_trace_path();
+    let summary_path = qw38g_r4_summary_path();
+    let receipt_path = qw38g_r4_receipt_path();
+    let full_vector_readback_used = total_readback_bytes > std::mem::size_of::<f32>();
+    let summary = serde_json::json!({
+        "patch_id": "16AI-QW-38G-R4",
+        "status": status,
+        "timestamp_unix_ms": qw38g_r3_now_ms(),
+        "total_events": total_events,
+        "steps_observed": if total_events > 0 { 1 } else { 0 },
+        "layers_observed": Vec::<String>::new(),
+        "stages_observed": if post_final_norm_tap_reached { vec!["post_final_norm".to_string()] } else { Vec::<String>::new() },
+        "projection_scalar_only": qw38g_r4_scalar_only(),
+        "full_vector_readback_used": full_vector_readback_used,
+        "total_readback_bytes": total_readback_bytes,
+        "tap_reached": tap_reached,
+        "post_mlp_tap_reached": false,
+        "post_block_tap_reached": false,
+        "pre_final_norm_tap_reached": false,
+        "post_final_norm_tap_reached": post_final_norm_tap_reached,
+        "strongest_layer": null,
+        "strongest_stage": if post_final_norm_tap_reached { serde_json::json!("post_final_norm") } else { serde_json::Value::Null },
+        "strongest_dot_to_target": serde_json::Value::Null,
+        "strongest_cosine_to_target": serde_json::Value::Null,
+        "reserved_direction_source_candidate": if post_final_norm_tap_reached { serde_json::json!("final_hidden_projection") } else { serde_json::Value::Null },
+        "warning_codes": warnings,
+        "extra": extra,
+    });
+    qw38g_r4_write_json(&summary_path, &summary);
+    let receipt = serde_json::json!({
+        "patch_id": "16AI-QW-38G-R4",
+        "status": status,
+        "timestamp_unix_ms": qw38g_r3_now_ms(),
+        "tap_reached": tap_reached,
+        "trace_path": trace_path,
+        "trace_written": total_events > 0 && qw38g_r4_path_written(&trace_path),
+        "summary_path": summary_path,
+        "summary_written": qw38g_r4_path_written(&summary_path),
+        "receipt_path": receipt_path,
+        "receipt_written": true,
+        "projection_scalar_only": qw38g_r4_scalar_only(),
+        "full_vector_readback_used": full_vector_readback_used,
+        "total_readback_bytes": total_readback_bytes,
+        "post_mlp_tap_reached": false,
+        "post_block_tap_reached": false,
+        "post_final_norm_tap_reached": post_final_norm_tap_reached,
+        "recommended_next_patch": if tap_reached { "16AI-QW-38H_FINAL_NORM_STABILITY_AUDIT" } else { "16AI-QW-38G-R6_SHADER_DEBUG_BUFFER_DESIGN" },
+        "warning_codes": summary.get("warning_codes").cloned().unwrap_or_else(|| serde_json::json!([])),
+    });
+    qw38g_r4_write_json(&receipt_path, &receipt);
+    eprintln!("[16AI-QW-38G-R4][summary_written] path={}", summary_path);
+    eprintln!("[16AI-QW-38G-R4][receipt_written] path={}", receipt_path);
+    eprintln!("[16AI-QW-38G-R4][done] status={}", status);
+}
