+fn qw38g_r4_gpu_debug_tap_candidate(
+    global_top_k: &[NativeVocabAtlasCandidate],
+    atlas: &NativeVocabAtlas,
+    last_hidden: &Tensor<NativeInferenceBackend, 2>,
+) {
+    if !qw38g_r4_enabled() {
+        return;
+    }
+    let step = QW38G_R4_TAP_STEP.fetch_add(1, Ordering::SeqCst);
+    let max_steps = qw38a_env_usize("ASH_GPU_DEBUG_TAP_MAX_STEPS", 1).max(1);
+    if step >= max_steps {
+        return;
+    }
+    let layers = qw38g_r4_split_env("ASH_GPU_DEBUG_TAP_LAYERS", "mid,last");
+    let stages = qw38g_r4_split_env("ASH_GPU_DEBUG_TAP_STAGES", "post_mlp,post_block");
+    let targets = qw38g_r4_target_ids();
+    let scalar_only = qw38g_r4_scalar_only();
+    eprintln!(
+        "[16AI-QW-38G-R4][start] step={} scalar_only={} max_steps={} targets={:?}",
+        step, scalar_only, max_steps, targets
+    );
+    eprintln!(
+        "[16AI-QW-38G-R4][env] enabled=true layers={} stages={} scalar_only={}",
+        layers.join(","), stages.join(","), scalar_only
+    );
+    eprintln!(
+        "[16AI-QW-38G-R4][tap_plan] projection_scalar_only={} requested_layers={:?} requested_stages={:?}",
+        scalar_only, layers, stages
+    );
+
+    for layer in &layers {
+        for stage in &stages {
+            if stage != "post_final_norm" && stage != "final_hidden_projection" {
+                eprintln!(
+                    "[16AI-QW-38G-R4][tap_unavailable] step={} layer={} stage={} reason=RUST_LAYERWISE_RESIDUAL_UNAVAILABLE",
+                    step, layer, stage
+                );
+            }
+        }
+    }
+
+    let final_stage_requested = stages.iter().any(|s| s == "post_final_norm" || s == "final_hidden_projection");
+    let trace_path = qw38g_r4_trace_path();
+    if !final_stage_requested {
+        qw38g_r4_write_summary_and_receipt(
+            "FAIL_TAP_UNAVAILABLE",
+            0,
+            false,
+            false,
+            0,
+            vec![
+                "GPU_DEBUG_TAP_STAGE_UNAVAILABLE".to_string(),
+                "POST_MLP_TAP_UNAVAILABLE".to_string(),
+                "POST_BLOCK_TAP_UNAVAILABLE".to_string(),
+                "RESERVED_DIRECTION_SOURCE_STILL_UNKNOWN".to_string(),
+            ],
+            serde_json::json!({
+                "requested_layers": layers,
+                "requested_stages": stages,
+                "actual_traceable_boundary": "final_hidden_projection",
+                "note": "bounded tap candidate did not read full activation vectors; requested intermediate stages are unavailable from current Rust-side boundary",
+            }),
+        );
+        return;
+    }
+
+    if !scalar_only {
+        qw38g_r4_write_summary_and_receipt(
+            "FAIL_FULL_VECTOR_REJECTED",
+            0,
+            false,
+            false,
+            0,
+            vec!["GPU_DEBUG_TAP_FULL_VECTOR_REJECTED".to_string()],
+            serde_json::json!({"requested_stages": stages}),
+        );
+        return;
+    }
+
+    let meta = qw38a_token_meta();
+    let Ok(hidden_vec) = last_hidden
+        .clone()
+        .reshape([atlas.hidden_size])
+        .into_data()
+        .to_vec::<f32>() else {
+        qw38g_r4_write_summary_and_receipt(
+            "FAIL_TAP_UNAVAILABLE",
+            0,
+            false,
+            false,
+            0,
+            vec!["GPU_DEBUG_TAP_SCALAR_READBACK_FAILED".to_string()],
+            serde_json::json!({"requested_stages": stages}),
+        );
+        return;
+    };
+    let hidden_norm = qw38d_l2_norm(&hidden_vec);
+    let target_id = targets.first().copied().unwrap_or(13);
+    let Some(row) = qw38d_token_row_from_atlas(atlas, target_id) else {
+        qw38g_r4_write_summary_and_receipt(
+            "FAIL_TAP_UNAVAILABLE",
+            0,
+            false,
+            false,
+            hidden_vec.len().saturating_mul(std::mem::size_of::<f32>()),
+            vec!["GPU_DEBUG_TAP_SCALAR_READBACK_FAILED".to_string()],
+            serde_json::json!({"target_id": target_id}),
+        );
+        return;
+    };
+    let row_norm = qw38d_l2_norm(&row);
+    let dot = qw38d_dot(&hidden_vec, &row);
+    let cosine = qw38d_cosine(dot, hidden_norm, row_norm);
+    let masked_top1 = global_top_k
+        .iter()
+        .find(|c| !meta.banned_reasons.contains_key(&c.token_id));
+    let event = serde_json::json!({
+        "patch_id": "16AI-QW-38G-R4",
+        "decode_step": step,
+        "layer_id": null,
+        "layer_label": "final_hidden_projection",
+        "stage": "post_final_norm",
+        "target_token_id": target_id,
+        "target_piece": qw38a_piece(meta, target_id),
+        "projection_scalar_only": true,
+        "dot_to_target": dot,
+        "hidden_norm": hidden_norm,
+        "target_row_norm": row_norm,
+        "cosine_to_target": cosine,
+        "masked_top1_token_id": masked_top1.map(|c| c.token_id),
+        "masked_top1_piece": masked_top1.map(|c| qw38a_piece(meta, c.token_id)),
+        "dot_to_masked_top1": serde_json::Value::Null,
+        "target_minus_masked_top1_margin": serde_json::Value::Null,
+        "readback_bytes": hidden_vec.len().saturating_mul(std::mem::size_of::<f32>()),
+        "readback_kind": "final_hidden_projection_reference",
+        "tap_reached": true,
+        "tap_stage_available": true,
+        "warning_codes": ["FINAL_NORM_TAP_ONLY"],
+    });
+    eprintln!(
+        "[16AI-QW-38G-R4][tap_event] step={} layer=final stage=post_final_norm target={} dot={} cosine={:?}",
+        step, target_id, dot, cosine
+    );
+    qw38g_r4_append_jsonl(&trace_path, &event);
+    qw38g_r4_write_summary_and_receipt(
+        "PASS_GPU_DEBUG_TAP_FINAL_ONLY",
+        1,
+        true,
+        true,
+        hidden_vec.len().saturating_mul(std::mem::size_of::<f32>()),
+        vec!["FINAL_NORM_TAP_ONLY".to_string()],
+        serde_json::json!({
+            "target_id": target_id,
+            "target_piece": qw38a_piece(meta, target_id),
+            "dot_to_target": dot,
+            "cosine_to_target": cosine,
+            "requested_layers": layers,
+            "requested_stages": stages,
+            "actual_traceable_boundary": "final_hidden_projection",
+        }),
+    );
+}
