+use anyhow::{anyhow, bail, Context, Result};
+use burn_webgpu_backend::{NativeAtlasFfn16AfDispatcher, NativeAtlasFfn16AfReadbackMode};
+use model_core::{
+    load_full_checkpoint_weights, native_atlas_ffn_16af_weight_layout,
+    run_native_atlas_ffn_16af_parity_probe_with_dispatcher_and_mode, synthetic_hidden_vector_16af,
+    validate_spec_consistency, ModelSpec, NativeAtlasFfn16AfParityReport,
+};
+use serde_json::json;
+use std::{env, fs, path::PathBuf, time::Instant};
+
+#[derive(Debug, Clone)]
+struct Args {
+    spec: PathBuf,
+    checkpoints: Vec<PathBuf>,
+    layers: Option<String>,
+    all_layers: bool,
+    threshold: f32,
+    top_k: usize,
+    fail_fast: bool,
+    out_json: PathBuf,
+    out_md: PathBuf,
+    out_acceptance: PathBuf,
+}
+
+#[derive(Debug, Clone)]
+struct LayerRun {
+    report: NativeAtlasFfn16AfParityReport,
+    elapsed_ms: f64,
+}
+
+fn main() -> Result<()> {
+    let started = Instant::now();
+    let args = parse_args()?;
+
+    eprintln!(
+        "[16AF-P][start] build_gate=pass layers={} threshold={} top_k={}",
+        args.layers.as_deref().unwrap_or(if args.all_layers { "all" } else { "0,1,last" }),
+        args.threshold,
+        args.top_k,
+    );
+    eprintln!("[16AF-P][ssot] generation_connected=false runtime_gate=multi_layer_ffn_parity_only");
+    eprintln!("[16AF-P][ffn] enable_native_atlas_ffn=true enable_silu_swiglu=true");
+    eprintln!("[16AF-P][ffn] burn_cubecl_ffn_matmul_disabled=true");
+
+    let spec = ModelSpec::load_toml(&args.spec)
+        .with_context(|| format!("failed to load model spec: {}", args.spec.display()))?;
+    validate_spec_consistency(&spec).context("model spec consistency check failed")?;
+
+    let full = load_full_checkpoint_weights(&spec, &args.checkpoints)
+        .with_context(|| format!("failed to load full checkpoint weights: {:?}", args.checkpoints))?;
+
+    let total_layers = full.layers.len();
+    let layers = resolve_layers(&args, total_layers)?;
+    eprintln!("[16AF-P][layers] resolved={}", format_layers(&layers));
+    eprintln!("[16AF-P][perf] dispatcher_reuse=true shader_pipeline_cached=true readback_mode=output_only");
+
+    let dispatcher = NativeAtlasFfn16AfDispatcher::try_new()
+        .context("failed to create reusable 16AF-P native atlas FFN dispatcher")?;
+
+    let mut runs: Vec<LayerRun> = Vec::with_capacity(layers.len());
+    let mut first_error: Option<anyhow::Error> = None;
+
+    for &layer_idx in &layers {
+        let layout = native_atlas_ffn_16af_weight_layout(&full, layer_idx)
+            .with_context(|| format!("failed to resolve 16AF-M FFN weight layout for layer {}", layer_idx))?;
+        eprintln!(
+            "[16AF-P][layout] layer={} hidden={} intermediate={} gate_shape={:?} up_shape={:?} down_shape={:?}",
+            layout.layer_idx, layout.hidden, layout.intermediate, layout.gate_shape, layout.up_shape, layout.down_shape,
+        );
+
+        let input = synthetic_hidden_vector_16af(layout.hidden);
+        let layer_started = Instant::now();
+        match run_native_atlas_ffn_16af_parity_probe_with_dispatcher_and_mode(
+            &dispatcher,
+            &full,
+            layer_idx,
+            &input,
+            args.threshold,
+            args.top_k,
+            NativeAtlasFfn16AfReadbackMode::OutputOnly,
+        ) {
+            Ok(report) => {
+                let elapsed_ms = layer_started.elapsed().as_secs_f64() * 1000.0;
+                eprintln!(
+                    "[16AF-P][ffn-parity] layer={} shape_match={} max_abs_delta={} mean_abs_delta={} nan_count={} inf_count={} top_index_match={} top_k_overlap={}/{} parity_pass={}",
+                    report.layer_idx,
+                    report.shape_match,
+                    report.max_abs_delta,
+                    report.mean_abs_delta,
+                    report.nan_count,
+                    report.inf_count,
+                    report.top_index_match,
+                    report.top_k_overlap,
+                    report.top_k,
+                    report.parity_pass,
+                );
+                eprintln!("[16AF-P][runtime] layer={} elapsed_ms={:.3}", report.layer_idx, elapsed_ms);
+                if let Some(telemetry) = report.telemetry.as_ref() {
+                    eprintln!(
+                        "[16AF-P][perf] layer={} readback_mode={} readback_buffers={} readback_elements={} weight_upload_ms={:.3} bind_encode_ms={:.3} submit_readback_ms={:.3} total_gpu_ms={:.3}",
+                        report.layer_idx,
+                        telemetry.readback_mode,
+                        telemetry.readback_buffers,
+                        telemetry.readback_elements,
+                        telemetry.weight_upload_ms,
+                        telemetry.bind_encode_ms,
+                        telemetry.submit_readback_ms,
+                        telemetry.total_gpu_ms,
+                    );
+                }
+                let layer_failed = !report.parity_pass;
+                runs.push(LayerRun { report, elapsed_ms });
+                if layer_failed && args.fail_fast {
+                    eprintln!("[16AF-P][fail-fast] stopping after layer={}", layer_idx);
+                    break;
+                }
+            }
+            Err(err) => {
+                eprintln!("[16AF-P][fail] layer={} reason={:#}", layer_idx, err);
+                if args.fail_fast {
+                    return Err(err).with_context(|| format!("16AF-M layer {} failed", layer_idx));
+                }
+                first_error = Some(err);
+                break;
+            }
+        }
+    }
+
+    let total_elapsed_ms = started.elapsed().as_secs_f64() * 1000.0;
+    let summary = build_summary(&runs, layers.len(), total_elapsed_ms);
+    let payload = json!({
+        "commit": "16AF-P",
+        "runtime_gate": "multi_layer_ffn_parity_only",
+        "build_gate": "pass_by_user_reported_local_cargo_check",
+        "generation_connected": false,
+        "threshold": args.threshold,
+        "top_k": args.top_k,
+        "requested_layers": layers,
+        "layers": runs.iter().map(layer_run_to_json).collect::<Vec<_>>(),
+        "summary": summary,
+    });
+
+    write_report_files(&args, &payload)?;
+
+    let parity_pass = payload["summary"]["parity_pass"].as_bool().unwrap_or(false);
+    eprintln!(
+        "[16AF-P][summary] total={} passed={} failed={} max_abs_delta_global={} mean_abs_delta_avg={} parity_pass={}",
+        payload["summary"]["total"].as_u64().unwrap_or(0),
+        payload["summary"]["passed"].as_u64().unwrap_or(0),
+        payload["summary"]["failed"].as_u64().unwrap_or(0),
+        payload["summary"]["max_abs_delta_global"].as_f64().unwrap_or(f64::INFINITY),
+        payload["summary"]["mean_abs_delta_avg"].as_f64().unwrap_or(f64::INFINITY),
+        parity_pass,
+    );
+
+    if parity_pass {
+        eprintln!("[16AF-P][seal] PASS selected layer parity matrix closed");
+        Ok(())
+    } else if let Some(err) = first_error {
+        eprintln!("[16AF-P][seal] FAIL selected layer parity matrix open");
+        Err(err).context("16AF-P failed before performance probe could be closed")
+    } else {
+        eprintln!("[16AF-P][seal] FAIL selected layer parity matrix open");
+        bail!("16AF-P parity/performance probe failed; see {}", args.out_json.display())
+    }
+}
+
+fn parse_args() -> Result<Args> {
+    let mut spec: Option<PathBuf> = None;
+    let mut checkpoints: Vec<PathBuf> = Vec::new();
+    let mut layers: Option<String> = None;
+    let mut all_layers = false;
+    let mut threshold = 1.0e-3f32;
+    let mut top_k = 8usize;
+    let mut fail_fast = false;
+    let mut out_json = PathBuf::from("infer_debug/16AF-P_ffn_perf_probe.json");
+    let mut out_md = PathBuf::from("infer_debug/16AF-P_ffn_perf_probe.md");
+    let mut out_acceptance = PathBuf::from("acceptance_reports/16AF-P_acceptance.md");
+
+    let mut iter = env::args().skip(1);
+    while let Some(flag) = iter.next() {
+        match flag.as_str() {
+            "--spec" => spec = Some(PathBuf::from(next_value(&mut iter, "--spec")?)),
+            "--checkpoint" => checkpoints.push(PathBuf::from(next_value(&mut iter, "--checkpoint")?)),
+            "--checkpoints" => {
+                let raw = next_value(&mut iter, "--checkpoints")?;
+                checkpoints.extend(raw.split(';').filter(|s| !s.trim().is_empty()).map(PathBuf::from));
+            }
+            "--layers" => layers = Some(next_value(&mut iter, "--layers")?),
+            "--all-layers" => all_layers = true,
+            "--threshold" => threshold = next_value(&mut iter, "--threshold")?.parse().context("invalid --threshold")?,
+            "--top-k" => top_k = next_value(&mut iter, "--top-k")?.parse().context("invalid --top-k")?,
+            "--fail-fast" => fail_fast = parse_bool(&next_value(&mut iter, "--fail-fast")?)?,
+            "--out-json" => out_json = PathBuf::from(next_value(&mut iter, "--out-json")?),
+            "--out-md" => out_md = PathBuf::from(next_value(&mut iter, "--out-md")?),
+            "--out-acceptance" => out_acceptance = PathBuf::from(next_value(&mut iter, "--out-acceptance")?),
+            "--help" | "-h" => {
+                print_usage();
+                std::process::exit(0);
+            }
+            other => bail!("unknown argument: {other}"),
+        }
+    }
+
+    let spec = spec.ok_or_else(|| anyhow!("missing --spec"))?;
+    if checkpoints.is_empty() {
+        bail!("missing --checkpoint or --checkpoints");
+    }
+    if top_k == 0 {
+        bail!("--top-k must be >= 1");
+    }
+    if layers.is_some() && all_layers {
+        bail!("use either --layers or --all-layers, not both");
+    }
+
+    Ok(Args { spec, checkpoints, layers, all_layers, threshold, top_k, fail_fast, out_json, out_md, out_acceptance })
+}
+
+fn next_value(iter: &mut impl Iterator<Item = String>, flag: &str) -> Result<String> {
+    iter.next().ok_or_else(|| anyhow!("missing value for {flag}"))
+}
+
+fn parse_bool(raw: &str) -> Result<bool> {
+    match raw.trim().to_ascii_lowercase().as_str() {
+        "1" | "true" | "yes" | "y" => Ok(true),
+        "0" | "false" | "no" | "n" => Ok(false),
+        other => bail!("invalid boolean value: {other}"),
+    }
+}
+
+fn resolve_layers(args: &Args, total_layers: usize) -> Result<Vec<usize>> {
+    if total_layers == 0 {
+        bail!("model has zero layers");
+    }
+
+    let mut layers = if args.all_layers {
+        (0..total_layers).collect::<Vec<_>>()
+    } else if let Some(raw) = &args.layers {
+        parse_layer_list(raw, total_layers)?
+    } else {
+        default_selected_layers(total_layers)
+    };
+
+    layers.sort_unstable();
+    layers.dedup();
+    if layers.is_empty() {
+        bail!("resolved layer list is empty");
+    }
+    for &layer in &layers {
+        if layer >= total_layers {
+            bail!("layer index out of range: layer={} total_layers={}", layer, total_layers);
+        }
+    }
+    Ok(layers)
+}
+
+fn default_selected_layers(total_layers: usize) -> Vec<usize> {
+    let last = total_layers.saturating_sub(1);
+    if total_layers == 1 {
+        vec![0]
+    } else {
+        vec![0, 1.min(last), last]
+    }
+}
+
+fn parse_layer_list(raw: &str, total_layers: usize) -> Result<Vec<usize>> {
+    let mut out = Vec::new();
+    for item in raw.split(',').map(str::trim).filter(|s| !s.is_empty()) {
+        if item.eq_ignore_ascii_case("last") {
+            out.push(total_layers.saturating_sub(1));
+        } else if let Some((start, end)) = item.split_once("..") {
+            let start: usize = start.trim().parse().context("invalid layer range start")?;
+            let end: usize = end.trim().parse().context("invalid layer range end")?;
+            if end < start {
+                bail!("invalid layer range: {item}");
+            }
+            out.extend(start..end);
+        } else {
+            out.push(item.parse().with_context(|| format!("invalid layer value: {item}"))?);
+        }
+    }
+    Ok(out)
+}
+
+fn format_layers(layers: &[usize]) -> String {
+    layers.iter().map(|v| v.to_string()).collect::<Vec<_>>().join(",")
+}
+
+fn layer_run_to_json(run: &LayerRun) -> serde_json::Value {
+    json!({
+        "layer": run.report.layer_idx,
+        "hidden": run.report.hidden,
+        "intermediate": run.report.intermediate,
+        "threshold": run.report.threshold,
+        "shape_match": run.report.shape_match,
+        "max_abs_delta": run.report.max_abs_delta,
+        "mean_abs_delta": run.report.mean_abs_delta,
+        "nan_count": run.report.nan_count,
+        "inf_count": run.report.inf_count,
+        "top_index_match": run.report.top_index_match,
+        "top_k_overlap": run.report.top_k_overlap,
+        "top_k": run.report.top_k,
+        "elapsed_ms": run.elapsed_ms,
+        "parity_pass": run.report.parity_pass,
+        "generation_connected": run.report.generation_connected,
+        "burn_cubecl_ffn_matmul_disabled": run.report.burn_cubecl_ffn_matmul_disabled,
+        "resolved_backend": run.report.resolved_backend,
+        "weight_layout": run.report.weight_layout,
+        "dispatch_log": run.report.dispatch_log,
+        "telemetry": run.report.telemetry,
+        "forbidden_paths_used": run.report.forbidden_paths_used,
+    })
+}
+
+fn build_summary(runs: &[LayerRun], requested_total: usize, elapsed_ms_total: f64) -> serde_json::Value {
+    let passed = runs.iter().filter(|r| r.report.parity_pass).count();
+    let failed = requested_total.saturating_sub(passed);
+    let max_abs_delta_global = runs.iter().map(|r| r.report.max_abs_delta).fold(0.0f32, f32::max);
+    let mean_abs_delta_avg = if runs.is_empty() {
+        f32::INFINITY
+    } else {
+        runs.iter().map(|r| r.report.mean_abs_delta).sum::<f32>() / runs.len() as f32
+    };
+    let telemetry_total_gpu_ms = runs.iter()
+        .filter_map(|r| r.report.telemetry.as_ref().map(|t| t.total_gpu_ms))
+        .sum::<f64>();
+    let telemetry_weight_upload_ms = runs.iter()
+        .filter_map(|r| r.report.telemetry.as_ref().map(|t| t.weight_upload_ms))
+        .sum::<f64>();
+    let telemetry_submit_readback_ms = runs.iter()
+        .filter_map(|r| r.report.telemetry.as_ref().map(|t| t.submit_readback_ms))
+        .sum::<f64>();
+    let telemetry_readback_buffers = runs.iter()
+        .filter_map(|r| r.report.telemetry.as_ref().map(|t| t.readback_buffers))
+        .sum::<usize>();
+    let telemetry_readback_elements = runs.iter()
+        .filter_map(|r| r.report.telemetry.as_ref().map(|t| t.readback_elements))
+        .sum::<usize>();
+    let parity_pass = requested_total > 0
+        && runs.len() == requested_total
+        && failed == 0
+        && runs.iter().all(|r| {
+            r.report.parity_pass
+                && !r.report.generation_connected
+                && r.report.burn_cubecl_ffn_matmul_disabled
+                && r.report.forbidden_paths_used.is_empty()
+        });
+
+    json!({
+        "total": requested_total,
+        "completed": runs.len(),
+        "passed": passed,
+        "failed": failed,
+        "max_abs_delta_global": max_abs_delta_global,
+        "mean_abs_delta_avg": mean_abs_delta_avg,
+        "elapsed_ms_total": elapsed_ms_total,
+        "telemetry_total_gpu_ms": telemetry_total_gpu_ms,
+        "telemetry_weight_upload_ms": telemetry_weight_upload_ms,
+        "telemetry_submit_readback_ms": telemetry_submit_readback_ms,
+        "telemetry_readback_buffers": telemetry_readback_buffers,
+        "telemetry_readback_elements": telemetry_readback_elements,
+        "parity_pass": parity_pass,
+    })
+}
+
+fn write_report_files(args: &Args, payload: &serde_json::Value) -> Result<()> {
+    if let Some(parent) = args.out_json.parent() { fs::create_dir_all(parent)?; }
+    if let Some(parent) = args.out_md.parent() { fs::create_dir_all(parent)?; }
+    if let Some(parent) = args.out_acceptance.parent() { fs::create_dir_all(parent)?; }
+
+    fs::write(&args.out_json, serde_json::to_string_pretty(payload)?)?;
+    let md = render_markdown(payload)?;
+    fs::write(&args.out_md, &md)?;
+    fs::write(&args.out_acceptance, render_acceptance(payload)?)?;
+    Ok(())
+}
+
+fn render_markdown(payload: &serde_json::Value) -> Result<String> {
+    let mut rows = String::new();
+    for layer in payload["layers"].as_array().ok_or_else(|| anyhow!("missing layers"))? {
+        rows.push_str(&format!(
+            "| {} | {} | {} | {} | {} | {} | {} | {} | {}/{} | {} | {:.3} |\n",
+            layer["layer"].as_u64().unwrap_or(0),
+            layer["shape_match"].as_bool().unwrap_or(false),
+            layer["max_abs_delta"].as_f64().unwrap_or(f64::INFINITY),
+            layer["mean_abs_delta"].as_f64().unwrap_or(f64::INFINITY),
+            layer["nan_count"].as_u64().unwrap_or(0),
+            layer["inf_count"].as_u64().unwrap_or(0),
+            layer["top_index_match"].as_bool().unwrap_or(false),
+            layer["top_k_overlap"].as_u64().unwrap_or(0),
+            layer["top_k_overlap"].as_u64().unwrap_or(0),
+            layer["top_k"].as_u64().unwrap_or(0),
+            layer["parity_pass"].as_bool().unwrap_or(false),
+            layer["elapsed_ms"].as_f64().unwrap_or(0.0),
+        ));
+    }
+
+    Ok(format!(
+        r#"# 16AF-P Native Atlas FFN Performance Probe Seal
+
+## Status
+
+```txt
+runtime_gate = {}
+generation_connected = {}
+threshold = {}
+top_k = {}
+parity_pass = {}
+```
+
+## Summary
+
+```txt
+total = {}
+completed = {}
+passed = {}
+failed = {}
+max_abs_delta_global = {}
+mean_abs_delta_avg = {}
+elapsed_ms_total = {}
+telemetry_total_gpu_ms = {}
+telemetry_weight_upload_ms = {}
+telemetry_submit_readback_ms = {}
+telemetry_readback_buffers = {}
+telemetry_readback_elements = {}
+```
+
+## Layer Matrix
+
+| layer | shape_match | max_abs_delta | mean_abs_delta | nan | inf | top_index_match | top_k_overlap | top_k_ratio | parity_pass | elapsed_ms |
+|---:|---|---:|---:|---:|---:|---|---:|---|---|---:|
+{}
+## Seal
+
+```txt
+if parity_pass == true:
+    16AF-P FFN performance probe closed
+else:
+    keep generation integration locked
+```
+"#,
+        payload["runtime_gate"].as_str().unwrap_or("unknown"),
+        payload["generation_connected"].as_bool().unwrap_or(false),
+        payload["threshold"].as_f64().unwrap_or(0.0),
+        payload["top_k"].as_u64().unwrap_or(0),
+        payload["summary"]["parity_pass"].as_bool().unwrap_or(false),
+        payload["summary"]["total"].as_u64().unwrap_or(0),
+        payload["summary"]["completed"].as_u64().unwrap_or(0),
+        payload["summary"]["passed"].as_u64().unwrap_or(0),
+        payload["summary"]["failed"].as_u64().unwrap_or(0),
+        payload["summary"]["max_abs_delta_global"].as_f64().unwrap_or(f64::INFINITY),
+        payload["summary"]["mean_abs_delta_avg"].as_f64().unwrap_or(f64::INFINITY),
+        payload["summary"]["elapsed_ms_total"].as_f64().unwrap_or(0.0),
+        payload["summary"]["telemetry_total_gpu_ms"].as_f64().unwrap_or(0.0),
+        payload["summary"]["telemetry_weight_upload_ms"].as_f64().unwrap_or(0.0),
+        payload["summary"]["telemetry_submit_readback_ms"].as_f64().unwrap_or(0.0),
+        payload["summary"]["telemetry_readback_buffers"].as_u64().unwrap_or(0),
+        payload["summary"]["telemetry_readback_elements"].as_u64().unwrap_or(0),
+        rows,
+    ))
+}
+
+fn render_acceptance(payload: &serde_json::Value) -> Result<String> {
+    let pass = payload["summary"]["parity_pass"].as_bool().unwrap_or(false);
+    Ok(format!(
+        r#"# 16AF-P Acceptance Report
+
+## Verdict
+
+```txt
+16AF-P = {}
+generation_connected = {}
+runtime_gate = {}
+```
+
+## Criteria
+
+```txt
+AC-16AF-P-1 selected layers shape_match=true: {}
+AC-16AF-P-2 nan_count=0 and inf_count=0: {}
+AC-16AF-P-3 max_abs_delta <= threshold: {}
+AC-16AF-P-4 mean_abs_delta <= threshold: {}
+AC-16AF-P-5 top_index_match=true: {}
+AC-16AF-P-6 top_k_overlap tracked: true
+AC-16AF-P-7 generation_connected=false: {}
+AC-16AF-P-8 forbidden path list empty: {}
+AC-16AF-P-9 JSON + Markdown report written: true
+```
+
+## Summary
+
+```txt
+total = {}
+completed = {}
+passed = {}
+failed = {}
+max_abs_delta_global = {}
+mean_abs_delta_avg = {}
+elapsed_ms_total = {}
+telemetry_total_gpu_ms = {}
+telemetry_weight_upload_ms = {}
+telemetry_submit_readback_ms = {}
+telemetry_readback_buffers = {}
+telemetry_readback_elements = {}
+```
+"#,
+        if pass { "PASS" } else { "PENDING_OR_FAIL" },
+        payload["generation_connected"].as_bool().unwrap_or(false),
+        payload["runtime_gate"].as_str().unwrap_or("unknown"),
+        bool_all_layers(payload, "shape_match"),
+        bool_zero_counts(payload),
+        bool_delta_under_threshold(payload, "max_abs_delta"),
+        bool_delta_under_threshold(payload, "mean_abs_delta"),
+        bool_all_layers(payload, "top_index_match"),
+        !payload["generation_connected"].as_bool().unwrap_or(true),
+        bool_forbidden_paths_empty(payload),
+        payload["summary"]["total"].as_u64().unwrap_or(0),
+        payload["summary"]["completed"].as_u64().unwrap_or(0),
+        payload["summary"]["passed"].as_u64().unwrap_or(0),
+        payload["summary"]["failed"].as_u64().unwrap_or(0),
+        payload["summary"]["max_abs_delta_global"].as_f64().unwrap_or(f64::INFINITY),
+        payload["summary"]["mean_abs_delta_avg"].as_f64().unwrap_or(f64::INFINITY),
+        payload["summary"]["elapsed_ms_total"].as_f64().unwrap_or(0.0),
+        payload["summary"]["telemetry_total_gpu_ms"].as_f64().unwrap_or(0.0),
+        payload["summary"]["telemetry_weight_upload_ms"].as_f64().unwrap_or(0.0),
+        payload["summary"]["telemetry_submit_readback_ms"].as_f64().unwrap_or(0.0),
+        payload["summary"]["telemetry_readback_buffers"].as_u64().unwrap_or(0),
+        payload["summary"]["telemetry_readback_elements"].as_u64().unwrap_or(0),
+    ))
+}
+
+fn bool_all_layers(payload: &serde_json::Value, key: &str) -> bool {
+    payload["layers"].as_array().map(|layers| !layers.is_empty() && layers.iter().all(|l| l[key].as_bool().unwrap_or(false))).unwrap_or(false)
+}
+
+fn bool_zero_counts(payload: &serde_json::Value) -> bool {
+    payload["layers"].as_array().map(|layers| !layers.is_empty() && layers.iter().all(|l| l["nan_count"].as_u64().unwrap_or(1) == 0 && l["inf_count"].as_u64().unwrap_or(1) == 0)).unwrap_or(false)
+}
+
+fn bool_delta_under_threshold(payload: &serde_json::Value, key: &str) -> bool {
+    let threshold = payload["threshold"].as_f64().unwrap_or(0.0);
+    payload["layers"].as_array().map(|layers| !layers.is_empty() && layers.iter().all(|l| l[key].as_f64().unwrap_or(f64::INFINITY) <= threshold)).unwrap_or(false)
+}
+
+fn bool_forbidden_paths_empty(payload: &serde_json::Value) -> bool {
+    payload["layers"].as_array().map(|layers| {
+        !layers.is_empty() && layers.iter().all(|l| {
+            l["forbidden_paths_used"].as_array().map(|items| items.is_empty()).unwrap_or(false)
+        })
+    }).unwrap_or(false)
+}
+
+fn print_usage() {
+    eprintln!("Usage:");
+    eprintln!("  cargo run --manifest-path crates/model_core/Cargo.toml --bin af16p_ffn_perf_probe -- \\");
+    eprintln!("    --spec specs/model_spec_300m_dialogue_continue_gqa8_headwise_atlas.toml \\");
+    eprintln!("    --checkpoint tokenizer_v5/artifacts/full_model_vocab_v5_resized.safetensors \\");
+    eprintln!("    --layers 0,1,last --threshold 0.001 --top-k 8");
+}
