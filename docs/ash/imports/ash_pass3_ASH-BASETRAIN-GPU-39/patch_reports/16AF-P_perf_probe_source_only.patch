@@ -0,0 +1,29 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SPEC_PATH="${SPEC_PATH:-specs/model_spec_300m_dialogue_continue_gqa8_headwise_atlas.toml}"
+CHECKPOINT_PATH="${CHECKPOINT_PATH:-tokenizer_v5/artifacts/full_model_vocab_v5_resized.safetensors}"
+LAYERS="${LAYERS:-all}"
+THRESHOLD="${THRESHOLD:-0.001}"
+TOP_K="${TOP_K:-8}"
+
+cmd=(
+  cargo run --manifest-path crates/model_core/Cargo.toml
+  --bin af16p_ffn_perf_probe --
+  --spec "$SPEC_PATH"
+  --checkpoint "$CHECKPOINT_PATH"
+  --threshold "$THRESHOLD"
+  --top-k "$TOP_K"
+  --fail-fast false
+  --out-json infer_debug/16AF-P_ffn_perf_probe.json
+  --out-md infer_debug/16AF-P_ffn_perf_probe.md
+  --out-acceptance acceptance_reports/16AF-P_acceptance.md
+)
+
+if [[ "$LAYERS" == "all" ]]; then
+  cmd+=(--all-layers)
+else
+  cmd+=(--layers "$LAYERS")
+fi
+
+"${cmd[@]}"
