+fn init_pipelines(device: &BackendDevice) -> Result<GpuPipelines> {
+    let gate_shader = device.create_shader_module(backend_wgpu::ShaderModuleDescriptor {
+        label: Some("16AF.native_atlas_ffn.gate.shader.cached"),
+        source: backend_wgpu::ShaderSource::Wgsl(SHADER_NATIVE_ATLAS_FFN_16AF_GATE.into()),
+    });
+    let up_shader = device.create_shader_module(backend_wgpu::ShaderModuleDescriptor {
+        label: Some("16AF.native_atlas_ffn.up.shader.cached"),
+        source: backend_wgpu::ShaderSource::Wgsl(SHADER_NATIVE_ATLAS_FFN_16AF_UP.into()),
+    });
+    let swiglu_shader = device.create_shader_module(backend_wgpu::ShaderModuleDescriptor {
+        label: Some("16AF.native_atlas_ffn.swiglu.shader.cached"),
+        source: backend_wgpu::ShaderSource::Wgsl(SHADER_NATIVE_ATLAS_FFN_16AF_SWIGLU.into()),
+    });
+    let down_shader = device.create_shader_module(backend_wgpu::ShaderModuleDescriptor {
+        label: Some("16AF.native_atlas_ffn.down.shader.cached"),
+        source: backend_wgpu::ShaderSource::Wgsl(SHADER_NATIVE_ATLAS_FFN_16AF_DOWN.into()),
+    });
+
+    let bind_group_layout = device.create_bind_group_layout(&backend_wgpu::BindGroupLayoutDescriptor {
+        label: Some("16AF.native_atlas_ffn.bgl.storage3.cached"),
+        entries: &[
+            uniform_entry(0),
+            read_storage_entry(1),
+            read_storage_entry(2),
+            rw_storage_entry(3),
+        ],
+    });
+
+    let pipeline_layout = device.create_pipeline_layout(&backend_wgpu::PipelineLayoutDescriptor {
+        label: Some("16AF.native_atlas_ffn.pipeline_layout.storage3.cached"),
+        bind_group_layouts: &[&bind_group_layout],
+        push_constant_ranges: &[],
+    });
+
+    let gate_pipeline = device.create_compute_pipeline(&backend_wgpu::ComputePipelineDescriptor {
+        label: Some("16AF.native_atlas_ffn.gate_project.pipeline.cached"),
+        layout: Some(&pipeline_layout),
+        module: &gate_shader,
+        entry_point: Some("gate_project"),
+        compilation_options: backend_wgpu::PipelineCompilationOptions::default(),
+        cache: None,
+    });
+    let up_pipeline = device.create_compute_pipeline(&backend_wgpu::ComputePipelineDescriptor {
+        label: Some("16AF.native_atlas_ffn.up_project.pipeline.cached"),
+        layout: Some(&pipeline_layout),
+        module: &up_shader,
+        entry_point: Some("up_project"),
+        compilation_options: backend_wgpu::PipelineCompilationOptions::default(),
+        cache: None,
+    });
+    let swiglu_pipeline = device.create_compute_pipeline(&backend_wgpu::ComputePipelineDescriptor {
+        label: Some("16AF.native_atlas_ffn.swiglu_project.pipeline.cached"),
+        layout: Some(&pipeline_layout),
+        module: &swiglu_shader,
+        entry_point: Some("swiglu_project"),
+        compilation_options: backend_wgpu::PipelineCompilationOptions::default(),
+        cache: None,
+    });
+    let down_pipeline = device.create_compute_pipeline(&backend_wgpu::ComputePipelineDescriptor {
+        label: Some("16AF.native_atlas_ffn.down_project.pipeline.cached"),
+        layout: Some(&pipeline_layout),
+        module: &down_shader,
+        entry_point: Some("down_project"),
+        compilation_options: backend_wgpu::PipelineCompilationOptions::default(),
+        cache: None,
+    });
+
+    Ok(GpuPipelines {
+        bind_group_layout,
+        gate_pipeline,
+        up_pipeline,
+        swiglu_pipeline,
+        down_pipeline,
+    })
+}
