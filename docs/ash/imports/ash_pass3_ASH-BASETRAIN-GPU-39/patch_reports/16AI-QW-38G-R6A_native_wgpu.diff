+fn qw38g_r6a_shader_debug_binding_surface(candidate_context: &str) {
+    if !qw38g_r6a_enabled() {
+        return;
+    }
+    if QW38G_R6A_DRY_RUN_DONE.fetch_add(1, Ordering::SeqCst) > 0 {
