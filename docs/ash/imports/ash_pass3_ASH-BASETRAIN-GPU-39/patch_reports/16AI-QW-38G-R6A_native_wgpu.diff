+    });
+    qw38g_r6a_write_json(&qw38g_r6a_receipt_path(), &receipt);
+    eprintln!("[16AI-QW-38G-R6A][map_written] path={}", qw38g_r6a_map_path());
+    eprintln!("[16AI-QW-38G-R6A][receipt_written] path={}", qw38g_r6a_receipt_path());
+    eprintln!("[16AI-QW-38G-R6A][done] status={}", status);
+}
