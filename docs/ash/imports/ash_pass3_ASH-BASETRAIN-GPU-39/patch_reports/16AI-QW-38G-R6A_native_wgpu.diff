+        .map(|v| !matches!(v.as_str(), "0" | "false" | "FALSE" | "no" | "NO"))
+        .unwrap_or(true)
+}
+
+fn qw38g_r6a_map_path() -> String {
+    std::env::var("ASH_SHADER_DEBUG_BINDING_MAP")
+        .unwrap_or_else(|_| "workspace/qw38g_r6a_debug_binding_map.json".to_string())
+}
+
+fn qw38g_r6a_receipt_path() -> String {
+    std::env::var("ASH_SHADER_DEBUG_BINDING_RECEIPT")
