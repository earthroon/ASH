+fn qw38g_r6a_write_map_and_receipt(status: &str, candidates: Vec<serde_json::Value>, surface_available: bool, warnings: Vec<String>, extra: serde_json::Value) {
+    let map_path = qw38g_r6a_map_path();
+    let receipt_path = qw38g_r6a_receipt_path();
+    let selected_candidate = if surface_available {
+        candidates.iter().find(|c| c.get("candidate_status").and_then(|v| v.as_str()) == Some("AVAILABLE_DRY_RUN")).cloned()
+    } else {
+        None
+    };
+    let pipeline_cache_key_extended = surface_available;
+    let shader_variant_required = surface_available;
+    let map = serde_json::json!({
+        "patch_id": "16AI-QW-38G-R6A",
+        "status": status,
+        "timestamp_unix_ms": qw38g_r3_now_ms(),
+        "enabled": qw38g_r6a_enabled(),
+        "dry_run": qw38g_r6a_dry_run(),
+        "max_bytes": qw38g_r6_max_bytes(),
+        "requested_group": qw38g_r6a_group_request(),
+        "requested_binding": qw38g_r6a_slot_request(),
+        "candidates": candidates,
+        "debug_binding_surface_available": surface_available,
+        "selected_candidate": selected_candidate.clone(),
+        "pipeline_cache_key_extended": pipeline_cache_key_extended,
+        "shader_variant_required": shader_variant_required,
+        "debug_write_performed": false,
+        "warning_codes": warnings,
+        "extra": extra,
+    });
+    qw38g_r6a_write_json(&map_path, &map);
+    let receipt = serde_json::json!({
+        "patch_id": "16AI-QW-38G-R6A",
+        "status": status,
+        "timestamp_unix_ms": qw38g_r3_now_ms(),
+        "enabled": qw38g_r6a_enabled(),
+        "dry_run": qw38g_r6a_dry_run(),
+        "debug_binding_surface_available": surface_available,
+        "selected_group": selected_candidate.as_ref().and_then(|c| c.get("bind_group_index")).cloned(),
+        "selected_binding": selected_candidate.as_ref().and_then(|c| c.get("binding_index")).cloned(),
+        "pipeline_cache_key_extended": pipeline_cache_key_extended,
+        "shader_variant_required": shader_variant_required,
+        "debug_write_performed": false,
+        "map_path": map_path,
+        "map_written": qw38g_r6a_path_written(&qw38g_r6a_map_path()),
