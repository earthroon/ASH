+    eprintln!(
+        "[16AI-QW-38G-R6A][env] enabled=true dry_run={} group={} slot={} max_bytes={}",
+        dry_run,
+        qw38g_r6a_group_request(),
+        qw38g_r6a_slot_request(),
+        max_bytes
+    );
+    eprintln!("[16AI-QW-38G-R6A][layout_scan_start] context={}", candidate_context);
+
+    if !dry_run {
+        qw38g_r6a_write_map_and_receipt(
+            "FAIL_DEBUG_BINDING_NON_DRY_RUN_REJECTED",
+            vec![serde_json::json!({
+                "pipeline_name": candidate_context,
+                "shader_name": "unknown",
+                "bind_group_index": null,
+                "binding_index": null,
+                "storage_buffer_allowed": false,
