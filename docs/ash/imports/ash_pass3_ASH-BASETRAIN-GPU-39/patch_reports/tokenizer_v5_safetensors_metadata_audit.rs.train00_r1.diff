+fn parse_shape(value: &Value) -> Vec<u64> {
+    value
+        .get("shape")
+        .and_then(Value::as_array)
+        .map(|shape| shape.iter().filter_map(Value::as_u64).collect())
+        .unwrap_or_default()
+}
+
+fn parse_offsets(value: &Value) -> Option<[u64; 2]> {
+    let offsets = value.get("data_offsets")?.as_array()?;
+    if offsets.len() != 2 {
+        return None;
+    }
+    Some([offsets[0].as_u64()?, offsets[1].as_u64()?])
+}
+
+fn element_count(shape: &[u64]) -> Option<u64> {
+    if shape.is_empty() {
+        return None;
+    }
+    let mut acc = 1u64;
+    for dim in shape {
+        acc = acc.checked_mul(*dim)?;
+    }
+    Some(acc)
+}
+
+fn tensor_summary(key: &str, value: &Value) -> QwTokTrain00R1TensorHeaderSummary {
+    let shape = parse_shape(value);
+    QwTokTrain00R1TensorHeaderSummary {
+        key: key.to_string(),
+        dtype: value.get("dtype").and_then(Value::as_str).map(str::to_string),
+        element_count: element_count(&shape),
+        data_offsets: parse_offsets(value),
+        shape,
+    }
+}
+
+fn collect_metadata_candidates(
+    metadata: &BTreeMap<String, String>,
+    candidate_keys: &[&str],
+) -> BTreeMap<String, String> {
+    let mut out = BTreeMap::new();
+    for key in candidate_keys {
+        if let Some(value) = metadata.get(*key) {
+            out.insert((*key).to_string(), value.clone());
+        }
+    }
+    out
+}
