+fn inspect_runtime_tokenizer(
+    path: &Path,
+    expected_vocab_size: usize,
+) -> QwTokTrain00R1RuntimeTokenizerAudit {
+    let mut failures = Vec::new();
+    let mut warnings = Vec::new();
+    let exists = path.exists();
+    let mut readable = false;
+    let mut tokenizer_id = None;
+    let mut manifest_id = None;
+    let mut tokenizer_spec_id = None;
+    let mut top_level_manifest_hash_present = false;
+    let mut vocab_len = None;
+    let mut hashes_manifest_hash = None;
+    let mut sentencepiece_model_hash = None;
+    let mut sentencepiece_vocab_hash = None;
+    let mut vocab_hash = None;
+    let mut reserved_tokens_hash_present = false;
+    let mut canonical_runtime_manifest_hash = None;
+
+    if exists {
+        match fs::read_to_string(path) {
+            Ok(text) => {
+                readable = true;
+                match serde_json::from_str::<Value>(text.trim_start_matches('\u{feff}')) {
+                    Ok(value) => {
+                        tokenizer_id = value.get("tokenizer_id").and_then(Value::as_str).map(str::to_string);
+                        manifest_id = value.get("manifest_id").and_then(Value::as_str).map(str::to_string);
+                        tokenizer_spec_id = value
+                            .get("tokenizer_spec_id")
+                            .and_then(Value::as_str)
+                            .map(str::to_string);
+                        top_level_manifest_hash_present = value.get("manifest_hash").is_some();
+                        vocab_len = value.get("vocab").and_then(Value::as_array).map(|v| v.len());
+                        if let Some(hashes) = value.get("hashes") {
+                            hashes_manifest_hash = hashes
+                                .get("manifest_hash")
+                                .and_then(Value::as_str)
+                                .map(str::to_string);
+                            sentencepiece_model_hash = hashes
+                                .get("sentencepiece_model_hash")
+                                .and_then(Value::as_str)
+                                .map(str::to_string);
+                            sentencepiece_vocab_hash = hashes
+                                .get("sentencepiece_vocab_hash")
+                                .and_then(Value::as_str)
+                                .map(str::to_string);
+                            vocab_hash = hashes.get("vocab_hash").and_then(Value::as_str).map(str::to_string);
+                            reserved_tokens_hash_present = hashes.get("reserved_tokens_hash").is_some();
+                        }
+                        canonical_runtime_manifest_hash = canonical_manifest_hash(&value);
+                    }
+                    Err(err) => failures.push(format!("tokenizer_manifest_json_parse_failed: {err}")),
+                }
+            }
+            Err(err) => failures.push(format!("tokenizer_manifest_read_failed: {err}")),
+        }
+    } else {
+        failures.push("tokenizer_manifest_missing".to_string());
+    }
+
+    if top_level_manifest_hash_present {
+        failures.push("top_level_manifest_hash_present".to_string());
+    }
+    if hashes_manifest_hash.is_none() {
+        failures.push("hashes_manifest_hash_missing".to_string());
+    }
+    if vocab_hash.is_none() {
+        warnings.push("hashes_vocab_hash_missing".to_string());
+    }
+    if vocab_len != Some(expected_vocab_size) {
+        failures.push("tokenizer_manifest_vocab_len_not_48259".to_string());
+    }
+
+    QwTokTrain00R1RuntimeTokenizerAudit {
+        path: path.display().to_string(),
+        exists,
+        readable,
+        tokenizer_id,
+        manifest_id,
+        tokenizer_spec_id,
+        top_level_manifest_hash_present,
+        vocab_len,
+        hashes_manifest_hash,
+        sentencepiece_model_hash,
+        sentencepiece_vocab_hash,
+        vocab_hash,
+        reserved_tokens_hash_present,
+        canonical_runtime_manifest_hash,
+        failures,
+        warnings,
+    }
+}
