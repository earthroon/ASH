+fn sha256_hex(bytes: &[u8]) -> String {
+    let mut hasher = Sha256::new();
+    hasher.update(bytes);
+    format!("{:x}", hasher.finalize())
+}
+
+fn canonical_manifest_hash(value: &Value) -> Option<String> {
+    let mut cloned = value.clone();
+    if let Some(obj) = cloned.as_object_mut() {
+        obj.remove("manifest_hash");
+        if let Some(hashes) = obj.get_mut("hashes").and_then(Value::as_object_mut) {
+            hashes.insert("manifest_hash".to_string(), Value::String(String::new()));
+        }
+    }
+    serde_json::to_vec(&cloned).ok().map(|bytes| sha256_hex(&bytes))
+}
+
+fn value_to_string(value: &Value) -> String {
+    value
+        .as_str()
+        .map(str::to_string)
+        .unwrap_or_else(|| value.to_string())
+}
