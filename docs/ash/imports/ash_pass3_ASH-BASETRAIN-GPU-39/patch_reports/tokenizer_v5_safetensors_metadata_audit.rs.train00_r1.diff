+fn inspect_checkpoint_header(path: &Path) -> QwTokTrain00R1CheckpointHeaderAudit {
+    let mut failures = Vec::new();
+    let mut warnings = Vec::new();
+    let exists = path.exists();
+    let mut readable = false;
+    let mut file_size_bytes = None;
+    let mut header_length_bytes = None;
+    let mut metadata_available = false;
+    let mut metadata = BTreeMap::new();
+    let mut tensor_key_count = 0usize;
+    let mut tensor_keys_first_32 = Vec::new();
+    let mut tensor_shape_summary = Vec::new();
+    let mut embedding_tensor_candidates = Vec::new();
+    let mut lm_head_tensor_candidates = Vec::new();
+
+    if exists {
+        match fs::metadata(path) {
+            Ok(meta) => file_size_bytes = Some(meta.len()),
+            Err(err) => warnings.push(format!("checkpoint_stat_failed: {err}")),
+        }
+        match File::open(path) {
+            Ok(mut file) => {
+                readable = true;
+                let mut len_buf = [0u8; 8];
+                if let Err(err) = file.read_exact(&mut len_buf) {
+                    failures.push(format!("safetensors_header_len_read_failed: {err}"));
+                } else {
+                    let header_len = u64::from_le_bytes(len_buf);
+                    header_length_bytes = Some(header_len);
+                    let mut header_bytes = vec![0u8; header_len as usize];
+                    if let Err(err) = file.read_exact(&mut header_bytes) {
+                        failures.push(format!("safetensors_header_read_failed: {err}"));
+                    } else {
+                        match serde_json::from_slice::<Value>(&header_bytes) {
+                            Ok(header) => {
+                                if let Some(meta_obj) = header.get("__metadata__").and_then(Value::as_object) {
+                                    metadata_available = true;
+                                    for (key, value) in meta_obj {
+                                        metadata.insert(key.clone(), value_to_string(value));
+                                    }
+                                } else {
+                                    warnings.push("safetensors_header_has_no___metadata__".to_string());
+                                }
+                                if let Some(obj) = header.as_object() {
+                                    let mut tensor_keys = obj
+                                        .keys()
+                                        .filter(|key| key.as_str() != "__metadata__")
+                                        .cloned()
+                                        .collect::<Vec<_>>();
+                                    tensor_keys.sort();
+                                    tensor_key_count = tensor_keys.len();
+                                    tensor_keys_first_32 = tensor_keys.iter().take(32).cloned().collect();
+                                    for key in tensor_keys.iter().take(128) {
+                                        if let Some(value) = obj.get(key) {
+                                            let summary = tensor_summary(key, value);
+                                            let lower = key.to_ascii_lowercase();
+                                            if lower.contains("embed") || lower.contains("tok_embeddings") {
+                                                embedding_tensor_candidates.push(summary.clone());
+                                            }
+                                            if lower.contains("lm_head") || lower.contains("output") {
+                                                lm_head_tensor_candidates.push(summary.clone());
+                                            }
+                                            tensor_shape_summary.push(summary);
+                                        }
+                                    }
+                                }
+                            }
+                            Err(err) => failures.push(format!("safetensors_header_json_parse_failed: {err}")),
+                        }
+                    }
+                }
+            }
+            Err(err) => failures.push(format!("checkpoint_open_failed: {err}")),
+        }
+    } else {
+        warnings.push("checkpoint_file_missing_audit_pending".to_string());
+    }
+
+    let checkpoint_tokenizer_hash_candidates = collect_metadata_candidates(
+        &metadata,
+        &[
+            "tokenizer_hash",
+            "tokenizer_manifest_hash",
+            "runtime_tokenizer_hash",
+            "source_tokenizer_hash",
+        ],
+    );
+    let checkpoint_manifest_hash_candidates = collect_metadata_candidates(
+        &metadata,
+        &[
+            "manifest_hash",
+            "checkpoint_manifest_hash",
+            "tokenizer_manifest_hash",
+        ],
+    );
+    let checkpoint_vocab_hash_candidates = collect_metadata_candidates(
+        &metadata,
+        &[
+            "vocab_hash",
+            "sentencepiece_vocab_hash",
+            "tokenizer_vocab_hash",
+        ],
+    );
+    let checkpoint_model_spec_id = metadata.get("model_spec_id").cloned();
+    let checkpoint_vocab_size = metadata.get("vocab_size").cloned();
+    let metadata_keys = metadata.keys().cloned().collect();
+
+    QwTokTrain00R1CheckpointHeaderAudit {
+        path: path.display().to_string(),
+        exists,
+        readable,
+        file_size_bytes,
+        header_length_bytes,
+        header_bytes_read_only: true,
+        tensor_payload_loaded: false,
+        metadata_available,
+        metadata,
+        metadata_keys,
+        checkpoint_tokenizer_hash_candidates,
+        checkpoint_manifest_hash_candidates,
+        checkpoint_vocab_hash_candidates,
+        checkpoint_model_spec_id,
+        checkpoint_vocab_size,
+        tensor_key_count,
+        tensor_keys_first_32,
+        tensor_shape_summary,
+        embedding_tensor_candidates,
+        lm_head_tensor_candidates,
+        failures,
+        warnings,
+    }
+}
+
+fn runtime_hash_candidates(
+    runtime: &QwTokTrain00R1RuntimeTokenizerAudit,
+) -> BTreeMap<String, String> {
+    let mut out = BTreeMap::new();
+    if let Some(value) = &runtime.hashes_manifest_hash {
+        out.insert("runtime.hashes.manifest_hash".to_string(), value.clone());
+    }
+    if let Some(value) = &runtime.canonical_runtime_manifest_hash {
+        out.insert("runtime.canonical_manifest_hash".to_string(), value.clone());
+    }
+    if let Some(value) = &runtime.vocab_hash {
+        out.insert("runtime.hashes.vocab_hash".to_string(), value.clone());
+    }
+    if let Some(value) = &runtime.sentencepiece_vocab_hash {
+        out.insert("runtime.hashes.sentencepiece_vocab_hash".to_string(), value.clone());
+    }
+    if let Some(value) = &runtime.sentencepiece_model_hash {
+        out.insert("runtime.hashes.sentencepiece_model_hash".to_string(), value.clone());
+    }
+    out
+}
+
+fn checkpoint_hash_candidates(
+    checkpoint: &QwTokTrain00R1CheckpointHeaderAudit,
+) -> BTreeMap<String, String> {
+    let mut out = BTreeMap::new();
+    for (key, value) in &checkpoint.checkpoint_tokenizer_hash_candidates {
+        out.insert(format!("checkpoint.metadata.{key}"), value.clone());
+    }
+    for (key, value) in &checkpoint.checkpoint_manifest_hash_candidates {
+        out.insert(format!("checkpoint.metadata.{key}"), value.clone());
+    }
+    for (key, value) in &checkpoint.checkpoint_vocab_hash_candidates {
+        out.insert(format!("checkpoint.metadata.{key}"), value.clone());
+    }
+    out
+}
+
+fn build_hash_matrix(
+    checkpoint: &QwTokTrain00R1CheckpointHeaderAudit,
+    runtime: &QwTokTrain00R1RuntimeTokenizerAudit,
+) -> QwTokTrain00R1HashMismatchMatrix {
+    let checkpoint_candidates = checkpoint_hash_candidates(checkpoint);
+    let runtime_candidates = runtime_hash_candidates(runtime);
+    let mut rows = Vec::new();
+    for (ck, cv) in &checkpoint_candidates {
+        for (rk, rv) in &runtime_candidates {
+            rows.push(QwTokTrain00R1HashComparisonRow {
+                checkpoint_key: ck.clone(),
+                checkpoint_value: cv.clone(),
+                runtime_key: rk.clone(),
+                runtime_value: rv.clone(),
+                match_observed: cv == rv,
+            });
+        }
+    }
+    let comparison_known = !rows.is_empty();
+    let any_match = rows.iter().any(|row| row.match_observed);
+    let mismatch_observed = comparison_known && rows.iter().any(|row| !row.match_observed);
+    let mut warnings = Vec::new();
+    if !comparison_known {
+        warnings.push("no_checkpoint_runtime_hash_pair_available".to_string());
+    } else if !any_match {
+        warnings.push("checkpoint_runtime_hash_mismatch_no_matching_candidate".to_string());
+    }
+    QwTokTrain00R1HashMismatchMatrix {
+        comparison_known,
+        any_match,
+        mismatch_observed,
+        rows,
+        warnings,
+    }
+}
+
+fn build_rebind_candidate(
+    cfg: &QwTokTrain00R1Config,
+    model_spec: &QwTokTrain00R1ModelSpecAudit,
+    runtime: &QwTokTrain00R1RuntimeTokenizerAudit,
+    checkpoint: &QwTokTrain00R1CheckpointHeaderAudit,
+    matrix: &QwTokTrain00R1HashMismatchMatrix,
+) -> QwTokTrain00R1RebindCandidateManifest {
+    let mut runtime_tokenizer = BTreeMap::new();
+    if let Some(value) = &runtime.tokenizer_id {
+        runtime_tokenizer.insert("tokenizer_id".to_string(), value.clone());
+    }
+    if let Some(value) = &runtime.manifest_id {
+        runtime_tokenizer.insert("manifest_id".to_string(), value.clone());
+    }
+    if let Some(value) = &runtime.tokenizer_spec_id {
+        runtime_tokenizer.insert("tokenizer_spec_id".to_string(), value.clone());
+    }
+    if let Some(value) = &runtime.hashes_manifest_hash {
+        runtime_tokenizer.insert("tokenizer_manifest_hash".to_string(), value.clone());
+    }
+    if let Some(value) = &runtime.vocab_hash {
+        runtime_tokenizer.insert("vocab_hash".to_string(), value.clone());
+    }
+
+    let mut recommended_metadata_after = BTreeMap::new();
+    if let Some(value) = &runtime.tokenizer_id {
+        recommended_metadata_after.insert("tokenizer_id".to_string(), value.clone());
+    }
+    if let Some(value) = &runtime.hashes_manifest_hash {
+        recommended_metadata_after.insert("tokenizer_manifest_hash".to_string(), value.clone());
+        recommended_metadata_after.insert("tokenizer_hash".to_string(), value.clone());
+    }
+    if let Some(value) = &runtime.vocab_hash {
+        recommended_metadata_after.insert("vocab_hash".to_string(), value.clone());
+    }
+    if let Some(value) = &model_spec.model_spec_id {
+        recommended_metadata_after.insert("model_spec_id".to_string(), value.clone());
+    }
+    if let Some(value) = model_spec.vocab_size {
+        recommended_metadata_after.insert("vocab_size".to_string(), value.to_string());
+    }
+
+    let recommendation_status = if !checkpoint.exists {
+        "PENDING_CHECKPOINT_FILE_MISSING".to_string()
+    } else if !matrix.comparison_known {
+        "CANDIDATE_AVAILABLE_METADATA_KEY_ABSENT".to_string()
+    } else if matrix.any_match && !matrix.mismatch_observed {
+        "NO_REBIND_NEEDED_HASH_ALREADY_MATCHED".to_string()
+    } else if matrix.any_match {
+        "REVIEW_REQUIRED_PARTIAL_HASH_MATCH".to_string()
+    } else {
+        "REVIEW_REQUIRED_REBIND_CANDIDATE".to_string()
+    };
+
+    QwTokTrain00R1RebindCandidateManifest {
+        patch_id: QW_TOK_TRAIN00_R1_PATCH_ID.to_string(),
+        candidate_for: "QW-TOK-TRAIN-00-R2".to_string(),
+        checkpoint_path: cfg.checkpoint_path.clone(),
+        metadata_commit_executed: false,
+        checkpoint_rewrite_executed: false,
+        weight_tensor_mutation_executed: false,
+        tensor_payload_loaded: false,
+        requires_operator_approval: true,
+        runtime_tokenizer,
+        checkpoint_metadata_before: checkpoint.metadata.clone(),
+        recommended_metadata_after,
+        recommendation_status,
+    }
+}
+
+pub fn run_qw_tok_train00_r1_safetensors_metadata_audit(
+    cfg: QwTokTrain00R1Config,
+) -> Result<QwTokTrain00R1AuditReport> {
+    if cfg.allow_training
+        || cfg.allow_weight_mutation
+        || cfg.allow_checkpoint_rewrite
+        || cfg.allow_metadata_commit
+        || cfg.allow_decode_execution
+    {
+        anyhow::bail!(
+            "QW-TOK-TRAIN-00-R1 forbids training, mutation, checkpoint rewrite, metadata commit, and decode execution"
+        );
+    }
+
+    let model_spec = inspect_model_spec(Path::new(&cfg.model_spec_path), &cfg);
+    let runtime_tokenizer = inspect_runtime_tokenizer(Path::new(&cfg.tokenizer_manifest_path), cfg.expected_vocab_size);
+    let checkpoint_header = inspect_checkpoint_header(Path::new(&cfg.checkpoint_path));
+    let hash_mismatch_matrix = build_hash_matrix(&checkpoint_header, &runtime_tokenizer);
+    let rebind_candidate = build_rebind_candidate(
+        &cfg,
+        &model_spec,
+        &runtime_tokenizer,
+        &checkpoint_header,
+        &hash_mismatch_matrix,
+    );
+    let no_mutation = QwTokTrain00R1NoMutationReceipt::default();
+
+    let mut failures = Vec::new();
+    failures.extend(model_spec.failures.clone());
+    failures.extend(runtime_tokenizer.failures.clone());
+    failures.extend(checkpoint_header.failures.clone());
+
+    let mut warnings = Vec::new();
+    warnings.extend(model_spec.warnings.clone());
+    warnings.extend(runtime_tokenizer.warnings.clone());
+    warnings.extend(checkpoint_header.warnings.clone());
+    warnings.extend(hash_mismatch_matrix.warnings.clone());
+
+    let critical_pass = failures.is_empty()
+        && model_spec.model_spec_id_match
+        && model_spec.vocab_size_match
+        && !runtime_tokenizer.top_level_manifest_hash_present
+        && runtime_tokenizer.hashes_manifest_hash.is_some()
+        && runtime_tokenizer.vocab_len == Some(cfg.expected_vocab_size)
+        && checkpoint_header.header_bytes_read_only
+        && !checkpoint_header.tensor_payload_loaded
+        && !no_mutation.weight_tensor_mutation_executed
+        && !no_mutation.checkpoint_rewrite_executed
+        && !no_mutation.metadata_commit_executed;
+
+    let status = if critical_pass && checkpoint_header.exists && hash_mismatch_matrix.comparison_known {
+        if hash_mismatch_matrix.any_match && !hash_mismatch_matrix.mismatch_observed {
+            "PASS_QW_TOK_TRAIN00_R1_METADATA_HASH_MATCH_AUDIT"
+        } else {
+            "PASS_QW_TOK_TRAIN00_R1_REBIND_CANDIDATE_REVIEW_REQUIRED"
+        }
+    } else if critical_pass {
+        "PARTIAL_QW_TOK_TRAIN00_R1_AUDIT_PENDING_CHECKPOINT_OR_HASH_KEYS"
+    } else {
+        "FAIL_QW_TOK_TRAIN00_R1_METADATA_AUDIT"
+    }
+    .to_string();
+
+    Ok(QwTokTrain00R1AuditReport {
+        patch_id: QW_TOK_TRAIN00_R1_PATCH_ID.to_string(),
+        title: QW_TOK_TRAIN00_R1_TITLE.to_string(),
+        status,
+        no_training_seal: true,
+        no_weight_mutation_seal: true,
+        no_checkpoint_rewrite_seal: true,
+        model_spec,
+        runtime_tokenizer,
+        checkpoint_header,
+        hash_mismatch_matrix,
+        rebind_candidate,
+        no_mutation,
+        failures,
+        warnings,
+    })
+}
+
+fn write_json<T: Serialize>(path: &Path, value: &T) -> Result<()> {
+    if let Some(parent) = path.parent() {
+        fs::create_dir_all(parent)?;
+    }
+    fs::write(path, serde_json::to_vec_pretty(value)?)
+        .with_context(|| format!("failed to write {}", path.display()))?;
+    Ok(())
+}
+
+pub fn write_qw_tok_train00_r1_artifacts(root: &Path, report: &QwTokTrain00R1AuditReport) -> Result<()> {
+    write_json(&root.join(QW_TOK_TRAIN00_R1_REPORT_PATH), report)?;
+    write_json(
+        &root.join(QW_TOK_TRAIN00_R1_HEADER_RECEIPT_PATH),
+        &report.checkpoint_header,
+    )?;
+    write_json(
+        &root.join(QW_TOK_TRAIN00_R1_RUNTIME_RECEIPT_PATH),
+        &report.runtime_tokenizer,
+    )?;
+    write_json(
+        &root.join(QW_TOK_TRAIN00_R1_MISMATCH_MATRIX_PATH),
+        &report.hash_mismatch_matrix,
+    )?;
+    write_json(
+        &root.join(QW_TOK_TRAIN00_R1_REBIND_CANDIDATE_PATH),
+        &report.rebind_candidate,
+    )?;
+    write_json(
+        &root.join(QW_TOK_TRAIN00_R1_NO_MUTATION_RECEIPT_PATH),
+        &report.no_mutation,
+    )?;
+    Ok(())
+}
