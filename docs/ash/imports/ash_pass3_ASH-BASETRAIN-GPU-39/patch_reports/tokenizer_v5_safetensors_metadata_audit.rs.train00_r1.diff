+pub fn qw_tok_train00_r1_config_from_args(args: &[String]) -> QwTokTrain00R1Config {
+    let mut cfg = QwTokTrain00R1Config::default();
+    let mut iter = args.iter();
+    while let Some(arg) = iter.next() {
+        match arg.as_str() {
+            "--model-spec" => {
+                if let Some(v) = iter.next() {
+                    cfg.model_spec_path = v.clone();
+                }
+            }
+            "--tokenizer" | "--tokenizer-manifest" => {
+                if let Some(v) = iter.next() {
+                    cfg.tokenizer_manifest_path = v.clone();
+                }
+            }
+            "--checkpoint" => {
+                if let Some(v) = iter.next() {
+                    cfg.checkpoint_path = v.clone();
+                }
+            }
+            "--out" => {
+                if let Some(v) = iter.next() {
+                    cfg.out_path = v.clone();
+                }
+            }
+            _ => {}
+        }
+    }
+    cfg
+}
