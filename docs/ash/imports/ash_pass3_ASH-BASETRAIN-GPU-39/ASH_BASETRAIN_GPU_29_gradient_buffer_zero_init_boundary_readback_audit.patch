+        readback_element_count: values.len(),
+        all_readback_bytes_zero: non_zero_byte_count == 0,
+        all_readback_f32_zero: non_zero_f32_count == 0,
+        non_zero_byte_count,
+        non_zero_f32_count,
+        max_abs_f32_value,
+        nan_count,
+        inf_count,
+        actual_zero_digest_hex,
+        runtime_error: None,
+    })
+}
+
+fn bytes_to_f32_values(bytes: &[u8]) -> Vec<f32> {
+    bytes
+        .chunks_exact(4)
+        .map(|chunk| {
+            let mut arr = [0_u8; 4];
+            arr.copy_from_slice(chunk);
+            f32::from_le_bytes(arr)
+        })
+        .collect()
+}
