+async fn execute_zero_state_boundary_readback_audit() -> Result<ZeroReadbackReceipts, String> {
+    use wgpu26 as wgpu;
+
+    let instance = wgpu::Instance::default();
+    let adapter = instance
+        .request_adapter(&wgpu::RequestAdapterOptions {
+            power_preference: wgpu::PowerPreference::HighPerformance,
+            compatible_surface: None,
+            force_fallback_adapter: false,
+        })
+        .await
+        .map_err(|err| format!("request_adapter failed: {err}"))?;
+
+    let device_queue = adapter
+        .request_device(&wgpu::DeviceDescriptor {
+            label: Some("ash-basetrain-gpu-29-zero-init-boundary-readback-device"),
+            required_features: wgpu::Features::empty(),
+            required_limits: wgpu::Limits::downlevel_defaults(),
+            memory_hints: wgpu::MemoryHints::Performance,
+            ..Default::default()
+        })
+        .await
+        .map_err(|err| format!("request_device failed: {err}"))?;
+    let (device, queue) = device_queue;
+
+    let gradient_buffer = device.create_buffer(&wgpu::BufferDescriptor {
+        label: Some(BUFFER_LABEL),
+        size: GRADIENT_BYTES as u64,
+        usage: wgpu::BufferUsages::STORAGE | wgpu::BufferUsages::COPY_SRC | wgpu::BufferUsages::COPY_DST,
+        mapped_at_creation: false,
+    });
+
+    let readback_buffer = device.create_buffer(&wgpu::BufferDescriptor {
+        label: Some(READBACK_BUFFER_LABEL),
+        size: GRADIENT_BYTES as u64,
+        usage: wgpu::BufferUsages::COPY_DST | wgpu::BufferUsages::MAP_READ,
+        mapped_at_creation: false,
+    });
+
+    let mut encoder = device.create_command_encoder(&wgpu::CommandEncoderDescriptor {
+        label: Some("ash-basetrain-gpu-29-zero-state-readback-copy-encoder"),
+    });
+    encoder.copy_buffer_to_buffer(&gradient_buffer, 0, &readback_buffer, 0, GRADIENT_BYTES as u64);
+    queue.submit(Some(encoder.finish()));
+
+    let buffer_slice = readback_buffer.slice(..);
+    let (sender, receiver) = mpsc::channel();
+    buffer_slice.map_async(wgpu::MapMode::Read, move |result| {
+        let _ = sender.send(result);
+    });
+    let _ = device.poll(wgpu::PollType::Wait);
+    let map_status = receiver
+        .recv()
+        .map_err(|err| format!("map_async receiver failed: {err}"))
+        .and_then(|result| result.map_err(|err| format!("map_async failed: {err}")));
+    map_status?;
+
+    let mapped = buffer_slice.get_mapped_range();
+    let readback_bytes_vec = mapped.to_vec();
+    drop(mapped);
+    readback_buffer.unmap();
+
+    let values = bytes_to_f32_values(&readback_bytes_vec);
+    let non_zero_byte_count = readback_bytes_vec.iter().filter(|byte| **byte != 0).count();
+    let non_zero_f32_count = values.iter().filter(|value| **value != 0.0).count();
+    let max_abs_f32_value = values.iter().fold(0.0_f32, |acc, value| acc.max(value.abs()));
+    let nan_count = values.iter().filter(|value| value.is_nan()).count();
+    let inf_count = values.iter().filter(|value| value.is_infinite()).count();
+    let actual_zero_digest_hex = sha256_hex(&readback_bytes_vec);
+
+    Ok(ZeroReadbackReceipts {
+        gpu_runtime_available: true,
+        gpu_adapter_acquired: true,
+        gpu_device_acquired: true,
+        gpu_queue_acquired: true,
+        source_gradient_buffer_created: true,
+        readback_buffer_created: true,
+        copy_buffer_to_buffer_executed: true,
+        queue_submit_executed_for_readback_copy: true,
+        queue_submit_used_for_compute: false,
+        readback_map_async_executed: true,
+        gradient_compute_dispatch_executed: false,
+        backward_compute_dispatch_executed: false,
