+        && candidate.target_probability >= 0.0
+        && candidate.target_probability <= 1.0
+        && candidate.candidate_nan_count == 0
+        && candidate.candidate_inf_count == 0;
+    let cpu_candidate_valid = candidate.candidate_bytes.len() == GRADIENT_BYTES
+        && candidate.candidate_finite_count == WINDOW_SIZE
+        && candidate.target_index_gradient_expected_negative
+        && candidate.non_target_gradient_expected_non_negative;
+    let cpu_candidate_digest_valid = candidate.candidate_digest_hex.len() == 64;
+    let gpu_no_write_guard_valid = true;
+    let model_weight_gradient_denylist_valid = true;
+    let body_training_claim_guard_valid = true;
+    let backward_optimizer_mutation_boundary_opened = false;
+    let static_rules_valid = true;
+
+    let violation_mask = ((!source_29_valid) as u32)
+        | (((!formula_input_binding_valid) as u32) << 1)
+        | (((!numerical_stability_valid) as u32) << 2)
+        | (((!cpu_candidate_valid) as u32) << 3)
+        | (((!cpu_candidate_digest_valid) as u32) << 4)
+        | (((!gpu_no_write_guard_valid) as u32) << 5)
+        | (((!model_weight_gradient_denylist_valid) as u32) << 6)
+        | (((!body_training_claim_guard_valid) as u32) << 7)
+        | ((backward_optimizer_mutation_boundary_opened as u32) << 8)
+        | (((!static_rules_valid) as u32) << 9);
+
+    let primary_blocker_index = ((violation_mask != 0) as usize) * ((violation_mask.trailing_zeros() as usize) + 1);
+    let verdict_lut = verdict_lut();
+    let status_lut = status_lut();
+    let verdict = verdict_lut[violation_mask as usize].clone();
+    let status = status_lut[violation_mask as usize].clone();
+    let pass = violation_mask == 0;
+
+    let mut atlas = Map::new();
+    ins(&mut atlas, "patch_id", PATCH_ID);
+    ins(&mut atlas, "title", TITLE);
+    atlas.insert("cpu_logits_gradient_formula_receipt_state".into(), build_state_tile(&payload, &candidate, violation_mask, &verdict, pass));
+    atlas.insert("source_29_validation".into(), build_source_29_validation_tile());
+    atlas.insert("formula_contract".into(), build_formula_contract_tile());
+    atlas.insert("formula_input_binding".into(), build_formula_input_binding_tile(&payload));
+    atlas.insert("numerical_stability_contract".into(), build_numerical_stability_contract_tile(&candidate));
+    atlas.insert("cpu_logits_gradient_candidate_receipt".into(), build_cpu_logits_gradient_candidate_receipt_tile(&candidate));
+    atlas.insert("candidate_stats".into(), build_candidate_stats_tile(&candidate));
+    atlas.insert("cpu_candidate_digest_receipt".into(), build_cpu_candidate_digest_receipt_tile(&candidate));
+    atlas.insert("gpu_no_write_guard".into(), build_gpu_no_write_guard_tile());
+    atlas.insert("model_weight_gradient_denylist_revalidation".into(), build_model_weight_gradient_denylist_revalidation_tile());
+    atlas.insert("body_training_claim_guard_revalidation".into(), build_body_training_claim_guard_revalidation_tile());
+    atlas.insert("no_backward_no_optimizer_contract".into(), build_no_backward_no_optimizer_contract_tile());
+    atlas.insert("control_flow_lut_receipt".into(), build_control_flow_lut_receipt_tile(violation_mask, primary_blocker_index, &status));
+    atlas.insert("verdict_lut_receipt".into(), build_verdict_lut_receipt_tile(&verdict, violation_mask));
+    atlas.insert("operator_run_packet".into(), build_operator_run_packet_tile());
+    ins(&mut atlas, "pass", pass);
+    ins(&mut atlas, "verdict", verdict);
+    Ok(Value::Object(atlas))
+}
