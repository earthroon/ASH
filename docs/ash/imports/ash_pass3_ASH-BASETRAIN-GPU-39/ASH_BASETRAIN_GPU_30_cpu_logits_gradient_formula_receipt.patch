+fn read_payload_source() -> Result<PayloadSource, String> {
+    let path = env::var(RAW_LOGITS_ENV_KEY).map_err(|err| format!("{RAW_LOGITS_ENV_KEY} missing: {err}"))?;
+    let bytes = fs::read(&path).map_err(|err| format!("payload read failed: {err}"))?;
+    (bytes.len() == GRADIENT_BYTES)
+        .then_some(())
+        .ok_or_else(|| format!("payload byte length mismatch: got {}, expected {GRADIENT_BYTES}", bytes.len()))?;
+    let digest_hex = sha256_hex(&bytes);
+    let values = bytes_to_f32_values(&bytes)?;
+    Ok(PayloadSource { path, bytes, digest_hex, values })
+}
+
+fn bytes_to_f32_values(bytes: &[u8]) -> Result<Vec<f32>, String> {
+    (bytes.len() % 4 == 0)
+        .then_some(())
+        .ok_or_else(|| "payload bytes not divisible by f32 width".to_string())?;
+    let values = bytes
+        .chunks_exact(4)
+        .map(|chunk| {
+            let mut word = [0u8; 4];
+            word.copy_from_slice(chunk);
+            f32::from_le_bytes(word)
+        })
+        .collect::<Vec<f32>>();
+    Ok(values)
+}
+
+fn compute_cpu_logits_gradient_candidate(values: &[f32]) -> Result<CpuCandidate, String> {
+    (values.len() == WINDOW_SIZE)
+        .then_some(())
+        .ok_or_else(|| format!("window size mismatch: got {}, expected {WINDOW_SIZE}", values.len()))?;
+    let max_logit = values.iter().copied().fold(f32::NEG_INFINITY, f32::max);
+    max_logit
+        .is_finite()
+        .then_some(())
+        .ok_or_else(|| "max logit is not finite".to_string())?;
+    let exp_values = values
+        .iter()
+        .map(|value| ((*value as f64) - (max_logit as f64)).exp())
+        .collect::<Vec<f64>>();
+    let sum_exp = exp_values.iter().copied().sum::<f64>();
+    (sum_exp.is_finite() && sum_exp > 0.0)
+        .then_some(())
+        .ok_or_else(|| format!("sum_exp invalid: {sum_exp}"))?;
+    let probabilities = exp_values
+        .iter()
+        .map(|value| (*value / sum_exp) as f32)
+        .collect::<Vec<f32>>();
+    let gradients = probabilities
+        .iter()
+        .enumerate()
+        .map(|(index, probability)| *probability - ((index == TARGET_INDEX) as u8 as f32))
+        .collect::<Vec<f32>>();
+    let probability_sum = probabilities.iter().map(|value| *value as f64).sum::<f64>();
+    let gradient_sum = gradients.iter().map(|value| *value as f64).sum::<f64>();
+    let target_probability = probabilities[TARGET_INDEX];
+    let target_gradient = gradients[TARGET_INDEX];
+    let candidate_nan_count = gradients.iter().filter(|value| value.is_nan()).count();
+    let candidate_inf_count = gradients.iter().filter(|value| value.is_infinite()).count();
+    let candidate_finite_count = gradients.iter().filter(|value| value.is_finite()).count();
+    let candidate_min = gradients.iter().copied().fold(f32::INFINITY, f32::min);
+    let candidate_max = gradients.iter().copied().fold(f32::NEG_INFINITY, f32::max);
+    let candidate_abs_max = gradients.iter().map(|value| value.abs()).fold(0.0_f32, f32::max);
+    let non_target_gradient_expected_non_negative = gradients
+        .iter()
+        .enumerate()
+        .filter(|(index, _)| *index != TARGET_INDEX)
+        .all(|(_, value)| *value >= 0.0);
+    let mut candidate_bytes = Vec::with_capacity(GRADIENT_BYTES);
+    gradients
+        .iter()
+        .for_each(|value| candidate_bytes.extend_from_slice(&value.to_le_bytes()));
+    let candidate_digest_hex = sha256_hex(&candidate_bytes);
+    Ok(CpuCandidate {
+        max_logit,
+        sum_exp,
+        probability_sum,
+        gradient_sum,
+        target_probability,
+        target_gradient,
+        candidate_digest_hex,
+        candidate_bytes,
+        candidate_nan_count,
+        candidate_inf_count,
+        candidate_finite_count,
+        candidate_min,
+        candidate_max,
+        candidate_abs_max,
+        target_index_gradient_expected_negative: target_gradient < 0.0,
+        non_target_gradient_expected_non_negative,
+    })
+}
