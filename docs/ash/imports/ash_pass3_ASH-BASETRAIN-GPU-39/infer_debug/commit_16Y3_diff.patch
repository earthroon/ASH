+    fn project_last_hidden_to_logits_vocab_atlas(
+        &self,
+        last_hidden: Tensor<NativeInferenceBackend, 2>,
+        atlas: &NativeVocabAtlas,
+    ) -> Tensor<NativeInferenceBackend, 2> {
+        let mut merged_logits = Vec::with_capacity(atlas.vocab_size);
+        let mut best_token_id = 0usize;
+        let mut best_logit = f32::NEG_INFINITY;
+
+        for tile in &atlas.tiles {
+            let tile_logits = last_hidden
+                .clone()
+                .matmul(tile.weight.clone().swap_dims(0, 1))
+                .reshape([tile.token_len]);
+            let tile_row = tile_logits
+                .into_data()
+                .to_vec::<f32>()
+                .expect("failed to materialize native vocab atlas tile logits");
+
+            for (local_id, logit) in tile_row.iter().copied().enumerate() {
+                if logit.is_finite() && logit > best_logit {
+                    best_logit = logit;
+                    best_token_id = tile.token_start + local_id;
+                }
+            }
+            merged_logits.extend_from_slice(&tile_row);
+        }
+
+        eprintln!(
+            "[native-vocab-atlas] tile_argmax token_id={} logit={} tile_count={} vocab={} full_vocab_bytes={}",
+            best_token_id,
+            best_logit,
+            atlas.tiles.len(),
+            atlas.vocab_size,
+            atlas.full_vocab_bytes,
+        );
+
+        Tensor::<NativeInferenceBackend, 2>::from_data(
+            TensorData::new(merged_logits, [1, atlas.vocab_size]),
+            &self.device,
+        )
+    }
