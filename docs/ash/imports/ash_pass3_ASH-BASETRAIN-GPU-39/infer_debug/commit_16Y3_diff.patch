+// Commit 16Y-3: lm_head is represented as a vocab atlas instead of a single
+// giant [vocab, hidden] WebGPU tensor when nativeVocabProjection=gpu_atlas.
+pub struct NativeVocabTile {
+    pub tile_id: usize,
+    pub token_start: usize,
+    pub token_len: usize,
+    pub hidden_size: usize,
+    pub bytes: usize,
+    pub weight: Tensor<NativeInferenceBackend, 2>,
+}
+
+pub struct NativeVocabAtlas {
+    pub vocab_size: usize,
+    pub hidden_size: usize,
+    pub tile_vocab: usize,
+    pub full_vocab_bytes: usize,
+    pub tiles: Vec<NativeVocabTile>,
+}
+
+fn build_native_vocab_atlas(
+    lm_head_cpu: &[f32],
+    vocab_size: usize,
+    hidden_size: usize,
+    tile_vocab: usize,
+    max_single_buffer_bytes: usize,
+    device: &WgpuDevice,
+) -> Result<NativeVocabAtlas> {
+    ensure!(tile_vocab > 0, "native vocab tile size must be > 0");
+    ensure!(hidden_size > 0, "native vocab atlas hidden size must be > 0");
+    ensure!(
+        lm_head_cpu.len() == vocab_size.saturating_mul(hidden_size),
+        "lm_head size mismatch for vocab atlas: got={} expected={}",
+        lm_head_cpu.len(),
+        vocab_size.saturating_mul(hidden_size),
+    );
+
+    let full_vocab_bytes = lm_head_cpu.len().saturating_mul(std::mem::size_of::<f32>());
+    let mut tiles = Vec::new();
+    let mut token_start = 0usize;
+
+    while token_start < vocab_size {
+        let tile_id = tiles.len();
+        let token_len = tile_vocab.min(vocab_size - token_start);
+        let row_start = token_start * hidden_size;
+        let row_end = row_start + token_len * hidden_size;
+        let tile_slice = &lm_head_cpu[row_start..row_end];
+        let bytes = tile_slice.len().saturating_mul(std::mem::size_of::<f32>());
+
+        ensure!(
+            bytes <= max_single_buffer_bytes,
+            "vocab atlas tile too large: tile={} bytes={} max={}",
+            tile_id,
+            bytes,
+            max_single_buffer_bytes,
+        );
+
+        eprintln!(
+            "[native-vocab-atlas] tile={} token_start={} token_len={} hidden={} bytes={}",
+            tile_id,
+            token_start,
+            token_len,
+            hidden_size,
+            bytes,
+        );
+
+        let weight = Tensor::<NativeInferenceBackend, 2>::from_data(
+            TensorData::new(tile_slice.to_vec(), [token_len, hidden_size]),
+            device,
+        );
+
+        tiles.push(NativeVocabTile {
+            tile_id,
+            token_start,
+            token_len,
+            hidden_size,
+            bytes,
+            weight,
+        });
+
+        token_start += token_len;
+    }
+
+    eprintln!(
+        "[native-vocab-atlas] built tile_count={} vocab={} hidden={} tile_vocab={} full_vocab_bytes={}",
+        tiles.len(),
+        vocab_size,
+        hidden_size,
+        tile_vocab,
+        full_vocab_bytes,
+    );
+
+    Ok(NativeVocabAtlas {
+        vocab_size,
+        hidden_size,
+        tile_vocab,
+        full_vocab_bytes,
+        tiles,
+    })
+}
