+fn env_flag_enabled(name: &str) -> bool {
+    std::env::var(name)
+        .map(|value| matches!(value.trim().to_ascii_lowercase().as_str(), "1" | "true" | "yes" | "on"))
+        .unwrap_or(false)
+}
+
+fn timestamp_query_disabled_by_env() -> bool {
+    env_flag_enabled("ASH_DISABLE_TIMESTAMP_QUERY")
+        || env_flag_enabled("ASH_NATIVE_DISABLE_TIMESTAMP_QUERY")
+        || env_flag_enabled("ASH_DISABLE_NATIVE_TIMESTAMP_QUERY")
+}
+
+fn native_required_features_for_adapter(adapter: &backend_wgpu::Adapter, source: &'static str) -> backend_wgpu::Features {
+    let adapter_features = adapter.features();
+    let timestamp_supported = adapter_features.contains(backend_wgpu::Features::TIMESTAMP_QUERY);
+    let timestamp_disabled = timestamp_query_disabled_by_env();
+    let timestamp_requested = timestamp_supported && !timestamp_disabled;
+
+    let mut required_features = backend_wgpu::Features::empty();
+    if timestamp_requested {
+        required_features |= backend_wgpu::Features::TIMESTAMP_QUERY;
+    }
+
+    eprintln!(
+        "[16AA][timestamp-query] source={} adapter_supported={} requested={} disabled_by_env={} required_features={:?}",
+        source,
+        timestamp_supported,
+        timestamp_requested,
+        timestamp_disabled,
+        required_features,
+    );
+
+    if !timestamp_supported {
+        eprintln!(
+            "[16AA][timestamp-query] source={} action=profiler_risk reason=adapter_does_not_support_timestamp_query",
+            source,
+        );
+    } else if timestamp_disabled {
+        eprintln!(
+            "[16AA][timestamp-query] source={} action=profiler_risk reason=timestamp_query_disabled_by_env",
+            source,
+        );
+    } else {
+        eprintln!(
+            "[16AA][timestamp-query] source={} action=request_feature reason=cubecl_query_profiler_requires_timestamp_query",
+            source,
+        );
+    }
+
+    required_features
+}
