+
+fn compare_atlas_candidate_desc(
+    a: &NativeVocabAtlasCandidate,
+    b: &NativeVocabAtlasCandidate,
+) -> std::cmp::Ordering {
+    b.logit
+        .partial_cmp(&a.logit)
+        .unwrap_or(std::cmp::Ordering::Equal)
+}
+
+fn top_k_tile_candidates(
+    logits: &[f32],
+    token_start: usize,
+    k: usize,
+) -> Vec<NativeVocabAtlasCandidate> {
+    let mut out = Vec::new();
+    for (local_id, &logit) in logits.iter().enumerate() {
+        if logit.is_finite() {
+            out.push(NativeVocabAtlasCandidate {
+                token_id: token_start + local_id,
+                logit,
+            });
+        }
+    }
+    out.sort_by(compare_atlas_candidate_desc);
+    out.truncate(k);
+    out
+}
+
+fn merge_atlas_top_k(
+    mut candidates: Vec<NativeVocabAtlasCandidate>,
+    k: usize,
+) -> Vec<NativeVocabAtlasCandidate> {
+    candidates.sort_by(compare_atlas_candidate_desc);
+    candidates.truncate(k);
+    candidates
+}
