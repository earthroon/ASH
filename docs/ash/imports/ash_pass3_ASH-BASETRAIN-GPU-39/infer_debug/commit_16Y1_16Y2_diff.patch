+#[derive(Debug, Clone, Serialize, Deserialize)]
+#[serde(default)]
+pub struct NativeVocabAllocationProbe {
+    pub requested_vocab_projection: String,
+    pub effective_vocab_projection: String,
+    pub requested_embedding_mode: String,
+    pub effective_embedding_mode: String,
+    pub vocab_size: usize,
+    pub hidden_size: usize,
+    pub full_vocab_bytes: usize,
