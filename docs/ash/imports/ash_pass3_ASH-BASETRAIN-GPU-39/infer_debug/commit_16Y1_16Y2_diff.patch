+    pub max_single_gpu_buffer_bytes: usize,
+    pub gpu_full_vocab_upload_skipped: bool,
+    pub allocation_source: Option<String>,
+}
+
+impl Default for NativeVocabAllocationProbe {
+    fn default() -> Self {
+        Self {
+            requested_vocab_projection: "auto".to_string(),
+            effective_vocab_projection: "auto".to_string(),
+            requested_embedding_mode: "auto".to_string(),
+            effective_embedding_mode: "auto".to_string(),
+            vocab_size: 0,
+            hidden_size: 0,
+            full_vocab_bytes: 0,
+            vocab_tile_size: 1024,
+            avoid_full_vocab_gpu_upload: true,
+            max_single_gpu_buffer_bytes: 268_435_456,
+            gpu_full_vocab_upload_skipped: false,
+            allocation_source: None,
+        }
+    }
+}
+
+impl NativeVocabAllocationProbe {
+    fn new(req: &ResolvedStandardInferRequest, vocab_size: usize, hidden_size: usize) -> Self {
+        let full_vocab_bytes = vocab_size
+            .saturating_mul(hidden_size)
+            .saturating_mul(std::mem::size_of::<f32>());
+        let effective_vocab_projection = match req.native_vocab_projection {
+            NativeVocabProjectionMode::Auto => {
+                if req.native_avoid_full_vocab_gpu_upload
+                    && full_vocab_bytes > req.native_max_single_gpu_buffer_bytes
+                {
+                    NativeVocabProjectionMode::GpuAtlas
+                } else {
+                    NativeVocabProjectionMode::GpuFull
+                }
+            }
+            explicit => explicit,
+        };
+        let effective_embedding_mode = match req.native_embedding_mode {
+            NativeEmbeddingMode::Auto => {
+                if req.native_avoid_full_vocab_gpu_upload
+                    && full_vocab_bytes > req.native_max_single_gpu_buffer_bytes
+                {
+                    NativeEmbeddingMode::RowGather
+                } else {
+                    NativeEmbeddingMode::GpuFull
+                }
+            }
+            explicit => explicit,
+        };
+        Self {
+            requested_vocab_projection: req.native_vocab_projection.as_str().to_string(),
+            effective_vocab_projection: effective_vocab_projection.as_str().to_string(),
+            requested_embedding_mode: req.native_embedding_mode.as_str().to_string(),
+            effective_embedding_mode: effective_embedding_mode.as_str().to_string(),
+            vocab_size,
+            hidden_size,
+            full_vocab_bytes,
+            vocab_tile_size: req.native_vocab_tile_size,
+            avoid_full_vocab_gpu_upload: req.native_avoid_full_vocab_gpu_upload,
+            max_single_gpu_buffer_bytes: req.native_max_single_gpu_buffer_bytes,
+            gpu_full_vocab_upload_skipped: effective_vocab_projection == NativeVocabProjectionMode::GpuAtlas,
+            allocation_source: None,
+        }
+    }
+}
