+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+#[serde(rename_all = "snake_case")]
+pub enum NativeVocabProjectionMode {
+    Auto,
+    GpuFull,
+    GpuAtlas,
+    CpuDebug,
+}
+
+impl Default for NativeVocabProjectionMode {
+    fn default() -> Self { Self::Auto }
+}
+
+impl NativeVocabProjectionMode {
+    pub fn as_str(&self) -> &'static str {
+        match self {
+            Self::Auto => "auto",
+            Self::GpuFull => "gpu_full",
+            Self::GpuAtlas => "gpu_atlas",
+            Self::CpuDebug => "cpu_debug",
+        }
+    }
+
+    pub fn parse(value: Option<&str>) -> Self {
+        match value.unwrap_or("auto") {
+            "gpu_full" | "gpuFull" | "full" => Self::GpuFull,
+            "gpu_atlas" | "gpuAtlas" | "atlas" => Self::GpuAtlas,
+            "cpu_debug" | "cpuDebug" | "cpu" => Self::CpuDebug,
+            _ => Self::Auto,
+        }
+    }
+}
+
+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+#[serde(rename_all = "snake_case")]
+pub enum NativeEmbeddingMode {
+    Auto,
+    GpuFull,
+    RowGather,
+}
+
+impl Default for NativeEmbeddingMode {
+    fn default() -> Self { Self::Auto }
+}
+
+impl NativeEmbeddingMode {
+    pub fn as_str(&self) -> &'static str {
+        match self {
+            Self::Auto => "auto",
+            Self::GpuFull => "gpu_full",
+            Self::RowGather => "row_gather",
+        }
+    }
+
+    pub fn parse(value: Option<&str>) -> Self {
+        match value.unwrap_or("auto") {
+            "gpu_full" | "gpuFull" | "full" => Self::GpuFull,
+            "row_gather" | "rowGather" | "gather" => Self::RowGather,
+            _ => Self::Auto,
+        }
+    }
+}
