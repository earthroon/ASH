+        qw38g_r6a_r4_write_dry_run_and_receipt(
+            "FAIL_BACKEND_EXTENSION_SPEC_NOT_FOUND",
+            false,
+            vec!["BACKEND_EXTENSION_SPEC_NOT_FOUND".to_string()],
+            "16AI-QW-38G-R6A-R3_BACKEND_DEBUG_BINDING_EXTENSION_SPEC",
+        );
+        return;
+    }
