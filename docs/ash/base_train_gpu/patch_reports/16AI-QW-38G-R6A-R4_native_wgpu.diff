+fn qw38g_r6a_r4_backend_extension_apply_dry_run() {
+    if !qw38g_r6a_r4_enabled() {
+        return;
+    }
+    if QW38G_R6A_R4_DRY_RUN_DONE.fetch_add(1, Ordering::SeqCst) > 0 {
+        return;
+    }
+
+    eprintln!("[16AI-QW-38G-R6A-R4][start]");
+    eprintln!("[16AI-QW-38G-R6A-R4][env] dry_run=true apply={}", qw38g_r6a_r4_apply_requested());
+
+    if qw38g_r6a_r4_apply_requested() {
+        qw38g_r6a_r4_write_dry_run_and_receipt(
+            "FAIL_APPLY_NOT_ALLOWED_IN_R4",
+            false,
+            vec!["APPLY_NOT_ALLOWED_IN_R4".to_string(), "DRY_RUN_ONLY".to_string()],
+            "16AI-QW-38G-R6A-R4_APPLY_REJECTED",
+        );
+        return;
+    }
+
+    let spec_path = qw38g_r6a_r4_spec_path();
+    let spec = qw38g_r6a_r4_load_spec(&spec_path);
+    let spec_loaded = spec.is_some();
+    eprintln!("[16AI-QW-38G-R6A-R4][spec_loaded] path={} loaded={}", spec_path, spec_loaded);
+
+    if let Some(spec_value) = spec.as_ref() {
+        let no_apply = spec_value.get("no_apply").and_then(|v| v.as_bool()).unwrap_or(false);
+        let full_vector_forbidden = spec_value
+            .get("debug_buffer_policy")
+            .and_then(|v| v.get("full_vector_readback_forbidden"))
+            .and_then(|v| v.as_bool())
+            .unwrap_or(false);
+        if !no_apply {
+            qw38g_r6a_r4_write_dry_run_and_receipt(
+                "FAIL_SPEC_NOT_NO_APPLY",
+                spec_loaded,
+                vec!["SPEC_NOT_NO_APPLY".to_string(), "NO_APPLY_REQUIRED".to_string()],
+                "16AI-QW-38G-R6A-R3_SPEC_RESEAL_REQUIRED",
+            );
+            return;
+        }
+        if !full_vector_forbidden {
+            qw38g_r6a_r4_write_dry_run_and_receipt(
+                "FAIL_FULL_VECTOR_POLICY_MISSING",
+                spec_loaded,
+                vec!["FULL_VECTOR_POLICY_MISSING".to_string(), "SCALAR_ONLY_POLICY_REQUIRED".to_string()],
+                "16AI-QW-38G-R6A-R3_SPEC_RESEAL_REQUIRED",
+            );
+            return;
+        }
+    }
+
