+fn write_runtime_receipts(receipt: &Value) -> Value {
+    let _ = fs::create_dir_all("artifacts");
+    let bytes = serde_json::to_vec_pretty(receipt).unwrap_or_else(|_| b"{}".to_vec());
+    let r1_written = fs::write(R1_37Q_RUNTIME_RECEIPT_PATH, &bytes).is_ok();
+    let legacy_written = fs::write(LEGACY_37Q_RUNTIME_RECEIPT_PATH, &bytes).is_ok();
+    json!({
+        "runtime_receipt_written": r1_written,
+        "runtime_receipt_path": R1_37Q_RUNTIME_RECEIPT_PATH,
+        "legacy_runtime_receipt_written": legacy_written,
+        "legacy_runtime_receipt_path": LEGACY_37Q_RUNTIME_RECEIPT_PATH,
+        "stdout_only": false
+    })
+}
+
+fn reason_for_status(status: &'static str) -> &'static str {
+    match status {
+        BLOCK_37P_UNSUPPORTED_PATCH_ID => "37P receipt patch_id is not supported by the 37Q-R1 input contract.",
+        BLOCK_37P_UNSUPPORTED_STATUS => "37P receipt status is not a supported PASS status for the 37Q-R1 input contract.",
+        BLOCK_37P_R1_SOURCE_BINDING_MISSING => "37P-R1 source binding did not prove no-placeholder runtime intake.",
+        BLOCK_37P_R1_SOURCE_BINDING_NOT_PASS => "37P-R1 source binding did not prove a valid 37F payload receipt/source read.",
+        BLOCK_37P_NOT_PASS => "37P receipt was found but was not PASS.",
+        BLOCK_37F_NOT_PASS => "37F payload receipt was found but was not PASS.",
+        _ => "37P or 37F receipt did not satisfy the 37Q-R1 input contract.",
+    }
+}
+
+fn is_supported_37p_patch_id(patch_id: Option<&str>) -> bool {
+    matches!(patch_id, Some(EXPECTED_37P_PATCH_ID) | Some(EXPECTED_37P_R1_PATCH_ID))
+}
+
+fn is_supported_37p_status(patch_id: Option<&str>, status: Option<&str>) -> bool {
+    match (patch_id, status) {
+        (Some(EXPECTED_37P_PATCH_ID), Some(s)) => s == EXPECTED_37P_STATUS,
+        (Some(EXPECTED_37P_R1_PATCH_ID), Some(s)) => s.starts_with(EXPECTED_37P_R1_STATUS_PREFIX),
+        _ => false,
+    }
+}
