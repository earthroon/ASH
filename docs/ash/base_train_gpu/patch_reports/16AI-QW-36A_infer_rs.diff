+    HybridTaskDialogueKo,
+}
+
+impl RuntimePromptTemplateId {
+    fn from_env() -> Self {
+        match std::env::var("ASH_PROMPT_TEMPLATE")
+            .unwrap_or_else(|_| "control_v5_current".to_string())
+            .as_str()
+        {
+            "ash_dialogue_ko" => RuntimePromptTemplateId::AshDialogueKo,
+            "hybrid_task_dialogue_ko" => RuntimePromptTemplateId::HybridTaskDialogueKo,
+            _ => RuntimePromptTemplateId::ControlV5Current,
+        }
+    }
+
+    fn as_str(self) -> &'static str {
+        match self {
+            RuntimePromptTemplateId::ControlV5Current => "control_v5_current",
+            RuntimePromptTemplateId::AshDialogueKo => "ash_dialogue_ko",
+            RuntimePromptTemplateId::HybridTaskDialogueKo => "hybrid_task_dialogue_ko",
+        }
+    }
