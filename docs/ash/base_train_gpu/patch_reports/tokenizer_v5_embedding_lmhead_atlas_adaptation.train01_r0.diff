+fn read_toml_path<'a>(value: &'a toml::Value, path: &[&str]) -> Option<&'a toml::Value> {
+    let mut current = value;
+    for segment in path {
+        current = current.get(*segment)?;
+    }
+    Some(current)
+}
+
+fn read_toml_string_candidates(value: &toml::Value, paths: &[&[&str]]) -> Option<String> {
+    for path in paths {
+        if let Some(s) = read_toml_path(value, path).and_then(|v| v.as_str()) {
+            return Some(s.to_string());
+        }
+    }
+    None
+}
+
+fn read_toml_usize_candidates(value: &toml::Value, paths: &[&[&str]]) -> Option<usize> {
+    for path in paths {
+        if let Some(v) = read_toml_path(value, path) {
+            if let Some(i) = v.as_integer() {
+                if i >= 0 {
+                    return Some(i as usize);
+                }
+            }
+            if let Some(s) = v.as_str() {
+                if let Ok(parsed) = s.trim().parse::<usize>() {
+                    return Some(parsed);
+                }
+            }
+        }
+    }
+    None
+}
