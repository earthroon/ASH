+enum ModuleLocalCaptureRuntime {
+    NativeFirst {
+        native: NativeWgpuModel,
+        fallback: ReferenceModel,
+    },
+    Reference(ReferenceModel),
+}
+
+impl ModuleLocalCaptureRuntime {
+    fn mode_label(&self) -> &'static str {
+        match self {
+            Self::NativeFirst { .. } => "native_first",
+            Self::Reference(_) => "reference_only",
+        }
+    }
+
+    fn capture_padded_batch(
+        &self,
+        target_key: &str,
+        token_ids: &[u32],
+        lengths: &[usize],
+        max_seq_len: usize,
+    ) -> Result<Vec<model_core::CapturedModuleIo>> {
+        match self {
+            Self::NativeFirst { native, fallback } => {
+                let request = model_core::ModuleTraceTapRequest {
+                    target_key: target_key.to_string(),
+                    batch_size: lengths.len(),
+                    max_seq_len,
+                    seq_lens: lengths.to_vec(),
+                };
+                match native.capture_module_io_native_padded_batch(&request, token_ids) {
+                    Ok(captures) => {
+                        println!(
+                            "[bridge][module_local][runtime] native capture ok target_key={} batch={} max_seq_len={}",
+                            target_key,
+                            lengths.len(),
+                            max_seq_len,
+                        );
+                        Ok(captures)
+                    }
+                    Err(err) => {
+                        println!(
+                            "[bridge][module_local][runtime] native capture fallback target_key={} batch={} max_seq_len={} reason={}",
+                            target_key,
+                            lengths.len(),
+                            max_seq_len,
+                            err,
+                        );
+                        fallback.capture_module_io_padded_batch(token_ids, lengths, max_seq_len, target_key)
+                    }
+                }
+            }
+            Self::Reference(reference) => {
+                reference.capture_module_io_padded_batch(token_ids, lengths, max_seq_len, target_key)
+            }
+        }
+    }
+}
