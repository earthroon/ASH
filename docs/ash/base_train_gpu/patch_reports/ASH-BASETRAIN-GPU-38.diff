+fn validate_37f(v: &Value) -> Result<(), (&'static str, &'static str)> {
+    let digest = v.get("gpu_readback_digest_receipt").unwrap_or(&Value::Null);
+    let cpu = str_value(digest, "cpu_source_payload_raw_sha256_hex").unwrap_or("");
+    let gpu = str_value(digest, "gpu_readback_raw_sha256_hex").or_else(|| str_value(digest, "gpu_readback_byte_digest_hex")).unwrap_or("");
+    match (
+        str_value(v, "patch_id") == Some("ASH-BASETRAIN-GPU-37F"),
+        bool_value(v, "pass") == Some(true) && str_value(v, "verdict") == Some("PASS"),
+        !cpu.is_empty() && cpu == gpu,
+    ) {
+        (false, _, _) => Err((BLOCK_37F_NOT_PASS, "37F receipt patch_id was not accepted.")),
+        (_, false, _) => Err((BLOCK_37F_NOT_PASS, "37F receipt was not PASS.")),
+        (_, _, false) => Err((BLOCK_37F_DIGEST, "37F CPU source and GPU readback digests did not match.")),
+        _ => Ok(()),
+    }
