+        false => Err(blocked_base(not_found, "required receipt was not found.")),
+        true => match fs::read(path) {
+            Err(_) => Err(blocked_base(read_failed, "required receipt could not be read.")),
+            Ok(bytes) => match serde_json::from_slice::<Value>(&bytes) {
+                Err(_) => Err(blocked_base(parse_failed, "required receipt could not be parsed as JSON.")),
+                Ok(value) => Ok(LoadedReceipt { path: path.to_string(), digest: sha256_hex(&bytes), value }),
+            },
+        },
+    }
