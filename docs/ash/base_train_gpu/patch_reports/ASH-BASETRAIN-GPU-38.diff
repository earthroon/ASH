+fn str_value<'a>(v: &'a Value, key: &str) -> Option<&'a str> { v.get(key).and_then(Value::as_str) }
+fn bool_value(v: &Value, key: &str) -> Option<bool> { v.get(key).and_then(Value::as_bool) }
+fn u64_value(v: &Value, key: &str) -> Option<u64> { v.get(key).and_then(Value::as_u64) }
+fn get_path<'a>(v: &'a Value, path: &[&str]) -> Option<&'a Value> { path.iter().try_fold(v, |acc, key| acc.get(*key)) }
+fn bool_path(v: &Value, path: &[&str]) -> Option<bool> { get_path(v, path).and_then(Value::as_bool) }
+
+fn sha256_hex(bytes: &[u8]) -> String {
+    let mut h = Sha256::new();
+    h.update(bytes);
+    format!("{:x}", h.finalize())
+}
+
+fn f32_digest(values: &[f32]) -> String {
+    let mut bytes = Vec::with_capacity(values.len() * 4);
+    for v in values { bytes.extend_from_slice(&v.to_le_bytes()); }
+    sha256_hex(&bytes)
+}
