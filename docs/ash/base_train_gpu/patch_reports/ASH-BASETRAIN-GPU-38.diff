+fn wgsl_source() -> String {
+    format!(r#"
+const ROW_COUNT: u32 = {row_count}u;
+const INPUT_VECTOR_LEN: u32 = {input_len}u;
+@group(0) @binding(0) var<storage, read> weights: array<f32>;
+@group(0) @binding(1) var<storage, read> input_vec: array<f32>;
+@group(0) @binding(2) var<storage, read_write> output: array<f32>;
+@compute @workgroup_size({workgroup_size})
+fn main(@builtin(global_invocation_id) gid: vec3<u32>) {{
+    let row: u32 = gid.x;
+    if (row >= ROW_COUNT) {{
+        return;
+    }}
+    var acc: f32 = 0.0;
+    var k: u32 = 0u;
+    loop {{
+        if (k >= INPUT_VECTOR_LEN) {{ break; }}
+        let w: f32 = weights[row * INPUT_VECTOR_LEN + k];
+        let x: f32 = input_vec[k];
+        acc = acc + (w * x);
+        k = k + 1u;
+    }}
+    output[row] = acc;
+}}
+"#, row_count = ROW_COUNT, input_len = INPUT_VECTOR_LEN, workgroup_size = WORKGROUP_SIZE_X)
+}
