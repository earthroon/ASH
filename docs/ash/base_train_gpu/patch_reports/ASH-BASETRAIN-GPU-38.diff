+fn pass_or_block(args: &Args, r37: LoadedReceipt, q37: LoadedReceipt, p37: LoadedReceipt, f37: LoadedReceipt, row_block: RowBlockPayload, cpu: CpuReference, runtime: MatVecRuntime) -> Output {
+    let shape_ok = runtime.gpu_output.len() == args.row_count as usize;
+    let finite_ok = runtime.gpu_output.iter().all(|v| v.is_finite()) && cpu.nan_count == 0 && cpu.inf_count == 0;
+    let parity = compare_outputs(&cpu.output, &runtime.gpu_output);
+    let dispatch_ok = runtime.dispatch_executed && runtime.readback_executed && runtime.status == "PASS";
+    let (pass, code, reason) = match (dispatch_ok, shape_ok, finite_ok, parity.0) {
+        (false, _, _, _) => (false, BLOCK_DISPATCH, "38 bounded MatVec GPU dispatch or readback did not complete."),
+        (_, false, _, _) => (false, BLOCK_SHAPE, "38 bounded MatVec output shape did not match row_count."),
+        (_, _, false, _) => (false, BLOCK_NONFINITE, "38 bounded MatVec output contained NaN or Inf."),
+        (_, _, _, false) => (false, BLOCK_PARITY, "38 bounded MatVec GPU output did not match CPU reference."),
+        _ => (true, "none", ""),
+    };
+    Output {
+        status: match pass { true => PASS_STATUS.to_string(), false => code.to_string() },
+        verdict: match pass { true => "PASS".to_string(), false => "BLOCKED".to_string() },
+        pass,
+        blocked_reason_code: code.to_string(),
+        blocked_reason: match pass { true => None, false => Some(reason.to_string()) },
+        r37: Some(r37), q37: Some(q37), p37: Some(p37), f37: Some(f37), row_block: Some(row_block), cpu_reference: Some(cpu), runtime: Some(runtime),
+    }
