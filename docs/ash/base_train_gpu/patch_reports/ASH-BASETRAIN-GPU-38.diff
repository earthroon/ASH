+fn compare_outputs(cpu: &[f32], gpu: &[f32]) -> (bool, usize, usize, f64, f64) {
+    let mut matched = 0usize;
+    let mut mismatched = 0usize;
+    let mut max_abs = 0.0f64;
+    let mut max_rel = 0.0f64;
+    for (c, g) in cpu.iter().zip(gpu.iter()) {
+        let abs = (*c as f64 - *g as f64).abs();
+        let rel = match c.abs() > 0.0 { true => abs / c.abs() as f64, false => abs };
+        match abs <= 0.00001_f64 || rel <= 0.0001_f64 { true => matched += 1, false => mismatched += 1 }
+        if abs > max_abs { max_abs = abs; }
+        if rel > max_rel { max_rel = rel; }
+    }
+    (cpu.len() == gpu.len() && mismatched == 0, matched, mismatched + cpu.len().abs_diff(gpu.len()), max_abs, max_rel)
+}
