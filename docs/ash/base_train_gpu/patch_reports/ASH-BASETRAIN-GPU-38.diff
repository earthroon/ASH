+fn cpu_reference(weights: &[f32], input_len: u32, row_count: u32) -> CpuReference {
+    let input_vector = (0..input_len).map(|i| ((i % 17) as f32 - 8.0) / 17.0).collect::<Vec<f32>>();
+    let mut output = Vec::with_capacity(row_count as usize);
+    let mut nan_count = 0usize;
+    let mut inf_count = 0usize;
+    for row in 0..row_count as usize {
+        let base = row * input_len as usize;
+        let mut acc = 0.0f32;
+        for k in 0..input_len as usize {
+            acc += weights[base + k] * input_vector[k];
+        }
+        match acc.is_nan() { true => nan_count += 1, false => () }
+        match acc.is_infinite() { true => inf_count += 1, false => () }
+        output.push(acc);
+    }
+    CpuReference { digest: f32_digest(&output), input_vector, output, nan_count, inf_count }
+}
