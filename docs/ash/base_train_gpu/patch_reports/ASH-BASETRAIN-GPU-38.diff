+        bool_value(v, "pass") == Some(true) && str_value(v, "verdict") == Some("PASS"),
+        bool_path(v, &["reduction_parity_matrix", "parity_passed"]) == Some(true),
+        bool_path(v, &["promotion_gate_matrix", "forward_candidate_allowed_next"]) == Some(true),
+        bool_path(v, &["promotion_gate_matrix", "forward_adoption_executed_now"]) == Some(false),
+        bool_path(v, &["promotion_gate_matrix", "optimizer_executed_now"]) == Some(false),
+        bool_path(v, &["promotion_gate_matrix", "weight_mutation_executed_now"]) == Some(false),
+    ) {
+        (false, _, _, _, _, _, _) => Err((BLOCK_37R_NOT_PASS, "37R-R2 receipt patch_id was not accepted.")),
+        (_, false, _, _, _, _, _) => Err((BLOCK_37R_NOT_PASS, "37R-R2 receipt was not PASS.")),
+        (_, _, false, _, _, _, _) => Err((BLOCK_37R_PARITY, "37R-R2 parity did not pass.")),
+        (_, _, _, false, _, _, _) => Err((BLOCK_37R_FORWARD_NOT_ALLOWED, "37R-R2 did not allow the next forward candidate.")),
