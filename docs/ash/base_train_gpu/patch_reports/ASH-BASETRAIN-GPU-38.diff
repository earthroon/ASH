+fn read_row_block_payload(v: &Value, args: &Args) -> Result<RowBlockPayload, (&'static str, &'static str)> {
+    let candidate = v.get("candidate_ref").ok_or((BLOCK_SOURCE_READ, "37F candidate_ref was missing."))?;
+    let source_path = str_value(candidate, "source_shard_path").ok_or((BLOCK_SOURCE_READ, "37F source_shard_path was missing."))?.to_string();
+    let segments = v.get("representative_gpu_readback_source_read_results").and_then(Value::as_array).ok_or((BLOCK_SOURCE_READ, "37F source read results were missing."))?;
+    let first = segments.first().ok_or((BLOCK_SOURCE_READ, "37F source segment list was empty."))?;
+    let first_start = u64_value(first, "source_file_offset_start").ok_or((BLOCK_SOURCE_READ, "37F first segment start was missing."))?;
+    let first_len = u64_value(first, "bytes_read").ok_or((BLOCK_SOURCE_READ, "37F first segment byte length was missing."))?;
+    let requested = (args.row_count as u64).saturating_mul(args.input_vector_len as u64).saturating_mul(4);
+    let byte_len = match (args.row_count == ROW_COUNT, args.input_vector_len == INPUT_VECTOR_LEN, requested > 0, requested <= first_len) {
+        (true, true, true, true) => requested,
+        _ => return Err((BLOCK_SOURCE_READ, "38 first candidate supports only row_count=256/input_vector_len=256 within the first 37F source segment.")),
+    };
+    let byte_offset = first_start.saturating_add((args.row_start as u64).saturating_mul(args.input_vector_len as u64).saturating_mul(4));
+    let mut file = File::open(&source_path).map_err(|_| (BLOCK_SOURCE_READ, "selected row-block source file could not be opened."))?;
+    file.seek(SeekFrom::Start(byte_offset)).map_err(|_| (BLOCK_SOURCE_READ, "selected row-block source seek failed."))?;
+    let mut bytes = vec![0u8; byte_len as usize];
+    file.read_exact(&mut bytes).map_err(|_| (BLOCK_SOURCE_READ, "selected row-block source bytes could not be read."))?;
+    match bytes.is_empty() {
+        true => Err((BLOCK_SOURCE_EMPTY, "selected row-block payload was empty.")),
+        false => {
+            let weights = bytes.chunks_exact(4).map(|chunk| f32::from_le_bytes([chunk[0], chunk[1], chunk[2], chunk[3]])).collect::<Vec<f32>>();
+            Ok(RowBlockPayload { source_path, source_file_offset_start: byte_offset, source_file_offset_end: byte_offset + byte_len, bytes_read: byte_len, digest: sha256_hex(&bytes), weights, weight_bytes: bytes })
+        }
+    }
+}
