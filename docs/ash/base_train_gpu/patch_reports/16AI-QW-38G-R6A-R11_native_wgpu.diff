+
+fn qw38g_r6a_r11_projection_boundary_margin_audit(
+    _atlas: &NativeVocabAtlas,
+    global_top_k: &[NativeVocabAtlasCandidate],
+    best_token_id: usize,
+    best_logit: f32,
+    merged_logits: &[f32],
+) {
+    if !qw38g_r6a_r11_enabled() {
+        return;
+    }
+    if QW38G_R6A_R11_MARGIN_DONE.fetch_add(1, Ordering::SeqCst) > 0 {
+        return;
+    }
+
+    let production_apply_requested = env_flag("ASH_BACKEND_EXTENSION_PRODUCTION_APPLY")
+        || env_flag("ASH_BACKEND_EXTENSION_FORCE_PRODUCTION_APPLY");
+    let full_vector_requested = env_flag("ASH_DEBUG_BUFFER_FULL_VECTOR")
+        || env_flag("ASH_SHADER_DEBUG_BUFFER_FULL_VECTOR")
+        || env_flag("ASH_GPU_DEBUG_TAP_FULL_VECTOR");
+    let scalar_only = std::env::var("ASH_PROJECTION_MARGIN_SCALAR_ONLY")
+        .ok()
+        .map(|v| !matches!(v.as_str(), "0" | "false" | "FALSE" | "no" | "NO"))
+        .unwrap_or(true);
+    let top_n = qw38a_env_usize("ASH_PROJECTION_MARGIN_TOP_N", 8).max(1);
+    let max_bytes = qw38a_env_usize("ASH_PROJECTION_MARGIN_MAX_BYTES", 4096).max(64);
+    let target_ids = qw38g_r6a_r11_target_ids();
+    let min_margin_threshold = qw38g_r6a_r11_min_margin();
+
+    eprintln!("[16AI-QW-38G-R6A-R11][start]");
+    eprintln!("[16AI-QW-38G-R6A-R11][env] mode={} scalar_only={} top_n={} min_margin={} targets={:?} max_bytes={}", qw38g_r6a_r11_mode(), scalar_only, top_n, min_margin_threshold, target_ids, max_bytes);
+
+    if production_apply_requested {
+        qw38g_r6a_r11_write_failure(
+            "FAIL_PRODUCTION_APPLY_NOT_ALLOWED_IN_R11",
+            vec!["PRODUCTION_APPLY_NOT_ALLOWED_IN_R11".to_string()],
+            "16AI-QW-38G-R6A-R11_DISABLE_PRODUCTION_APPLY",
+        );
+        return;
+    }
+    if full_vector_requested || !scalar_only {
+        qw38g_r6a_r11_write_failure(
+            "FAIL_FULL_VECTOR_POLICY_VIOLATION",
+            vec!["FULL_VECTOR_READBACK_FORBIDDEN".to_string(), "SCALAR_ONLY_REQUIRED".to_string()],
+            "16AI-QW-38G-R6A-R11_FULL_VECTOR_GUARD",
+        );
+        return;
+    }
+    if top_n > 64 {
+        qw38g_r6a_r11_write_failure(
+            "FAIL_R11_TOP_N_LIMIT_EXCEEDED",
+            vec!["R11_TOP_N_LIMIT_EXCEEDED".to_string()],
+            "16AI-QW-38G-R6A-R11_REDUCE_TOP_N",
+        );
+        return;
+    }
+    if target_ids.is_empty() || target_ids.len() > 2 {
+        qw38g_r6a_r11_write_failure(
+            "FAIL_R11_TARGET_LIMIT_EXCEEDED",
+            vec!["R11_TARGET_LIMIT_EXCEEDED".to_string()],
+            "16AI-QW-38G-R6A-R11_SET_TARGET_IDS_13",
+        );
+        return;
+    }
+    if max_bytes > 16_384 {
+        qw38g_r6a_r11_write_failure(
+            "FAIL_R11_BYTE_BUDGET_EXCEEDED",
+            vec!["R11_BYTE_BUDGET_EXCEEDED".to_string()],
+            "16AI-QW-38G-R6A-R11_REDUCE_BYTE_BUDGET",
+        );
+        return;
+    }
+
+    let r8_summary_path = qw38g_r6a_r11_r8_summary_path();
+    let r8_receipt_path = qw38g_r6a_r11_r8_receipt_path();
+    let r8_trace_path = qw38g_r6a_r11_r8_trace_path();
+    let r10_summary_path = qw38g_r6a_r11_r10_summary_path();
+    let r10_receipt_path = qw38g_r6a_r11_r10_receipt_path();
+    let r10_trace_path = qw38g_r6a_r11_r10_trace_path();
+    let raw_topk_trace_path = qw38g_r6a_r11_raw_topk_trace_path();
+
+    let r8_summary = qw38g_r6a_r5_load_json(&r8_summary_path);
+    let r8_receipt = qw38g_r6a_r5_load_json(&r8_receipt_path);
+    let r10_summary = qw38g_r6a_r5_load_json(&r10_summary_path);
+    let r10_receipt = qw38g_r6a_r5_load_json(&r10_receipt_path);
+    let r8_loaded = r8_summary.is_some() && r8_receipt.is_some();
+    let r10_loaded = r10_summary.is_some() && r10_receipt.is_some();
+    let raw_topk_loaded = std::path::Path::new(&raw_topk_trace_path).exists();
+
+    let r8_status = qw38g_r6a_r8_string(r8_summary.as_ref(), "status", "MISSING_R8_SUMMARY");
+    let r10_status = qw38g_r6a_r8_string(r10_summary.as_ref(), "status", "MISSING_R10_SUMMARY");
+    let r8_passed = r8_status == "PASS_DEBUG_BUFFER_SCALAR_READBACK_SMOKE"
+        || qw38g_r6a_r8_bool(r8_receipt.as_ref(), "source_valid_for_r8", false)
+        || qw38g_r6a_r8_bool(r8_receipt.as_ref(), "readback_executed", false);
+    let r10_confirmed = qw38g_r6a_r8_bool(r10_summary.as_ref(), "final_boundary_confirmed", false)
+        || qw38g_r6a_r8_bool(r10_receipt.as_ref(), "final_boundary_confirmed", false);
+    let r10_candidate = r10_summary
+        .as_ref()
+        .and_then(|v| v.get("confirmed_candidate"))
+        .and_then(|v| v.as_str())
+        .map(|s| s.to_string())
+        .or_else(|| r10_receipt.as_ref().and_then(|v| v.get("confirmed_candidate")).and_then(|v| v.as_str()).map(|s| s.to_string()));
+    let r10_confidence = qw38g_r6a_r8_string(r10_summary.as_ref(), "confirm_confidence", "none");
+    let source_valid_for_r11 = r8_loaded
+        && r10_loaded
+        && r8_passed
+        && r10_status == "PASS_FINAL_BOUNDARY_CONFIRM"
+        && r10_confirmed
+        && r10_candidate.as_deref() == Some("final_norm_or_projection_boundary");
+    eprintln!("[16AI-QW-38G-R6A-R11][source_loaded] r8={} r10={} raw_topk={} candidate={:?} valid={}", r8_loaded, r10_loaded, raw_topk_loaded, r10_candidate, source_valid_for_r11);
+
+    if !source_valid_for_r11 {
+        let mut warnings = Vec::new();
+        if !r8_loaded { warnings.push("R8_SOURCE_MISSING".to_string()); }
+        if !r10_loaded { warnings.push("R10_SOURCE_MISSING".to_string()); }
+        if !r8_passed { warnings.push("R8_SCALAR_READBACK_NOT_PASSED".to_string()); }
+        if !r10_confirmed { warnings.push("R10_FINAL_BOUNDARY_NOT_CONFIRMED".to_string()); }
+        if r10_candidate.as_deref() != Some("final_norm_or_projection_boundary") { warnings.push("R10_CANDIDATE_NOT_FINAL_BOUNDARY".to_string()); }
+        qw38g_r6a_r11_write_failure(
+            "FAIL_PROJECTION_MARGIN_SOURCE_INVALID",
+            warnings,
+            "16AI-QW-38G-R6A-R10_REGENERATE_FINAL_BOUNDARY_CONFIRM",
+        );
+        return;
+    }
+
+    let meta = qw38a_token_meta();
+    let selected_top_k = global_top_k.iter().take(top_n).collect::<Vec<_>>();
+    let masked_top1 = global_top_k
+        .iter()
+        .find(|c| !meta.banned_reasons.contains_key(&c.token_id));
+    let masked_top1_token_id = masked_top1.map(|c| c.token_id);
+    let masked_top1_logit = masked_top1.map(|c| c.logit);
+    let raw_top1_is_banned = meta.banned_reasons.contains_key(&best_token_id);
+    let raw_top1_is_reserved = qw38a_is_reserved(meta, best_token_id);
+    let raw_topk_reserved_count = selected_top_k
+        .iter()
+        .filter(|c| qw38a_is_reserved(meta, c.token_id))
+        .count();
+    let raw_topk_banned_count = selected_top_k
+        .iter()
+        .filter(|c| meta.banned_reasons.contains_key(&c.token_id))
+        .count();
+
+    let mut events = Vec::new();
+    let mut margins_vs_masked = Vec::new();
+    let mut margins_vs_raw_top2 = Vec::new();
+    let mut raw_top1_target_count = 0usize;
+    let mut displacement_count = 0usize;
+    let record_size_bytes = 64usize;
+
+    for target_id in target_ids.iter().take(2) {
+        let idx = *target_id as usize;
+        let target_logit = merged_logits.get(idx).copied();
+        let target_rank_raw = global_top_k.iter().position(|c| c.token_id == idx).map(|p| p + 1);
+        let target_is_raw_top1 = best_token_id == idx;
+        if target_is_raw_top1 {
+            raw_top1_target_count += 1;
+        }
+        let raw_top2_logit = if target_is_raw_top1 {
+            global_top_k.iter().find(|c| c.token_id != idx).map(|c| c.logit)
+        } else {
+            None
+        };
+        let target_minus_masked_top1_margin = match (target_logit, masked_top1_logit) {
+            (Some(target), Some(masked)) => Some(target - masked),
+            _ => None,
+        };
+        let target_minus_raw_top2_margin = match (target_logit, raw_top2_logit) {
+            (Some(target), Some(raw2)) => Some(target - raw2),
+            _ => None,
+        };
+        if let Some(margin) = target_minus_masked_top1_margin {
+            if margin.is_finite() {
+                margins_vs_masked.push(margin);
+            }
+        }
+        if let Some(margin) = target_minus_raw_top2_margin {
+            if margin.is_finite() {
+                margins_vs_raw_top2.push(margin);
+            }
+        }
+        let target_is_banned = meta.banned_reasons.contains_key(&idx);
+        let ban_mask_displaced_target = target_is_raw_top1 && target_is_banned && masked_top1_token_id != Some(idx);
+        if ban_mask_displaced_target {
+            displacement_count += 1;
+        }
+        let record_status = if target_logit.map(|v| v.is_finite()).unwrap_or(false) {
+            "OK"
+        } else {
+            "TARGET_LOGIT_UNAVAILABLE"
+        };
+        eprintln!("[16AI-QW-38G-R6A-R11][event] seed={:?} target={} raw_top1={} masked_top1={:?} margin={:?}", std::env::var("ASH_SEED").ok(), target_id, best_token_id, masked_top1_token_id, target_minus_masked_top1_margin);
+        let event = serde_json::json!({
+            "patch_id": "16AI-QW-38G-R6A-R11",
+            "seed": std::env::var("ASH_SEED").ok().and_then(|v| v.trim().parse::<u64>().ok()),
+            "prompt_id": std::env::var("ASH_FINAL_BOUNDARY_PROMPT_SET").unwrap_or_else(|_| "default".to_string()),
+            "decode_step": 0,
+            "layer_label": "last",
+            "stage": "post_final_norm",
+            "target_token_id": target_id,
+            "target_piece": qw38a_piece(meta, idx),
+            "raw_top1_token_id": best_token_id,
+            "raw_top1_piece": qw38a_piece(meta, best_token_id),
+            "raw_top1_logit": best_logit,
+            "masked_top1_token_id": masked_top1_token_id,
+            "masked_top1_piece": masked_top1_token_id.map(|id| qw38a_piece(meta, id)),
+            "masked_top1_logit": qw38g_r6a_r11_json_f32(masked_top1_logit),
+            "target_logit": qw38g_r6a_r11_json_f32(target_logit),
+            "target_is_raw_top1": target_is_raw_top1,
+            "target_rank_raw": target_rank_raw,
+            "target_rank_masked": serde_json::Value::Null,
+            "target_minus_masked_top1_margin": qw38g_r6a_r11_json_f32(target_minus_masked_top1_margin),
+            "target_minus_raw_top2_margin": qw38g_r6a_r11_json_f32(target_minus_raw_top2_margin),
+            "raw_topk_contains_target": selected_top_k.iter().any(|c| c.token_id == idx),
+            "raw_topk_reserved_count": raw_topk_reserved_count,
+            "raw_topk_banned_count": raw_topk_banned_count,
+            "raw_top1_is_reserved": raw_top1_is_reserved,
+            "raw_top1_is_banned": raw_top1_is_banned,
+            "ban_mask_displaced_target": ban_mask_displaced_target,
+            "displacement_kind": if ban_mask_displaced_target { "raw_reserved_target_masked_to_best_allowed" } else { "none" },
+            "scalar_only": true,
+            "full_vector_readback_used": false,
+            "readback_bytes": if record_status == "OK" { record_size_bytes } else { 0 },
+            "record_status": record_status,
+            "warning_codes": if record_status == "OK" { serde_json::json!([]) } else { serde_json::json!(["TARGET_LOGIT_UNAVAILABLE"]) },
+        });
+        events.push(event);
+    }
+
