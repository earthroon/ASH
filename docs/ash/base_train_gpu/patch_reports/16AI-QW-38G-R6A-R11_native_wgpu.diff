+    qw38g_r6a_r8_write_jsonl(&trace_path, &[]);
+    let rollback_written = qw38g_r6a_r11_write_rollback("ROLLBACK_RECEIPT_R11_FAILURE_GUARDED", warning_codes.clone());
+    let target_ids = qw38g_r6a_r11_target_ids();
+    let summary = serde_json::json!({
+        "patch_id": "16AI-QW-38G-R6A-R11",
+        "status": status,
+        "timestamp_unix_ms": qw38g_r3_now_ms(),
+        "margin_audit_enabled": true,
+        "audit_mode": qw38g_r6a_r11_mode(),
+        "source_valid_for_r11": false,
+        "target_ids": target_ids,
+        "top_n": qw38a_env_usize("ASH_PROJECTION_MARGIN_TOP_N", 8).max(1),
+        "min_margin_threshold": qw38g_r6a_r11_min_margin(),
+        "total_events": 0,
+        "ok_event_count": 0,
+        "failed_event_count": 0,
+        "scalar_only": true,
+        "full_vector_readback_used": false,
+        "total_readback_bytes": 0,
+        "raw_top1_target_count": 0,
+        "raw_top1_target_rate": 0.0,
+        "ban_mask_displacement_count": 0,
+        "ban_mask_displacement_rate": 0.0,
+        "projection_margin_confirmed": false,
+        "projection_margin_strength": "none",
+        "confirmed_candidate": serde_json::Value::Null,
+        "candidate_confidence_after_margin": "none",
+        "normal_path_guard_passed": false,
+        "rollback_receipt_written": rollback_written,
+        "recommended_next_patch": recommended_next_patch,
+        "warning_codes": warning_codes,
+    });
+    qw38g_r6a_r2_write_json(&summary_path, &summary);
+    let receipt = serde_json::json!({
+        "patch_id": "16AI-QW-38G-R6A-R11",
+        "status": status,
+        "timestamp_unix_ms": qw38g_r3_now_ms(),
+        "source_valid_for_r11": false,
+        "projection_margin_confirmed": false,
+        "projection_margin_strength": "none",
+        "candidate_confidence_after_margin": "none",
+        "scalar_only": true,
+        "full_vector_readback_used": false,
+        "normal_path_guard_passed": false,
