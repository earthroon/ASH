+    qw38g_r6a_r2_write_json(&receipt_path, &receipt);
+    eprintln!("[16AI-QW-38G-R6A-R11][receipt_written] path={}", qw38g_r6a_r11_receipt_path());
+    eprintln!("[16AI-QW-38G-R6A-R11][done] status={}", status);
