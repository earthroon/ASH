+        "summary_path": summary_path,
+        "summary_json_written": qw38g_r6a_r2_path_written(&summary_path),
+        "rollback_receipt_path": qw38g_r6a_r11_rollback_path(),
+        "receipt_path": receipt_path,
+        "receipt_written": true,
+        "recommended_next_patch": recommended_next_patch,
+        "warning_codes": summary.get("warning_codes").cloned().unwrap_or_else(|| serde_json::json!([])),
