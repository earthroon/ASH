+fn qw38g_r6a_r9_reference_dot(summary: Option<&serde_json::Value>, trace_path: &str) -> Option<f32> {
+    if let Some(dot) = summary
+        .and_then(|v| v.get("strongest_dot_to_target"))
+        .and_then(|v| v.as_f64())
+    {
+        return Some(dot as f32);
+    }
+    if let Ok(text) = std::fs::read_to_string(trace_path) {
+        for line in text.lines() {
+            if let Ok(value) = serde_json::from_str::<serde_json::Value>(line) {
+                if let Some(dot) = value.get("dot_to_target").and_then(|v| v.as_f64()) {
+                    return Some(dot as f32);
+                }
+            }
+        }
+    }
+    None
+}
