+fn qw38g_r6a_r9_source_candidate(
+    strongest_stage: Option<&str>,
+    strongest_layer: Option<&str>,
+    ok_count: usize,
+    unavailable_count: usize,
+) -> (Option<String>, String, Vec<String>) {
+    let mut warnings = Vec::new();
+    if unavailable_count > 0 {
+        warnings.push("INTERMEDIATE_STAGE_NOT_EXPOSED_IN_CURRENT_SANDBOX".to_string());
+    }
+    if ok_count == 0 {
+        return (None, "none".to_string(), warnings);
+    }
+    match (strongest_layer.unwrap_or("unknown"), strongest_stage.unwrap_or("unknown")) {
+        ("last", "post_final_norm") => (
+            Some("final_norm_or_projection_boundary".to_string()),
+            if unavailable_count > 0 { "medium".to_string() } else { "strong".to_string() },
+            warnings,
+        ),
+        ("last", "post_block") => (
+            Some("post_block_residual_output".to_string()),
+            "medium".to_string(),
+            warnings,
+        ),
+        (_, "post_mlp") => (
+            Some("post_mlp_or_ffn_output".to_string()),
+            "medium".to_string(),
+            warnings,
+        ),
+        ("last", _) => (
+            Some("late_layer_accumulation".to_string()),
+            "medium".to_string(),
+            warnings,
+        ),
+        _ => (
+            Some("early_or_input_carried_direction".to_string()),
+            "weak".to_string(),
+            warnings,
+        ),
+    }
+}
