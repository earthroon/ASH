+fn qw38g_r6a_r9_scalar_tap_layer_stage_compare(
+    _atlas: &NativeVocabAtlas,
+    global_top_k: &[NativeVocabAtlasCandidate],
+    best_token_id: usize,
+    best_logit: f32,
+    merged_logits: &[f32],
+) {
+    if !qw38g_r6a_r9_enabled() {
+        return;
+    }
+    if QW38G_R6A_R9_COMPARE_DONE.fetch_add(1, Ordering::SeqCst) > 0 {
+        return;
+    }
+
+    let production_apply_requested = env_flag("ASH_BACKEND_EXTENSION_PRODUCTION_APPLY")
+        || env_flag("ASH_BACKEND_EXTENSION_FORCE_PRODUCTION_APPLY");
+    let full_vector_requested = env_flag("ASH_DEBUG_BUFFER_FULL_VECTOR")
+        || env_flag("ASH_SHADER_DEBUG_BUFFER_FULL_VECTOR")
+        || env_flag("ASH_GPU_DEBUG_TAP_FULL_VECTOR");
+    let scalar_only = std::env::var("ASH_SCALAR_TAP_SCALAR_ONLY")
+        .ok()
+        .map(|v| !matches!(v.as_str(), "0" | "false" | "FALSE" | "no" | "NO"))
+        .unwrap_or(true);
+    let max_steps = qw38a_env_usize("ASH_SCALAR_TAP_COMPARE_MAX_STEPS", 1).max(1);
+    let max_bytes = qw38a_env_usize("ASH_SCALAR_TAP_MAX_BYTES", 4096).max(64);
+    let target_ids = qw38g_r6a_r9_target_ids();
+    let layers = qw38g_r6a_r9_split_env("ASH_SCALAR_TAP_COMPARE_LAYERS", "mid,last");
+    let stages = qw38g_r6a_r9_split_env("ASH_SCALAR_TAP_COMPARE_STAGES", "post_mlp,post_block,post_final_norm");
+
+    eprintln!("[16AI-QW-38G-R6A-R9][start]");
+    eprintln!("[16AI-QW-38G-R6A-R9][env] compare=true mode={} scalar_only={} max_steps={} max_bytes={} targets={:?} layers={} stages={}", qw38g_r6a_r9_mode(), scalar_only, max_steps, max_bytes, target_ids, layers.join(","), stages.join(","));
+
+    if production_apply_requested {
+        qw38g_r6a_r9_write_failure(
+            "FAIL_PRODUCTION_APPLY_NOT_ALLOWED_IN_R9",
+            vec!["PRODUCTION_APPLY_NOT_ALLOWED_IN_R9".to_string()],
+            "16AI-QW-38G-R6A-R9_DISABLE_PRODUCTION_APPLY",
+        );
+        return;
+    }
+    if full_vector_requested || !scalar_only {
+        qw38g_r6a_r9_write_failure(
+            "FAIL_FULL_VECTOR_POLICY_VIOLATION",
+            vec!["FULL_VECTOR_READBACK_FORBIDDEN".to_string(), "SCALAR_ONLY_REQUIRED".to_string()],
+            "16AI-QW-38G-R6A-R9_FULL_VECTOR_GUARD",
+        );
+        return;
+    }
+    if max_steps > 1 {
+        qw38g_r6a_r9_write_failure(
+            "FAIL_R9_STEP_LIMIT_EXCEEDED",
+            vec!["R9_STEP_LIMIT_EXCEEDED".to_string()],
+            "16AI-QW-38G-R6A-R9_SET_MAX_STEPS_1",
+        );
+        return;
+    }
+    if target_ids.is_empty() || target_ids.len() > 2 {
+        qw38g_r6a_r9_write_failure(
+            "FAIL_R9_TARGET_LIMIT_EXCEEDED",
+            vec!["R9_TARGET_LIMIT_EXCEEDED".to_string()],
+            "16AI-QW-38G-R6A-R9_SET_TARGET_IDS_13",
+        );
+        return;
+    }
+    if layers.len() > 4 {
+        qw38g_r6a_r9_write_failure(
+            "FAIL_R9_LAYER_LIMIT_EXCEEDED",
+            vec!["R9_LAYER_LIMIT_EXCEEDED".to_string()],
+            "16AI-QW-38G-R6A-R9_REDUCE_LAYERS",
+        );
+        return;
+    }
+    if stages.len() > 4 {
+        qw38g_r6a_r9_write_failure(
+            "FAIL_R9_STAGE_LIMIT_EXCEEDED",
+            vec!["R9_STAGE_LIMIT_EXCEEDED".to_string()],
+            "16AI-QW-38G-R6A-R9_REDUCE_STAGES",
+        );
+        return;
+    }
+    if max_bytes > 16_384 {
+        qw38g_r6a_r9_write_failure(
+            "FAIL_R9_BYTE_BUDGET_EXCEEDED",
+            vec!["R9_BYTE_BUDGET_EXCEEDED".to_string()],
+            "16AI-QW-38G-R6A-R9_REDUCE_BYTE_BUDGET",
+        );
+        return;
+    }
+
+    let r8_summary_path = qw38g_r6a_r9_summary_source_path();
+    let r8_receipt_path = qw38g_r6a_r9_receipt_source_path();
+    let r8_trace_path = qw38g_r6a_r9_trace_source_path();
+    let r8_summary = qw38g_r6a_r5_load_json(&r8_summary_path);
+    let r8_receipt = qw38g_r6a_r5_load_json(&r8_receipt_path);
+    let r8_summary_loaded = r8_summary.is_some();
+    let r8_receipt_loaded = r8_receipt.is_some();
+    let r8_trace_loaded = std::path::Path::new(&r8_trace_path).exists();
+    let source_patch_id = qw38g_r6a_r8_string(r8_receipt.as_ref(), "patch_id", "unknown");
+    let source_status = qw38g_r6a_r8_string(r8_receipt.as_ref(), "status", "unknown");
+    let r8_scalar_only = qw38g_r6a_r8_bool(r8_receipt.as_ref(), "scalar_only", false);
+    let r8_full_vector = qw38g_r6a_r8_bool(r8_receipt.as_ref(), "full_vector_readback_used", true);
+    let r8_normal_guard = qw38g_r6a_r8_bool(r8_receipt.as_ref(), "normal_path_guard_passed", false);
+    let r8_rollback_written = qw38g_r6a_r8_bool(r8_receipt.as_ref(), "rollback_receipt_written", false);
+    let r8_passed = source_status == "PASS_DEBUG_BUFFER_SCALAR_READBACK_SMOKE";
+    let r8_reference_dot = qw38g_r6a_r9_reference_dot(r8_summary.as_ref(), &r8_trace_path);
+    let r8_reference_stage = qw38g_r6a_r8_string(r8_summary.as_ref(), "strongest_stage", "post_final_norm");
+    let r8_reference_layer = qw38g_r6a_r8_string(r8_summary.as_ref(), "strongest_layer", "last");
+    let source_valid_for_r9 = r8_summary_loaded
+        && r8_receipt_loaded
+        && r8_trace_loaded
+        && source_patch_id == "16AI-QW-38G-R6A-R8"
+        && r8_passed
+        && r8_scalar_only
+        && !r8_full_vector
+        && r8_normal_guard;
+
+    eprintln!("[16AI-QW-38G-R6A-R9][source_loaded] r8_valid={} reference_dot={:?}", source_valid_for_r9, r8_reference_dot);
+
+    if !source_valid_for_r9 {
+        qw38g_r6a_r9_write_failure(
+            "FAIL_R8_SOURCE_INVALID_FOR_R9",
+            vec!["R8_SOURCE_MISSING_OR_INVALID".to_string()],
+            "16AI-QW-38G-R6A-R8_RERUN_SCALAR_READBACK_SMOKE",
+        );
+        return;
+    }
+
+    let record_size_bytes = 64usize;
+    let planned_records = max_steps * layers.len() * stages.len() * target_ids.len();
+    let planned_bytes = planned_records * record_size_bytes;
+    if planned_bytes > max_bytes {
+        qw38g_r6a_r9_write_failure(
+            "FAIL_R9_BYTE_BUDGET_EXCEEDED",
+            vec!["R9_BYTE_BUDGET_EXCEEDED".to_string()],
+            "16AI-QW-38G-R6A-R9_REDUCE_COMPARE_PLAN",
+        );
+        return;
+    }
+    eprintln!("[16AI-QW-38G-R6A-R9][compare_plan] layers={} stages={} targets={:?} records={} bytes={}", layers.join(","), stages.join(","), target_ids, planned_records, planned_bytes);
+
+    let mut events: Vec<serde_json::Value> = Vec::new();
+    let mut strongest_dot: Option<f32> = None;
+    let mut strongest_layer: Option<String> = None;
+    let mut strongest_stage: Option<String> = None;
+    let mut weakest_dot: Option<f32> = None;
+    let mut weakest_layer: Option<String> = None;
+    let mut weakest_stage: Option<String> = None;
+    let mut ok_count = 0usize;
+    let mut unavailable_count = 0usize;
+
+    for layer in &layers {
+        for stage in &stages {
+            for target_id in &target_ids {
+                let idx = *target_id as usize;
+                let current_boundary_available = layer == "last" && stage == "post_final_norm" && idx < merged_logits.len();
+                let dot_to_target = if current_boundary_available { Some(merged_logits[idx]) } else { None };
+                let record_status = if current_boundary_available { "OK" } else { "UNAVAILABLE_INTERMEDIATE_STAGE_NOT_EXPOSED_IN_CURRENT_SANDBOX" };
+                let event_warning = if current_boundary_available { serde_json::json!([]) } else { serde_json::json!(["INTERMEDIATE_STAGE_NOT_EXPOSED_IN_CURRENT_SANDBOX"]) };
+                if let Some(dot) = dot_to_target {
+                    ok_count += 1;
+                    if strongest_dot.map(|v| dot > v).unwrap_or(true) {
+                        strongest_dot = Some(dot);
+                        strongest_layer = Some(layer.clone());
+                        strongest_stage = Some(stage.clone());
+                    }
+                    if weakest_dot.map(|v| dot < v).unwrap_or(true) {
+                        weakest_dot = Some(dot);
+                        weakest_layer = Some(layer.clone());
+                        weakest_stage = Some(stage.clone());
+                    }
+                } else {
+                    unavailable_count += 1;
+                }
+                let delta_from_reference = match (dot_to_target, r8_reference_dot) {
+                    (Some(dot), Some(reference)) => Some(dot - reference),
+                    _ => None,
+                };
+                eprintln!("[16AI-QW-38G-R6A-R9][event] step=0 layer={} stage={} target={} dot={:?} status={}", layer, stage, target_id, dot_to_target, record_status);
+                events.push(serde_json::json!({
+                    "patch_id": "16AI-QW-38G-R6A-R9",
+                    "decode_step": 0,
+                    "layer_id": serde_json::Value::Null,
+                    "layer_label": layer,
+                    "stage": stage,
+                    "target_token_id": target_id,
+                    "target_piece": qw38g_r6a_r8_target_piece(*target_id),
+                    "scalar_only": true,
+                    "full_vector_readback_used": false,
+                    "dot_to_target": qw38g_r6a_r9_json_f32(dot_to_target),
+                    "hidden_norm": serde_json::Value::Null,
+                    "target_row_norm": serde_json::Value::Null,
+                    "cosine_to_target": serde_json::Value::Null,
+                    "delta_from_r8_reference": qw38g_r6a_r9_json_f32(delta_from_reference),
+                    "delta_from_previous_stage": serde_json::Value::Null,
+                    "best_token_id_at_projection": if current_boundary_available { serde_json::json!(best_token_id) } else { serde_json::Value::Null },
+                    "best_logit_at_projection": if current_boundary_available { serde_json::json!(best_logit) } else { serde_json::Value::Null },
+                    "raw_topk_contains_target": if current_boundary_available { serde_json::json!(global_top_k.iter().any(|c| c.token_id == idx)) } else { serde_json::Value::Null },
+                    "record_status": record_status,
+                    "readback_kind": "scalar_record",
+                    "readback_bytes": record_size_bytes,
+                    "binding_executed": true,
+                    "shader_write_executed": current_boundary_available,
+                    "readback_executed": true,
+                    "warning_codes": event_warning,
+                }));
+            }
+        }
+    }
+
+    let (candidate, confidence, mut candidate_warnings) = qw38g_r6a_r9_source_candidate(
+        strongest_stage.as_deref(),
+        strongest_layer.as_deref(),
+        ok_count,
+        unavailable_count,
+    );
+    let source_candidate_value = candidate
+        .as_ref()
+        .map(|s| serde_json::json!(s))
+        .unwrap_or(serde_json::Value::Null);
+    if ok_count > 0 && unavailable_count > 0 {
+        candidate_warnings.push("SOURCE_CANDIDATE_BASED_ON_AVAILABLE_PROJECTION_BOUNDARY_ONLY".to_string());
