+fn q38g_r2_enabled() -> bool {
+    q35e_env_truthy("ASH_LAYERWISE_RESERVED_TRACE")
+        || q35e_env_truthy("ASH_QW38G_R2_HEARTBEAT")
+        || q35e_env_truthy("ASH_38G_R2_HEARTBEAT")
+}
+
+fn q38g_r2_env(name: &str, default: &str) -> String {
+    std::env::var(name).unwrap_or_else(|_| default.to_string())
+}
+
+fn q38g_r2_path_written(path: &str) -> bool {
+    std::fs::metadata(path)
+        .map(|m| m.is_file() && m.len() > 0)
+        .unwrap_or(false)
+}
+
+fn q38g_r2_write_json(path: &str, value: &serde_json::Value) {
+    if let Some(parent) = std::path::Path::new(path).parent() {
+        let _ = std::fs::create_dir_all(parent);
+    }
+    if let Ok(text) = serde_json::to_string_pretty(value) {
+        let _ = std::fs::write(path, text);
+    }
+}
+
+fn q38g_r2_receipt_paths() -> (String, String, String, String, String) {
+    (
+        q38g_r2_env(
+            "ASH_LAYERWISE_RESERVED_TRACE_JSONL",
+            "workspace/qw38g_layerwise_reserved_direction_trace.jsonl",
+        ),
+        q38g_r2_env(
+            "ASH_LAYERWISE_RESERVED_SUMMARY_JSON",
+            "workspace/qw38g_layerwise_reserved_direction_summary.json",
+        ),
+        q38g_r2_env(
+            "ASH_LAYERWISE_RESERVED_RECEIPT_JSON",
+            "workspace/qw38g_runtime_receipt.json",
+        ),
+        q38g_r2_env(
+            "ASH_RAW_TOPK_TRACE_JSONL",
+            "workspace/qw38a_raw_topk_trace.jsonl",
+        ),
+        q38g_r2_env(
+            "ASH_HIDDEN_PROJECTION_TRACE_JSONL",
+            "workspace/qw38d_hidden_projection_trace.jsonl",
+        ),
+    )
+}
+
+fn q38g_r2_write_receipt(status: &str, last_stage: &str, extra: serde_json::Value) {
+    let (layer_trace_path, summary_path, receipt_path, raw_topk_path, hidden_proj_path) =
+        q38g_r2_receipt_paths();
+    let layerwise_trace_jsonl_written = q38g_r2_path_written(&layer_trace_path);
+    let summary_written = q38g_r2_path_written(&summary_path);
+    let raw_topk_trace_written = q38g_r2_path_written(&raw_topk_path);
+    let hidden_projection_trace_written = q38g_r2_path_written(&hidden_proj_path);
+
+    let mut warning_codes: Vec<&str> = Vec::new();
+    if !layerwise_trace_jsonl_written {
+        warning_codes.push("LAYERWISE_TRACE_HOOK_NOT_REACHED");
+    }
+    if !summary_written {
+        warning_codes.push("SUMMARY_NOT_WRITTEN");
+    }
+
+    let payload = serde_json::json!({
+        "patch_id": "16AI-QW-38G-R2",
+        "status": status,
+        "last_stage": last_stage,
+        "timestamp_unix_ms": current_unix_ms(),
+        "infer_entered": true,
+        "layerwise_trace_jsonl_path": layer_trace_path,
+        "layerwise_trace_jsonl_written": layerwise_trace_jsonl_written,
+        "summary_path": summary_path.clone(),
+        "summary_written": summary_written,
+        "receipt_path": receipt_path,
+        "receipt_written": true,
+        "raw_topk_trace_path": raw_topk_path,
+        "raw_topk_trace_written": raw_topk_trace_written,
+        "hidden_projection_trace_path": hidden_proj_path,
+        "hidden_projection_trace_written": hidden_projection_trace_written,
+        "python_postprocess_required": false,
+        "powershell_summary_required": false,
+        "warning_codes": warning_codes,
+        "extra": extra,
+    });
+
+    eprintln!(
+        "[16AI-QW-38G-R2][receipt] status={} last_stage={} path={}",
+        status, last_stage, receipt_path
+    );
+    q38g_r2_write_json(&receipt_path, &payload);
+}
+
+fn q38g_r2_heartbeat(stage: &str, extra: serde_json::Value) {
+    let text = serde_json::to_string(&extra).unwrap_or_else(|_| "{}".to_string());
+    eprintln!("[16AI-QW-38G-R2][{}] {}", stage, text);
+    q38g_r2_write_receipt("RUNNING", stage, extra);
+}
