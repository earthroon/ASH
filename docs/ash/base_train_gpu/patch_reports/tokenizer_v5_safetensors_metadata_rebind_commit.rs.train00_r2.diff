+fn sha256_hex(bytes: &[u8]) -> String {
+    let mut hasher = Sha256::new();
+    hasher.update(bytes);
+    format!("{:x}", hasher.finalize())
+}
+
+fn sha256_reader<R: Read>(reader: &mut R) -> Result<String> {
+    let mut hasher = Sha256::new();
+    let mut buf = [0u8; 1024 * 1024];
+    loop {
+        let n = reader.read(&mut buf)?;
+        if n == 0 {
+            break;
+        }
+        hasher.update(&buf[..n]);
+    }
+    Ok(format!("{:x}", hasher.finalize()))
+}
+
+fn value_to_metadata_string(value: &Value) -> String {
+    value.as_str().map(str::to_string).unwrap_or_else(|| value.to_string())
+}
+
+fn metadata_map_to_json(metadata: &BTreeMap<String, String>) -> Value {
+    let mut obj = Map::new();
+    for (key, value) in metadata {
+        obj.insert(key.clone(), Value::String(value.clone()));
+    }
+    Value::Object(obj)
+}
+
+fn descriptor_value(header: &Value) -> Value {
+    let mut out = BTreeMap::<String, Value>::new();
+    if let Some(obj) = header.as_object() {
+        for (key, value) in obj {
+            if key != "__metadata__" {
+                out.insert(key.clone(), value.clone());
+            }
+        }
+    }
+    serde_json::to_value(out).unwrap_or(Value::Null)
+}
+
+fn parse_metadata(header: &Value) -> BTreeMap<String, String> {
+    let mut out = BTreeMap::new();
+    if let Some(obj) = header.get("__metadata__").and_then(Value::as_object) {
+        for (key, value) in obj {
+            out.insert(key.clone(), value_to_metadata_string(value));
+        }
+    }
+    out
+}
+
+fn tensor_keys_first_32(header: &Value) -> (usize, Vec<String>) {
+    let mut keys = Vec::new();
+    if let Some(obj) = header.as_object() {
+        for key in obj.keys() {
+            if key != "__metadata__" {
+                keys.push(key.clone());
+            }
+        }
+    }
+    keys.sort();
+    let count = keys.len();
+    (count, keys.into_iter().take(32).collect())
+}
