+fn inspect_model_spec(path: &Path, cfg: &QwTokTrain00R2Config) -> QwTokTrain00R2ModelSpecSsot {
+    let mut failures = Vec::new();
+    let mut warnings = Vec::new();
+    let exists = path.exists();
+    let mut readable = false;
+    let mut model_spec_id = None;
+    let mut model_name = None;
+    let mut vocab_size = None;
+    let mut v4_residue_detected = false;
+
+    if exists {
+        match fs::read_to_string(path) {
+            Ok(text) => {
+                readable = true;
+                v4_residue_detected = text.contains("model_tinyllama_1p1b_v4")
+                    || text.contains("TinyLlama 1.1B V4")
+                    || text.contains("V4 vocab 56832")
+                    || text.contains("56832");
+                match text.parse::<toml::Value>() {
+                    Ok(value) => {
+                        model_spec_id = value.get("model_spec_id").and_then(|v| v.as_str()).map(str::to_string);
+                        model_name = value.get("model_name").and_then(|v| v.as_str()).map(str::to_string);
+                        vocab_size = value
+                            .get("dimensions")
+                            .and_then(|d| d.get("vocab_size"))
+                            .and_then(|v| v.as_integer())
+                            .map(|v| v as usize)
+                            .or_else(|| value.get("vocab_size").and_then(|v| v.as_integer()).map(|v| v as usize));
+                    }
+                    Err(err) => failures.push(format!("model_spec_toml_parse_failed: {err}")),
+                }
+            }
+            Err(err) => failures.push(format!("model_spec_read_failed: {err}")),
+        }
+    } else {
+        failures.push("model_spec_missing".to_string());
+    }
+
+    let model_spec_id_match = model_spec_id.as_deref() == Some(cfg.expected_model_spec_id.as_str());
+    let vocab_size_match = vocab_size == Some(cfg.expected_vocab_size);
+    if !model_spec_id_match {
+        failures.push("model_spec_id_not_v5_48259".to_string());
+    }
+    if !vocab_size_match {
+        failures.push("vocab_size_not_48259".to_string());
+    }
+    if v4_residue_detected {
+        warnings.push("v4_residue_detected_in_model_spec".to_string());
+    }
+
+    QwTokTrain00R2ModelSpecSsot {
+        path: path.display().to_string(),
+        exists,
+        readable,
+        model_spec_id,
+        model_name,
+        vocab_size,
+        expected_model_spec_id: cfg.expected_model_spec_id.clone(),
+        expected_vocab_size: cfg.expected_vocab_size,
+        model_spec_id_match,
+        vocab_size_match,
+        v4_residue_detected,
+        failures,
+        warnings,
+    }
+}
